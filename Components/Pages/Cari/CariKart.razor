    // ===================== CALISAN ISLEMLERI =====================
    private void CalisanSec(CariCalisanlar c)
    {
        selectedCalisanId = c.Id;
        calisanAdSoyad = c.AdSoyad ?? "";
        calisanBirim = c.Birim ?? "";
        calisanTelefon = c.Telefon ?? "";
        calisanEPosta = c.EPosta ?? "";
    }

    private void CalisanTemizle()
    {
        selectedCalisanId = null;
        calisanAdSoyad = "";
        calisanBirim = "";
        calisanTelefon = "";
        calisanEPosta = "";
    }

    private async Task CalisanKaydet()
    {
        if (model.Id <= 0) { statusMessage = "Once cari karti kaydedin."; isError = true; return; }
        if (string.IsNullOrWhiteSpace(calisanAdSoyad)) { statusMessage = "Ad Soyad bos olamaz."; isError = true; return; }

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var entity = new CariCalisanlar
            {
                CariId = model.Id,
                AdSoyad = calisanAdSoyad,
                Birim = calisanBirim,
                Telefon = calisanTelefon,
                EPosta = calisanEPosta
            };
            db.CariCalisanlar.Add(entity);
            await db.SaveChangesAsync();

            calisanList.Add(entity);
            CalisanTemizle();
            statusMessage = "Calisan kaydedildi.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = "Calisan kayit hatasi: " + ex.Message;
            isError = true;
        }
    }

    private async Task CalisanGuncelle()
    {
        if (selectedCalisanId == null) { statusMessage = "Guncellenecek calisani secin."; isError = true; return; }
        if (string.IsNullOrWhiteSpace(calisanAdSoyad)) { statusMessage = "Ad Soyad bos olamaz."; isError = true; return; }

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var entity = await db.CariCalisanlar.FindAsync(selectedCalisanId.Value);
            if (entity == null) { statusMessage = "Kayit bulunamadi!"; isError = true; return; }

            entity.AdSoyad = calisanAdSoyad;
            entity.Birim = calisanBirim;
            entity.Telefon = calisanTelefon;
            entity.EPosta = calisanEPosta;

            db.CariCalisanlar.Update(entity);
            await db.SaveChangesAsync();

            var local = calisanList.FirstOrDefault(c => c.Id == selectedCalisanId.Value);
            if (local != null)
            {
                local.AdSoyad = calisanAdSoyad;
                local.Birim = calisanBirim;
                local.Telefon = calisanTelefon;
                local.EPosta = calisanEPosta;
            }
            statusMessage = "Calisan guncellendi.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = "Calisan guncelleme hatasi: " + ex.Message;
            isError = true;
        }
    }

    private async Task CalisanSil()
    {
        if (selectedCalisanId == null) { statusMessage = "Silinecek calisani secin."; isError = true; return; }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bu calisani silmek istediginize emin misiniz?");
        if (!confirmed) return;

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var entity = await db.CariCalisanlar.FindAsync(selectedCalisanId.Value);
            if (entity == null) { statusMessage = "Kayit bulunamadi!"; isError = true; return; }

            db.CariCalisanlar.Remove(entity);
            await db.SaveChangesAsync();

            calisanList.RemoveAll(c => c.Id == selectedCalisanId.Value);
            CalisanTemizle();
            statusMessage = "Calisan silindi.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = "Calisan silme hatasi: " + ex.Message;
            isError = true;
        }
    }

