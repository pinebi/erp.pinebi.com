    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        using var dbFiyat = await FirmaFactory.CreateDbContextAsync();
        fiyatGruplari = await dbFiyat.FiyatGruplari.Where(g => g.Aktif).OrderBy(g => g.GrupNo).ToListAsync();

        if (Id > 0)
        {
            await LoadCariById(Id);
        }
        StateHasChanged();
    }

    private async Task LoadCariById(int cariId)
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var cari = await db.Cariler.AsNoTracking().FirstOrDefaultAsync(c => c.Id == cariId);
            if (cari == null) return;

            model.Id = cari.Id;
            model.CariKodu = cari.CariKodu ?? "";
            model.Unvani = cari.Unvani ?? "";
            model.Ad = cari.Ad ?? "";
            model.Soyad = cari.Soyad ?? "";
            model.TckNo = cari.TckNo ?? "";
            model.Yetkili1 = cari.Yetkili1 ?? "";
            model.Yetkili2 = cari.Yetkili2 ?? "";
            model.VdKodu = cari.VdKodu ?? "";
            model.Vd = cari.Vd ?? "";
            model.Vn = cari.Vn ?? "";
            model.GsmNo = cari.GsmNo ?? "";
            model.Telefon1 = cari.Telefon1 ?? "";
            model.Telefon2 = cari.Telefon2 ?? "";
            model.Faks = cari.Faks ?? "";
            model.Email = cari.Email ?? "";
            model.Adres1 = cari.Adres1 ?? "";
            model.Adres2 = cari.Adres2 ?? "";
            model.PostaKodu = cari.PostaKodu ?? "";
            model.UlkeId = cari.UlkeId;
            model.SehirId = cari.SehirId;
            model.IlceId = cari.IlceId;
            model.EFatura = cari.EFatura ?? false;
            model.SahisSirketi = cari.SahisSirketi ?? false;
            model.YurtDisi = cari.YurtDisi ?? false;
            model.CariGrubu = cari.CariGrubu ?? "";
            model.OzelKod1 = cari.OzelKod1 ?? "";
            model.OzelKod2 = cari.OzelKod2 ?? "";
            model.OzelKod3 = cari.OzelKod3 ?? "";
            model.OzelKod4 = cari.OzelKod4 ?? "";
            model.OzelKod5 = cari.OzelKod5 ?? "";
            model.FiyatGrubu = cari.FiyatGrubu ?? 1;
            model.EFaturaUrnMail = cari.EFaturaUrnMail ?? "";
            model.EIrsaliyeUrnMail = cari.EIrsaliyeUrnMail ?? "";

            // Load sub-tables
            calisanList = await db.CariCalisanlar.AsNoTracking().Where(c => c.CariId == cariId).ToListAsync();
            sevkList = await db.CariSevkAdresleri.AsNoTracking().Where(s => s.CariId == cariId).ToListAsync();
            gorusmeList = await db.CariGorusmeler.AsNoTracking().Where(g => g.CariId == cariId).ToListAsync();
            ekstreList = await db.CariHesapEkstresi.AsNoTracking().Where(e => e.CariId == cariId).OrderBy(e => e.TarihSaat).ToListAsync();
        }
        catch (Exception ex)
        {
            statusMessage = "Veri yuklenirken hata: " + ex.Message;
            isError = true;
        }
    }

    // ===================== KAYDET (Ana Cari Kart) =====================
    private async Task Kaydet()
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();

            if (model.Id > 0)
            {
                // Update
                var entity = await db.Cariler.FindAsync(model.Id);
                if (entity == null) { statusMessage = "Kayit bulunamadi!"; isError = true; return; }
                MapModelToEntity(entity);
                db.Cariler.Update(entity);
            }
            else
            {
                // Insert
                var entity = new Cariler { Aktif = true };
                MapModelToEntity(entity);
                db.Cariler.Add(entity);
                await db.SaveChangesAsync();
                model.Id = entity.Id;
                Id = entity.Id;
                statusMessage = "Cari kart kaydedildi.";
                isError = false;
                StateHasChanged();
                return;
            }

            await db.SaveChangesAsync();
            statusMessage = "Cari kart kaydedildi.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = "Kayit hatasi: " + ex.Message;
            isError = true;
        }
    }

