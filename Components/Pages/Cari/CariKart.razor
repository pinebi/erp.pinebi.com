@page "/cari/kart"
@page "/cari/kart/{Id:int}"
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MACHINEBISS_Web.Db
@using MACHINEBISS_Web.Models.MachineBiss
@inject NavigationManager Nav
@inject IDbContextFactory<FirmaContext> FirmaFactory
@inject IJSRuntime JS

<PageTitle>Cari Kart</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-id-card"></i> Cari Kart @(Id > 0 ? "- Duzenle" : "- Yeni")
    </div>
    <div class="card-body">
        <!-- Tab Control -->
        <div class="xtab">
            <div class="xtab-header">
                <div class="xtab-header-item @(activeTab == 0 ? "active" : "")" @onclick="() => activeTab = 0">
                    Cari Bilgileri
                </div>
                <div class="xtab-header-item @(activeTab == 1 ? "active" : "")" @onclick="() => activeTab = 1">
                    Ekstre
                </div>
                <div class="xtab-header-item @(activeTab == 2 ? "active" : "")" @onclick="() => activeTab = 2">
                    Teklifler
                </div>
                <div class="xtab-header-item @(activeTab == 3 ? "active" : "")" @onclick="() => activeTab = 3">
                    Calisanlar
                </div>
                <div class="xtab-header-item @(activeTab == 4 ? "active" : "")" @onclick="() => activeTab = 4">
                    Sevk Adresleri
                </div>
                <div class="xtab-header-item @(activeTab == 5 ? "active" : "")" @onclick="() => activeTab = 5">
                    Gorusmeler
                </div>
            </div>

            <div class="xtab-body" style="padding:10px;">
                @if (activeTab == 0)
                {
                    <!-- CARI BILGILERI -->
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <!-- Sol Kolon: Temel Bilgiler -->
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Temel Bilgiler</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Cari Kodu</label>
                                        <input type="text" class="form-control" @bind="model.CariKodu" style="max-width:180px;" />
                                    </div>
                                    <div class="form-check" style="margin-left:10px;">
                                        <input type="checkbox" @bind="model.EFatura" />
                                        <label style="font-weight:700; color:#dc2626;">E-Fatura</label>
                                    </div>
                                    <div class="form-check" style="margin-left:10px;">
                                        <input type="checkbox" @bind="model.SahisSirketi" />
                                        <label>Sahis Sirketi</label>
                                    </div>
                                    <div class="form-check" style="margin-left:10px;">
                                        <input type="checkbox" @bind="model.YurtDisi" />
                                        <label>Yurt Disi</label>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Unvan</label>
                                        <input type="text" class="form-control" @bind="model.Unvani" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Ad</label>
                                        <input type="text" class="form-control" @bind="model.Ad" style="max-width:200px;" />
                                    </div>
                                    <div class="form-inline" style="flex:1;">
                                        <label style="min-width:auto;">Soyad</label>
                                        <input type="text" class="form-control" @bind="model.Soyad" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Tck No</label>
                                        <input type="text" class="form-control" @bind="model.TckNo" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Yetkili 1</label>
                                        <input type="text" class="form-control" @bind="model.Yetkili1" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Yetkili 2</label>
                                        <input type="text" class="form-control" @bind="model.Yetkili2" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>V.D. Kodu</label>
                                        <input type="text" class="form-control" @bind="model.VdKodu" style="max-width:120px;" />
                                    </div>
                                    <div class="form-inline" style="flex:1;">
                                        <label style="min-width:auto;">V. Dairesi</label>
                                        <input type="text" class="form-control" @bind="model.Vd" />
                                        <button class="btn btn-sm btn-outline" title="V.D. Sec">...</button>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Vergi No</label>
                                        <input type="text" class="form-control" @bind="model.Vn" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Cari Grubu</label>
                                        <input type="text" class="form-control" @bind="model.CariGrubu" style="max-width:200px;" />
                                        <button class="btn btn-sm btn-outline" title="Grup Sec">...</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Sag Kolon: Iletisim ve Adres -->
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Iletisim Bilgileri</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Gsm No</label>
                                        <input type="text" class="form-control" @bind="model.GsmNo" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Telefon 1</label>
                                        <input type="text" class="form-control" @bind="model.Telefon1" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Telefon 2</label>
                                        <input type="text" class="form-control" @bind="model.Telefon2" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Faks</label>
                                        <input type="text" class="form-control" @bind="model.Faks" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Email</label>
                                        <input type="text" class="form-control" @bind="model.Email" />
                                    </div>
                                </div>
                            </div>

                            <div class="group-box">
                                <span class="group-box-title">Adres Bilgileri</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Adres 1</label>
                                        <input type="text" class="form-control" @bind="model.Adres1" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Adres 2</label>
                                        <input type="text" class="form-control" @bind="model.Adres2" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Posta Kodu</label>
                                        <input type="text" class="form-control" @bind="model.PostaKodu" style="max-width:120px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Ulke</label>
                                        <select class="form-control" @bind="model.UlkeId" style="max-width:200px;">
                                            <option value="">Seciniz</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Sehir</label>
                                        <select class="form-control" @bind="model.SehirId" style="max-width:200px;">
                                            <option value="">Seciniz</option>
                                        </select>
                                    </div>
                                    <div class="form-inline" style="flex:1;">
                                        <label style="min-width:auto;">Ilce</label>
                                        <select class="form-control" @bind="model.IlceId" style="max-width:200px;">
                                            <option value="">Seciniz</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Ozel Kodlar ve E-Fatura -->
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div class="group-box" style="flex:1; min-width:400px;">
                            <span class="group-box-title">Ozel Kodlar</span>
                            <div class="form-row">
                                <div class="form-inline" style="flex:1;">
                                    <label>Ozel Kod 1</label>
                                    <input type="text" class="form-control" @bind="model.OzelKod1" />
                                    <button class="btn btn-sm btn-outline">...</button>
                                </div>
                                <div class="form-inline" style="flex:1;">
                                    <label style="min-width:auto;">Ozel Kod 2</label>
                                    <input type="text" class="form-control" @bind="model.OzelKod2" />
                                    <button class="btn btn-sm btn-outline">...</button>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-inline" style="flex:1;">
                                    <label>Ozel Kod 3</label>
                                    <input type="text" class="form-control" @bind="model.OzelKod3" />
                                    <button class="btn btn-sm btn-outline">...</button>
                                </div>
                                <div class="form-inline" style="flex:1;">
                                    <label style="min-width:auto;">Ozel Kod 4</label>
                                    <input type="text" class="form-control" @bind="model.OzelKod4" />
                                    <button class="btn btn-sm btn-outline">...</button>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-inline" style="flex:1;">
                                    <label>Ozel Kod 5</label>
                                    <input type="text" class="form-control" @bind="model.OzelKod5" />
                                    <button class="btn btn-sm btn-outline">...</button>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-inline">
                                    <label>Fiyat Grubu</label>
                                    <select class="form-control" @bind="model.FiyatGrubu" style="width:200px;">
                                        <option value="0">-- Secin --</option>
                                        @foreach (var g in fiyatGruplari)
                                        {
                                            <option value="@g.GrupNo">@g.GrupNo - @g.GrupAdi</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="group-box" style="flex:1; min-width:400px;">
                            <span class="group-box-title">E-Belge Bilgileri</span>
                            <div class="form-row">
                                <div class="form-inline" style="flex:1;">
                                    <label>E-Fatura URN/Mail</label>
                                    <input type="text" class="form-control" @bind="model.EFaturaUrnMail" />
                                    <button class="btn btn-sm btn-outline" title="GIB Sorgula">
                                        <i class="fa fa-search"></i> GIB Sorgula
                                    </button>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-inline" style="flex:1;">
                                    <label>E-Irsaliye URN/Mail</label>
                                    <input type="text" class="form-control" @bind="model.EIrsaliyeUrnMail" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (activeTab == 1)
                {
                    <!-- EKSTRE -->
                    <div class="grid-container" style="max-height:400px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th>Tarih</th>
                                    <th>Fis No</th>
                                    <th>Belge No</th>
                                    <th>Aciklama 1</th>
                                    <th>Aciklama 2</th>
                                    <th>Borc</th>
                                    <th>Alacak</th>
                                    <th>Bakiye</th>
                                    <th>Doviz</th>
                                    <th>Kaynak</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ekstreList != null)
                                {
                                    @foreach (var item in ekstreList)
                                    {
                                        <tr>
                                            <td>@item.TarihSaat.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>@item.FisNo</td>
                                            <td>@item.BelgeNo</td>
                                            <td>@item.Aciklama1</td>
                                            <td>@item.Aciklama2</td>
                                            <td style="text-align:right;">@item.Borc.ToString("N2")</td>
                                            <td style="text-align:right;">@item.Alacak.ToString("N2")</td>
                                            <td style="text-align:right;">@item.Bakiye.ToString("N2")</td>
                                            <td>@item.Doviz</td>
                                            <td>@item.Kaynak</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (activeTab == 2)
                {
                    <!-- TEKLIFLER -->
                    <div class="grid-container" style="max-height:400px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th>Tarih</th>
                                    <th>Teklif No</th>
                                    <th>Unvan</th>
                                    <th>Aciklama</th>
                                    <th>Tutar</th>
                                    <th>Doviz</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- TODO: Load data from API -->
                            </tbody>
                        </table>
                    </div>
                }
                else if (activeTab == 3)
                {
                    <!-- CALISANLAR -->
                    <div class="group-box">
                        <span class="group-box-title">Calisan Bilgileri</span>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Ad Soyad</label>
                                <input type="text" class="form-control" @bind="calisanAdSoyad" />
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">Birim</label>
                                <input type="text" class="form-control" @bind="calisanBirim" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Telefon</label>
                                <input type="text" class="form-control" @bind="calisanTelefon" />
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">E-Posta</label>
                                <input type="text" class="form-control" @bind="calisanEPosta" />
                            </div>
                        </div>
                        <div class="toolbar" style="border-top:1px solid var(--pinebi-border); padding-top:8px; margin-top:8px; border-bottom:none;">
                            <button class="btn btn-success btn-sm" @onclick="CalisanKaydet">
                                <i class="fa fa-save"></i> Kaydet
                            </button>
                            <button class="btn btn-primary btn-sm" @onclick="CalisanGuncelle">
                                <i class="fa fa-pencil"></i> Guncelle
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="CalisanSil">
                                <i class="fa fa-trash"></i> Sil
                            </button>
                        </div>
                    </div>
                    <div class="grid-container" style="max-height:250px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th>Ad Soyad</th>
                                    <th>Birim</th>
                                    <th>Telefon</th>
                                    <th>E-Posta</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in calisanList)
                                {
                                    <tr class="@(selectedCalisanId == c.Id ? "selected" : "")" @onclick="() => CalisanSec(c)">
                                        <td>@c.AdSoyad</td>
                                        <td>@c.Birim</td>
                                        <td>@c.Telefon</td>
                                        <td>@c.EPosta</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (activeTab == 4)
                {
                    <!-- SEVK ADRESLERI -->
                    <div class="group-box">
                        <span class="group-box-title">Sevk Adresi</span>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Baslik</label>
                                <input type="text" class="form-control" @bind="sevkBaslik" style="max-width:300px;" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Adres</label>
                                <input type="text" class="form-control" @bind="sevkAdres" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Telefon</label>
                                <input type="text" class="form-control" @bind="sevkTelefon" style="max-width:200px;" />
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">Posta Kodu</label>
                                <input type="text" class="form-control" @bind="sevkPostaKodu" style="max-width:120px;" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Ulke</label>
                                <select class="form-control" @bind="sevkUlkeId" style="max-width:200px;">
                                    <option value="">Seciniz</option>
                                </select>
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">Sehir</label>
                                <select class="form-control" @bind="sevkSehirId" style="max-width:200px;">
                                    <option value="">Seciniz</option>
                                </select>
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">Ilce</label>
                                <select class="form-control" @bind="sevkIlceId" style="max-width:200px;">
                                    <option value="">Seciniz</option>
                                </select>
                            </div>
                        </div>
                        <div class="toolbar" style="border-top:1px solid var(--pinebi-border); padding-top:8px; margin-top:8px; border-bottom:none;">
                            <button class="btn btn-success btn-sm" @onclick="SevkKaydet">
                                <i class="fa fa-save"></i> Kaydet
                            </button>
                            <button class="btn btn-primary btn-sm" @onclick="SevkGuncelle">
                                <i class="fa fa-pencil"></i> Guncelle
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="SevkSil">
                                <i class="fa fa-trash"></i> Sil
                            </button>
                        </div>
                    </div>
                    <div class="grid-container" style="max-height:200px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th>Baslik</th>
                                    <th>Adres</th>
                                    <th>Telefon</th>
                                    <th>Posta Kodu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in sevkList)
                                {
                                    <tr class="@(selectedSevkId == s.Id ? "selected" : "")" @onclick="() => SevkSec(s)">
                                        <td>@s.Baslik</td>
                                        <td>@s.Adres</td>
                                        <td>@s.Telefon</td>
                                        <td>@s.PostaKodu</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (activeTab == 5)
                {
                    <!-- GORUSMELER -->
                    <div class="group-box">
                        <span class="group-box-title">Gorusme Bilgileri</span>
                        <div class="form-row">
                            <div class="form-inline" style="flex:0.5;">
                                <label>Tarih</label>
                                <input type="date" class="form-control" @bind="gorusmeTarihi" style="max-width:160px;" />
                            </div>
                            <div class="form-inline" style="flex:1;">
                                <label style="min-width:auto;">Gorusulen Kisi</label>
                                <input type="text" class="form-control" @bind="gorusulenKisi" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-inline" style="flex:1;">
                                <label>Aciklama</label>
                                <textarea class="form-control" @bind="gorusmeAciklama" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="toolbar" style="border-top:1px solid var(--pinebi-border); padding-top:8px; margin-top:8px; border-bottom:none;">
                            <button class="btn btn-success btn-sm" @onclick="GorusmeKaydet">
                                <i class="fa fa-save"></i> Kaydet
                            </button>
                            <button class="btn btn-primary btn-sm" @onclick="GorusmeGuncelle">
                                <i class="fa fa-pencil"></i> Guncelle
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="GorusmeSil">
                                <i class="fa fa-trash"></i> Sil
                            </button>
                        </div>
                    </div>
                    <div class="grid-container" style="max-height:200px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th>Tarih</th>
                                    <th>Gorusulen Kisi</th>
                                    <th>Aciklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in gorusmeList)
                                {
                                    <tr class="@(selectedGorusmeId == g.Id ? "selected" : "")" @onclick="() => GorusmeSec(g)">
                                        <td>@(g.GorusmeTarihi?.ToString("dd.MM.yyyy"))</td>
                                        <td>@g.GorusulenKisi</td>
                                        <td>@g.Aciklama</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Status Message -->
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div style="padding:8px 12px; margin-top:10px; border-radius:4px; background:@(isError ? "#fef2f2" : "#f0fdf4"); color:@(isError ? "#dc2626" : "#16a34a"); border:1px solid @(isError ? "#fecaca" : "#bbf7d0");">
                @statusMessage
            </div>
        }

        <!-- Bottom Toolbar -->
        <div class="toolbar" style="border-top:1px solid var(--pinebi-border); margin-top:10px; padding-top:10px; border-bottom:none; justify-content:flex-end;">
            <button class="btn btn-primary" @onclick="Kaydet">
                <i class="fa fa-save"></i> Kaydet
            </button>
            <button class="btn btn-secondary" @onclick="Kapat">
                <i class="fa fa-times"></i> Kapat
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private int activeTab = 0;
    private CariKartModel model = new();
    private string? statusMessage;
    private bool isError;
    private List<MACHINEBISS_Web.Models.MachineBiss.FiyatGruplari> fiyatGruplari = new();

    // Ekstre
    private List<CariHesapEkstresi> ekstreList = new();

    // Calisan
    private List<CariCalisanlar> calisanList = new();
    private int? selectedCalisanId;
    private string calisanAdSoyad = "";
    private string calisanBirim = "";
    private string calisanTelefon = "";
    private string calisanEPosta = "";

    // Sevk
    private List<CariSevkAdresleri> sevkList = new();
    private int? selectedSevkId;
    private string sevkBaslik = "";
    private string sevkAdres = "";
