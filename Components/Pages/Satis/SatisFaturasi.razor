        public int KdvOrani { get; set; } = 20;
        public double Tutar => Miktar * Fiyat;
        public double IskontoOrani { get; set; }
        public double IskontoTutari => Tutar * IskontoOrani / 100;
        public double KdvMatrahi => Tutar - IskontoTutari;
        public double KdvTutari => KdvMatrahi * KdvOrani / 100;
        public double NetTutar => KdvMatrahi + KdvTutari;
        public string KdvMuafiyetSebebi { get; set; } = "";
        public string TevkifatKodu { get; set; } = "";
        public string GTipKodu { get; set; } = "";
    }

