    private void SatirDegisti(int idx)
    {
        // Son satira yazildiysa yeni bos satir ekle
        if (idx == satirlar.Count - 1 && !string.IsNullOrWhiteSpace(satirlar[idx].MalHizmet))
        {
            satirlar.Add(new FaturaSatir());
        }
        Hesapla();
    }

    private void SatirSil(int idx)
    {
        if (satirlar.Count > 1)
        {
            satirlar.RemoveAt(idx);
            Hesapla();
        }
    }

    private void Hesapla()
    {
        var aktifSatirlar = satirlar.Where(s => !string.IsNullOrEmpty(s.MalHizmetKodu) || s.Miktar > 0).ToList();
        tutar = aktifSatirlar.Sum(s => s.Tutar);
        iskontoToplam = aktifSatirlar.Sum(s => s.IskontoTutari);
        kdvMatrahi = aktifSatirlar.Sum(s => s.KdvMatrahi);
        kdvToplam = aktifSatirlar.Sum(s => s.KdvTutari);
        tevkifatMuafiyeti = 0;
        toplamTutar = kdvMatrahi + kdvToplam;
        odenecekTutar = toplamTutar - tevkifatMuafiyeti;

        // KDV matrahini orana gore ayir
        kdvMatrahDetay = aktifSatirlar
            .Where(s => s.KdvMatrahi > 0)
            .GroupBy(s => s.KdvOrani)
            .Select(g => new KdvMatrahItem
            {
                Oran = g.Key,
                Matrah = g.Sum(s => s.KdvMatrahi),
                KdvTutari = g.Sum(s => s.KdvTutari)
            })
            .OrderBy(k => k.Oran)
            .ToList();
    }

    private async Task StokKodAra(int idx)
    {
        var satir = satirlar[idx];
        if (string.IsNullOrWhiteSpace(satir.MalHizmetKodu) || satir.MalHizmetKodu.Length < 1)
        {
            aramaStokSonuc = new();
            return;
        }
        using var db = await FirmaFactory.CreateDbContextAsync();
        var aranan = satir.MalHizmetKodu.Trim().ToUpper();

        // Tam eslesme kontrolu (stok kodu veya barkod - case insensitive)
        var tam = await db.StokKart.FirstOrDefaultAsync(s =>
            s.StokKodu.ToUpper() == aranan || s.Barkod == satir.MalHizmetKodu.Trim());
        if (tam != null)
        {
            await StokSec(idx, tam);
            return;
        }

        // Kismi arama (case insensitive)
        aramaStokSonuc = await db.StokKart
            .Where(s => s.StokKodu.ToUpper().Contains(aranan) || s.Barkod.Contains(satir.MalHizmetKodu.Trim()))
            .Take(8)
            .ToListAsync();
    }

    private async Task StokAdAra(int idx)
    {
        var satir = satirlar[idx];
        if (string.IsNullOrWhiteSpace(satir.MalHizmet) || satir.MalHizmet.Length < 2)
        {
            aramaAdSonuc = new();
            SatirDegisti(idx);
            return;
        }
        using var db = await FirmaFactory.CreateDbContextAsync();
        var aranan = satir.MalHizmet.Trim().ToUpper();
        aramaAdSonuc = await db.StokKart
            .Where(s => s.StokCinsi.ToUpper().Contains(aranan))
            .Take(8)
            .ToListAsync();
    }

    private async Task StokKodBlur(int idx)
    {
        var satir = satirlar[idx];
        if (string.IsNullOrWhiteSpace(satir.MalHizmetKodu)) return;
        if (!string.IsNullOrEmpty(satir.MalHizmet)) return;

        using var db = await FirmaFactory.CreateDbContextAsync();
        var aranan = satir.MalHizmetKodu.Trim().ToUpper();
        var stok = await db.StokKart.FirstOrDefaultAsync(s =>
            s.StokKodu.ToUpper() == aranan || s.Barkod == satir.MalHizmetKodu.Trim());

        if (stok != null)
        {
            await StokSec(idx, stok);
        }
    }

    private async Task StokSec(int idx, MACHINEBISS_Web.Models.MachineBiss.StokKart stok)
    {
        var satir = satirlar[idx];
        satir.MalHizmetKodu = stok.StokKodu;
        satir.MalHizmet = stok.StokCinsi;
        satir.Birim = stok.Birim ?? "Adet";
        satir.KdvOrani = (int)stok.Kdv;

        // Fiyat hiyerarsisi: 1) Cari ozel fiyat, 2) Fiyat grubu fiyati, 3) Varsayilan satis fiyati
        decimal fiyat = stok.KdvHaricSatisFiyati;
        try
        {
            using var dbFiyat = await FirmaFactory.CreateDbContextAsync();

            // Cari Id bul
            var cariEntity = await dbFiyat.Cariler.AsNoTracking()
                .FirstOrDefaultAsync(c => c.CariKodu == cariKodu);
            int cariIdFiyat = cariEntity?.Id ?? 0;

            // 1. Cariye ozel fiyat
            if (cariIdFiyat > 0)
            {
                var cariFiyat = await dbFiyat.CariFiyatlar.AsNoTracking()
                    .FirstOrDefaultAsync(f => f.CariId == cariIdFiyat && f.StokId == stok.Id && f.Aktif == true);
                if (cariFiyat != null)
                {
                    fiyat = cariFiyat.Fiyat;
                }
                else
                {
                    // 2. Fiyat grubuna gore fiyat
                    var stokFiyat = await dbFiyat.StokFiyatlar.AsNoTracking()
                        .FirstOrDefaultAsync(f => f.StokId == stok.Id && f.FiyatGrubu == cariFiyatGrubu && f.Aktif);
                    if (stokFiyat != null)
                    {
                        fiyat = stokFiyat.Fiyat;
                    }
                }
            }
            else
            {
                // Cari yok ama fiyat grubu kontrolu yap
                var stokFiyat = await dbFiyat.StokFiyatlar.AsNoTracking()
                    .FirstOrDefaultAsync(f => f.StokId == stok.Id && f.FiyatGrubu == cariFiyatGrubu && f.Aktif);
                if (stokFiyat != null)
                {
                    fiyat = stokFiyat.Fiyat;
                }
            }
        }
        catch { }

        satir.Fiyat = (double)fiyat;
        satir.Miktar = satir.Miktar == 0 ? 1 : satir.Miktar;
        aramaStokSonuc = new();
        aramaAdSonuc = new();
        aramaAktifIdx = -1;
        SatirDegisti(idx);
    }

