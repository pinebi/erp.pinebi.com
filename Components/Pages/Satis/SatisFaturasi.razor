    private void FormuTemizle()
    {
        // Evrak bilgileri
        var yeniFisNo = fisNo;
        // Fis numarasini artir
        try
        {
            var prefix = new string(fisNo.TakeWhile(c => !char.IsDigit(c)).ToArray());
            var numStr = new string(fisNo.SkipWhile(c => !char.IsDigit(c)).ToArray());
            if (long.TryParse(numStr, out var num))
                yeniFisNo = prefix + (num + 1).ToString().PadLeft(numStr.Length, '0');
        }
        catch { }

        fisNo = yeniFisNo;
        belgeNo = "";
        tarih = DateTime.Today;
        vadeTarihi = DateTime.Today;

        // Cari temizle
        cariKodu = "";
        cariUnvan = "";
        yetkili = "";
        tel = "";
        tckNo = "";
        faks = "";
        email = "";
        ulke = "";
        vDairesi = "";
        vNo = "";
        sehir = "";
        ilce = "";
        adres = "";
        eFaturaMukellefi = false;

        // Odeme
        odemeSecimi = "0";
        kapayanKodu = "";

        // Satirlar temizle
        satirlar = new List<FaturaSatir> { new FaturaSatir() };

        // Toplamlar sifirla
