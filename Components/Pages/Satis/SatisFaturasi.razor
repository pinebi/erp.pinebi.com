}

<!-- YAZDIRMA ONIZLEME POPUP -->
@if (yazdirmaOnizlemeAcik)
{
    <div class="modal-overlay" @onclick="() => yazdirmaOnizlemeAcik = false">
        <div class="modal-box" style="width:850px; max-height:90vh;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><i class="fa fa-print"></i> @yazdirmaTipi Onizleme</span>
                <button class="modal-close" @onclick="() => yazdirmaOnizlemeAcik = false">X</button>
            </div>
            <div class="modal-body">
                <!-- Yazici Secimi -->
                <div class="form-row mb-2" style="background:#f8fafc; padding:8px; border-radius:4px; border:1px solid var(--pinebi-border);">
                    <div class="form-inline" style="flex:1;">
                        <label style="min-width:60px; font-weight:700;"><i class="fa fa-print"></i> Yazici:</label>
                        <select class="form-control" @bind="seciliYazici" style="max-width:300px;">
                            @foreach (var y in yaziciListesi)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                    <div class="form-inline">
                        <label style="min-width:50px;">Kopya:</label>
                        <input type="number" class="form-control" @bind="yazdirmaKopya" min="1" max="5" style="max-width:60px;" />
                    </div>
                    <button class="btn btn-success btn-sm" @onclick="YazdirOnayla">
                        <i class="fa fa-print"></i> Yazdir
                    </button>
                </div>

                <!-- Fatura/Irsaliye Onizleme -->
                <div style="border:1px solid #ccc; padding:30px; background:white; min-height:500px; font-family:'Times New Roman', serif;">
                    <!-- Ust Kisim: Firma Bilgileri -->
                    <div style="display:flex; justify-content:space-between; border-bottom:2px solid var(--pinebi-primary); padding-bottom:12px; margin-bottom:16px;">
                        <div>
                            <div style="font-size:18px; font-weight:700; color:var(--pinebi-primary);">PINEBI BILISIM TEKNOLOJILERI</div>
                            <div style="font-size:11px; color:#666;">Yazilim ve Danismanlik Hizmetleri</div>
                            <div style="font-size:10px; color:#888; margin-top:4px;">Tel: 0212 555 1001 | info@pinebi.com</div>
                        </div>
                        <div style="text-align:right;">
                            <div style="font-size:16px; font-weight:700; color:var(--pinebi-primary);">@yazdirmaTipi.ToUpper()</div>
                            <div style="font-size:11px; margin-top:4px;">
                                <strong>Fis No:</strong> @fisNo<br/>
                                <strong>Tarih:</strong> @tarih.ToString("dd.MM.yyyy")<br/>
                                <strong>Fatura Tipi:</strong> @faturaTipi
                            </div>
                        </div>
                    </div>

                    <!-- Musteri Bilgileri -->
                    <div style="display:flex; gap:20px; margin-bottom:16px; font-size:11px;">
                        <div style="flex:1; border:1px solid #ddd; padding:8px; border-radius:4px;">
                            <div style="font-weight:700; color:var(--pinebi-primary); margin-bottom:4px;">MUSTERI BILGILERI</div>
                            <div><strong>Unvan:</strong> @cariUnvan</div>
                            <div><strong>Adres:</strong> @adres</div>
                            <div><strong>V.D. / V.N.:</strong> @vDairesi / @vNo</div>
                            <div><strong>Tel:</strong> @tel | <strong>Email:</strong> @email</div>
                        </div>
                        <div style="border:1px solid #ddd; padding:8px; border-radius:4px; min-width:200px;">
                            <div style="font-weight:700; color:var(--pinebi-primary); margin-bottom:4px;">FATURA BILGILERI</div>
                            <div><strong>Vade:</strong> @vadeTarihi.ToString("dd.MM.yyyy")</div>
                            <div><strong>Doviz:</strong> @dovizTipi</div>
                            <div><strong>Isyeri:</strong> @isyeri</div>
                        </div>
                    </div>

                    <!-- Satirlar Tablosu -->
                    <table style="width:100%; border-collapse:collapse; font-size:11px; margin-bottom:16px;">
                        <thead>
                            <tr style="background:var(--pinebi-primary); color:white;">
                                <th style="padding:4px 6px; border:1px solid #999; text-align:left;">Stok Kodu</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:left;">Mal/Hizmet</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">Miktar</th>
                                <th style="padding:4px 6px; border:1px solid #999;">Birim</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">Fiyat</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">KDV%</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">Tutar</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">KDV</th>
                                <th style="padding:4px 6px; border:1px solid #999; text-align:right;">Net Tutar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in satirlar.Where(s => !string.IsNullOrEmpty(s.MalHizmetKodu)))
                            {
                                <tr>
                                    <td style="padding:3px 6px; border:1px solid #ddd;">@s.MalHizmetKodu</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd;">@s.MalHizmet</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right;">@s.Miktar.ToString("N2")</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd;">@s.Birim</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right;">@s.Fiyat.ToString("N2")</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right;">%@s.KdvOrani</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right;">@s.Tutar.ToString("N2")</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right;">@s.KdvTutari.ToString("N2")</td>
                                    <td style="padding:3px 6px; border:1px solid #ddd; text-align:right; font-weight:700;">@s.NetTutar.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- Toplamlar -->
                    <div style="display:flex; justify-content:flex-end;">
                        <table style="font-size:12px; min-width:250px;">
                            <tr><td style="padding:3px 8px; text-align:right;">Ara Toplam:</td><td style="padding:3px 8px; text-align:right;">@tutar.ToString("N2") TL</td></tr>
                            <tr><td style="padding:3px 8px; text-align:right;">Iskonto:</td><td style="padding:3px 8px; text-align:right;">@iskontoToplam.ToString("N2") TL</td></tr>
                            <tr><td style="padding:3px 8px; text-align:right;">KDV Matrahi:</td><td style="padding:3px 8px; text-align:right;">@kdvMatrahi.ToString("N2") TL</td></tr>
                            <tr><td style="padding:3px 8px; text-align:right;">KDV Toplam:</td><td style="padding:3px 8px; text-align:right;">@kdvToplam.ToString("N2") TL</td></tr>
                            <tr style="font-weight:700; font-size:14px; border-top:2px solid var(--pinebi-primary);"><td style="padding:6px 8px; text-align:right; color:var(--pinebi-primary);">GENEL TOPLAM:</td><td style="padding:6px 8px; text-align:right; color:var(--pinebi-primary);">@toplamTutar.ToString("N2") TL</td></tr>
                        </table>
                    </div>

                    <!-- Alt Notlar -->
                    @if (!string.IsNullOrEmpty(not1) || !string.IsNullOrEmpty(not2))
                    {
                        <div style="margin-top:16px; font-size:10px; color:#666; border-top:1px solid #ddd; padding-top:8px;">
                            <div style="font-weight:700;">Notlar:</div>
                            @if (!string.IsNullOrEmpty(not1)) { <div>@not1</div> }
                            @if (!string.IsNullOrEmpty(not2)) { <div>@not2</div> }
                            @if (!string.IsNullOrEmpty(not3)) { <div>@not3</div> }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ONCEKI FATURALAR POPUP -->
@if (oncekiFaturalarAcik)
{
    <div class="modal-overlay" @onclick="() => oncekiFaturalarAcik = false">
        <div class="modal-box" style="width:950px; max-height:85vh;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><i class="fa fa-file-invoice-dollar"></i> Onceki Faturalar</span>
                <button class="modal-close" @onclick="() => oncekiFaturalarAcik = false">X</button>
            </div>
            <div class="modal-body">
                <div class="form-inline mb-2">
                    <label>Ara:</label>
                    <input type="text" class="form-control" placeholder="Fis no, cari unvan, belge no ile ara..." @bind="oncekiFaturaArama" @bind:event="oninput" @bind:after="OncekiFaturaAra" style="flex:1;" />
                </div>
                <div class="grid-container" style="max-height:450px;">
                    <table class="data-grid">
                        <thead>
                            <tr>
                                <th style="width:130px;">Fis No</th>
                                <th style="width:90px;">Tarih</th>
                                <th style="min-width:200px;">Cari Unvan</th>
                                <th style="width:90px;">Belge No</th>
                                <th style="width:80px;">Fatura Tipi</th>
                                <th style="width:100px; text-align:right;">Tutar</th>
                                <th style="width:100px; text-align:right;">KDV</th>
                                <th style="width:110px; text-align:right;">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (oncekiFaturaListesi.Any())
                            {
                                @foreach (var f in oncekiFaturaListesi)
                                {
                                    <tr style="cursor:pointer;" @onclick="() => OncekiFaturaSecildi(f)">
                                        <td>@f.FisNo</td>
                                        <td>@f.Tarih.ToString("dd.MM.yyyy")</td>
                                        <td><strong>@f.CariUnvan</strong></td>
                                        <td>@f.BelgeNo</td>
                                        <td>@f.FaturaTipi</td>
