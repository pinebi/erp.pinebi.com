                        {
                            <span style="background:#16a34a; color:white; padding:1px 6px; border-radius:3px; font-size:10px;">Acik</span>
                        }
                        else
                        {
                            <span style="background:#9ca3af; color:white; padding:1px 6px; border-radius:3px; font-size:10px;">Kapali</span>
