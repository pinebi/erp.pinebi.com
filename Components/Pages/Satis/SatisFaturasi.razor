@page "/satis/fatura/yeni"
@page "/satis/fatura/{Id:int}"
@inject NavigationManager Nav
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@inject IDbContextFactory<MACHINEBISS_Web.Db.NetworkContext> NetworkFactory
@* NetworkFactory now points to same MSSQL PineERP database *@
@inject MACHINEBISS_Web.Services.FaturaAlanAyarlariService AlanAyar
@inject MACHINEBISS_Web.Services.DovizKuruService DovizSvc
@using Microsoft.EntityFrameworkCore

<PageTitle>Satis Faturasi</PageTitle>

<div class="card" @onkeydown="KlavyeKisayol" tabindex="0" style="outline:none;">
    <!-- ANA TAB: Fatura / Detay -->
    <div class="xtab">
        <div class="xtab-header">
            <div class="xtab-header-item @(activeTab == 0 ? "active" : "")" @onclick="() => activeTab = 0">
                <i class="fa fa-file-invoice"></i> Fatura
            </div>
            <div class="xtab-header-item @(activeTab == 1 ? "active" : "")" @onclick="() => activeTab = 1">
                <i class="fa fa-info-circle"></i> Detay
            </div>
            <div class="xtab-header-item @(activeTab == 2 ? "active" : "")" @onclick="() => activeTab = 2">
                <i class="fa fa-print"></i> Yazdir
            </div>
        </div>

        <div class="xtab-body" style="padding:10px;">
            @if (activeTab == 0)
            {
                <!-- FATURA FORM - 3 Kolon -->
                <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px 16px; margin-bottom:10px; padding:8px; border:1px solid var(--pinebi-border); border-radius:4px; background:#fafbfc;">
                    <!-- Satir 1 -->
                    <div class="form-inline">
                        <label style="min-width:75px; font-weight:700;">Evrak No</label>
                        <input type="text" class="form-control" @bind="fisNo" style="flex:1;" />
                        <button class="btn btn-sm btn-outline" @onclick="OncekiFaturalarAc" title="Onceki Faturalar" style="padding:2px 5px;"><i class="fa fa-search"></i></button>
                    </div>
                    <div class="form-inline">
                        <label style="min-width:50px;">Tarih</label>
                        <input type="date" class="form-control" @bind="tarih" style="flex:1;" />
                    </div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Ith.Ihrc.Kodu</label>
                        <input type="text" class="form-control" @bind="ithIhrcKodu" style="flex:1;" />
                    </div>

                    <!-- Satir 2 -->
                    <div class="form-inline">
                        <label style="min-width:75px;">Belge No</label>
                        <input type="text" class="form-control" @bind="belgeNo" style="flex:1;" />
                    </div>
                    <div class="form-inline">
                        <label style="min-width:50px;">Vade</label>
                        <input type="date" class="form-control" @bind="vadeTarihi" style="flex:1;" />
                    </div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Odeme</label>
                        <input type="text" class="form-control" @bind="odemeSekli" style="flex:1;" />
                    </div>

                    <!-- Satir 3 -->
                    <div class="form-inline">
                        <label style="min-width:75px; font-weight:700;">Nor/Iade</label>
                        <select class="form-control" @bind="islemTipi" style="max-width:100px;">
                            <option value="Normal">Normal</option>
                            <option value="Iade">Iade</option>
                        </select>
                        <label style="margin-left:8px;">Odeme</label>
                        <select class="form-control" @bind="odemeSecimi" @bind:after="OdemeSecimiDegisti" style="max-width:160px;">
                            <option value="0">Acik Hesap</option>
                            <option value="1">Kasadan Kapanacak (Nakit)</option>
                            <option value="2">Bankadan Kapanacak (Havale)</option>
                            <option value="3">Bankadan Kapanacak (Kredi Karti)</option>
                        </select>
                    </div>
                    <div></div>
                    <div class="form-inline">
                        @if (odemeSecimi == "1")
                        {
                            <label style="min-width:75px;">Kasa Hesabi</label>
                            <select class="form-control" @bind="kapayanKodu" style="flex:1;">
                                <option value="">-- Kasa Sec --</option>
                                @foreach (var k in kasaHesaplari)
                                {
                                    <option value="@k.Kodu">@k.Kodu - @k.Adi</option>
                                }
                            </select>
                        }
                        else if (odemeSecimi == "2" || odemeSecimi == "3")
                        {
                            <label style="min-width:75px;">Banka Hesabi</label>
                            <select class="form-control" @bind="kapayanKodu" style="flex:1;">
                                <option value="">-- Banka Sec --</option>
                                @foreach (var b in bankaHesaplari)
                                {
                                    <option value="@b.Kodu">@b.Kodu - @b.Adi</option>
                                }
                            </select>
                        }
                        else
                        {
                            <label style="min-width:75px;">Kapayan kodu</label>
                            <input type="text" class="form-control" @bind="kapayanKodu" style="flex:1;" disabled />
                        }
                    </div>

                    <!-- Satir 4 -->
                    <div class="form-inline">
                        <label style="min-width:75px;">Tic.turu</label>
                        <select class="form-control" @bind="faturaTuru" style="flex:1;">
                            <option value="0">Toptan</option>
                            <option value="1">Perakende</option>
                            <option value="2">Dis Ticaret</option>
                            <option value="3">Stok Virman</option>
                            <option value="4">Fire</option>
                            <option value="5">Sarf</option>
                            <option value="6">Transfer</option>
                            <option value="7">Uretim</option>
                            <option value="8">Fason</option>
                            <option value="9">Deger Farki</option>
                            <option value="10">Sayim</option>
                            <option value="11">Stok Acilis</option>
                            <option value="12">Ithalat-Ihracat</option>
                            <option value="13">Hal</option>
                            <option value="14">Mustahsil</option>
                            <option value="15">Gider Pusulasi</option>
                        </select>
                    </div>
                    <div></div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Depo</label>
                        <select class="form-control" @bind="ambar" style="flex:1;">
                            <option>MERKEZ</option>
                        </select>
                    </div>

                    <!-- Satir 5 -->
                    <div class="form-inline">
                        <label style="min-width:75px;">C/H Kodu</label>
                        <input type="text" class="form-control" @bind="cariKodu" style="flex:1;" />
                        <button class="btn btn-sm btn-outline" @onclick="CariSecAc" style="padding:2px 5px;"><i class="fa fa-search"></i></button>
                    </div>
                    <div></div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Plasiyer</label>
                        <select class="form-control" @bind="satinalmaSorumlusu" style="flex:1;">
                            <option value="">-- Sec --</option>
                            @foreach (var p in plasiyerListesi)
                            {
                                <option value="@p.Adi">@p.Kodu - @p.Adi</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-success" style="padding:2px 5px; font-size:10px;" @onclick="() => plasiyerPopupAcik = true">+</button>
                    </div>

                    <!-- Satir 6 -->
                    <div class="form-inline">
                        <label style="min-width:75px;">C/H Ismi</label>
                        <input type="text" class="form-control" @bind="cariUnvan" style="flex:1;" />
                        <button class="btn btn-sm btn-success" @onclick="YeniCariAc" style="padding:2px 5px; font-size:10px;">+</button>
                        @if (eFaturaMukellefi)
                        {
                            <span style="background:#dc2626; color:white; padding:1px 6px; border-radius:3px; font-size:9px; margin-left:4px;">E-FAT</span>
                        }
                    </div>
                    <div></div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Proje</label>
                        <select class="form-control" @bind="proformaNo" style="flex:1;">
                            <option value="">-- Sec --</option>
                            @foreach (var p in projeListesi)
                            {
                                <option value="@p.Adi">@p.Kodu - @p.Adi</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-success" style="padding:2px 5px; font-size:10px;" @onclick="() => projePopupAcik = true">+</button>
                    </div>

                    <!-- Satir 7 -->
                    <div class="form-inline">
                        <label style="min-width:75px;">Doviz</label>
                        <select class="form-control" @bind="dovizTipi" @bind:after="DovizTipiDegisti" style="max-width:70px;">
                            <option>TL</option>
                            <option>USD</option>
                            <option>EUR</option>
                            <option>GBP</option>
                        </select>
                        <input type="number" class="form-control" @bind="dovizKuru" step="0.0001" style="max-width:100px; font-weight:700;" />
                    </div>
                    <div></div>
                    <div class="form-inline">
                        <label style="min-width:75px;">Sor. merkezi</label>
                        <select class="form-control" @bind="bolumSatinalmaSorumlusu" style="flex:1;">
                            <option value="">-- Sec --</option>
                            @foreach (var s in sorMerkezListesi)
                            {
                                <option value="@s.Adi">@s.Kodu - @s.Adi</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-success" style="padding:2px 5px; font-size:10px;" @onclick="() => sorMerkezPopupAcik = true">+</button>
                    </div>
                </div>

                <!-- SATIRLAR GRID -->
                <div style="position:relative; margin-bottom:10px;">
                    <!-- Grid Ayar Butonu -->
                    <button class="btn btn-outline btn-sm" style="position:absolute; top:-28px; right:0; z-index:10; font-size:10px; padding:2px 8px;" @onclick="() => gridAyarAcik = !gridAyarAcik">
                        <i class="fa fa-cog"></i> Grid Ayar
                    </button>
                <div class="grid-container" style="overflow:visible;">
                    <table class="data-grid">
                        <thead>
                            <tr>
                                <th style="width:120px;">Mal / Hizmet Kodu</th>
                                <th style="min-width:200px;">Mal / Hizmet</th>
                                @if (AlanAyar.KolonGorunurMu("aciklama1")) { <th style="min-width:120px;">Aciklama1</th> }
                                @if (AlanAyar.KolonGorunurMu("aciklama2")) { <th style="min-width:120px;">Aciklama2</th> }
                                @if (AlanAyar.KolonGorunurMu("aciklama3")) { <th style="min-width:120px;">Aciklama3</th> }
                                @if (AlanAyar.KolonGorunurMu("aciklama4")) { <th style="min-width:120px;">Aciklama4</th> }
                                <th style="width:70px;">Miktar</th>
                                <th style="width:60px;">Birim</th>
                                <th style="width:80px;">Fiyat</th>
                                <th style="width:75px;">Kdv</th>
                                <th style="width:80px;">Tutar</th>
                                <th style="width:50px;">Isk%</th>
                                <th style="width:90px;">Iskonto Tutari</th>
                                <th style="width:90px;">Kdv Matrahi</th>
                                <th style="width:80px;">Kdv Tutari</th>
                                <th style="width:80px;">Net Tutar</th>
                                @if (AlanAyar.KolonGorunurMu("kdvMuafiyet")) { <th>KdvMuafiyetSe...</th> }
                                @if (AlanAyar.KolonGorunurMu("tevkifat")) { <th>TevkifatKodu</th> }
                                @if (AlanAyar.KolonGorunurMu("gtipKodu")) { <th>GTipKodu</th> }
                                <th style="width:30px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < satirlar.Count; i++)
                            {
                                var idx = i;
                                var satir = satirlar[idx];
                                <tr>
                                    <td style="position:relative;">
                                        <input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.MalHizmetKodu" @bind:event="oninput" @bind:after="() => StokKodAra(idx)" @onfocus="() => aramaAktifIdx = idx" @onblur="() => StokKodBlur(idx)" />
                                        @if (aramaAktifIdx == idx && aramaStokSonuc.Any() && !string.IsNullOrEmpty(satir.MalHizmetKodu))
                                        {
                                            <div class="arama-dropdown">
                                                @foreach (var s in aramaStokSonuc)
                                                {
                                                    <div class="arama-item" @onclick="async () => await StokSec(idx, s)">
                                                        <strong>@s.StokKodu</strong> - @s.StokCinsi <span class="text-muted" style="font-size:10px;">(@s.Barkod)</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td style="position:relative;">
                                        <input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.MalHizmet" @bind:event="oninput" @bind:after="() => StokAdAra(idx)" @onfocus="() => aramaAktifIdx = idx" />
                                        @if (aramaAktifIdx == idx && aramaAdSonuc.Any() && !string.IsNullOrEmpty(satir.MalHizmet))
                                        {
                                            <div class="arama-dropdown">
                                                @foreach (var s in aramaAdSonuc)
                                                {
                                                    <div class="arama-item" @onclick="async () => await StokSec(idx, s)">
                                                        <strong>@s.StokCinsi</strong> <span class="text-muted" style="font-size:10px;">(@s.StokKodu)</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    @if (AlanAyar.KolonGorunurMu("aciklama1")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.Aciklama1" /></td> }
                                    @if (AlanAyar.KolonGorunurMu("aciklama2")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.Aciklama2" /></td> }
                                    @if (AlanAyar.KolonGorunurMu("aciklama3")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.Aciklama3" /></td> }
                                    @if (AlanAyar.KolonGorunurMu("aciklama4")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.Aciklama4" /></td> }
                                    <td><input type="text" class="form-control text-right" style="padding:2px 4px; font-size:11px;" value="@(satir.Miktar == 0 && string.IsNullOrEmpty(satir.MalHizmetKodu) ? "" : satir.Miktar.ToString())" @onchange="@(e => { double.TryParse(e.Value?.ToString(), out var v); satir.Miktar = v; Hesapla(); })" /></td>
                                    <td>
                                        <select class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.Birim">
                                            @foreach (var b in birimListesi)
                                            {
                                                <option value="@b.BirimAdi">@b.BirimAdi</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input type="text" class="form-control text-right" style="padding:2px 4px; font-size:11px;" value="@(satir.Fiyat == 0 && string.IsNullOrEmpty(satir.MalHizmetKodu) ? "" : satir.Fiyat.ToString("G"))" @onchange="@(e => { double.TryParse(e.Value?.ToString()?.Replace(',','.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v); satir.Fiyat = v; Hesapla(); })" /></td>
                                    <td>
                                        <select class="form-control" style="padding:2px 2px; font-size:11px; min-width:65px;" value="@satir.KdvOrani" @onchange="@(e => { satir.KdvOrani = int.Parse(e.Value?.ToString() ?? "20"); Hesapla(); })">
                                            @if (kdvOranlari != null && kdvOranlari.Any())
                                            {
                                                @foreach (var ko in kdvOranlari)
                                                {
                                                    var v = (int)(ko.KdvOrani ?? 0);
                                                    <option value="@v">%@v</option>
                                                }
                                            }
                                            else
                                            {
                                                <option value="0">%0</option>
                                                <option value="1">%1</option>
                                                <option value="10">%10</option>
                                                <option value="20">%20</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="text-right" style="font-size:11px;">@(satir.Tutar == 0 ? "" : satir.Tutar.ToString("N2"))</td>
                                    <td><input type="text" class="form-control text-right" style="padding:2px 4px; font-size:11px;" value="@(satir.IskontoOrani == 0 ? "" : satir.IskontoOrani.ToString())" @onchange="@(e => { double.TryParse(e.Value?.ToString(), out var v); satir.IskontoOrani = v; Hesapla(); })" /></td>
                                    <td class="text-right" style="font-size:11px;">@(satir.IskontoTutari == 0 ? "" : satir.IskontoTutari.ToString("N2"))</td>
                                    <td class="text-right" style="font-size:11px;">@(satir.KdvMatrahi == 0 ? "" : satir.KdvMatrahi.ToString("N2"))</td>
                                    <td class="text-right" style="font-size:11px;">@(satir.KdvTutari == 0 ? "" : satir.KdvTutari.ToString("N2"))</td>
                                    <td class="text-right" style="font-size:11px; font-weight:600;">@(satir.NetTutar == 0 ? "" : satir.NetTutar.ToString("N2"))</td>
                                    @if (AlanAyar.KolonGorunurMu("kdvMuafiyet")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.KdvMuafiyetSebebi" /></td> }
                                    @if (AlanAyar.KolonGorunurMu("tevkifat")) { <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.TevkifatKodu" /></td> }
                                    @if (AlanAyar.KolonGorunurMu("gtipKodu"))
                                    {
                                        <td><input type="text" class="form-control" style="padding:2px 4px; font-size:11px;" @bind="satir.GTipKodu" /></td>
                                    }
                                    <td style="width:30px;">
                                        <button class="btn btn-danger btn-sm" style="padding:1px 5px; font-size:10px;" @onclick="() => SatirSil(idx)" title="Satir Sil">x</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:#f0f9ff;">
                                <td colspan="7" style="text-align:right; font-weight:600; font-size:11px; padding:4px 8px;">Toplamlar:</td>
                                <td class="text-right" style="font-weight:700; font-size:11px;">@tutar.ToString("N2")</td>
                                <td></td>
                                <td class="text-right" style="font-weight:700; font-size:11px;">@iskontoToplam.ToString("N2")</td>
                                <td class="text-right" style="font-weight:700; font-size:11px;">@kdvMatrahi.ToString("N2")</td>
                                <td class="text-right" style="font-weight:700; font-size:11px;">@kdvToplam.ToString("N2")</td>
                                <td class="text-right" style="font-weight:700; font-size:11px; color:var(--pinebi-primary);">@toplamTutar.ToString("N2")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                </div>

                <!-- ALT KISIM - Toplamlar + Butonlar -->
                <div style="display:flex; gap:12px; justify-content:flex-end;">

                    <!-- Toplamlar + Butonlar -->
                    <div style="min-width:240px;">
                        <div class="form-inline mb-1">
                            <label style="min-width:140px; text-align:right; font-size:11px;">Tutar</label>
                            <input type="text" class="form-control text-right" value="@tutar.ToString("N2")" readonly style="max-width:100px; font-size:11px;" />
                        </div>
                        <div class="form-inline mb-1">
                            <label style="min-width:140px; text-align:right; font-size:11px;">Iskonto</label>
                            <input type="text" class="form-control text-right" value="@iskontoToplam.ToString("N2")" readonly style="max-width:100px; font-size:11px;" />
                        </div>
                        <!-- KDV Detay - orana gore -->
                        @foreach (var km in kdvMatrahDetay)
                        {
                            <div style="display:flex; gap:4px; margin-bottom:2px; align-items:center;">
                                <label style="min-width:50px; text-align:right; font-size:11px; font-weight:700; color:var(--pinebi-primary);">%@km.Oran</label>
                                <div style="flex:1; font-size:11px; font-weight:600;">Matrah:</div>
                                <input type="text" class="form-control text-right" value="@km.Matrah.ToString("N2")" readonly style="max-width:80px; font-size:11px; font-weight:700; padding:1px 4px;" />
                                <div style="font-size:11px; font-weight:600;">KDV:</div>
                                <input type="text" class="form-control text-right" value="@km.KdvTutari.ToString("N2")" readonly style="max-width:80px; font-size:11px; font-weight:700; padding:1px 4px;" />
                            </div>
                        }
                        <div class="form-inline mb-1" style="border-top:2px solid var(--pinebi-primary); padding-top:4px;">
                            <label style="min-width:140px; text-align:right; font-weight:700; color:var(--pinebi-primary);">TOPLAM</label>
                            <input type="text" class="form-control text-right text-bold" value="@toplamTutar.ToString("N2")" readonly style="max-width:100px; font-size:14px; color:var(--pinebi-primary);" />
                        </div>
                        @if (!string.IsNullOrEmpty(kayitMesaji))
                        {
                            <div class="alert @(kayitBasarili ? "alert-success" : "alert-danger") mt-1" style="font-size:11px; padding:4px 8px;">
                                @kayitMesaji
                            </div>
                        }
                        <div style="display:flex; gap:6px; margin-top:8px;">
                            <button class="btn btn-success" @onclick="Kaydet"><i class="fa fa-save"></i> [F2] Kaydet</button>
                            <button class="btn btn-secondary" @onclick="Kapat"><i class="fa fa-times"></i> [Esc] Kapat</button>
                        </div>
                    </div>
                </div>

                <!-- ALT TOOLBAR: Ice/Disa Aktar + Onceki/Sonraki -->
                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px; padding:6px 0; border-top:1px solid var(--pinebi-border);">
                    <!-- Sol: Ice/Disa Aktar -->
                    <div style="display:flex; gap:6px;">
                        <button class="btn btn-outline btn-sm" @onclick="IceAktarAc"><i class="fa fa-file-import"></i> Ice Aktar (Excel/Yapistir)</button>
                        <button class="btn btn-outline btn-sm" @onclick="DisaAktar"><i class="fa fa-file-export"></i> Disa Aktar</button>
                    </div>
                    <!-- Sag: Onceki/Sonraki -->
                    <div style="display:flex; gap:4px; align-items:center;">
                        <button class="btn btn-outline btn-sm" @onclick="OncekiFaturaGit"><i class="fa fa-chevron-left"></i> Onceki</button>
                        <span style="font-size:11px; font-weight:600; color:var(--pinebi-primary); min-width:120px; text-align:center;">@fisNo</span>
                        <button class="btn btn-outline btn-sm" @onclick="SonrakiFaturaGit"><i class="fa fa-chevron-right"></i> Sonraki</button>
                    </div>
                </div>
            }
            else if (activeTab == 1)
            {
                <!-- DETAY TAB -->
                <div style="display:flex; gap:12px;">
                    <!-- Fatura Aciklamalari -->
                    <div class="group-box" style="flex:1;">
                        <span class="group-box-title">Fatura Aciklamalari</span>
                        <div class="form-inline mb-1"><label style="min-width:40px;">Not 1</label><input type="text" class="form-control" @bind="not1" /></div>
                        <div class="form-inline mb-1"><label style="min-width:40px;">Not 2</label><input type="text" class="form-control" @bind="not2" /></div>
                        <div class="form-inline mb-1"><label style="min-width:40px;">Not 3</label><input type="text" class="form-control" @bind="not3" /></div>
                        <div class="form-inline mb-1"><label style="min-width:40px;">Not 4</label><input type="text" class="form-control" @bind="not4" /></div>
                        <div class="form-inline"><label style="min-width:40px;">Not 5</label><input type="text" class="form-control" @bind="not5" /></div>
                    </div>

                    <!-- Sevk Adresi -->
                    <div class="group-box" style="flex:1;">
                        <span class="group-box-title">Sevk Adresi</span>
                        <div class="form-inline mb-1">
                            <label style="min-width:100px;">Adres Basligi</label>
                            <input type="text" class="form-control" @bind="sevkAdresBasligi" />
                            <button class="btn btn-sm btn-success" @onclick="SevkAdresiEkle"><i class="fa fa-plus"></i> Ekle</button>
                            <button class="btn btn-sm btn-danger" @onclick="SevkAdresiSil"><i class="fa fa-trash"></i> Sil</button>
                        </div>
                        @if (sevkAdresleri.Any())
                        {
                            <div class="grid-container mb-1" style="max-height:60px;">
                                <table class="data-grid"><tbody>
                                    @foreach (var sa in sevkAdresleri)
                                    {
                                        <tr style="cursor:pointer; @(seciliSevkIdx == sevkAdresleri.IndexOf(sa) ? "background:#dbeafe;" : "")" @onclick="() => SevkAdresiSec(sevkAdresleri.IndexOf(sa))">
                                            <td style="font-size:11px;">@sa.Baslik</td><td style="font-size:11px;">@sa.Adres</td><td style="font-size:11px;">@sa.Sehir</td>
                                        </tr>
                                    }
                                </tbody></table>
                            </div>
                        }
                        <div class="form-inline mb-1"><label style="min-width:100px;">Irtibat Tel</label><input type="text" class="form-control" @bind="sevkIrtibatTel" /></div>
                        <div class="form-inline mb-1"><label style="min-width:100px;">Adres</label><input type="text" class="form-control" @bind="sevkAdres" /></div>
                        <div class="form-inline mb-1"><label style="min-width:100px;">Posta Kodu</label><input type="text" class="form-control" @bind="sevkPostaKodu" /></div>
                        <div class="form-inline mb-1"><label style="min-width:100px;">Ulke</label><input type="text" class="form-control" @bind="sevkUlke" /></div>
                        <div class="form-inline"><label style="min-width:100px;">Ilce/Sehir</label><input type="text" class="form-control" @bind="sevkIlce" style="max-width:120px;" /><span>/</span><input type="text" class="form-control" @bind="sevkSehir" /></div>
                    </div>

                    <!-- Banka Bilgileri -->
                    <div class="group-box" style="flex:0.7;">
                        <span class="group-box-title">Banka Bilgileri</span>
                        <div class="grid-container" style="max-height:200px;">
                            <table class="data-grid">
                                <thead><tr><th style="width:30px;">Sec</th><th>Banka Adi</th><th>Para Birimi</th></tr></thead>
                                <tbody><tr><td><input type="checkbox" /></td><td>ZIRAAT BANKASI</td><td>TRY(t)</td></tr></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == 2)
            {
                <!-- YAZDIR TAB -->
                <div style="display:flex; gap:12px;">
                    <div style="flex:0.4;">
                        <div class="group-box">
                            <span class="group-box-title">Yazdirma Islemleri</span>
                            <div style="display:flex; gap:8px; flex-direction:column;">
                                <button class="btn @(irsaliyeYazdirildiMi ? "btn-danger" : "btn-success")" @onclick='() => YazdirmaOnizlemeAc("Irsaliye")'>
                                    <i class="fa fa-print"></i> Irsaliye Onizleme / Yazdir
                                    @if (irsaliyeYazdirildiMi) { <span style="font-size:10px;"> (Daha once yazdirildi)</span> }
                                </button>
                                <button class="btn @(faturaYazdirildiMi ? "btn-danger" : "btn-success")" @onclick='() => YazdirmaOnizlemeAc("Fatura")'>
                                    <i class="fa fa-print"></i> Fatura Onizleme / Yazdir
                                    @if (faturaYazdirildiMi) { <span style="font-size:10px;"> (Daha once yazdirildi)</span> }
                                </button>
                            </div>
                        </div>
                    </div>
                    <div style="flex:1;">
                        <div class="group-box">
                            <span class="group-box-title">Yazdirma Gecmisi</span>
                            @if (yazdirmaGecmisi.Any())
                            {
                                <div class="grid-container" style="max-height:300px;">
                                    <table class="data-grid">
                                        <thead><tr><th>Tip</th><th>Tarih</th><th>Saat</th><th>Kullanici</th><th>Yazici</th></tr></thead>
                                        <tbody>
                                            @foreach (var yg in yazdirmaGecmisi)
                                            {
                                                <tr>
                                                    <td>@yg.Tip</td>
                                                    <td>@yg.Tarih.ToString("dd.MM.yyyy")</td>
                                                    <td>@yg.Tarih.ToString("HH:mm:ss")</td>
                                                    <td>@yg.Kullanici</td>
                                                    <td>@yg.Yazici</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted" style="padding:20px;">Henuz yazdirma yapilmadi.</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

