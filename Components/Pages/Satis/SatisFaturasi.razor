        tevkifatMuafiyeti = 0; toplamTutar = 0; odenecekTutar = 0;
        kdvMatrahDetay = new();

        // Notlar temizle
        not1 = ""; not2 = ""; not3 = ""; not4 = ""; not5 = "";

