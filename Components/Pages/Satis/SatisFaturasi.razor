    private void IceAktarAc()
    {
        iceAktarMetin = "";
        iceAktarSonuc = "";
        iceAktarAcik = true;
    }

    private async Task IceAktarUygula()
    {
        if (string.IsNullOrWhiteSpace(iceAktarMetin))
        {
            iceAktarSonuc = "Veri giriniz!";
            iceAktarBasarili = false;
            return;
        }

        var satirSayisi = 0;
        var hataSayisi = 0;
        using var db = await FirmaFactory.CreateDbContextAsync();

        var lines = iceAktarMetin.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            var parts = line.Trim().Split('\t', ';', ',');
            if (parts.Length < 1 || string.IsNullOrWhiteSpace(parts[0])) continue;

            var stokKodu = parts[0].Trim();
            var miktar = 1.0;
            var fiyat = 0.0;

            if (parts.Length >= 2) double.TryParse(parts[1].Trim().Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out miktar);
            if (parts.Length >= 3) double.TryParse(parts[2].Trim().Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out fiyat);

            try
            {
                var stok = await db.StokKart.AsNoTracking().FirstOrDefaultAsync(s => s.StokKodu == stokKodu);
                if (stok != null)
                {
                    // Son bos satiri kaldir, yeni ekle
                    if (satirlar.Any() && string.IsNullOrEmpty(satirlar.Last().MalHizmetKodu))
                        satirlar.RemoveAt(satirlar.Count - 1);

                    satirlar.Add(new FaturaSatir
                    {
                        MalHizmetKodu = stok.StokKodu ?? stokKodu,
                        MalHizmet = stok.StokCinsi ?? "",
                        Miktar = miktar,
                        Birim = stok.Birim ?? "Adet",
                        Fiyat = fiyat > 0 ? fiyat : (double)stok.KdvHaricSatisFiyati,
                        KdvOrani = (int)stok.Kdv
                    });
                    satirSayisi++;
                }
                else
                {
                    // Stok bulunamadi - yine de ekle
                    if (satirlar.Any() && string.IsNullOrEmpty(satirlar.Last().MalHizmetKodu))
                        satirlar.RemoveAt(satirlar.Count - 1);

                    satirlar.Add(new FaturaSatir
                    {
                        MalHizmetKodu = stokKodu,
                        MalHizmet = $"[{stokKodu}]",
                        Miktar = miktar,
                        Fiyat = fiyat
                    });
                    hataSayisi++;
                }
            }
            catch { hataSayisi++; }
        }

        satirlar.Add(new FaturaSatir()); // bos satir ekle
        Hesapla();

        iceAktarSonuc = $"{satirSayisi} urun eklendi" + (hataSayisi > 0 ? $", {hataSayisi} urun DB'de bulunamadi" : "");
        iceAktarBasarili = hataSayisi == 0;
        iceAktarAcik = false;
    }

    private void DisaAktar()
    {
        // Tab-separated olarak clipboard'a kopyalanacak veriyi olustur
        var aktifSatirlar = satirlar.Where(s => !string.IsNullOrEmpty(s.MalHizmetKodu)).ToList();
        if (!aktifSatirlar.Any()) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("StokKodu\tStokCinsi\tMiktar\tBirim\tFiyat\tKDV%\tTutar\tNetTutar");
        foreach (var s in aktifSatirlar)
        {
            sb.AppendLine($"{s.MalHizmetKodu}\t{s.MalHizmet}\t{s.Miktar}\t{s.Birim}\t{s.Fiyat:N2}\t{s.KdvOrani}\t{s.Tutar:N2}\t{s.NetTutar:N2}");
        }
        disaAktarMetin = sb.ToString();
        disaAktarAcik = true;
    }

