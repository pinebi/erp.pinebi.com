            <div class="modal-header">
                <span><i class="fa fa-cog"></i> Grid Kolon Ayarlari</span>
                <button class="modal-close" @onclick="() => gridAyarAcik = false">X</button>
            </div>
            <div class="modal-body" style="max-height:400px; overflow-y:auto;">
                <div class="alert alert-info" style="font-size:11px; padding:6px 10px;">
                    <i class="fa fa-info-circle"></i> Acik/kapali secimleriniz aninda uygulanir.
                </div>
                @foreach (var kolon in AlanAyar.KolonlariGetir("fatura"))
                {
                    <label style="display:flex; align-items:center; gap:8px; font-size:12px; padding:6px 4px; cursor:pointer; border-bottom:1px solid #f3f4f6;">
                        <input type="checkbox" checked="@kolon.Gorunur"
                               style="width:16px; height:16px; accent-color:var(--pinebi-primary);"
                               @onchange="@(e => AlanAyar.KolonGorunurlukDegistir(kolon.KolonId, (bool)(e.Value ?? false)))" />
