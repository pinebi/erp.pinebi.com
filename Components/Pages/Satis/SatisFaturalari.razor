@page "/satis/faturalar"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore

<PageTitle>Satis Faturalari</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-file-text"></i> Satis Faturalari
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="YeniFatura">
                <i class="fa fa-plus"></i> Yeni
            </button>
            <button class="btn btn-success btn-sm" @onclick="YeniIadeFatura">
                <i class="fa fa-plus"></i> Satis Iade Faturasi
            </button>
            <button class="btn btn-primary btn-sm" @onclick="Duzenle">
                <i class="fa fa-pencil"></i> Duzenle
            </button>
            <button class="btn btn-danger btn-sm" @onclick="Iptal">
                <i class="fa fa-ban"></i> Iptal
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="FaturaTahsilati">
                <i class="fa fa-money"></i> Fatura Tahsilati
            </button>
            <button class="btn btn-outline btn-sm" @onclick="TahsilatGecmisi">
                <i class="fa fa-history"></i> Tahsilat Gecmisi
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                <i class="fa fa-file-excel-o"></i> Excel Aktar
            </button>
        </div>

        <!-- Filtre Alani -->
        <div class="form-row" style="margin-bottom:10px;">
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarihi" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarihi" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Listele">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <div class="form-check" style="margin-left:10px;">
                <input type="checkbox" @bind="iptalListele" @bind:after="IptalFiltrele" />
                <label>Iptal Faturalari Listele</label>
            </div>
            <div class="form-inline" style="margin-left:auto;">
                <label style="min-width:30px;">Ara</label>
                <input type="text" class="form-control" placeholder="Fatura no, cari kodu, unvan..." @bind="aramaMetni" @bind:event="oninput" style="max-width:250px;" />
            </div>
        </div>

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 280px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:90px;">Fis Tipi</th>
                        <th style="width:80px;">Fatura Turu</th>
                        <th style="width:90px;">Tarih</th>
                        <th style="width:50px;">Saat</th>
                        <th style="width:90px;">Sevk Tarihi</th>
                        <th style="width:110px;">Fis No</th>
                        <th style="width:100px;">Belge No</th>
                        <th style="width:100px;">Cari Kodu</th>
                        <th style="min-width:200px;">Unvani</th>
                        <th style="width:90px;">Vade Tarihi</th>
                        <th style="width:90px;">Temlik Tarihi</th>
                        <th style="width:100px;">Siparis No</th>
                        <th style="width:90px;">Siparis Tarihi</th>
                        <th style="width:70px;">Doviz Cinsi</th>
                        <th style="width:100px;">Personel</th>
                        <th style="min-width:150px;">Aciklama</th>
                        <th style="width:100px;">Proforma No</th>
                        <th style="width:120px;">Satinalma Sor.</th>
                        <th style="width:120px;">GIB Gonderim</th>
                        <th style="width:100px;">Fatura Durumu</th>
                        <th style="width:100px; text-align:right;">Tutar</th>
                        <th style="width:100px; text-align:right;">Toplam Indirim</th>
                        <th style="width:100px; text-align:right;">KDV Matrahi</th>
                        <th style="width:100px; text-align:right;">KDV Tutari</th>
                        <th style="width:100px; text-align:right;">Toplam Tutar</th>
                        <th style="width:110px; text-align:right;">Odenecek Tutar</th>
                        <th style="width:100px; text-align:right;">TL Tutar</th>
                        <th style="width:100px; text-align:right;">TL Top. Indirim</th>
                        <th style="width:100px; text-align:right;">TL KDV Matrahi</th>
                        <th style="width:100px; text-align:right;">TL KDV Tutari</th>
                        <th style="width:100px; text-align:right;">TL Toplam Tutar</th>
                        <th style="width:110px; text-align:right;">TL Odenecek Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fatura in filtreliFaturalar)
                    {
                        <tr class="@(seciliId == fatura.Id ? "selected" : "")" @onclick="() => SatirSec(fatura.Id)" @ondblclick="Duzenle">
                            <td>@fatura.Fis</td>
                            <td>@fatura.FaturaTuru</td>
                            <td>@fatura.Tarih.ToString("dd.MM.yyyy")</td>
                            <td>@fatura.Saat?.ToString(@"hh\:mm")</td>
                            <td>@fatura.SevkTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@fatura.FisNo</td>
                            <td>@fatura.BelgeNo</td>
                            <td>@fatura.CariKodu</td>
                            <td>@fatura.Unvani</td>
                            <td>@fatura.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@fatura.TemlikTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@fatura.SiparisNo</td>
                            <td>@fatura.SiparisTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@fatura.DovizCinsi</td>
                            <td>@fatura.Personel</td>
                            <td>@fatura.Aciklama1</td>
                            <td>@fatura.ProformaNo</td>
                            <td>@fatura.SatinalmaSorumlusu</td>
                            <td>@fatura.GibGonderimDurumu</td>
                            <td>
                                @if (fatura.FaturaDurumu == "Onaylandi")
                                {
                                    <span style="background:#16a34a; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.FaturaDurumu</span>
                                }
                                else if (fatura.FaturaDurumu == "Onaylanmadi")
                                {
                                    <span style="background:#dc2626; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.FaturaDurumu</span>
                                }
                                else
                                {
                                    @fatura.FaturaDurumu
                                }
                            </td>
                            <td class="text-right">@fatura.Tutar?.ToString("N2")</td>
                            <td class="text-right">@fatura.ToplamIndirim?.ToString("N2")</td>
                            <td class="text-right">@fatura.KdvMatrahi?.ToString("N2")</td>
                            <td class="text-right">@fatura.KdvTutari?.ToString("N2")</td>
                            <td class="text-right">@fatura.ToplamTutar?.ToString("N2")</td>
                            <td class="text-right" style="font-weight:700;">@fatura.OdenecekTutar?.ToString("N2")</td>
                            <td class="text-right">@fatura.TLTutar?.ToString("N2")</td>
                            <td class="text-right">@fatura.TLToplamIndirim?.ToString("N2")</td>
                            <td class="text-right">@fatura.TLKdvMatrahi?.ToString("N2")</td>
                            <td class="text-right">@fatura.TLKdvTutari?.ToString("N2")</td>
                            <td class="text-right">@fatura.TLToplamTutar?.ToString("N2")</td>
                            <td class="text-right" style="font-weight:700;">@fatura.TLOdenecekTutar?.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:var(--pinebi-primary); color:white; font-weight:700;">
                        <td colspan="20" class="text-right">Toplam:</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.Tutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.ToplamIndirim ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.KdvMatrahi ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.KdvTutari ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.ToplamTutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.OdenecekTutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLTutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLToplamIndirim ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLKdvMatrahi ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLKdvTutari ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLToplamTutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliFaturalar.Sum(f => f.TLOdenecekTutar ?? 0).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Kayit Sayisi -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
            <span class="text-muted">Toplam @filtreliFaturalar.Count kayit</span>
        </div>
    </div>
</div>

@* ===== TAHSILAT MODAL ===== *@
@if (tahsilatModalAcik)
{
    <div class="modal-backdrop" @onclick="() => tahsilatModalAcik = false"></div>
    <div class="modal-dialog" style="width:450px;">
        <div class="card">
            <div class="card-header">
                <i class="fa fa-money"></i> Fatura Tahsilati - @seciliFaturaNo
                <button class="btn btn-sm" style="float:right;" @onclick="() => tahsilatModalAcik = false">X</button>
            </div>
            <div class="card-body" style="padding:16px;">
                <div style="margin-bottom:12px;">
                    <label>Fatura Tutari:</label>
                    <input type="text" class="form-control" value="@seciliFaturaTutar.ToString("N2")" readonly />
                </div>
                <div style="margin-bottom:12px;">
                    <label>Tahsilat Tutari:</label>
                    <input type="number" class="form-control" @bind="tahsilatTutari" step="0.01" />
                </div>
                <div style="margin-bottom:12px;">
                    <label>Islem Tipi:</label>
                    <select class="form-control" @bind="tahsilatIslemId">
                        <option value="1">Nakit</option>
                        <option value="2">Havale/EFT</option>
                        <option value="3">Kredi Karti</option>
                        <option value="4">Cek</option>
                        <option value="5">Senet</option>
                    </select>
                </div>
                <div style="margin-bottom:12px;">
                    <label>Aciklama:</label>
                    <input type="text" class="form-control" @bind="tahsilatAciklama" />
                </div>
                @if (!string.IsNullOrEmpty(tahsilatMesaj))
                {
                    <div style="color:red; margin-bottom:8px;">@tahsilatMesaj</div>
                }
                <div style="text-align:right;">
                    <button class="btn btn-success btn-sm" @onclick="TahsilatKaydet">
                        <i class="fa fa-save"></i> Kaydet
                    </button>
                    <button class="btn btn-outline btn-sm" @onclick="() => tahsilatModalAcik = false">Vazgec</button>
                </div>
            </div>
        </div>
    </div>
}

@* ===== TAHSILAT GECMISI MODAL ===== *@
@if (gecmisModalAcik)
{
    <div class="modal-backdrop" @onclick="() => gecmisModalAcik = false"></div>
    <div class="modal-dialog" style="width:500px;">
        <div class="card">
            <div class="card-header">
                <i class="fa fa-history"></i> Tahsilat Gecmisi - @seciliFaturaNo
                <button class="btn btn-sm" style="float:right;" @onclick="() => gecmisModalAcik = false">X</button>
            </div>
            <div class="card-body" style="padding:16px;">
                @if (tahsilatGecmisi.Any())
                {
                    <table class="xtable">
                        <thead><tr><th>Tarih</th><th style="text-align:right;">Tutar</th><th>Personel</th></tr></thead>
                        <tbody>
                            @foreach (var t in tahsilatGecmisi)
                            {
                                <tr>
                                    <td>@t.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td style="text-align:right; font-weight:700;">@t.Tutar.ToString("N2")</td>
                                    <td>@t.Personel</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="font-weight:700;">
                                <td>Toplam:</td>
                                <td style="text-align:right;">@tahsilatGecmisi.Sum(t => t.Tutar).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <p class="text-muted">Tahsilat gecmisi bulunamadi.</p>
                }
                <div style="text-align:right; margin-top:12px;">
                    <button class="btn btn-outline btn-sm" @onclick="() => gecmisModalAcik = false">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-90);
    private DateTime bitisTarihi = DateTime.Today;
    private bool iptalListele = false;
    private string aramaMetni = "";
    private int seciliId = 0;

    private List<SatisFaturaItem> faturalar = new();
    private List<SatisFaturaItem> filtreliFaturalar => string.IsNullOrWhiteSpace(aramaMetni)
        ? faturalar
        : faturalar.Where(f =>
            (f.FisNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (f.CariKodu ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (f.Unvani ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (f.BelgeNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await Listele();
    }

    private async Task Listele()
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var trCode = new List<int> { 2, 3, 7, 8 };
            var iptalDeger = iptalListele ? 1 : 0;
            var dbList = await db.FaturalarView.AsNoTracking()
                .Where(s => trCode.Contains(s.TrCode) && s.Tarih >= baslangicTarihi && s.Tarih <= bitisTarihi && (iptalListele || s.Iptal != true))
                .OrderByDescending(s => s.Tarih)
                .Take(500)
                .ToListAsync();
            faturalar = dbList.Select(f => new SatisFaturaItem
            {
                Id = f.Id, Fis = f.Fis, FaturaTuru = f.FaturaTuru, Tarih = f.Tarih, Saat = f.Saat,
                SevkTarihi = f.SevkTarihi, FisNo = f.FisNo, BelgeNo = f.BelgeNo, CariKodu = f.CariKodu,
                Unvani = f.Unvani, VadeTarihi = f.VadeTarihi, TemlikTarihi = f.TemlikTarihi,
                SiparisNo = f.SiparisNo, SiparisTarihi = f.SiparisTarihi, DovizCinsi = f.DovizCinsi,
                DovizKuru = f.DovizKuru, Personel = f.Personel, Aciklama1 = f.Aciklama1,
                ProformaNo = f.ProformaNo, SatinalmaSorumlusu = f.SatinalmaSorumlusu,
                GibGonderimDurumu = f.GibGonderimDurumu, FaturaDurumu = f.FaturaDurumu, Iptal = f.Iptal,
                Tutar = f.Tutar, ToplamIndirim = f.ToplamIndirim, KdvMatrahi = f.KdvMatrahi,
                KdvTutari = f.KdvTutari, ToplamTutar = f.ToplamTutar, OdenecekTutar = f.OdenecekTutar,
                TLTutar = f.TLTutar, TLToplamIndirim = f.TLToplamIndirim, TLKdvMatrahi = f.TLKdvMatrahi,
                TLKdvTutari = f.TLKdvTutari, TLToplamTutar = f.TLToplamTutar, TLOdenecekTutar = f.TLOdenecekTutar
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SatisFaturalari DB hatasi: {ex.Message}");
            faturalar = GetPlaceholderData();
        }
    }

    private async Task IptalFiltrele()
    {
        await Listele();
    }

    private void SatirSec(int id) => seciliId = id;

    private void YeniFatura()
    {
        Nav.NavigateTo("/satis/fatura/yeni");
    }

    private void YeniIadeFatura()
    {
        Nav.NavigateTo("/satis/fatura/yeni?tip=iade");
    }

    private void Duzenle()
    {
        if (seciliId == 0) return;
        Nav.NavigateTo($"/satis/fatura/{seciliId}");
    }

    private async Task Iptal()
    {
        if (seciliId == 0) return;
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var fatura = await db.Faturalar.FirstOrDefaultAsync(f => f.Id == seciliId);
            if (fatura == null) return;

            if (fatura.Iptal == true)
            {
                Console.WriteLine("Bu fatura zaten iptal edilmis.");
                return;
            }

            fatura.Iptal = true;
            fatura.IptalTarihi = DateTime.Now;
            fatura.IptalEden = "Admin"; // TODO: Aktif kullanici bilgisi

            // Fatura satirlarini da iptal et
            var satirlar = await db.FatIrsSatirlar.Where(s => s.FaturaId == seciliId).ToListAsync();
            foreach (var satir in satirlar)
            {
                satir.Iptal = true;
            }

            // Cari hareketleri iptal et
            var cariHareketler = await db.CariHareketler.Where(c => c.FisId == seciliId).ToListAsync();
            foreach (var hareket in cariHareketler)
            {
                hareket.Iptal = true;
                hareket.IptalEden = "Admin";
            }

            // Iptal logunu kaydet
            db.FaturaIptalLog.Add(new MACHINEBISS_Web.Models.MachineBiss.FaturaIptalLog
            {
                FaturaTipi = fatura.FaturaTipi,
                FaturaTuru = fatura.FaturaTuru,
                FaturaTarihi = fatura.Tarih,
                FaturaNo = fatura.FisNo,
                IptalTarihi = DateTime.Now,
                IptalEden = "Admin"
            });

            await db.SaveChangesAsync();
            await Listele(); // Listeyi yenile
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fatura iptal hatasi: {ex.Message}");
        }
    }

    // ===== TAHSILAT =====
    private bool tahsilatModalAcik = false;
    private bool gecmisModalAcik = false;
    private decimal tahsilatTutari = 0;
    private string tahsilatAciklama = "";
    private int tahsilatIslemId = 1; // 1=Nakit, 2=Havale, 3=Kredi Karti
    private string tahsilatMesaj = "";
    private List<TahsilatGecmisItem> tahsilatGecmisi = new();
    private decimal seciliFaturaTutar = 0;
    private string seciliFaturaNo = "";

    private void FaturaTahsilati()
    {
        if (seciliId == 0) return;
        var fat = faturalar.FirstOrDefault(f => f.Id == seciliId);
        if (fat == null) return;
        seciliFaturaTutar = fat.OdenecekTutar ?? 0;
        seciliFaturaNo = fat.FisNo ?? "";
        tahsilatTutari = seciliFaturaTutar;
        tahsilatAciklama = "";
        tahsilatMesaj = "";
        tahsilatModalAcik = true;
    }

    private async Task TahsilatKaydet()
    {
        if (tahsilatTutari <= 0) { tahsilatMesaj = "Tutar giriniz!"; return; }
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            db.FaturaTahsilatOdeme.Add(new MACHINEBISS_Web.Models.MachineBiss.FaturaTahsilatOdeme
            {
                Tarih = DateTime.Now,
                FaturaId = seciliId,
                IslemId = tahsilatIslemId,
                FaturaTutari = (double)seciliFaturaTutar,
                IslemTutari = (double)tahsilatTutari,
                Personel = "Admin",
                Iptal = false
            });
            await db.SaveChangesAsync();
            tahsilatMesaj = "Tahsilat kaydedildi!";
            tahsilatModalAcik = false;
            await Listele();
        }
        catch (Exception ex) { tahsilatMesaj = $"Hata: {ex.Message}"; }
    }

    private async Task TahsilatGecmisi()
    {
        if (seciliId == 0) return;
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var gecmis = await db.FaturaTahsilatOdeme.AsNoTracking()
                .Where(t => t.FaturaId == seciliId && t.Iptal != true)
                .OrderByDescending(t => t.Tarih)
                .ToListAsync();
            tahsilatGecmisi = gecmis.Select(t => new TahsilatGecmisItem
            {
                Tarih = t.Tarih ?? DateTime.MinValue,
                Tutar = t.IslemTutari,
                Personel = t.Personel ?? ""
            }).ToList();
            var fat = faturalar.FirstOrDefault(f => f.Id == seciliId);
            seciliFaturaNo = fat?.FisNo ?? "";
            gecmisModalAcik = true;
        }
        catch (Exception ex) { Console.WriteLine($"Gecmis hatasi: {ex.Message}"); }
    }

    public class TahsilatGecmisItem
    {
        public DateTime Tarih { get; set; }
        public double Tutar { get; set; }
        public string Personel { get; set; } = "";
    }

    private async void Yazdir()
    { await JS.InvokeVoidAsync("window.print");
        // TODO: Yazdir islemi
    }

    private void ExcelAktar()
    { /* Excel export - coming soon */
        // TODO: Excel export islemi
    }

    private List<SatisFaturaItem> GetPlaceholderData()
    {
        var result = new List<SatisFaturaItem>();
        var cariler = new[] {
            ("C-001", "Pinebi Bilisim Teknolojileri A.S.", "Ahmet Yilmaz"),
            ("C-002", "BlockBiss Yazilim Ltd. Sti.", "Mehmet Demir"),
            ("C-003", "Anadolu Makina Sanayi A.S.", "Ali Kaya"),
            ("C-004", "Ege Elektronik Tic. Ltd. Sti.", "Fatma Ozturk"),
            ("C-005", "Karadeniz Gida Pazarlama A.S.", "Hasan Celik")
        };
        var rnd = new Random(123);
        for (int i = 1; i <= 35; i++)
        {
            var c = cariler[i % cariler.Length];
            var gun = rnd.Next(1, 90);
            var tutar = (decimal)Math.Round(rnd.NextDouble() * 80000 + 2000, 2);
            var kdv = (decimal)Math.Round((double)tutar * 0.20, 2);
            result.Add(new SatisFaturaItem
            {
                Id = i, Fis = i % 5 == 0 ? "Satis Iade Faturasi" : "Satis Faturasi",
                FaturaTuru = i % 3 == 0 ? "E-Fatura" : "E-Arsiv",
                Tarih = DateTime.Today.AddDays(-gun), Saat = new TimeSpan(rnd.Next(8,18), rnd.Next(0,59), 0),
                FisNo = $"HTA{DateTime.Today.Year}{i:D8}", BelgeNo = i % 2 == 0 ? $"BLG-{i:D3}" : "",
                CariKodu = c.Item1, Unvani = c.Item2, DovizCinsi = "TL", Personel = c.Item3,
                VadeTarihi = DateTime.Today.AddDays(-gun + 30), FaturaDurumu = "Acik",
                Tutar = tutar, ToplamIndirim = 0m, KdvMatrahi = tutar, KdvTutari = kdv,
                ToplamTutar = tutar + kdv, OdenecekTutar = tutar + kdv,
                TLTutar = tutar, TLToplamIndirim = 0m, TLKdvMatrahi = tutar, TLKdvTutari = kdv,
                TLToplamTutar = tutar + kdv, TLOdenecekTutar = tutar + kdv
            });
        }
        return result.OrderByDescending(x => x.Tarih).ToList();
    }

