@page "/satis/siparisler"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore

<PageTitle>Satis Siparisleri</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-shopping-cart"></i> Satis Siparisleri
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="YeniSiparis">
                <i class="fa fa-plus"></i> Yeni
            </button>
            <button class="btn btn-primary btn-sm" @onclick="Duzenle">
                <i class="fa fa-pencil"></i> Duzenle
            </button>
            <button class="btn btn-danger btn-sm" @onclick="Iptal">
                <i class="fa fa-ban"></i> Iptal
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                <i class="fa fa-file-excel-o"></i> Excel Aktar
            </button>
        </div>

        <!-- Filtre Alani -->
        <div class="form-row" style="margin-bottom:10px;">
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarihi" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarihi" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Listele">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <div class="form-inline" style="margin-left:auto;">
                <label style="min-width:30px;">Ara</label>
                <input type="text" class="form-control" placeholder="Siparis no, cari kodu, unvan..." @bind="aramaMetni" @bind:event="oninput" style="max-width:250px;" />
            </div>
        </div>

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 260px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:90px;">Tarih</th>
                        <th style="width:50px;">Saat</th>
                        <th style="width:90px;">Sevk Tarihi</th>
                        <th style="width:110px;">Fis No</th>
                        <th style="width:100px;">Belge No</th>
                        <th style="width:100px;">Cari Kodu</th>
                        <th style="min-width:200px;">Unvani</th>
                        <th style="width:80px;">Fatura Turu</th>
                        <th style="width:90px;">Vade Tarihi</th>
                        <th style="width:90px;">Opsiyon Tarihi</th>
                        <th style="width:70px;">Doviz Kodu</th>
                        <th style="width:100px;">Personel</th>
                        <th style="min-width:150px;">Aciklama</th>
                        <th style="width:100px; text-align:right;">Tutar</th>
                        <th style="width:100px; text-align:right;">Toplam Indirim</th>
                        <th style="width:100px; text-align:right;">KDV Matrahi</th>
                        <th style="width:100px; text-align:right;">KDV Tutari</th>
                        <th style="width:110px; text-align:right;">Toplam Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var siparis in filtreliSiparisler)
                    {
                        <tr class="@(seciliId == siparis.Id ? "selected" : "")" @onclick="() => SatirSec(siparis.Id)" @ondblclick="Duzenle">
                            <td>@siparis.Tarih.ToString("dd.MM.yyyy")</td>
                            <td>@siparis.Saat?.ToString(@"hh\:mm")</td>
                            <td>@siparis.SevkTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@siparis.FisNo</td>
                            <td>@siparis.BelgeNo</td>
                            <td>@siparis.CariKodu</td>
                            <td>@siparis.Unvani</td>
                            <td>@siparis.FaturaTuru</td>
                            <td>@siparis.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@siparis.OpsiyonTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@siparis.DovizKodu</td>
                            <td>@siparis.Personel</td>
                            <td>@siparis.Aciklama1</td>
                            <td class="text-right">@siparis.Tutar?.ToString("N2")</td>
                            <td class="text-right">@siparis.ToplamIndirim?.ToString("N2")</td>
                            <td class="text-right">@siparis.KdvMatrahi?.ToString("N2")</td>
                            <td class="text-right">@siparis.KdvTutari?.ToString("N2")</td>
                            <td class="text-right" style="font-weight:700;">@siparis.ToplamTutar?.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:var(--pinebi-primary); color:white; font-weight:700;">
                        <td colspan="13" class="text-right">Toplam:</td>
                        <td class="text-right">@filtreliSiparisler.Sum(s => s.Tutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliSiparisler.Sum(s => s.ToplamIndirim ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliSiparisler.Sum(s => s.KdvMatrahi ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliSiparisler.Sum(s => s.KdvTutari ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliSiparisler.Sum(s => s.ToplamTutar ?? 0).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Kayit Sayisi -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
            <span class="text-muted">Toplam @filtreliSiparisler.Count kayit</span>
        </div>
    </div>
</div>

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-30);
    private DateTime bitisTarihi = DateTime.Today;
    private string aramaMetni = "";
    private int seciliId = 0;

    private List<SatissiparisItem> siparisler = new();
    private List<SatissiparisItem> filtreliSiparisler => string.IsNullOrWhiteSpace(aramaMetni)
        ? siparisler
        : siparisler.Where(s =>
            (s.FisNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (s.CariKodu ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (s.Unvani ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (s.BelgeNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await Listele();
    }

    private async Task Listele()
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var trCode = new List<int> { 1 };
            var dbList = await db.SiparislerView.AsNoTracking()
                .Where(s => trCode.Contains(s.TrCode) && s.Tarih >= baslangicTarihi && s.Tarih <= bitisTarihi && s.Iptal != true)
                .OrderByDescending(s => s.Tarih)
                .Take(500)
                .ToListAsync();
            siparisler = dbList.Select(s => new SatissiparisItem
            {
                Id = s.Id, Tarih = s.Tarih, Saat = s.Saat, SevkTarihi = s.SevkTarihi,
                FisNo = s.FisNo, BelgeNo = s.BelgeNo, CariKodu = s.CariKodu, Unvani = s.Unvani,
                FaturaTuru = s.FaturaTuru, VadeTarihi = s.VadeTarihi, OpsiyonTarihi = s.OpsiyonTarihi,
                DovizKodu = s.DovizKodu, Personel = s.Personel, Aciklama1 = s.Aciklama1,
                Tutar = s.Tutar, ToplamIndirim = s.ToplamIndirim, KdvMatrahi = s.KdvMatrahi,
                KdvTutari = s.KdvTutari, ToplamTutar = s.ToplamTutar
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SatisSiparisleri DB hatasi: {ex.Message}");
            siparisler = GetPlaceholderData();
        }
    }

    private void SatirSec(int id) => seciliId = id;

    private void YeniSiparis()
    {
        Nav.NavigateTo("/satis/fatura/yeni?tip=siparis");
    }

    private void Duzenle()
    {
        if (seciliId == 0) return;
        Nav.NavigateTo($"/satis/fatura/{seciliId}");
    }

    private void Iptal()
    {
        if (seciliId == 0) return;
        // TODO: Siparis iptal islemi
    }

    private async void Yazdir()
    { await JS.InvokeVoidAsync("window.print");
        // TODO: Yazdir islemi
    }

    private void ExcelAktar()
    { /* Excel export - coming soon */
        // TODO: Excel export islemi
    }

    private List<SatissiparisItem> GetPlaceholderData()
    {
        return new List<SatissiparisItem>
        {
            new() { Id = 1, Tarih = DateTime.Today.AddDays(-10), Saat = new TimeSpan(9, 30, 0), FisNo = "SPS202600001", CariKodu = "C001", Unvani = "ABC Ticaret Ltd. Sti.", FaturaTuru = "Siparis", DovizKodu = "TL", Personel = "Ahmet Yilmaz", Tutar = 25000.00m, ToplamIndirim = 1000.00m, KdvMatrahi = 24000.00m, KdvTutari = 4320.00m, ToplamTutar = 28320.00m, VadeTarihi = DateTime.Today.AddDays(45) },
            new() { Id = 2, Tarih = DateTime.Today.AddDays(-7), Saat = new TimeSpan(11, 0, 0), FisNo = "SPS202600002", CariKodu = "C003", Unvani = "DEF Makina San. Tic. A.S.", FaturaTuru = "Siparis", DovizKodu = "EUR", Personel = "Mehmet Demir", Tutar = 8500.00m, ToplamIndirim = 0m, KdvMatrahi = 8500.00m, KdvTutari = 1530.00m, ToplamTutar = 10030.00m, VadeTarihi = DateTime.Today.AddDays(60) },
            new() { Id = 3, Tarih = DateTime.Today.AddDays(-2), Saat = new TimeSpan(15, 45, 0), FisNo = "SPS202600003", CariKodu = "C005", Unvani = "GHI Elektrik Ltd. Sti.", FaturaTuru = "Siparis", DovizKodu = "TL", Personel = "Ahmet Yilmaz", Tutar = 12000.00m, ToplamIndirim = 600.00m, KdvMatrahi = 11400.00m, KdvTutari = 2052.00m, ToplamTutar = 13452.00m, VadeTarihi = DateTime.Today.AddDays(30) }
        };
    }

    public class SatissiparisItem
    {
        public int Id { get; set; }
        public DateTime Tarih { get; set; }
        public TimeSpan? Saat { get; set; }
        public DateTime? SevkTarihi { get; set; }
        public string FisNo { get; set; } = "";
        public string BelgeNo { get; set; } = "";
        public string CariKodu { get; set; } = "";
        public string Unvani { get; set; } = "";
        public string FaturaTuru { get; set; } = "";
        public DateTime? VadeTarihi { get; set; }
        public DateTime? OpsiyonTarihi { get; set; }
        public string DovizKodu { get; set; } = "";
        public string Personel { get; set; } = "";
        public string Aciklama1 { get; set; } = "";
        public decimal? Tutar { get; set; }
        public decimal? ToplamIndirim { get; set; }
        public decimal? KdvMatrahi { get; set; }
        public decimal? KdvTutari { get; set; }
        public decimal? ToplamTutar { get; set; }
    }
}
