@page "/satis/irsaliyeler"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore

<PageTitle>Satis Irsaliyeleri</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-truck"></i> Satis Irsaliyeleri
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="YeniIrsaliye">
                <i class="fa fa-plus"></i> Yeni
            </button>
            <button class="btn btn-primary btn-sm" @onclick="Duzenle">
                <i class="fa fa-pencil"></i> Duzenle
            </button>
            <button class="btn btn-danger btn-sm" @onclick="Iptal">
                <i class="fa fa-ban"></i> Iptal
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                <i class="fa fa-file-excel-o"></i> Excel Aktar
            </button>
        </div>

        <!-- Filtre Alani -->
        <div class="form-row" style="margin-bottom:10px;">
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarihi" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarihi" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Listele">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <div class="form-inline" style="margin-left:auto;">
                <label style="min-width:30px;">Ara</label>
                <input type="text" class="form-control" placeholder="Irsaliye no, cari kodu, unvan..." @bind="aramaMetni" @bind:event="oninput" style="max-width:250px;" />
            </div>
        </div>

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 260px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:90px;">Fis Tipi</th>
                        <th style="width:80px;">Fatura Turu</th>
                        <th style="width:90px;">Tarih</th>
                        <th style="width:50px;">Saat</th>
                        <th style="width:90px;">Sevk Tarihi</th>
                        <th style="width:110px;">Fis No</th>
                        <th style="width:100px;">Belge No</th>
                        <th style="width:100px;">Cari Kodu</th>
                        <th style="min-width:200px;">Unvani</th>
                        <th style="width:90px;">Vade Tarihi</th>
                        <th style="width:70px;">Doviz Kodu</th>
                        <th style="width:100px;">Personel</th>
                        <th style="min-width:150px;">Aciklama</th>
                        <th style="width:120px;">Tasiyici Firma</th>
                        <th style="width:100px;">Sofor Adi</th>
                        <th style="width:100px;">Plaka No</th>
                        <th style="width:120px;">GIB Gonderim</th>
                        <th style="width:120px;">Sevkiyat Baslik</th>
                        <th style="width:100px; text-align:right;">Tutar</th>
                        <th style="width:100px; text-align:right;">Toplam Indirim</th>
                        <th style="width:100px; text-align:right;">KDV Matrahi</th>
                        <th style="width:100px; text-align:right;">KDV Tutari</th>
                        <th style="width:110px; text-align:right;">Toplam Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var irsaliye in filtreliIrsaliyeler)
                    {
                        <tr class="@(seciliId == irsaliye.Id ? "selected" : "")" @onclick="() => SatirSec(irsaliye.Id)" @ondblclick="Duzenle">
                            <td>@irsaliye.Fis</td>
                            <td>@irsaliye.FaturaTuru</td>
                            <td>@irsaliye.Tarih.ToString("dd.MM.yyyy")</td>
                            <td>@irsaliye.Saat?.ToString(@"hh\:mm")</td>
                            <td>@irsaliye.SevkTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@irsaliye.FisNo</td>
                            <td>@irsaliye.BelgeNo</td>
                            <td>@irsaliye.CariKodu</td>
                            <td>@irsaliye.Unvani</td>
                            <td>@irsaliye.VadeTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>@irsaliye.DovizKodu</td>
                            <td>@irsaliye.Personel</td>
                            <td>@irsaliye.Aciklama1</td>
                            <td>@irsaliye.TasiyiciFirmaUnvani</td>
                            <td>@irsaliye.TasiyiciSoforAdi</td>
                            <td>@irsaliye.TasiyiciAracPlakaNo</td>
                            <td>@irsaliye.GibGonderimDurumu</td>
                            <td>@irsaliye.SevkiyatBaslik</td>
                            <td class="text-right">@irsaliye.Tutar?.ToString("N2")</td>
                            <td class="text-right">@irsaliye.ToplamIndirim?.ToString("N2")</td>
                            <td class="text-right">@irsaliye.KdvMatrahi?.ToString("N2")</td>
                            <td class="text-right">@irsaliye.KdvTutari?.ToString("N2")</td>
                            <td class="text-right" style="font-weight:700;">@irsaliye.ToplamTutar?.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:var(--pinebi-primary); color:white; font-weight:700;">
                        <td colspan="18" class="text-right">Toplam:</td>
                        <td class="text-right">@filtreliIrsaliyeler.Sum(i => i.Tutar ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliIrsaliyeler.Sum(i => i.ToplamIndirim ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliIrsaliyeler.Sum(i => i.KdvMatrahi ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliIrsaliyeler.Sum(i => i.KdvTutari ?? 0).ToString("N2")</td>
                        <td class="text-right">@filtreliIrsaliyeler.Sum(i => i.ToplamTutar ?? 0).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Kayit Sayisi -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
            <span class="text-muted">Toplam @filtreliIrsaliyeler.Count kayit</span>
        </div>
    </div>
</div>

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-30);
    private DateTime bitisTarihi = DateTime.Today;
    private string aramaMetni = "";
    private int seciliId = 0;

    private List<SatisIrsaliyeItem> irsaliyeler = new();
    private List<SatisIrsaliyeItem> filtreliIrsaliyeler => string.IsNullOrWhiteSpace(aramaMetni)
        ? irsaliyeler
        : irsaliyeler.Where(i =>
            (i.FisNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (i.CariKodu ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (i.Unvani ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (i.BelgeNo ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase)
        ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await Listele();
    }

    private async Task Listele()
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            var trCode = new List<int> { 7, 8 };
            var dbList = await db.IrsaliyelerView.AsNoTracking()
                .Where(s => trCode.Contains(s.TrCode) && s.Tarih >= baslangicTarihi && s.Tarih <= bitisTarihi && s.Iptal != true)
                .OrderByDescending(s => s.Tarih)
                .Take(500)
                .ToListAsync();
            irsaliyeler = dbList.Select(i => new SatisIrsaliyeItem
            {
                Id = i.Id, Fis = i.Fis, FaturaTuru = i.FaturaTuru, Tarih = i.Tarih, Saat = i.Saat,
                SevkTarihi = i.SevkTarihi, FisNo = i.FisNo, BelgeNo = i.BelgeNo, CariKodu = i.CariKodu,
                Unvani = i.Unvani, VadeTarihi = i.VadeTarihi, DovizKodu = i.DovizKodu,
                Personel = i.Personel, Aciklama1 = i.Aciklama1,
                TasiyiciFirmaUnvani = i.TasiyiciFirmaUnvani, TasiyiciSoforAdi = i.TasiyiciSoforAdi,
                TasiyiciAracPlakaNo = i.TasiyiciAracPlakaNo, GibGonderimDurumu = i.GibGonderimDurumu,
                SevkiyatBaslik = i.SevkiyatBaslik,
                Tutar = i.Tutar, ToplamIndirim = i.ToplamIndirim, KdvMatrahi = i.KdvMatrahi,
                KdvTutari = i.KdvTutari, ToplamTutar = i.ToplamTutar
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SatisIrsaliyeleri DB hatasi: {ex.Message}");
            irsaliyeler = GetPlaceholderData();
        }
    }

    private void SatirSec(int id) => seciliId = id;

    private void YeniIrsaliye()
    {
        Nav.NavigateTo("/satis/fatura/yeni?tip=irsaliye");
    }

    private void Duzenle()
    {
        if (seciliId == 0) return;
        Nav.NavigateTo($"/satis/fatura/{seciliId}");
    }

    private void Iptal()
    {
        if (seciliId == 0) return;
        // TODO: Irsaliye iptal islemi
    }

    private async void Yazdir()
    { await JS.InvokeVoidAsync("window.print");
        // TODO: Yazdir islemi
    }

    private void ExcelAktar()
    { /* Excel export - coming soon */
        // TODO: Excel export islemi
    }

    private List<SatisIrsaliyeItem> GetPlaceholderData()
    {
        return new List<SatisIrsaliyeItem>
        {
            new() { Id = 1, Fis = "Satis Irsaliyesi", FaturaTuru = "Irsaliye", Tarih = DateTime.Today.AddDays(-8), Saat = new TimeSpan(8, 30, 0), SevkTarihi = DateTime.Today.AddDays(-8), FisNo = "IRS202600001", CariKodu = "C001", Unvani = "ABC Ticaret Ltd. Sti.", DovizKodu = "TL", Personel = "Ahmet Yilmaz", TasiyiciFirmaUnvani = "Hizli Nakliyat", TasiyiciSoforAdi = "Ali Kaya", TasiyiciAracPlakaNo = "34 AB 1234", Tutar = 15000.00m, ToplamIndirim = 500.00m, KdvMatrahi = 14500.00m, KdvTutari = 2610.00m, ToplamTutar = 17110.00m, VadeTarihi = DateTime.Today.AddDays(30) },
            new() { Id = 2, Fis = "Satis Irsaliyesi", FaturaTuru = "Irsaliye", Tarih = DateTime.Today.AddDays(-5), Saat = new TimeSpan(13, 0, 0), SevkTarihi = DateTime.Today.AddDays(-5), FisNo = "IRS202600002", CariKodu = "C002", Unvani = "XYZ Insaat A.S.", DovizKodu = "TL", Personel = "Mehmet Demir", TasiyiciFirmaUnvani = "Guven Lojistik", TasiyiciSoforAdi = "Veli Ozturk", TasiyiciAracPlakaNo = "41 CD 5678", Tutar = 32000.00m, ToplamIndirim = 0m, KdvMatrahi = 32000.00m, KdvTutari = 5760.00m, ToplamTutar = 37760.00m, VadeTarihi = DateTime.Today.AddDays(45), GibGonderimDurumu = "Gonderildi" },
            new() { Id = 3, Fis = "Satis Irsaliyesi", FaturaTuru = "Irsaliye", Tarih = DateTime.Today.AddDays(-1), Saat = new TimeSpan(16, 30, 0), SevkTarihi = DateTime.Today.AddDays(-1), FisNo = "IRS202600003", CariKodu = "C005", Unvani = "GHI Elektrik Ltd. Sti.", DovizKodu = "TL", Personel = "Ahmet Yilmaz", Tutar = 8500.00m, ToplamIndirim = 200.00m, KdvMatrahi = 8300.00m, KdvTutari = 1494.00m, ToplamTutar = 9794.00m, VadeTarihi = DateTime.Today.AddDays(15) }
        };
    }

    public class SatisIrsaliyeItem
    {
        public int Id { get; set; }
        public string Fis { get; set; } = "";
        public string FaturaTuru { get; set; } = "";
        public DateTime Tarih { get; set; }
        public TimeSpan? Saat { get; set; }
        public DateTime? SevkTarihi { get; set; }
        public string FisNo { get; set; } = "";
        public string BelgeNo { get; set; } = "";
        public string CariKodu { get; set; } = "";
        public string Unvani { get; set; } = "";
        public DateTime? VadeTarihi { get; set; }
        public string DovizKodu { get; set; } = "";
        public string Personel { get; set; } = "";
        public string Aciklama1 { get; set; } = "";
        public string TasiyiciFirmaUnvani { get; set; } = "";
        public string TasiyiciSoforAdi { get; set; } = "";
        public string TasiyiciAracPlakaNo { get; set; } = "";
        public string GibGonderimDurumu { get; set; } = "";
        public string SevkiyatBaslik { get; set; } = "";
        public decimal? Tutar { get; set; }
        public decimal? ToplamIndirim { get; set; }
        public decimal? KdvMatrahi { get; set; }
        public decimal? KdvTutari { get; set; }
        public decimal? ToplamTutar { get; set; }
    }
}
