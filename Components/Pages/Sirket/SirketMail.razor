@page "/sirket/mail"
@inject NavigationManager Nav

<PageTitle>Sirket Mail Ayarlari</PageTitle>

<div class="card">
    <div class="card-header"><i class="fa fa-envelope"></i> Sirket Mail Ayarlari</div>
    <div class="card-body">
        <div class="toolbar">
            <button class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Yeni</button>
            <button class="btn btn-primary btn-sm"><i class="fa fa-edit"></i> Duzenle</button>
            <button class="btn btn-danger btn-sm"><i class="fa fa-trash"></i> Sil</button>
            <button class="btn btn-outline btn-sm"><i class="fa fa-save"></i> Kaydet</button>
        </div>
        <div class="grid-container" style="max-height:300px; margin-bottom:12px;">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Mail Adresi</th>
                        <th>Sifre</th>
                        <th>SMTP Sunucu</th>
                        <th>SMTP Port</th>
                        <th>SSL</th>
                        <th>Varsayilan</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="text-center text-muted">Kayit bulunamadi</td></tr>
                </tbody>
            </table>
        </div>

        <div class="group-box">
            <span class="group-box-title">Mail Ayarlari</span>
            <div class="form-row">
                <div class="form-inline" style="flex:1;">
                    <label style="min-width:100px;">Mail Adresi</label>
                    <input type="text" class="form-control" />
                </div>
                <div class="form-inline" style="flex:1;">
                    <label style="min-width:80px;">Sifre</label>
                    <input type="password" class="form-control" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-inline" style="flex:1;">
                    <label style="min-width:100px;">SMTP Sunucu</label>
                    <input type="text" class="form-control" />
                </div>
                <div class="form-inline" style="flex:0.5;">
                    <label style="min-width:80px;">Port</label>
                    <input type="number" class="form-control" value="587" />
                </div>
                <div class="form-check">
                    <input type="checkbox" checked /> <label>SSL</label>
                </div>
                <div class="form-check">
                    <input type="checkbox" /> <label>Varsayilan</label>
                </div>
            </div>
        </div>
    </div>
</div>
