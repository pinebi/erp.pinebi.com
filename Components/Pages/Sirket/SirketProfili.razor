            mesajTipi = "danger";
        }
    }

    // ==================== DOSYA INDIR ====================
    private async Task DosyaIndir()
    {
        try
        {
            mesaj = "";
            if (string.IsNullOrEmpty(seciliFtpDosya))
            {
                mesaj = "Lutfen indirmek icin bir dosya seciniz.";
                mesajTipi = "danger";
                return;
            }

            var dosyaYolu = Path.Combine(ftpKlasorYolu, seciliFtpDosya);
            if (!File.Exists(dosyaYolu))
            {
                mesaj = "Secilen dosya bulunamadi.";
                mesajTipi = "danger";
                return;
            }

            // TODO: Blazor Server'da dosya indirme icin JS interop kullanilacak.
            // Ornek: IJSRuntime.InvokeVoidAsync("saveAsFile", dosyaAdi, Convert.ToBase64String(dosyaIcerigi))
            // seklinde bir JS fonksiyonu ile dosya indirilecek.
            mesaj = $"Dosya indirme icin JS interop entegrasyonu yapilacak: {seciliFtpDosya} (TODO)";
            mesajTipi = "success";

            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            mesaj = $"Dosya indirilirken hata: {ex.Message}";
            mesajTipi = "danger";
        }
    }

    // ==================== DOSYA SIL ====================
    private async Task DosyaSil()
    {
        try
        {
            mesaj = "";
            if (string.IsNullOrEmpty(seciliFtpDosya))
            {
                mesaj = "Lutfen silmek icin bir dosya seciniz.";
                mesajTipi = "danger";
                return;
            }

            var dosyaYolu = Path.Combine(ftpKlasorYolu, seciliFtpDosya);
            if (File.Exists(dosyaYolu))
            {
                File.Delete(dosyaYolu);
                mesaj = $"{seciliFtpDosya} dosyasi silindi.";
                mesajTipi = "success";
            }
            else
            {
                mesaj = "Secilen dosya bulunamadi.";
                mesajTipi = "danger";
            }

            seciliFtpDosya = "";
            await FtpDosyalariYukle();
        }
        catch (Exception ex)
        {
            mesaj = $"Dosya silinirken hata: {ex.Message}";
            mesajTipi = "danger";
        }
    }

