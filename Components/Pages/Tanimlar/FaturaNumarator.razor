@page "/tanimlar/numarator"
@inject NavigationManager Nav
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore

<PageTitle>Fatura Numarator</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-sort-numeric-up"></i> Fatura Numarator
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <div style="margin-left:auto; display:flex; gap:6px;">
                <button class="btn btn-primary btn-sm" @onclick="Save">
                    <i class="fa fa-save"></i> Kaydet
                </button>
                <button class="btn btn-outline btn-sm" @onclick="Close">
                    <i class="fa fa-times"></i> Kapat
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-top:8px;">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" style="margin-top:8px;">@successMessage</div>
        }

        <!-- Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 220px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:75px;">On Ek</th>
                        <th style="width:111px;">Tip</th>
                        <th style="width:175px;">Numara</th>
                    </tr>
                </thead>
                <tbody>
                    @if (list != null)
                    {
                        @foreach (var item in list)
                        {
                            <tr class="@(selectedItem == item ? "selected" : "")" @onclick="() => selectedItem = item">
                                <td>
                                    <input type="text" class="form-control" @bind="item.OnEk"
                                           style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                                <td>@item.Tip</td>
                                <td>
                                    <input type="number" class="form-control" @bind="item.Numara"
                                           style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:10px;">
            <button class="btn btn-primary btn-sm" @onclick="Save">
                <i class="fa fa-save"></i> Kaydet
            </button>
            <button class="btn btn-outline btn-sm" @onclick="Close">
                <i class="fa fa-times"></i> Kapat
            </button>
        </div>
    </div>
</div>

@code {
    private List<MACHINEBISS_Web.Models.MachineBiss.Numarator> list = new();
    private MACHINEBISS_Web.Models.MachineBiss.Numarator? selectedItem;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            errorMessage = null;
            using var ctx = await FirmaFactory.CreateDbContextAsync();
            list = await ctx.Numarator.OrderBy(x => x.Tip).ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Veri yukleme hatasi: " + ex.Message;
        }
    }

    private async Task Save()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            using var ctx = await FirmaFactory.CreateDbContextAsync();
            foreach (var item in list)
            {
                ctx.Numarator.Update(item);
            }
            await ctx.SaveChangesAsync();
            successMessage = "Basariyla kaydedildi.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Kaydetme hatasi: " + ex.Message;
        }
    }

    private void Close()
    {
        Nav.NavigateTo("/dashboard");
    }
}
