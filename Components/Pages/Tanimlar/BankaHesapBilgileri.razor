@page "/tanimlar/bankahesap"
@inject NavigationManager Nav
@inject IDbContextFactory<MACHINEBISS_Web.Db.NetworkContext> NetworkFactory
@inject MACHINEBISS_Web.Services.SistemAyarlariService Sistem
@using Microsoft.EntityFrameworkCore

<PageTitle>Banka Hesap Bilgileri</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-university"></i> Banka Hesap Bilgileri
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="AddNewRow">
                <i class="fa fa-plus"></i> Yeni
            </button>
            <button class="btn btn-danger btn-sm" @onclick="DeleteSelected">
                <i class="fa fa-trash"></i> Sil
            </button>
            <div style="margin-left:auto; display:flex; gap:6px;">
                <button class="btn btn-primary btn-sm" @onclick="Save">
                    <i class="fa fa-save"></i> Kaydet
                </button>
                <button class="btn btn-outline btn-sm" @onclick="Close">
                    <i class="fa fa-times"></i> Kapat
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-top:8px;">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" style="margin-top:8px;">@successMessage</div>
        }

        <!-- Grid (editable) -->
        <div class="grid-container" style="max-height:calc(100vh - 220px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:42px;">Sec</th>
                        <th style="width:155px;">Banka Adi</th>
                        <th style="width:89px;">Para Birimi</th>
                        <th style="width:176px;">Sube Adi</th>
                        <th style="width:219px;">IBAN</th>
                        <th style="width:150px;">Swift Kodu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (list != null)
                    {
                        @foreach (var item in list)
                        {
                            <tr class="@(selectedItem == item ? "selected" : "")" @onclick="() => selectedItem = item">
                                <td style="text-align:center;">
                                    <input type="checkbox" @bind="item.Sec" />
                                </td>
                                <td>
                                    <input type="text" class="form-control" @bind="item.Banka" style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                                <td>
                                    <select class="form-control" @bind="item.ParaBirimi" style="border:none; background:transparent; padding:2px 4px;">
                                        <option value="">--</option>
                                        <option value="TRY">TRY</option>
                                        <option value="USD">USD</option>
                                        <option value="EUR">EUR</option>
                                        <option value="GBP">GBP</option>
                                        <option value="CHF">CHF</option>
                                        <option value="JPY">JPY</option>
                                        <option value="CNY">CNY</option>
                                        <option value="RUB">RUB</option>
                                        <option value="SAR">SAR</option>
                                        <option value="AED">AED</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" class="form-control" @bind="item.Sube" style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control" @bind="item.Iban" style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                                <td>
                                    <input type="text" class="form-control" @bind="item.SwiftKodu" style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:10px;">
            <button class="btn btn-primary btn-sm" @onclick="Save">
                <i class="fa fa-save"></i> Kaydet
            </button>
            <button class="btn btn-outline btn-sm" @onclick="Close">
                <i class="fa fa-times"></i> Kapat
            </button>
        </div>
    </div>
</div>

@if (showConfirmDelete)
{
    <div class="modal-overlay">
        <div class="modal-box" style="min-width:350px;">
            <div class="modal-header">
                <span><i class="fa fa-exclamation-triangle"></i> Uyari</span>
                <button class="modal-close" @onclick="() => showConfirmDelete = false">&times;</button>
            </div>
            <div class="modal-body">
                <p>Secili kayit silinecek! Emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete">Evet, Sil</button>
                <button class="btn btn-outline btn-sm" @onclick="() => showConfirmDelete = false">Hayir</button>
            </div>
        </div>
    </div>
}

@code {
    private List<MACHINEBISS_Web.Models.BlockBiss.SirketBankaBilgileri> list = new();
    private MACHINEBISS_Web.Models.BlockBiss.SirketBankaBilgileri? selectedItem;
    private bool showConfirmDelete = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            errorMessage = null;
            int.TryParse(Sistem.SirketNo, out int sirketNo);
            using var ctx = await NetworkFactory.CreateDbContextAsync();
            list = await ctx.SirketBankaBilgileri
                .Where(x => x.SirketNo == sirketNo)
                .OrderBy(x => x.Banka)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Veri yukleme hatasi: " + ex.Message;
        }
    }

    private void AddNewRow()
    {
        int.TryParse(Sistem.SirketNo, out int sirketNo);
        var newItem = new MACHINEBISS_Web.Models.BlockBiss.SirketBankaBilgileri { SirketNo = sirketNo };
        list.Add(newItem);
        selectedItem = newItem;
    }

    private async Task Save()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            int.TryParse(Sistem.SirketNo, out int sirketNo);
            using var ctx = await NetworkFactory.CreateDbContextAsync();
            foreach (var item in list)
            {
                item.SirketNo = sirketNo;
                if (item.Id == 0)
                {
                    ctx.SirketBankaBilgileri.Add(item);
                }
                else
                {
                    ctx.SirketBankaBilgileri.Update(item);
                }
            }
            await ctx.SaveChangesAsync();
            successMessage = "Basariyla kaydedildi.";
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Kaydetme hatasi: " + ex.Message;
        }
    }

    private void DeleteSelected()
    {
        if (selectedItem == null || selectedItem.Id == 0)
        {
            if (selectedItem != null && selectedItem.Id == 0)
            {
                list.Remove(selectedItem);
                selectedItem = null;
            }
            return;
        }
        showConfirmDelete = true;
    }

    private async Task ConfirmDelete()
    {
        if (selectedItem != null)
        {
            try
            {
                errorMessage = null;
                using var ctx = await NetworkFactory.CreateDbContextAsync();
                var entity = await ctx.SirketBankaBilgileri.FindAsync(selectedItem.Id);
                if (entity != null)
                {
                    ctx.SirketBankaBilgileri.Remove(entity);
                    await ctx.SaveChangesAsync();
                }
                selectedItem = null;
                await LoadData();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                errorMessage = "Silme hatasi: " + ex.Message;
            }
        }
        showConfirmDelete = false;
    }

    private void Close()
    {
        Nav.NavigateTo("/dashboard");
    }
}
