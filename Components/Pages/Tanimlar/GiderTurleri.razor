@page "/tanimlar/giderturleri"
@inject NavigationManager Nav
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore

<PageTitle>Gider Turleri</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-money-bill-wave"></i> Gider Turleri
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="AddNew">
                <i class="fa fa-plus"></i> Yeni
            </button>
            <button class="btn btn-danger btn-sm" @onclick="DeleteSelected">
                <i class="fa fa-trash"></i> Sil
            </button>
            <div style="margin-left:auto; display:flex; gap:6px;">
                <button class="btn btn-primary btn-sm" @onclick="Save">
                    <i class="fa fa-save"></i> Kaydet
                </button>
                <button class="btn btn-outline btn-sm" @onclick="Close">
                    <i class="fa fa-times"></i> Kapat
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-top:8px;">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success" style="margin-top:8px;">@successMessage</div>
        }

        <!-- Grid (editable) -->
        <div class="grid-container" style="max-height:calc(100vh - 220px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Gider Tipi</th>
                    </tr>
                </thead>
                <tbody>
                    @if (list != null)
                    {
                        @foreach (var item in list)
                        {
                            <tr class="@(selectedItem == item ? "selected" : "")" @onclick="() => selectedItem = item">
                                <td>
                                    <input type="text" class="form-control" @bind="item.GiderTipi" style="border:none; background:transparent; width:100%; padding:2px 4px;" />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div style="display:flex; justify-content:space-between; margin-top:10px;">
            <span style="font-size:12px; color:var(--pinebi-text-light);">
                Toplam: @(list?.Count ?? 0) kayit
            </span>
            <div style="display:flex; gap:8px;">
                <button class="btn btn-primary btn-sm" @onclick="Save">
                    <i class="fa fa-save"></i> Kaydet
                </button>
                <button class="btn btn-outline btn-sm" @onclick="Close">
                    <i class="fa fa-times"></i> Kapat
                </button>
            </div>
        </div>
    </div>
</div>

@if (showConfirmDelete)
{
    <div class="modal-overlay">
        <div class="modal-box" style="min-width:350px;">
            <div class="modal-header">
                <span><i class="fa fa-exclamation-triangle"></i> Uyari</span>
                <button class="modal-close" @onclick="() => showConfirmDelete = false">&times;</button>
            </div>
            <div class="modal-body">
                <p>Secili kayit silinecek! Emin misiniz?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete">Evet, Sil</button>
                <button class="btn btn-outline btn-sm" @onclick="() => showConfirmDelete = false">Hayir</button>
            </div>
        </div>
    </div>
}

@code {
    private List<MACHINEBISS_Web.Models.MachineBiss.GiderTipleri> list = new();
    private MACHINEBISS_Web.Models.MachineBiss.GiderTipleri? selectedItem;
    private bool showConfirmDelete = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            errorMessage = null;
            using var ctx = await FirmaFactory.CreateDbContextAsync();
            list = await ctx.GiderTipleri.OrderBy(x => x.GiderTipi).ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Veri yukleme hatasi: " + ex.Message;
        }
    }

    private void AddNew()
    {
        var newItem = new MACHINEBISS_Web.Models.MachineBiss.GiderTipleri();
        list.Add(newItem);
        selectedItem = newItem;
    }

    private void DeleteSelected()
    {
        if (selectedItem == null) return;
        if (selectedItem.Id == 0)
        {
            list.Remove(selectedItem);
            selectedItem = null;
            return;
        }
        showConfirmDelete = true;
    }

    private async Task ConfirmDelete()
    {
        if (selectedItem != null)
        {
            try
            {
                errorMessage = null;
                using var ctx = await FirmaFactory.CreateDbContextAsync();
                var entity = await ctx.GiderTipleri.FindAsync(selectedItem.Id);
                if (entity != null)
                {
                    ctx.GiderTipleri.Remove(entity);
                    await ctx.SaveChangesAsync();
                }
                selectedItem = null;
                await LoadData();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                errorMessage = "Silme hatasi: " + ex.Message;
            }
        }
        showConfirmDelete = false;
    }

    private async Task Save()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            using var ctx = await FirmaFactory.CreateDbContextAsync();
            foreach (var item in list)
            {
                if (item.Id == 0)
                {
                    ctx.GiderTipleri.Add(item);
                }
                else
                {
                    ctx.GiderTipleri.Update(item);
                }
            }
            await ctx.SaveChangesAsync();
            successMessage = "Basariyla kaydedildi.";
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Kaydetme hatasi: " + ex.Message;
        }
    }

    private void Close()
    {
        Nav.NavigateTo("/dashboard");
    }
}
