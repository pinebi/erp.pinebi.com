    async Task DetayAc(Guid tenantId)
    {
        detayTenantId = tenantId;
        try
        {
            // HttpClient cookie olmadan 401 dondurur. Direkt DB.
            await using var conn = new SqlConnection(MasterConn);
            await conn.OpenAsync();

            await using var cmd = new SqlCommand(@"
SELECT t.tenant_code, t.tenant_name, t.subdomain, t.db_name, t.region_id, t.status, t.contact_email,
       t.created_at, t.activated_at, t.vergi_no, st.tier_code, st.tier_name,
       st.max_users, st.max_storage_gb, st.max_invoices_month, st.monthly_price_usd
FROM tenants t JOIN subscription_tiers st ON t.tier_id = st.tier_id
WHERE t.tenant_id = @id", conn);
            cmd.Parameters.AddWithValue("@id", tenantId);

            using var rdr = await cmd.ExecuteReaderAsync();
            if (!await rdr.ReadAsync()) return;

            detayData = new TenantDetay
            {
                TenantCode = rdr.GetString(0),
                TenantName = rdr.GetString(1),
                Subdomain = rdr.GetString(2),
                DbName = rdr.GetString(3),
                RegionId = rdr.GetString(4),
                Status = rdr.GetString(5),
                ContactEmail = rdr.GetString(6),
                CreatedAt = rdr.GetDateTime(7),
                ActivatedAt = rdr.IsDBNull(8) ? null : rdr.GetDateTime(8),
                VergiNo = rdr.IsDBNull(9) ? null : rdr.GetString(9),
                TierCode = rdr.GetString(10),
                MaxUsers = rdr.GetInt32(12),
                MaxStorageGb = rdr.GetInt32(13),
                MaxInvoicesMonth = rdr.GetInt32(14),
                MonthlyPriceUsd = rdr.GetDecimal(15)
            };
            await rdr.CloseAsync();
            yeniTier = detayData.TierCode;

            // API Keyler
            detayApiKeys.Clear();
            await using (var k = new SqlCommand(@"
SELECT key_prefix, ISNULL(description,''), scopes, last_used_at
FROM api_keys WHERE tenant_id=@id ORDER BY created_at DESC", conn))
            {
                k.Parameters.AddWithValue("@id", tenantId);
                await using var r = await k.ExecuteReaderAsync();
                while (await r.ReadAsync())
                    detayApiKeys.Add(new ApiKeyDetay {
                        Prefix = r.GetString(0),
                        Description = r.GetString(1),
                        Scopes = r.GetString(2),
                        LastUsedAt = r.IsDBNull(3) ? null : r.GetDateTime(3)
                    });
            }

            // Davetler
            detayInvites.Clear();
            await using (var i = new SqlCommand(@"
SELECT email, kullanici_adi, rol, expires_at, accepted_at, revoked_at
FROM user_invites WHERE tenant_id=@id ORDER BY created_at DESC", conn))
            {
                i.Parameters.AddWithValue("@id", tenantId);
                await using var r = await i.ExecuteReaderAsync();
                while (await r.ReadAsync())
                    detayInvites.Add(new InviteDetay {
                        Email = r.GetString(0),
                        KullaniciAdi = r.GetString(1),
                        Rol = r.GetString(2),
                        ExpiresAt = r.GetDateTime(3),
                        AcceptedAt = r.IsDBNull(4) ? null : r.GetDateTime(4),
                        RevokedAt = r.IsDBNull(5) ? null : r.GetDateTime(5)
                    });
            }

            // Events
            detayEvents.Clear();
            await using (var e = new SqlCommand(@"
SELECT TOP 20 occurred_at, event_type, actor_type, details_json
FROM control_audit_events WHERE tenant_id=@id ORDER BY event_id DESC", conn))
            {
                e.Parameters.AddWithValue("@id", tenantId);
                await using var r = await e.ExecuteReaderAsync();
                while (await r.ReadAsync())
                    detayEvents.Add(new AuditRow {
                        OccurredAt = r.GetDateTime(0),
                        EventType = r.GetString(1),
                        ActorType = r.GetString(2),
                        Details = r.GetString(3).Length > 120 ? r.GetString(3).Substring(0, 120) + "..." : r.GetString(3)
                    });
            }

            StateHasChanged();
        }
        catch (Exception ex) { formMesaj = ex.Message; formMesajTip = "alert-err"; }
    }

    async Task TierDegistir()
    {
        await using var conn = new SqlConnection(MasterConn);
        await conn.OpenAsync();
        int newTierId;
        await using (var q = new SqlCommand("SELECT tier_id FROM subscription_tiers WHERE tier_code=@t", conn))
        {
            q.Parameters.AddWithValue("@t", yeniTier);
            newTierId = (int)(await q.ExecuteScalarAsync() ?? 0);
        }
        if (newTierId == 0) return;
        await using (var upd = new SqlCommand("UPDATE tenants SET tier_id=@t WHERE tenant_id=@id", conn))
        {
            upd.Parameters.AddWithValue("@t", newTierId);
            upd.Parameters.AddWithValue("@id", detayTenantId);
            await upd.ExecuteNonQueryAsync();
        }
        await using (var a = new SqlCommand("INSERT INTO control_audit_events (occurred_at, actor_type, tenant_id, event_type, details_json) VALUES (SYSUTCDATETIME(), 'admin_ui', @tid, 'tenant.tier_changed', @d)", conn))
        {
            a.Parameters.AddWithValue("@tid", detayTenantId);
            a.Parameters.AddWithValue("@d", $"{{\"newTier\":\"{yeniTier}\"}}");
            await a.ExecuteNonQueryAsync();
        }
        await DetayAc(detayTenantId);
        await VerileriYukle();
    }

    async Task MigrationCalistir(Guid tenantId)
    {
        migrationCalisiyor = true;
        migrationSonuc = "";
        StateHasChanged();
        try
        {
            // Tenant DB connection string al
            string? encCs = null;
            await using (var m = new SqlConnection(MasterConn))
            {
                await m.OpenAsync();
                await using var q = new SqlCommand("SELECT connection_string_encrypted FROM tenant_connections WHERE tenant_id=@id", m);
                q.Parameters.AddWithValue("@id", tenantId);
                encCs = (string?)await q.ExecuteScalarAsync();
            }
            if (encCs == null) { migrationSonuc = "Connection yok"; migrationCalisiyor = false; return; }
            var protector = (IConnectionStringProtector)ScopedServices.GetRequiredService(typeof(IConnectionStringProtector));
            var cs = protector.Unprotect(encCs);

            int sBefore=0, cBefore=0, sAfter=0, cAfter=0;
            await using (var tc = new SqlConnection(cs))
            {
                await tc.OpenAsync();
                await using (var cc = new SqlCommand("SELECT COUNT(*) FROM stoklar", tc))
                    sBefore = (int)(await cc.ExecuteScalarAsync() ?? 0);
                await using (var cc = new SqlCommand("SELECT COUNT(*) FROM cari_hesaplar", tc))
                    cBefore = (int)(await cc.ExecuteScalarAsync() ?? 0);

                await using (var cmd = new SqlCommand(@"
MERGE INTO stoklar AS tgt
USING (SELECT sto_kod, LEFT(sto_isim,50) AS sto_isim, LEFT(sto_kisa_isim,25) AS sto_kisa_ismi,
              LEFT(sto_yabanci_isim,50) AS sto_yabanci_isim, LEFT(sto_birim1_ad,10) AS sto_birim1_ad,
              sto_perakende_vergi, NEWID() AS sto_Guid
       FROM pine_stoklar WHERE rec_iptal=0 AND rec_gizli=0 AND sto_kod IS NOT NULL) src
ON tgt.sto_kod=src.sto_kod
WHEN MATCHED THEN UPDATE SET sto_isim=src.sto_isim, sto_kisa_ismi=src.sto_kisa_ismi, sto_yabanci_isim=src.sto_yabanci_isim, sto_birim1_ad=src.sto_birim1_ad, sto_perakende_vergi=src.sto_perakende_vergi
WHEN NOT MATCHED THEN INSERT (sto_kod, sto_isim, sto_kisa_ismi, sto_yabanci_isim, sto_birim1_ad, sto_perakende_vergi, sto_Guid, sto_iptal, sto_hidden, sto_kilitli, sto_degisti)
VALUES (src.sto_kod, src.sto_isim, src.sto_kisa_ismi, src.sto_yabanci_isim, src.sto_birim1_ad, src.sto_perakende_vergi, src.sto_Guid, 0, 0, 0, 0);", tc))
                {
                    cmd.CommandTimeout = 300;
                    await cmd.ExecuteNonQueryAsync();
                }
                await using (var cmd = new SqlCommand(@"
MERGE INTO cari_hesaplar AS tgt
USING (SELECT car_kod AS cari_kod, car_unvan1 AS cari_unvan1, car_unvan2 AS cari_unvan2, NEWID() AS cari_Guid
       FROM pine_cari_hesaplar WHERE rec_iptal=0 AND rec_gizli=0 AND car_kod IS NOT NULL) src
ON tgt.cari_kod=src.cari_kod
WHEN MATCHED THEN UPDATE SET cari_unvan1=src.cari_unvan1, cari_unvan2=src.cari_unvan2
WHEN NOT MATCHED THEN INSERT (cari_kod, cari_unvan1, cari_unvan2, cari_Guid, cari_iptal, cari_hidden, cari_kilitli, cari_degisti)
VALUES (src.cari_kod, src.cari_unvan1, src.cari_unvan2, src.cari_Guid, 0, 0, 0, 0);", tc))
                {
                    cmd.CommandTimeout = 300;
                    await cmd.ExecuteNonQueryAsync();
                }

                await using (var cc = new SqlCommand("SELECT COUNT(*) FROM stoklar", tc))
                    sAfter = (int)(await cc.ExecuteScalarAsync() ?? 0);
                await using (var cc = new SqlCommand("SELECT COUNT(*) FROM cari_hesaplar", tc))
                    cAfter = (int)(await cc.ExecuteScalarAsync() ?? 0);
            }
            migrationSonuc = $"✓ Stok: {sAfter} (+{sAfter-sBefore}), Cari: {cAfter} (+{cAfter-cBefore})";

            // Audit
            await using var m2 = new SqlConnection(MasterConn);
            await m2.OpenAsync();
            await using var aud = new SqlCommand(@"
INSERT INTO control_audit_events (occurred_at, actor_type, tenant_id, event_type, details_json)
VALUES (SYSUTCDATETIME(), 'admin_ui', @tid, 'migration.pine_to_mikro', @d)", m2);
            aud.Parameters.AddWithValue("@tid", tenantId);
            aud.Parameters.AddWithValue("@d", $"{{\"sto\":{sAfter},\"cari\":{cAfter}}}");
            await aud.ExecuteNonQueryAsync();
        }
        catch (Exception ex) { migrationSonuc = ex.Message; }
        migrationCalisiyor = false;
    }

