@page "/platform/admin"
@layout MACHINEBISS_Web.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@inject IConfiguration Config
@inject NavigationManager Nav
@inject IServiceProvider ScopedServices
@using Microsoft.Data.SqlClient
@using MACHINEBISS_Web.MultiTenant

<PageTitle>Platform Admin - Pinebi</PageTitle>

<div style="padding:20px; font-family: 'Segoe UI', Arial;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2 style="color:#235881; margin:0;">
            <i class="fa fa-tachometer-alt"></i> Pinebi Platform Admin
        </h2>
        <button class="btn-outline" @onclick="Cikis">
            <i class="fa fa-sign-out-alt"></i> Cikis
        </button>
    </div>

    <div class="admin-tabs">
        <button class="tab-btn @(aktif=="ozet"?"active":"")"   @onclick='() => aktif="ozet"'>Özet</button>
        <button class="tab-btn @(aktif=="genel"?"active":"")"  @onclick='() => aktif="genel"'>Genel Bakis</button>
        <button class="tab-btn @(aktif=="tenant"?"active":"")" @onclick='() => aktif="tenant"'>Tenantlar (@tenantlar.Count)</button>
        <button class="tab-btn @(aktif=="api"?"active":"")"    @onclick='() => aktif="api"'>API Keyler (@apiKeyler.Count)</button>
        <button class="tab-btn @(aktif=="prov"?"active":"")"   @onclick='() => aktif="prov"'>Provisioning (@provisionJobs.Count)</button>
        <button class="tab-btn @(aktif=="audit"?"active":"")"  @onclick='() => aktif="audit"'>Audit (@auditEvents.Count)</button>
        <button class="tab-btn @(aktif=="quota"?"active":"")"  @onclick='() => aktif="quota"'>Kullanim/Quota</button>
        <button class="tab-btn @(aktif=="trend"?"active":"")"  @onclick='() => aktif="trend"'>Trendler</button>
        <button class="tab-btn @(aktif=="backup"?"active":"")" @onclick='() => aktif="backup"'>Yedekler</button>
        <button class="tab-btn @(aktif=="changelog"?"active":"")" @onclick='() => aktif="changelog"'>Degisiklikler</button>
        <button class="tab-btn refresh" @onclick="VerileriYukle"><i class="fa fa-sync"></i> Yenile</button>
    </div>

    @if (aktif == "ozet")
    {
        <div class="stats-grid">
            <div class="stat-card"><div class="stat-label">Aktif Tenant</div><div class="stat-value">@tenantlar.Count(t => t.Status == "active")</div></div>
            <div class="stat-card"><div class="stat-label">Toplam Tenant</div><div class="stat-value">@tenantlar.Count</div></div>
            <div class="stat-card"><div class="stat-label">Aktif API Key</div><div class="stat-value">@apiKeyler.Count(k => k.Active)</div></div>
            <div class="stat-card"><div class="stat-label">Provisioning Job</div><div class="stat-value">@provisionJobs.Count</div></div>
        </div>

        <h3 style="margin-top:30px;">Sistem Durumu</h3>
        <table class="admin-table">
            <thead><tr><th>Bilesen</th><th>Durum</th></tr></thead>
            <tbody>
                <tr><td>Pinebi_Master DB</td><td><span class="badge-ok">Calisiyor</span> (@tenantlar.Count tenant)</td></tr>
                <tr><td>DataProtection Key Ring</td><td><span class="badge-ok">Aktif</span> (C:\ProgramData\Pinebi\dp-keys)</td></tr>
                <tr><td>Subdomain Routing</td><td><span class="badge-ok">Aktif</span></td></tr>
                <tr><td>API Gateway (erpapi.pinebi.com)</td><td><span class="badge-ok">Aktif</span></td></tr>
                <tr><td>Encryption</td><td><span class="badge-ok">ENC: prefix</span></td></tr>
            </tbody>
        </table>
    }

    @if (aktif == "genel")
    {
        <h3>Pinebi ERP - Sistem Haritasi</h3>

        <div class="gb-grid">
            <div class="gb-card">
                <h4><i class="fa fa-sign-in-alt"></i> Public Girisler</h4>
                <ul class="gb-links">
                    <li><a href="/signup" target="_blank"><b>/signup</b></a><span>Firma Kaydi (self-serve)</span></li>
                    <li><a href="/platform/login" target="_blank"><b>/platform/login</b></a><span>Platform Admin Girisi</span></li>
                    <li><a href="/davet/kabul?token=XXX" target="_blank"><b>/davet/kabul?token=...</b></a><span>Davet Kabul (tokenle)</span></li>
                </ul>
            </div>

            <div class="gb-card">
                <h4><i class="fa fa-user-shield"></i> Platform Admin</h4>
                <ul class="gb-links">
                    <li><a href="/platform/admin"><b>/platform/admin</b></a><span>Admin Dashboard (bu sayfa)</span></li>
                    <li><code>admin@pinebi.com</code> / <code>admin</code><span>Varsayilan giris</span></li>
                </ul>
            </div>

            <div class="gb-card">
                <h4><i class="fa fa-building"></i> Tenant Sayfalari (her firma)</h4>
                <ul class="gb-links">
                    <li><a href="https://erp.pinebi.com/pine" target="_blank"><b>{tenant}.pinebi.com/pine</b></a><span>Dashboard</span></li>
                    <li><a href="https://erp.pinebi.com/pine/fatura/yeni" target="_blank"><b>/pine/fatura/yeni</b></a><span>Yeni Fatura (Mikro 3-sutun)</span></li>
                    <li><a href="https://erp.pinebi.com/pine/stok/kart" target="_blank"><b>/pine/stok/kart</b></a><span>Stok Kart</span></li>
                    <li><a href="https://erp.pinebi.com/pine/cari/kart" target="_blank"><b>/pine/cari/kart</b></a><span>Cari Kart</span></li>
                    <li><a href="https://erp.pinebi.com/pine/sistem/kullanicilar" target="_blank"><b>/pine/sistem/kullanicilar</b></a><span>Kullanici Yonetimi</span></li>
                    <li><a href="https://erp.pinebi.com/pine/sistem/davetler" target="_blank"><b>/pine/sistem/davetler</b></a><span>Davet Yonetimi</span></li>
                    <li><a href="https://erp.pinebi.com/pine/sistem/ayarlar" target="_blank"><b>/pine/sistem/ayarlar</b></a><span>Firma Ayarlari</span></li>
                    <li><a href="https://erp.pinebi.com/pine/sistem/audit" target="_blank"><b>/pine/sistem/audit</b></a><span>Aktivite Gecmisi</span></li>
                </ul>
            </div>

            <div class="gb-card">
                <h4><i class="fa fa-code"></i> API Gateway</h4>
                <ul class="gb-links">
                    <li><code>https://erpapi.pinebi.com/api/*</code><span>Dis entegrasyonlar (X-Api-Key header)</span></li>
                    <li><code>/api/mikro/stok/ara</code><span>Mikro stok CRUD</span></li>
                    <li><code>/api/mikro/cari/ara</code><span>Mikro cari arama</span></li>
                    <li><code>/api/public/signup</code><span>Public tenant olusturma (anonim)</span></li>
                    <li><code>/api/tenant/settings</code><span>Tenant ayarlari (GET/PUT)</span></li>
                    <li><code>/api/tenant/audit</code><span>Tenant audit log</span></li>
                </ul>
            </div>

            <div class="gb-card">
                <h4><i class="fa fa-database"></i> Mevcut Tenant'lar (@tenantlar.Count)</h4>
                <ul class="gb-links">
                    @foreach (var t in tenantlar.Where(x => x.Status != "deleted"))
                    {
                        <li>
                            <a href="@($"https://{t.Subdomain}.pinebi.com")" target="_blank"><b>@($"{t.Subdomain}.pinebi.com")</b></a>
                            <span>@t.TenantName · <span class="badge-@t.Status">@t.Status</span></span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <h3 style="margin-top:30px;">Bolum Bolum Neler Yapildi</h3>

        <div class="yap-grid">
            <div class="yap-card">
                <div class="yap-num">1</div>
                <h4>Multi-Tenant Altyapi</h4>
                <ul>
                    <li>Her firmaya ayri SQL database (Database-per-Tenant)</li>
                    <li>Subdomain routing: acme.pinebi.com → ACME DB</li>
                    <li>Pinebi_Master: tum firmalarin metadata'si (tenants, tier, connection)</li>
                    <li>Tam veri izolasyonu (bir firmanin verisi digerine dokunmuyor)</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">2</div>
                <h4>Self-Serve Signup</h4>
                <ul>
                    <li>/signup sayfasi - anonim herkes firma acabilir</li>
                    <li>10 saniyede: DB olustu + admin kullanici + welcome mail</li>
                    <li>Subdomain canli benzersizlik kontrolu</li>
                    <li>Rezerve subdomain listesi (api, admin, erp vb)</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">3</div>
                <h4>Provisioning + Yasam Dongusu</h4>
                <ul>
                    <li>Template backup/restore ile yeni tenant ~3sn</li>
                    <li>Suspend / Reactivate / Soft-Delete / Hard-Delete</li>
                    <li>Tier upgrade/downgrade (Free/Starter/Pro/Enterprise)</li>
                    <li>Tum islemler audit loglaniyor</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">4</div>
                <h4>Guvenlik</h4>
                <ul>
                    <li>Platform admin: cookie auth + BCrypt (DataProtection encrypted)</li>
                    <li>API Gateway: X-Api-Key + SHA256 hash + scoped tenant</li>
                    <li>Connection string'ler ENC: prefix ile sifreli (AES)</li>
                    <li>Key ring: C:\ProgramData\Pinebi\dp-keys</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">5</div>
                <h4>Kullanici + Davet</h4>
                <ul>
                    <li>Tenant ici kullanici CRUD (admin/yonetici/kullanici/okuyucu)</li>
                    <li>Davet akisi: 7 gun gecerli token + email</li>
                    <li>Yandex SMTP app password entegrasyonu</li>
                    <li>Davetli kendi sifresini belirler, tokenla kabul eder</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">6</div>
                <h4>Mikro V16 Gecis</h4>
                <ul>
                    <li>413 Mikro tablosu icin EF entity + MikroContext</li>
                    <li>Tum tenant DB'leri hibrit: 222 Pine + 413 Mikro = 635 tablo</li>
                    <li>Pine → Mikro veri migration (stok + cari)</li>
                    <li>MikroStokController + MikroCariController CRUD</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">7</div>
                <h4>Fatura Formu</h4>
                <ul>
                    <li>Klasik Mikro 3-sutun layout (label-left, kompakt)</li>
                    <li>Eksik alanlar eklendi: Ith/Ihrc, Kapayan Hesap, Nor/Iade, Tic. Turu</li>
                    <li>5 fatura tipi (Satis/Iade/Satinalma/SatinalmaIade/Proforma)</li>
                    <li>Acik/Kapali durumu</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">8</div>
                <h4>Admin Panel (bu sayfa)</h4>
                <ul>
                    <li>Tenant listele + detay modal + tier upgrade</li>
                    <li>API key listesi + uret</li>
                    <li>Audit events + son 30 gun trendler (sparkline)</li>
                    <li>Kullanim/Quota + Yedekler</li>
                    <li>Commit history + Genel Bakis (bu sekme)</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">9</div>
                <h4>Quota + Backup</h4>
                <ul>
                    <li>Tier basina max user/storage/fatura limitleri</li>
                    <li>Limit asiminda 402 Payment Required (fatura yazmada)</li>
                    <li>Otomatik gecelik backup (03:00, 14 gun retention)</li>
                    <li>Manuel 'Simdi Yedekle' butonu</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">10</div>
                <h4>Audit Log</h4>
                <ul>
                    <li>Tum olaylar control_audit_events tablosuna</li>
                    <li>tenant.created/suspended/reactivated/deleted</li>
                    <li>platform.login/login_failed, apikey.created</li>
                    <li>invite.created/accepted/revoked, migration.pine_to_mikro</li>
                    <li>Tenant kendi olaylarini /pine/sistem/audit'tan goruntuler</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">11</div>
                <h4>Deploy + Git</h4>
                <ul>
                    <li>IIS site: erp.pinebi.com (+ wildcard + api + tenant subdomain'ler)</li>
                    <li>SQL: 185.210.92.248 - Pinebi_Master + 7+ tenant DB</li>
                    <li>GitHub: github.com/pinebi/erp.pinebi.com (main branch)</li>
                    <li>DB yedekleri (.bak) repo'da database/ klasorunde</li>
                </ul>
            </div>

            <div class="yap-card">
                <div class="yap-num">12</div>
                <h4>Onemli Konfigurasyon</h4>
                <ul>
                    <li><code>appsettings.json</code>: Email (Yandex app password)</li>
                    <li><code>C:\Pinebi\backups\</code>: gecelik yedekler</li>
                    <li><code>C:\ProgramData\Pinebi\dp-keys\</code>: key ring</li>
                    <li>IIS binding her tenant icin manuel eklenmeli (ileride otomasyon)</li>
                </ul>
            </div>
        </div>
    }

    @if (aktif == "tenant")
    {
        <div style="display:flex; justify-content:space-between; align-items:center; margin: 16px 0;">
            <h3>Tenantlar</h3>
            <button class="btn-primary" @onclick="YeniTenantAc">
                <i class="fa fa-plus"></i> Yeni Tenant
            </button>
        </div>

        @if (yeniTenantAcik)
        {
            <div class="inline-form">
                <input placeholder="Kod (ACME)" @bind="formKod" />
                <input placeholder="Ad (ACME Ltd.)" @bind="formAd" />
                <input placeholder="Subdomain (acme)" @bind="formSub" />
                <select @bind="formTier">
                    <option value="free">Free</option>
                    <option value="starter">Starter</option>
                    <option value="pro">Pro</option>
                    <option value="enterprise">Enterprise</option>
                </select>
                <input placeholder="Owner email" @bind="formEmail" type="email" />
                <button class="btn-primary" @onclick="TenantOlustur" disabled="@olusturuluyor">
                    @(olusturuluyor ? "Olusturuluyor..." : "Olustur")
                </button>
                <button class="btn-outline" @onclick='() => yeniTenantAcik = false'>Iptal</button>
            </div>
            @if (!string.IsNullOrEmpty(formMesaj))
            {
                <div class="alert @(formMesajTip)">@formMesaj</div>
            }
        }

        <table class="admin-table">
            <thead><tr><th>Subdomain</th><th>Kod</th><th>Ad</th><th>DB</th><th>Region</th><th>Durum</th><th>Olusturma</th><th>Aksiyon</th></tr></thead>
            <tbody>
                @foreach (var t in tenantlar)
                {
                    <tr>
                        <td><b>@t.Subdomain</b></td>
                        <td>@t.TenantCode</td>
                        <td>@t.TenantName</td>
                        <td><code>@t.DbName</code></td>
                        <td>@t.RegionId</td>
                        <td>
                            <span class="badge-@t.Status">@t.Status</span>
                        </td>
                        <td>@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <button class="btn-mini" @onclick="() => DetayAc(t.TenantId)">Detay</button>
                            <a href="@($"https://{t.Subdomain}.pinebi.com")" target="_blank" class="btn-mini">Aç</a>
                            <button class="btn-mini" @onclick="() => ApiKeyUret(t.TenantId, t.Subdomain)">Key Uret</button>
                            @if (t.Status == "active")
                            {
                                <button class="btn-mini" style="color:#b45309;border-color:#fde68a;" @onclick="() => Suspend(t.TenantId)">Dondur</button>
                            }
                            @if (t.Status == "suspended")
                            {
                                <button class="btn-mini" style="color:#166534;border-color:#bbf7d0;" @onclick="() => Reactivate(t.TenantId)">Aktif Et</button>
                            }
                            @if (t.Status != "deleted")
                            {
                                <button class="btn-mini" style="color:#991b1b;border-color:#fecaca;" @onclick="() => Sil(t.TenantId, t.Subdomain)">Sil</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!string.IsNullOrEmpty(yeniKey))
        {
            <div class="alert alert-ok">
                <b>Yeni API Key olusturuldu:</b>
                <code>@yeniKey</code>
                <br/><small>Bu anahtari simdi kaydedin, tekrar gosterilmez.</small>
            </div>
        }
    }

    @if (detayData != null)
    {
        <div class="modal-ov" @onclick="() => detayData = null">
            <div class="modal-dt" @onclick:stopPropagation="true">
                <div class="modal-hdr">
                    <h3>@detayData.TenantName <small>(@($"{detayData.Subdomain}.pinebi.com"))</small></h3>
                    <button class="btn-mini" @onclick="() => detayData = null">X</button>
                </div>
                <div class="modal-bd">
                    <div class="dt-grid">
                        <div><b>Kod:</b> @detayData.TenantCode</div>
                        <div><b>DB:</b> <code>@detayData.DbName</code></div>
                        <div><b>Region:</b> @detayData.RegionId</div>
                        <div><b>Status:</b> <span class="badge-@detayData.Status">@detayData.Status</span></div>
                        <div><b>Email:</b> @detayData.ContactEmail</div>
                        <div><b>Vergi No:</b> @(detayData.VergiNo ?? "-")</div>
                        <div><b>Olusturma:</b> @detayData.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div><b>Aktiflestirme:</b> @(detayData.ActivatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                    </div>

                    <h4>Tier: <span class="tier-badge">@detayData.TierCode</span> ($@detayData.MonthlyPriceUsd/ay)</h4>
                    <div class="dt-grid">
                        <div>Max user: @detayData.MaxUsers</div>
                        <div>Max storage: @detayData.MaxStorageGb GB</div>
                        <div>Max fatura/ay: @detayData.MaxInvoicesMonth</div>
                    </div>
                    <div style="margin-top:8px; display:flex; gap:10px; flex-wrap:wrap;">
                        <div>
                            <select @bind="yeniTier">
                                <option value="free">Free</option>
                                <option value="starter">Starter</option>
                                <option value="pro">Pro</option>
                                <option value="enterprise">Enterprise</option>
                            </select>
                            <button class="btn-primary" style="padding:4px 12px;" @onclick="TierDegistir">Tier Degistir</button>
                        </div>
                        <div>
                            <button class="btn-mini" @onclick="() => MigrationCalistir(detayTenantId)" disabled="@migrationCalisiyor">
                                @(migrationCalisiyor ? "Calisiyor..." : "Pine -> Mikro Migrate")
                            </button>
                            @if (migrationSonuc != "")
                            {
                                <small style="color:#166534; margin-left:8px;">@migrationSonuc</small>
                            }
                        </div>
                    </div>

                    <h4>API Keyler (@detayApiKeys.Count)</h4>
                    @if (detayApiKeys.Count == 0) { <p style="color:#64748b;">Henuz yok.</p> }
                    else
                    {
                        <table class="admin-table"><thead><tr><th>Prefix</th><th>Desc</th><th>Scopes</th><th>Son Kullanim</th></tr></thead><tbody>
                        @foreach (var k in detayApiKeys)
                        {
                            <tr><td><code>@k.Prefix</code></td><td>@k.Description</td><td>@k.Scopes</td><td>@(k.LastUsedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td></tr>
                        }
                        </tbody></table>
                    }

                    <h4>Davetler (@detayInvites.Count)</h4>
                    @if (detayInvites.Count == 0) { <p style="color:#64748b;">Henuz davet yok.</p> }
                    else
                    {
                        <table class="admin-table"><thead><tr><th>Email</th><th>Kullanici</th><th>Rol</th><th>Durum</th></tr></thead><tbody>
                        @foreach (var i in detayInvites)
                        {
                            var durum = i.RevokedAt.HasValue ? "iptal"
                                      : i.AcceptedAt.HasValue ? "kabul"
                                      : i.ExpiresAt < DateTime.UtcNow ? "suresi_doldu" : "beklemede";
                            <tr><td>@i.Email</td><td>@i.KullaniciAdi</td><td>@i.Rol</td><td><span class="badge-@durum">@durum</span></td></tr>
                        }
                        </tbody></table>
                    }

                    <h4>Son Olaylar (@detayEvents.Count)</h4>
                    <table class="admin-table"><thead><tr><th>Zaman</th><th>Olay</th><th>Aktor</th></tr></thead><tbody>
                    @foreach (var e in detayEvents)
                    {
                        <tr><td>@e.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</td><td>@e.EventType</td><td>@e.ActorType</td></tr>
                    }
                    </tbody></table>
                </div>
            </div>
        </div>
    }

    @if (aktif == "api")
    {
        <h3>API Keyler</h3>
        <table class="admin-table">
            <thead><tr><th>Prefix</th><th>Tenant</th><th>Aciklama</th><th>Scope</th><th>Aktif</th><th>Olusturma</th><th>Son Kullanim</th></tr></thead>
            <tbody>
                @foreach (var k in apiKeyler)
                {
                    <tr>
                        <td><code>@k.KeyPrefix...</code></td>
                        <td>@k.TenantCode</td>
                        <td>@k.Description</td>
                        <td>@k.Scopes</td>
                        <td><span class="badge-@(k.Active ? "ok" : "off")">@(k.Active ? "Aktif" : "Pasif")</span></td>
                        <td>@k.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>@(k.LastUsedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (aktif == "prov")
    {
        <h3>Provisioning Jobs</h3>
        @if (provisionJobs.Count == 0)
        {
            <p>Henuz job yok (tabloya henuz kayit yazilmadi - otomatik kaydi asagidaki commit adiminda ekleyebiliriz).</p>
        }
        <table class="admin-table">
            <thead><tr><th>Job</th><th>Tenant</th><th>Durum</th><th>Baslangic</th><th>Bitis</th><th>Hata</th></tr></thead>
            <tbody>
                @foreach (var j in provisionJobs)
                {
                    <tr>
                        <td><code>@j.JobId.ToString()[..8]</code></td>
                        <td>@j.TenantId.ToString()[..8]</td>
                        <td><span class="badge-@j.Status">@j.Status</span></td>
                        <td>@j.StartedAt?.ToString("HH:mm:ss")</td>
                        <td>@j.FinishedAt?.ToString("HH:mm:ss")</td>
                        <td>@(j.ErrorMessage ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (aktif == "audit")
    {
        <h3>Audit Events (son 100)</h3>
        @if (auditEvents.Count == 0)
        {
            <p>Henuz audit event yok.</p>
        }
        <table class="admin-table">
            <thead><tr><th>Zaman</th><th>Tip</th><th>Actor</th><th>Tenant</th><th>Detay</th></tr></thead>
            <tbody>
                @foreach (var e in auditEvents)
                {
                    <tr>
                        <td>@e.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@e.EventType</td>
                        <td>@e.ActorType</td>
                        <td>@(e.TenantId?.ToString()[..8] ?? "-")</td>
                        <td><code style="font-size:11px;">@e.Details</code></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (aktif == "quota")
    {
        <h3>Tenant Kullanim Istatistikleri</h3>
        <p style="color:#64748b; font-size:12px;">Tier limitlerini asan tenant'lar kirmizi ile isaretlenmistir.</p>
        @if (quotaData == null)
        {
            <button class="btn-primary" @onclick="QuotaYukle">Yukle</button>
        }
        else
        {
            <table class="admin-table">
                <thead><tr><th>Tenant</th><th>Tier</th><th>Users</th><th>Stoklar</th><th>Cariler</th><th>Bu Ay Fatura</th><th>DB Boyut</th></tr></thead>
                <tbody>
                    @foreach (var q in quotaData)
                    {
                        <tr>
                            <td><b>@q.Subdomain</b><br/><small style="color:#64748b;">@q.TenantCode</small></td>
                            <td><span class="tier-badge">@q.Tier</span></td>
                            <td class="@(q.UsersOver ? "over" : "")">@q.Users / @q.MaxUsers</td>
                            <td>@q.Stoks</td>
                            <td>@q.Cariler</td>
                            <td class="@(q.InvoicesOver ? "over" : "")">@q.InvoicesThisMonth / @q.MaxInvoicesMonth</td>
                            <td class="@(q.StorageOver ? "over" : "")">@q.DbSizeMb MB / @(q.MaxStorageGb * 1024) MB</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    @if (aktif == "trend")
    {
        <h3>Son 30 Gun Trend</h3>
        <p style="color:#64748b; font-size:12px;">Audit event'lerden gunluk olarak toplanan aktiviteler.</p>
        @if (trendData == null)
        {
            <button class="btn-primary" @onclick="TrendYukle">Yukle</button>
        }
        else
        {
            <div class="trend-grid">
                <div class="trend-card">
                    <div class="trend-title">Yeni Tenant</div>
                    <div class="trend-value">@trendData.TenantCreated.Sum()</div>
                    <div class="spark">
                        @foreach (var v in trendData.TenantCreated)
                        {
                            var h = trendData.TenantCreated.Max() == 0 ? 0 : (int)(v * 40.0 / Math.Max(1, trendData.TenantCreated.Max()));
                            <div class="bar" style="height:@(h)px;" title="@v"></div>
                        }
                    </div>
                </div>
                <div class="trend-card">
                    <div class="trend-title">Login</div>
                    <div class="trend-value">@trendData.Logins.Sum()</div>
                    <div class="spark">
                        @foreach (var v in trendData.Logins)
                        {
                            var h = trendData.Logins.Max() == 0 ? 0 : (int)(v * 40.0 / Math.Max(1, trendData.Logins.Max()));
                            <div class="bar" style="height:@(h)px; background:#0ea5e9;" title="@v"></div>
                        }
                    </div>
                </div>
                <div class="trend-card">
                    <div class="trend-title">Davet</div>
                    <div class="trend-value">@trendData.Invites.Sum()</div>
                    <div class="spark">
                        @foreach (var v in trendData.Invites)
                        {
                            var h = trendData.Invites.Max() == 0 ? 0 : (int)(v * 40.0 / Math.Max(1, trendData.Invites.Max()));
                            <div class="bar" style="height:@(h)px; background:#a855f7;" title="@v"></div>
                        }
                    </div>
                </div>
                <div class="trend-card">
                    <div class="trend-title">API Key</div>
                    <div class="trend-value">@trendData.ApiKeys.Sum()</div>
                    <div class="spark">
                        @foreach (var v in trendData.ApiKeys)
                        {
                            var h = trendData.ApiKeys.Max() == 0 ? 0 : (int)(v * 40.0 / Math.Max(1, trendData.ApiKeys.Max()));
                            <div class="bar" style="height:@(h)px; background:#f59e0b;" title="@v"></div>
                        }
                    </div>
                </div>
            </div>

            <h4 style="margin-top:20px;">Gunluk Detay</h4>
            <table class="admin-table">
                <thead><tr><th>Gun</th><th>Tenant</th><th>Login</th><th>Davet</th><th>API Key</th></tr></thead>
                <tbody>
                    @for (int i = trendData.Labels.Count - 1; i >= 0; i--)
                    {
                        <tr>
                            <td>@trendData.Labels[i]</td>
                            <td>@trendData.TenantCreated[i]</td>
                            <td>@trendData.Logins[i]</td>
                            <td>@trendData.Invites[i]</td>
                            <td>@trendData.ApiKeys[i]</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }

    @if (aktif == "backup")
    {
        <div style="display:flex; justify-content:space-between; align-items:center; margin: 16px 0;">
            <h3>DB Yedekleri</h3>
            <button class="btn-primary" @onclick="BackupShimdi" disabled="@backupCalisiyor">
                <i class="fa fa-download"></i> @(backupCalisiyor ? "Yedekleniyor..." : "Simdi Yedekle")
            </button>
        </div>
        <p style="color:#64748b; font-size:12px;">Otomatik: Her gece 03:00. Konum: <code>C:\Pinebi\backups\yyyy-MM-dd\</code>. Retention: 14 gun.</p>

        @if (backupSonucu != null)
        {
            <div class="alert alert-ok">
                <b>Manuel yedek tamamlandi.</b>
                Sure: @backupSonucu.DurationSeconds sn · Basarili: @backupSonucu.Success / Toplam: @backupSonucu.TotalTenants · Klasor: <code>@backupSonucu.Folder</code>
            </div>
        }

        @if (backupFolders == null)
        {
            <button class="btn-primary" @onclick="BackupYukle">Yukle</button>
        }
        else if (backupFolders.Count == 0)
        {
            <p>Henuz yedek yok. 'Simdi Yedekle' ile olusturabilirsiniz.</p>
        }
        else
        {
            @foreach (var bf in backupFolders)
            {
                <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:6px; padding:12px; margin-bottom:10px;">
                    <b>@bf.Date</b> — <small style="color:#64748b;">@bf.Files.Count dosya</small>
                    <table class="admin-table" style="margin-top:8px;">
                        <thead><tr><th>Dosya</th><th style="text-align:right;">Boyut</th></tr></thead>
                        <tbody>
                            @foreach (var f in bf.Files)
                            {
                                <tr>
                                    <td><code>@f.File</code></td>
                                    <td style="text-align:right;">@f.SizeMb MB</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    }

    @if (aktif == "changelog")
    {
        <h3>Yapilan Isler (Git commit gecmisi)</h3>
        <ul class="changelog">
            @foreach (var c in commits)
            {
                <li>
                    <div style="display:flex; justify-content:space-between;">
                        <code>@c.Hash</code>
                        <span style="color:#64748b; font-size:12px;">@c.Date</span>
                    </div>
                    <div style="margin-top:4px;">@c.Subject</div>
                </li>
            }
        </ul>
    }
</div>

