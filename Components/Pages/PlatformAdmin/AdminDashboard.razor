                    DurationSeconds = j.GetProperty("durationSeconds").GetDouble()
                };
                await BackupYukle();
            }
        }
        catch (Exception ex) { formMesaj = ex.Message; formMesajTip = "alert-err"; }
        backupCalisiyor = false;
    }

