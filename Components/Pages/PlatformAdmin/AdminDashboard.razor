    record BackupFolder { public string Date { get; init; } = ""; public string Path { get; init; } = ""; public List<BackupFile> Files { get; init; } = new(); }
    record BackupFile { public string File { get; init; } = ""; public long SizeMb { get; init; } }
    record BackupSonucu { public string Folder { get; init; } = ""; public int TotalTenants { get; init; } public int Success { get; init; } public int Failed { get; init; } public double DurationSeconds { get; init; } }

    async Task BackupYukle()
    {
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var resp = await http.GetFromJsonAsync<System.Text.Json.JsonElement>("api/platform/backup");
            var list = new List<BackupFolder>();
            foreach (var bf in resp.GetProperty("folders").EnumerateArray())
            {
                var files = new List<BackupFile>();
                foreach (var f in bf.GetProperty("files").EnumerateArray())
                    files.Add(new BackupFile { File = f.GetProperty("file").GetString() ?? "", SizeMb = f.GetProperty("sizeMb").GetInt64() });
                list.Add(new BackupFolder {
                    Date = bf.GetProperty("date").GetString() ?? "",
                    Path = bf.GetProperty("path").GetString() ?? "",
                    Files = files
                });
            }
            backupFolders = list;
        }
        catch (Exception ex) { formMesaj = ex.Message; formMesajTip = "alert-err"; }
    }

    async Task BackupShimdi()
    {
        backupCalisiyor = true;
        backupSonucu = null;
        StateHasChanged();
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var resp = await http.PostAsync("api/platform/backup/run-now", null);
            if (resp.IsSuccessStatusCode)
            {
                var j = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                backupSonucu = new BackupSonucu {
                    Folder = j.GetProperty("folder").GetString() ?? "",
                    TotalTenants = j.GetProperty("totalTenants").GetInt32(),
                    Success = j.GetProperty("success").GetInt32(),
                    Failed = j.GetProperty("failed").GetInt32(),
                    DurationSeconds = j.GetProperty("durationSeconds").GetDouble()
                };
                await BackupYukle();
            }
        }
        catch (Exception ex) { formMesaj = ex.Message; formMesajTip = "alert-err"; }
        backupCalisiyor = false;
    }

    async Task QuotaYukle()
    {
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var resp = await http.GetFromJsonAsync<System.Text.Json.JsonElement>("api/platform/quota");
            var list = new List<QuotaRow>();
            foreach (var it in resp.GetProperty("items").EnumerateArray())
            {
                var u = it.GetProperty("usage");
                var l = it.GetProperty("limits");
                var s = it.GetProperty("quotaStatus");
                list.Add(new QuotaRow
                {
                    TenantId = it.GetProperty("tenantId").GetGuid(),
                    TenantCode = it.GetProperty("tenantCode").GetString() ?? "",
                    Subdomain = it.GetProperty("subdomain").GetString() ?? "",
                    Tier = it.GetProperty("tier").GetString() ?? "",
                    Users = u.GetProperty("users").GetInt32(),
                    Stoks = u.GetProperty("stoks").GetInt32(),
                    Cariler = u.GetProperty("cariler").GetInt32(),
                    InvoicesThisMonth = u.GetProperty("invoicesThisMonth").GetInt32(),
                    InvoicesTotal = u.GetProperty("invoicesTotal").GetInt32(),
                    DbSizeMb = u.GetProperty("dbSizeMb").GetInt64(),
                    MaxUsers = l.GetProperty("maxUsers").GetInt32(),
                    MaxStorageGb = l.GetProperty("maxStorageGb").GetInt32(),
                    MaxInvoicesMonth = l.GetProperty("maxInvoicesMonth").GetInt32(),
                    UsersOver = s.GetProperty("usersOverLimit").GetBoolean(),
                    StorageOver = s.GetProperty("storageOverLimit").GetBoolean(),
                    InvoicesOver = s.GetProperty("invoicesOverLimit").GetBoolean()
                });
            }
            quotaData = list;
        }
        catch (Exception ex) { formMesaj = $"Quota hatasi: {ex.Message}"; formMesajTip = "alert-err"; }
    }
