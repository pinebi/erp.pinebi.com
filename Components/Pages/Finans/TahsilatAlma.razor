@page "/finans/tahsilat"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@inject IDbContextFactory<MACHINEBISS_Web.Db.NetworkContext> NetworkFactory
@inject MACHINEBISS_Web.Services.AuthService Auth
@using Microsoft.EntityFrameworkCore
@using MACHINEBISS_Web.Models.MachineBiss
@using MACHINEBISS_Web.Models.BlockBiss

<PageTitle>Tahsilat Alma</PageTitle>

<div class="card" @onkeydown="KlavyeKisayol" tabindex="0" style="outline:none;">
    <div class="card-header">
        <i class="fa fa-money-bill-wave"></i> Tahsilat Alma
    </div>
    <div class="card-body">

        <!-- FORM - Two Column Layout -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 24px; margin-bottom:12px; padding:10px; border:1px solid var(--pinebi-border); border-radius:4px; background:#fafbfc;">

            <!-- LEFT COLUMN -->
            <div style="display:flex; flex-direction:column; gap:6px;">
                <div class="form-inline">
                    <label style="min-width:90px; font-weight:700;">Fis No</label>
                    <input type="text" class="form-control" @bind="fisNo" readonly style="flex:1; background:#f0f0f0;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">Tarih</label>
                    <input type="date" class="form-control" @bind="tarih" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px; font-weight:700;">C/H Kodu</label>
                    <input type="text" class="form-control" @bind="cariKodu" style="flex:1;" />
                    <button class="btn btn-sm btn-outline" @onclick="CariSecAc" style="padding:2px 6px;" title="Cari Sec">
                        <i class="fa fa-search"></i>
                    </button>
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">C/H Ismi</label>
                    <input type="text" class="form-control" value="@cariUnvan" readonly style="flex:1; background:#f0f0f0;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">Doviz</label>
                    <select class="form-control" @bind="doviz" style="max-width:80px;">
                        <option>TL</option>
                        <option>USD</option>
                        <option>EUR</option>
                    </select>
                    <label style="margin-left:8px; min-width:30px;">Kur</label>
                    <input type="number" class="form-control" @bind="kur" step="0.0001" style="max-width:100px; font-weight:700;" />
                </div>
            </div>

            <!-- RIGHT COLUMN -->
            <div style="display:flex; flex-direction:column; gap:6px;">
                <div class="form-inline">
                    <label style="min-width:100px; font-weight:700;">Tahsilat Tipi</label>
                    <select class="form-control" @bind="tahsilatTipiId" @bind:after="TahsilatTipiDegisti" style="flex:1;">
                        <option value="1">Nakit</option>
                        <option value="2">Havale/EFT</option>
                        <option value="3">Kredi Karti</option>
                        <option value="4">Cek</option>
                        <option value="5">Senet</option>
                    </select>
                </div>
                <div class="form-inline">
                    @if (tahsilatTipiId == 1)
                    {
                        <label style="min-width:100px;">Kasa</label>
                        <select class="form-control" @bind="kasaId" style="flex:1;">
                            <option value="0">-- Kasa Sec --</option>
                            @foreach (var k in kasaHesaplari)
                            {
                                <option value="@k.Id">@k.Kodu - @k.Adi</option>
                            }
                        </select>
                    }
                    else if (tahsilatTipiId == 2 || tahsilatTipiId == 3)
                    {
                        <label style="min-width:100px;">Banka</label>
                        <select class="form-control" @bind="bankaId" style="flex:1;">
                            <option value="0">-- Banka Sec --</option>
                            @foreach (var b in bankaHesaplari)
                            {
                                <option value="@b.Id">@b.Kodu - @b.Adi</option>
                            }
                        </select>
                    }
                    else
                    {
                        <label style="min-width:100px;">Hesap</label>
                        <input type="text" class="form-control" value="Cek/Senet" readonly style="flex:1; background:#f0f0f0;" />
                    }
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Belge No</label>
                    <input type="text" class="form-control" @bind="belgeNo" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Aciklama 1</label>
                    <input type="text" class="form-control" @bind="aciklama1" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Aciklama 2</label>
                    <input type="text" class="form-control" @bind="aciklama2" style="flex:1;" />
                </div>
            </div>
        </div>

        <!-- CONDITIONAL: Cek/Senet Fields -->
        @if (tahsilatTipiId == 4 || tahsilatTipiId == 5)
        {
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:12px; padding:10px; border:1px solid #e0a030; border-radius:4px; background:#fffcf0;">
                <div class="form-inline">
                    <label style="min-width:80px; font-weight:600;"><i class="fa fa-calendar"></i> Vade Tarihi</label>
                    <input type="date" class="form-control" @bind="vadeTarihi" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:60px; font-weight:600;">Banka</label>
                    <input type="text" class="form-control" @bind="cekBanka" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:60px; font-weight:600;">Seri No</label>
                    <input type="text" class="form-control" @bind="seriNo" style="flex:1;" />
                </div>
            </div>
        }

        <!-- ACIK FATURALAR GRID -->
        <div style="margin-bottom:12px;">
            <div style="background:#235881; color:white; padding:6px 10px; font-weight:600; font-size:12px; border-radius:4px 4px 0 0;">
                <i class="fa fa-file-invoice"></i> Acik Faturalar
                @if (cariId > 0)
                {
                    <span style="font-weight:400; font-size:11px; margin-left:8px;">(@cariUnvan)</span>
                }
            </div>
            <div class="grid-container" style="max-height:280px; overflow:auto;">
                <table class="data-grid">
                    <thead>
                        <tr>
                            <th style="width:40px; text-align:center;">Sec</th>
                            <th style="width:130px;">Fatura No</th>
                            <th style="width:100px;">Tarih</th>
                            <th style="width:110px; text-align:right;">Tutar</th>
                            <th style="width:110px; text-align:right;">Odenen</th>
                            <th style="width:110px; text-align:right;">Kalan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (acikFaturalar.Any())
                        {
                            @foreach (var f in acikFaturalar)
                            {
                                <tr>
                                    <td style="text-align:center;">
                                        <input type="checkbox" @bind="f.Secili" @bind:after="FaturaSecimDegisti" />
                                    </td>
                                    <td>@f.FaturaNo</td>
                                    <td>@f.Tarih.ToString("dd.MM.yyyy")</td>
                                    <td style="text-align:right;">@f.Tutar.ToString("N2")</td>
                                    <td style="text-align:right;">@f.Odenen.ToString("N2")</td>
                                    <td style="text-align:right; font-weight:700;">@f.Kalan.ToString("N2")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted" style="padding:20px;">
                                    @if (cariId == 0)
                                    {
                                        <span>Cari hesap secin</span>
                                    }
                                    else
                                    {
                                        <span>Acik fatura bulunamadi</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (acikFaturalar.Any())
                    {
                        <tfoot>
                            <tr style="background:#235881; color:white; font-weight:700;">
                                <td colspan="5" style="text-align:right; padding:6px 8px;">Secilen Toplam:</td>
                                <td style="text-align:right; padding:6px 8px;">@acikFaturalar.Where(f => f.Secili).Sum(f => f.Kalan).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        <!-- SUMMARY & BUTTONS -->
        <div style="border:1px solid var(--pinebi-border); border-radius:4px; padding:12px; background:#fafbfc;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                <label style="font-weight:700; font-size:14px; min-width:60px;">Tutar</label>
                <input type="number" class="form-control" @bind="tutar" step="0.01"
                       style="max-width:200px; font-size:16px; font-weight:700; text-align:right; border:2px solid #235881;" />
                <span style="font-size:13px; color:#666;">@doviz</span>
            </div>
            <div style="border-top:1px solid var(--pinebi-border); padding-top:10px; display:flex; gap:8px; align-items:center;">
                <button class="btn btn-success" @onclick="Kaydet" style="min-width:140px;">
                    <i class="fa fa-save"></i> [F2] Kaydet
                </button>
                <button class="btn btn-outline" @onclick="Kapat" style="min-width:100px;">
                    <i class="fa fa-times"></i> [Esc] Kapat
                </button>
                <button class="btn btn-outline" @onclick="Temizle" style="margin-left:auto;">
                    <i class="fa fa-eraser"></i> Temizle
                </button>
            </div>
        </div>

        <!-- MESAJ -->
        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div style="margin-top:10px; padding:8px 12px; border-radius:4px;
                        background:@(mesajTipi == "success" ? "#dcfce7" : "#fee2e2");
                        color:@(mesajTipi == "success" ? "#166534" : "#991b1b");
                        border:1px solid @(mesajTipi == "success" ? "#86efac" : "#fca5a5");">
                <i class="fa @(mesajTipi == "success" ? "fa-check-circle" : "fa-exclamation-triangle")"></i> @mesaj
            </div>
        }
    </div>
</div>

<!-- CARI SECME POPUP -->
@if (cariSecmeAcik)
{
    <div class="modal-overlay" @onclick="CariSecKapat">
        <div class="modal-box" style="width:800px; max-height:80vh;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><i class="fa fa-address-book"></i> Cari Sec</span>
                <button class="modal-close" @onclick="CariSecKapat">X</button>
            </div>
            <div class="modal-body">
                <div class="form-inline mb-2">
                    <label>Ara:</label>
                    <input type="text" class="form-control" placeholder="Cari kodu, unvan, vergi no ile ara..." @bind="cariAramaText" @bind:event="oninput" @bind:after="CariAra" style="flex:1;" />
                </div>
                <div class="grid-container" style="max-height:400px;">
                    <table class="data-grid">
                        <thead>
                            <tr>
                                <th style="width:80px;">Cari Kodu</th>
                                <th style="min-width:200px;">Unvan</th>
                                <th>Yetkili</th>
                                <th>Telefon</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (cariListesi.Any())
                            {
                                @foreach (var c in cariListesi)
                                {
                                    <tr style="cursor:pointer;" @onclick="() => CariSecildi(c)">
                                        <td>@c.CariKodu</td>
                                        <td><strong>@c.Unvani</strong></td>
                                        <td>@c.Yetkili1</td>
                                        <td>@c.Telefon1</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted">@(string.IsNullOrEmpty(cariHataMesaji) ? "Yukleniyor..." : cariHataMesaji)</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Form fields
    private string fisNo = "";
    private DateTime tarih = DateTime.Today;
    private string cariKodu = "";
    private string cariUnvan = "";
    private int cariId = 0;
    private string doviz = "TL";
    private decimal kur = 1;
    private int tahsilatTipiId = 1;
    private int kasaId = 0;
    private int bankaId = 0;
    private string belgeNo = "";
    private string aciklama1 = "";
    private string aciklama2 = "";
    private decimal tutar = 0;

    // Cek/Senet fields
    private DateTime vadeTarihi = DateTime.Today.AddDays(30);
    private string cekBanka = "";
    private string seriNo = "";

    // UI state
    private string mesaj = "";
    private string mesajTipi = "success";
    private bool kaydetAktif = false;

    // Cari secme
    private bool cariSecmeAcik = false;
    private string cariAramaText = "";
    private string cariHataMesaji = "";
    private List<Cariler> cariListesi = new();

    // Hesap listeleri
    private List<HesapItem> kasaHesaplari = new();
    private List<HesapItem> bankaHesaplari = new();

    // Acik faturalar
    private List<AcikFaturaItem> acikFaturalar = new();

    protected override async Task OnInitializedAsync()
    {
        fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();

            // Kasa hesaplarini yukle (Isyerleri tablosundan)
            var isyerleri = await db.Isyerleri.AsNoTracking().ToListAsync();
            kasaHesaplari = isyerleri.Select(x => new HesapItem { Id = x.Id, Kodu = x.IsyeriNo ?? "", Adi = x.IsyeriAdi ?? "" }).ToList();
            if (!kasaHesaplari.Any())
            {
                kasaHesaplari.Add(new HesapItem { Id = 1, Kodu = "KASA-01", Adi = "Ana Kasa TL" });
            }

            // Banka hesaplarini yukle (SirketBankaBilgileri - NetworkContext)
            using var ndb = await NetworkFactory.CreateDbContextAsync();
            var bankalar = await ndb.SirketBankaBilgileri.AsNoTracking().ToListAsync();
            bankaHesaplari = bankalar.Select(x => new HesapItem { Id = x.Id, Kodu = x.Id.ToString(), Adi = x.Banka ?? "" }).ToList();
            if (!bankaHesaplari.Any())
            {
                bankaHesaplari.Add(new HesapItem { Id = 1, Kodu = "BNK-01", Adi = "Banka Hesabi" });
            }
        }
        catch
        {
            kasaHesaplari.Add(new HesapItem { Id = 1, Kodu = "KASA-01", Adi = "Ana Kasa TL" });
            bankaHesaplari.Add(new HesapItem { Id = 1, Kodu = "BNK-01", Adi = "Banka Hesabi" });
        }
    }

    private void TahsilatTipiDegisti()
    {
        // Reset hesap secimi when type changes
        kasaId = 0;
        bankaId = 0;
    }

    private void FaturaSecimDegisti()
    {
        tutar = acikFaturalar.Where(f => f.Secili).Sum(f => f.Kalan);
    }

    // =================== CARI SECME ===================

    private async Task CariSecAc()
    {
        cariAramaText = "";
        cariHataMesaji = "";
        cariSecmeAcik = true;
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            cariListesi = await db.Cariler.AsNoTracking().OrderBy(c => c.CariKodu).Take(50).ToListAsync();
            cariHataMesaji = cariListesi.Any() ? "" : "Cari bulunamadi";
        }
        catch (Exception ex)
        {
            cariHataMesaji = $"HATA: {ex.Message}";
            cariListesi = new();
        }
    }

    private void CariSecKapat() => cariSecmeAcik = false;

    private async Task CariAra()
    {
        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();
            if (string.IsNullOrWhiteSpace(cariAramaText))
            {
                cariListesi = await db.Cariler.AsNoTracking().OrderBy(c => c.CariKodu).Take(50).ToListAsync();
            }
            else
            {
                var q = cariAramaText.Trim();
                cariListesi = await db.Cariler.AsNoTracking()
                    .Where(c => c.CariKodu.Contains(q) || c.Unvani.Contains(q) || c.Vn.Contains(q))
                    .Take(50)
                    .ToListAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"CariAra HATA: {ex.Message}");
        }
    }

    private async Task CariSecildi(Cariler c)
    {
        cariKodu = c.CariKodu ?? "";
        cariUnvan = c.Unvani ?? "";
        cariId = c.Id;
        cariSecmeAcik = false;

        // Acik faturalari yukle
        await AcikFaturalariYukle();
    }

    private async Task AcikFaturalariYukle()
    {
        acikFaturalar = new();
        if (cariId == 0) return;

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();

            // Satis faturalari (TrCode 2=Satis, 3=Satis Iade) iptal olmayan
            var faturalar = await db.FaturalarView.AsNoTracking()
                .Where(f => f.CariId == cariId && (f.TrCode == 2 || f.TrCode == 3) && f.Iptal != true)
                .OrderByDescending(f => f.Tarih)
                .ToListAsync();

            foreach (var f in faturalar)
            {
                var toplamTutar = f.OdenecekTutar ?? f.ToplamTutar ?? 0;

                // Odenmis tutari hesapla
                var odenen = await db.FaturaTahsilatOdeme.AsNoTracking()
                    .Where(t => t.FaturaId == f.Id && t.Iptal != true)
                    .SumAsync(t => (double?)t.IslemTutari) ?? 0;

                var kalan = (decimal)((double)toplamTutar - odenen);
                if (kalan <= 0) continue; // Tamamen odenmis faturalari gosterme

                acikFaturalar.Add(new AcikFaturaItem
                {
                    Id = f.Id,
                    FaturaNo = f.FisNo ?? "",
                    Tarih = f.Tarih,
                    Tutar = toplamTutar,
                    Odenen = (decimal)odenen,
                    Kalan = kalan,
                    Secili = false
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AcikFaturalariYukle HATA: {ex.Message}");
        }
    }

    // =================== KAYDET ===================

    private async Task Kaydet()
    {
        mesaj = "";

        // Validation
        if (cariId == 0)
        {
            mesaj = "Lutfen bir cari hesap secin!";
            mesajTipi = "error";
            return;
        }
        if (tutar <= 0)
        {
            mesaj = "Tutar sifirdan buyuk olmalidir!";
            mesajTipi = "error";
            return;
        }
        if (tahsilatTipiId == 1 && kasaId == 0)
        {
            mesaj = "Lutfen bir kasa secin!";
            mesajTipi = "error";
            return;
        }
        if ((tahsilatTipiId == 2 || tahsilatTipiId == 3) && bankaId == 0)
        {
            mesaj = "Lutfen bir banka hesabi secin!";
            mesajTipi = "error";
            return;
        }

        try
        {
            using var db = await FirmaFactory.CreateDbContextAsync();

            fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");

            // 1. CariHareketler - Alacak hareketi (IslemId=2 = Alacak)
            db.CariHareketler.Add(new MACHINEBISS_Web.Models.MachineBiss.CariHareketler
            {
                FisNo = fisNo,
                Tarih = tarih,
                CariId = cariId,
                IslemId = 2,
                OdemeId = tahsilatTipiId,
                Tutar = tutar,
                DovizId = doviz,
                Aciklama1 = aciklama1,
                Aciklama2 = aciklama2,
                Iptal = false,
                Kaynak = "Tahsilat"
            });

            // 2. Based on type: Kasa or Banka or CekSenet
            if (tahsilatTipiId == 1) // Nakit -> Kasa
            {
                db.KasaHareketleri.Add(new MACHINEBISS_Web.Models.MachineBiss.KasaHareketleri
                {
                    Tarih = tarih,
                    FisNo = fisNo,
                    KasaId = kasaId,
                    IslemId = 1, // Giris
                    Tutar = tutar,
                    DovizId = doviz,
                    Iptal = false,
                    Aciklama1 = aciklama1,
                    Aciklama2 = aciklama2
                });
            }
            else if (tahsilatTipiId == 2 || tahsilatTipiId == 3) // Havale/KK -> Banka
            {
                db.BankaHareketleri.Add(new MACHINEBISS_Web.Models.MachineBiss.BankaHareketleri
                {
                    Tarih = tarih,
                    FisNo = fisNo,
                    BankaId = bankaId,
                    CariId = cariId,
                    IslemId = 1, // Giris
                    Tutar = tutar,
                    DovizId = doviz,
                    Iptal = false,
                    Aciklama1 = aciklama1,
                    Aciklama2 = aciklama2
                });
            }
            else // Cek/Senet
            {
                db.CekSenetHareketleri.Add(new MACHINEBISS_Web.Models.MachineBiss.CekSenetHareketleri
                {
                    Tarih = tarih,
                    VadeTarihi = vadeTarihi,
                    Tip = "A", // Alinan
                    Cs = tahsilatTipiId == 4 ? "C" : "S",
                    FisNo = fisNo,
                    CariId = cariId,
                    Banka = cekBanka,
                    SeriNo = seriNo,
                    Tutar = tutar,
                    DovizId = doviz,
                    Durumu = "Portfoyde",
                    Iptal = false,
                    IslemId = 1,
                    Aciklama1 = aciklama1,
                    Aciklama2 = aciklama2
                });
            }

            // 3. FaturaTahsilatOdeme for selected invoices
            var secilenFaturalar = acikFaturalar.Where(f => f.Secili).ToList();
            foreach (var fatura in secilenFaturalar)
            {
                db.FaturaTahsilatOdeme.Add(new MACHINEBISS_Web.Models.MachineBiss.FaturaTahsilatOdeme
                {
                    Tarih = DateTime.Now,
                    FaturaId = fatura.Id,
                    IslemId = tahsilatTipiId,
                    FaturaTutari = (double)fatura.Kalan,
                    IslemTutari = (double)tutar,
                    Personel = Auth.ErpKullaniciAdi,
                    Iptal = false
                });
            }

            await db.SaveChangesAsync();

            mesaj = $"Tahsilat basariyla kaydedildi! Fis No: {fisNo}";
            mesajTipi = "success";

            // Reset for new entry
            fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");
            tutar = 0;
            belgeNo = "";
            aciklama1 = "";
            aciklama2 = "";
            cekBanka = "";
            seriNo = "";

            // Faturalari yenile
            await AcikFaturalariYukle();
        }
        catch (Exception ex)
        {
            mesaj = $"Kayit hatasi: {ex.Message}";
            mesajTipi = "error";
        }
    }

    private void Kapat()
    {
        Nav.NavigateTo("/");
    }

    private void Temizle()
    {
        fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");
        cariKodu = "";
        cariUnvan = "";
        cariId = 0;
        doviz = "TL";
        kur = 1;
        tahsilatTipiId = 1;
        kasaId = 0;
        bankaId = 0;
        belgeNo = "";
