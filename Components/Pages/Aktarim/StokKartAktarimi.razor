@page "/aktarim/stokkart"
@inject NavigationManager Nav

<PageTitle>Stok Kart Aktarimi</PageTitle>

<div class="card">
    <div class="card-header"><i class="fa fa-file-import"></i> Stok Kart Aktarimi</div>
    <div class="card-body">
        <div class="toolbar">
            <button class="btn btn-success btn-sm"><i class="fa fa-upload"></i> Dosya Sec</button>
            <button class="btn btn-primary btn-sm"><i class="fa fa-play"></i> Aktarimi Baslat</button>
            <button class="btn btn-outline btn-sm"><i class="fa fa-download"></i> Ornek Sablon Indir</button>
        </div>
        <div class="alert alert-info">
            <i class="fa fa-info-circle"></i> Excel dosyanizi secin ve Aktarimi Baslat butonuna basin.
        </div>
        <div class="grid-container" style="max-height:400px;">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Stok Kodu</th>
                        <th>Stok Adi</th>
                        <th>Birim</th>
                        <th>KDV Orani</th>
                        <th>Alis Fiyati</th>
                        <th>Satis Fiyati</th>
                        <th>Barkod</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="8" class="text-center text-muted">Dosya secilmedi</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
