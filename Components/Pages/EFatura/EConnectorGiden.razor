@page "/efatura/giden"
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Giden E-Faturalar</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-paper-plane"></i> Giden E-Faturalar
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-outline btn-sm" @onclick="FaturaGoster">
                <i class="fa fa-eye"></i> Fatura Goster
            </button>
            <button class="btn btn-outline btn-sm" @onclick="TekrarGondermekIcinEkle">
                <i class="fa fa-list-alt"></i> Tekrar Gondermek Icin Listeye Ekle
            </button>
            <button class="btn btn-danger btn-sm" @onclick="FaturaIptalEt">
                <i class="fa fa-ban"></i> Fatura Iptal Et
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="FaturaLinkiKopyala">
                <i class="fa fa-link"></i> Fatura Linki Kopyala
            </button>
            <button class="btn btn-outline btn-sm" @onclick="TumunuSec">
                <i class="fa fa-check-square-o"></i> Tumunu Sec
            </button>
            <button class="btn btn-outline btn-sm" @onclick="SecimleriTemizle">
                <i class="fa fa-square-o"></i> Secimleri Temizle
            </button>
            <button class="btn btn-outline btn-sm" @onclick="FaturaIndir">
                <i class="fa fa-download"></i> Fatura Indir
            </button>
        </div>

        <!-- Filtre Alani -->
        <div class="form-row" style="margin-bottom:10px; margin-top:10px;">
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarihi" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarihi" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Yenile">
                <i class="fa fa-refresh"></i> [F5] Yenile
            </button>
            <div class="form-check" style="margin-left:10px;">
                <input type="checkbox" @bind="basarisizGosterilsin" @bind:after="DurumDegisti" />
                <label>Basarisiz Gonderiler</label>
            </div>
            <button class="btn btn-outline btn-sm" style="margin-left:10px;" @onclick="DurumGuncelle">
                <i class="fa fa-sync"></i> Durum Guncelle
            </button>
            <button class="btn btn-outline btn-sm" @onclick="GibHataKodlari">
                <i class="fa fa-exclamation-triangle"></i> GIB Hata Kodlari
            </button>
            <span style="margin-left:auto;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> [F4] Yazdir
            </button>
        </div>

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 300px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:40px;">Sec</th>
                        <th style="width:130px;">Fatura No</th>
                        <th style="width:280px;">Fatura ETTN</th>
                        <th style="width:130px;">Olusturma Tarihi</th>
                        <th style="width:90px;">Fatura Tarihi</th>
                        <th style="min-width:200px;">Cari Unvani</th>
                        <th style="width:100px;">Vergi No</th>
                        <th style="width:200px;">Gonderi Durum Aciklama</th>
                        <th style="width:200px;">Onay/Red Durumu</th>
                        <th style="width:200px;">Zarf Durum Aciklama</th>
                    </tr>
                </thead>
                <tbody>
                    @if (gidenFaturalar.Count == 0)
                    {
                        <tr><td colspan="10" class="text-center text-muted">Kayit bulunamadi</td></tr>
                    }
                    else
                    {
                        @foreach (var fatura in gidenFaturalar)
                        {
                            <tr class="@(seciliId == fatura.Id ? "selected" : "")" @onclick="() => seciliId = fatura.Id">
                                <td style="text-align:center;">
                                    <input type="checkbox" @bind="fatura.Secili" />
                                </td>
                                <td>@fatura.FaturaNo</td>
                                <td style="font-size:11px;">@fatura.FaturaETTN</td>
                                <td>@fatura.OlusturmaTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@fatura.FaturaTarihi?.ToString("dd.MM.yyyy")</td>
                                <td>@fatura.CariUnvani</td>
                                <td>@fatura.VergiNo</td>
                                <td>
                                    @if (fatura.GonderiDurumu == "0")
                                    {
                                        <span style="background:#16a34a; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.GonderiDurumAciklama</span>
                                    }
                                    else if (fatura.GonderiDurumu == "-1")
                                    {
                                        <span style="background:#dc2626; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.GonderiDurumAciklama</span>
                                    }
                                    else
                                    {
                                        @fatura.GonderiDurumAciklama
                                    }
                                </td>
                                <td>
                                    @{
                                        var bgOnay = fatura.InvoiceStatus switch
                                        {
                                            "3" or "5" => "background:#16a34a; color:white;",
                                            "2" => "background:#eab308; color:black;",
                                            "4" or "10" => "background:#f97316; color:black;",
                                            "1" or "6" or "7" or "8" or "9" => "background:#ef4444; color:white;",
                                            _ => ""
                                        };
                                    }
                                    @if (!string.IsNullOrEmpty(bgOnay))
                                    {
                                        <span style="@bgOnay padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.OnayRedDurumu</span>
                                    }
                                    else
                                    {
                                        @fatura.OnayRedDurumu
                                    }
                                </td>
                                <td>
                                    @{
                                        var bgZarf = fatura.ZarfDurumu switch
                                        {
                                            "0" => "background:#eab308; color:black;",
                                            "1" or "3" or "4" => "background:#dc2626; color:white;",
                                            "2" or "34" => "background:#86efac; color:black;",
                                            "5" or "39" => "background:#16a34a; color:white;",
                                            _ => ""
                                        };
                                    }
                                    @if (!string.IsNullOrEmpty(bgZarf))
                                    {
                                        <span style="@bgZarf padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.ZarfDurumAciklama</span>
                                    }
                                    else
                                    {
                                        @fatura.ZarfDurumAciklama
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Kayit Sayisi -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
            <span class="text-muted">Toplam @gidenFaturalar.Count kayit | @gidenFaturalar.Count(f => f.Secili) secili</span>
            @if (isDurumGuncelleniyor)
            {
                <span style="color:#800000; font-weight:bold;"><i class="fa fa-spinner fa-spin"></i> Fatura durum bilgileri guncelleniyor...</span>
            }
        </div>
    </div>
</div>

