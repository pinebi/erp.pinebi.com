@page "/efatura/gelenfaturalar"
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Gelen Faturalar</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-file-text-o"></i> Gelen Faturalar
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="OnayVer">
                <i class="fa fa-check"></i> Onay
            </button>
            <button class="btn btn-danger btn-sm" @onclick="RedVer">
                <i class="fa fa-times"></i> Red
            </button>
            <button class="btn btn-outline btn-sm" @onclick="FaturaGoster">
                <i class="fa fa-eye"></i> Fatura Goster
            </button>
            <button class="btn btn-primary btn-sm" @onclick="SatinalmaFaturasi">
                <i class="fa fa-file-invoice"></i> Satinalma Faturasi Olustur
            </button>
            <div style="position:relative; display:inline-block;">
                <button class="btn btn-outline btn-sm" @onclick="() => ozelAktarimMenuAcik = !ozelAktarimMenuAcik">
                    <i class="fa fa-cog"></i> Ozel Fatura Aktarimi <i class="fa fa-caret-down"></i>
                </button>
                @if (ozelAktarimMenuAcik)
                {
                    <div style="position:absolute; top:100%; left:0; z-index:100; background:white; border:1px solid #ddd; border-radius:4px; box-shadow:0 2px 8px rgba(0,0,0,0.15); min-width:140px;">
                        <button class="btn btn-sm" style="display:block; width:100%; text-align:left; border:none; padding:6px 12px;" @onclick="OzelAktarimElektrik">Elektrik</button>
                        <button class="btn btn-sm" style="display:block; width:100%; text-align:left; border:none; padding:6px 12px;" @onclick="OzelAktarimDogalgaz">Dogalgaz</button>
                        <button class="btn btn-sm" style="display:block; width:100%; text-align:left; border:none; padding:6px 12px;" @onclick="OzelAktarimSu">Su</button>
                        <button class="btn btn-sm" style="display:block; width:100%; text-align:left; border:none; padding:6px 12px;" @onclick="OzelAktarimTelefon">Telefon</button>
                        <button class="btn btn-sm" style="display:block; width:100%; text-align:left; border:none; padding:6px 12px;" @onclick="OzelAktarimInternet">Internet</button>
                    </div>
                }
            </div>
            <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="TumunuSec">
                <i class="fa fa-check-square-o"></i> Tumunu Sec
            </button>
            <button class="btn btn-outline btn-sm" @onclick="SecimleriTemizle">
                <i class="fa fa-square-o"></i> Secimleri Temizle
            </button>
            <button class="btn btn-outline btn-sm" @onclick="FaturaIndir">
                <i class="fa fa-download"></i> Fatura Indir
            </button>
        </div>

        <!-- Filtre Alani -->
        <div class="form-row" style="margin-bottom:10px; margin-top:10px;">
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarihi" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarihi" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Yenile">
                <i class="fa fa-refresh"></i> [F5] Yenile
            </button>
            <!-- Fatura Turu Filtresi -->
            <div class="form-inline" style="margin-left:20px;">
                <label class="form-check" style="margin-right:10px;">
                    <input type="radio" name="faturaTuru" checked="@isTumu" @onchange="FiltreTumu" />
                    Tumu
                </label>
                <label class="form-check" style="margin-right:10px;">
                    <input type="radio" name="faturaTuru" checked="@isTicari" @onchange="FiltreTicari" />
                    Ticari Faturalar
                </label>
                <label class="form-check">
                    <input type="radio" name="faturaTuru" checked="@isTemel" @onchange="FiltreTemel" />
                    Temel Faturalar (Onay ve Reddedilemez)
                </label>
            </div>
            <span style="margin-left:auto;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> [F4] Yazdir
            </button>
        </div>

        <!-- Split Layout: Faturalar (left) + Detay (right) -->
        <div style="display:flex; gap:10px;">
            <!-- Faturalar Grid -->
            <div style="flex:1.4; min-width:0;">
                <div class="grid-container" style="max-height:calc(100vh - 320px);">
                    <table class="data-grid">
                        <thead>
                            <tr>
                                <th style="width:40px;">Sec</th>
                                <th style="width:100px;">Fatura Turu</th>
                                <th style="width:80px;">Fatura Tipi</th>
                                <th style="width:90px;">Tarih</th>
                                <th style="width:130px;">Fatura No</th>
                                <th style="min-width:200px;">Tedarikci</th>
                                <th style="width:120px;">Vergi Dairesi</th>
                                <th style="width:100px;">Vergi No</th>
                                <th style="width:100px; text-align:right;">KDV Matrahi</th>
                                <th style="width:100px; text-align:right;">KDV Tutari</th>
                                <th style="width:110px; text-align:right;">Toplam Tutar</th>
                                <th style="width:120px;">Durumu</th>
                                <th style="width:120px;">Kayit Durumu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filtreliFaturalar.Count == 0)
                            {
                                <tr><td colspan="13" class="text-center text-muted">Kayit bulunamadi</td></tr>
                            }
                            else
                            {
                                @foreach (var fatura in filtreliFaturalar)
                                {
                                    <tr class="@(seciliId == fatura.Id ? "selected" : "")" @onclick="() => SatirSec(fatura)">
                                        <td style="text-align:center;">
                                            <input type="checkbox" @bind="fatura.Secili" />
                                        </td>
                                        <td>@fatura.FaturaTuru</td>
                                        <td>@fatura.FaturaTipi</td>
                                        <td>@fatura.Tarih?.ToString("dd.MM.yyyy")</td>
                                        <td>@fatura.FaturaNo</td>
                                        <td>@fatura.Tedarikci</td>
                                        <td>@fatura.VergiDairesi</td>
                                        <td>@fatura.VergiNo</td>
                                        <td class="text-right">@fatura.KdvMatrahi.ToString("N2")</td>
                                        <td class="text-right">@fatura.KdvTutari.ToString("N2")</td>
                                        <td class="text-right" style="font-weight:700;">@fatura.ToplamTutar.ToString("N2")</td>
                                        <td>
                                            @if (fatura.Durumu == "Onaylandi")
                                            {
                                                <span style="background:#16a34a; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.Durumu</span>
                                            }
                                            else if (fatura.Durumu == "Reddedildi")
                                            {
                                                <span style="background:#dc2626; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.Durumu</span>
                                            }
                                            else
                                            {
                                                <span style="background:#eab308; color:black; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.Durumu</span>
                                            }
                                        </td>
                                        <td>
                                            @if (fatura.KayitDurumu == "Aktarildi")
                                            {
                                                <span style="background:#16a34a; color:white; padding:2px 8px; border-radius:3px; font-size:11px;">@fatura.KayitDurumu</span>
                                            }
                                            else
                                            {
                                                @fatura.KayitDurumu
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background:var(--pinebi-primary); color:white; font-weight:700;">
                                <td colspan="8" class="text-right">Toplam:</td>
                                <td class="text-right">@filtreliFaturalar.Sum(f => f.KdvMatrahi).ToString("N2")</td>
                                <td class="text-right">@filtreliFaturalar.Sum(f => f.KdvTutari).ToString("N2")</td>
                                <td class="text-right">@filtreliFaturalar.Sum(f => f.ToplamTutar).ToString("N2")</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Detay Panel: Satirlar + Fatura Onizleme -->
            <div style="flex:0.6; min-width:0; display:flex; flex-direction:column; gap:10px;">
                <!-- Satirlar Grid -->
                <div class="group-box" style="flex:1;">
                    <div class="group-box-title">Fatura Satirlari</div>
                    <div class="grid-container" style="max-height:200px;">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="width:100px;">Malzeme Kodu</th>
                                    <th style="min-width:150px;">Malzeme Adi</th>
                                    <th style="width:70px; text-align:right;">Miktar</th>
                                    <th style="width:60px;">Birim</th>
                                    <th style="width:80px; text-align:right;">Fiyat</th>
                                    <th style="width:50px;">KDV%</th>
                                    <th style="width:90px; text-align:right;">Mal/Hizmet Tutari</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (satirlar.Count == 0)
                                {
                                    <tr><td colspan="7" class="text-center text-muted">Fatura seciniz</td></tr>
                                }
                                else
                                {
                                    @foreach (var satir in satirlar)
                                    {
                                        <tr>
                                            <td>@satir.MalzemeKodu</td>
                                            <td>@satir.MalzemeAdi</td>
                                            <td class="text-right">@satir.Miktar.ToString("N2")</td>
                                            <td>@satir.BirimKodu</td>
                                            <td class="text-right">@satir.Fiyat.ToString("N4")</td>
                                            <td>@satir.KdvOrani</td>
                                            <td class="text-right">@satir.MalHizmetTutari.ToString("N2")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Fatura Onizleme -->
                <div class="group-box" style="flex:1;">
                    <div class="group-box-title">Fatura Onizleme</div>
                    <div style="height:200px; background:#f8f9fa; border:1px solid #ddd; border-radius:4px; display:flex; align-items:center; justify-content:center; color:#999;">
                        @if (!string.IsNullOrEmpty(seciliFaturaUrl))
                        {
                            <iframe src="@seciliFaturaUrl" style="width:100%; height:100%; border:none;"></iframe>
                        }
                        else
                        {
                            <span><i class="fa fa-file-pdf-o fa-2x"></i><br/>Fatura onizlemesi icin fatura seciniz</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Kayit Sayisi -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
            <span class="text-muted">Toplam @filtreliFaturalar.Count kayit | @filtreliFaturalar.Count(f => f.Secili) secili</span>
        </div>
    </div>
</div>

@code {
    private DateTime baslangicTarihi = DateTime.Today.AddDays(-30);
    private DateTime bitisTarihi = DateTime.Today;
    private string faturaTuruFiltre = "Tumu";
    private int seciliId = 0;
    private string seciliFaturaUrl = "";
    private bool ozelAktarimMenuAcik = false;

    private List<GelenFaturaDetayItem> faturalar = new();
    private bool isTumu => faturaTuruFiltre == "Tumu";
    private bool isTicari => faturaTuruFiltre == "Ticari";
    private bool isTemel => faturaTuruFiltre == "Temel";

    private List<GelenFaturaDetayItem> filtreliFaturalar => faturaTuruFiltre switch
    {
        "Ticari" => faturalar.Where(f => f.FaturaTuru == "Ticari Fatura").ToList(),
        "Temel" => faturalar.Where(f => f.FaturaTuru == "Temel Fatura").ToList(),
        _ => faturalar
    };
    private List<GelenFaturaSatirItem> satirlar = new();

    protected override void OnInitialized()
    {
        GelenFaturalariListele();
    }

    private void GelenFaturalariListele()
    {
        // TODO: FirmaContext ile gelen faturalari listele
        // db.GelenFaturalarView.OrderByDescending(s => s.Tarih)
        //     .Where(s => s.FaturaTarihi >= baslangicTarihi && s.FaturaTarihi <= bitisTarihi).ToList();
        faturalar = GetPlaceholderData();
        satirlar.Clear();
        seciliFaturaUrl = "";
    }

    private void SatirSec(GelenFaturaDetayItem fatura)
    {
        seciliId = fatura.Id;
        seciliFaturaUrl = fatura.FatUrl;
        ozelAktarimMenuAcik = false;
        // TODO: Satirlari db'den cek
        // satirlar = db.GelenFaturalarSatirlar.Where(s => s.FatId == fatura.Id).ToList();
        satirlar = GetPlaceholderSatirlar();
    }

    private void FaturaTuruDegisti(string tur)
    {
        faturaTuruFiltre = tur;
    }

    private void FiltreTumu() => FaturaTuruDegisti("Tumu");
    private void FiltreTicari() => FaturaTuruDegisti("Ticari");
    private void FiltreTemel() => FaturaTuruDegisti("Temel");

    private void Yenile()
    {
        GelenFaturalariListele();
    }

    private void OnayVer()
    {
        if (seciliId == 0) return;
        // TODO: Innova API uzerinden onay ver
        // InvoiceApproval(referenceNumber, UUID, InvoiceStatus=1)
    }

    private void RedVer()
    {
        if (seciliId == 0) return;
        // TODO: Innova API uzerinden red ver
        // InvoiceApproval(referenceNumber, UUID, InvoiceStatus=2)
    }

    private void FaturaGoster()
    {
        if (seciliId == 0) return;
        // TODO: Fatura URL ile onizleme goster
    }

    private void SatinalmaFaturasi()
    {
        if (seciliId == 0) return;
        // TODO: Secili gelen faturadan satinalma faturasi olustur
    }

    private void OzelAktarimElektrik() => OzelAktarim("Elektrik");
    private void OzelAktarimDogalgaz() => OzelAktarim("Dogalgaz");
    private void OzelAktarimSu() => OzelAktarim("Su");
    private void OzelAktarimTelefon() => OzelAktarim("Telefon");
    private void OzelAktarimInternet() => OzelAktarim("Internet");

    private void OzelAktarim(string tip)
    {
        ozelAktarimMenuAcik = false;
        if (seciliId == 0) return;
        // TODO: Ozel fatura aktarimi (Elektrik, Dogalgaz, Su, Telefon, Internet)
    }

    private void TumunuSec()
    {
        foreach (var f in filtreliFaturalar) f.Secili = true;
    }

    private void SecimleriTemizle()
    {
        foreach (var f in filtreliFaturalar) f.Secili = false;
    }

    private void FaturaIndir()
    {
        var secili = faturalar.Where(f => f.Secili).ToList();
        if (secili.Count == 0) return;
        // TODO: PDF olarak indir
    }

    private async void Yazdir()
    { await JS.InvokeVoidAsync("window.print");
        // TODO: Yazdir islemi
    }

    private List<GelenFaturaDetayItem> GetPlaceholderData()
    {
        return new List<GelenFaturaDetayItem>
        {
            new() { Id = 1, FaturaTuru = "Ticari Fatura", FaturaTipi = "SATIS", Tarih = DateTime.Today.AddDays(-10), FaturaNo = "GBF2026000001", Tedarikci = "ABC Tedarik A.S.", VergiDairesi = "Adapazari", VergiNo = "1234567890", KdvMatrahi = 15000.00, KdvTutari = 3000.00, ToplamTutar = 18000.00, Durumu = "Onay bekleniyor", KayitDurumu = "" },
            new() { Id = 2, FaturaTuru = "Temel Fatura", FaturaTipi = "SATIS", Tarih = DateTime.Today.AddDays(-7), FaturaNo = "GBF2026000002", Tedarikci = "XYZ Malzeme Ltd.", VergiDairesi = "Mecidiyekoy", VergiNo = "9876543210", KdvMatrahi = 8500.00, KdvTutari = 1700.00, ToplamTutar = 10200.00, Durumu = "Onaylandi", KayitDurumu = "Aktarildi" },
            new() { Id = 3, FaturaTuru = "Ticari Fatura", FaturaTipi = "SATIS", Tarih = DateTime.Today.AddDays(-3), FaturaNo = "GBF2026000003", Tedarikci = "DEF Uretim San.", VergiDairesi = "Kadikoy", VergiNo = "1122334455", KdvMatrahi = 22000.00, KdvTutari = 4400.00, ToplamTutar = 26400.00, Durumu = "Onay bekleniyor", KayitDurumu = "" },
            new() { Id = 4, FaturaTuru = "Ticari Fatura", FaturaTipi = "IADE", Tarih = DateTime.Today.AddDays(-1), FaturaNo = "GBF2026000004", Tedarikci = "GHI Elektrik A.S.", VergiDairesi = "Uskudar", VergiNo = "5566778899", KdvMatrahi = 1200.00, KdvTutari = 240.00, ToplamTutar = 1440.00, Durumu = "Reddedildi", KayitDurumu = "" }
        };
    }

    private List<GelenFaturaSatirItem> GetPlaceholderSatirlar()
    {
        return new List<GelenFaturaSatirItem>
        {
            new() { MalzemeKodu = "MLZ001", MalzemeAdi = "Elektrik Kablosu 3x2.5", Miktar = 500, BirimKodu = "MT", Fiyat = 12.50, KdvOrani = "%20", MalHizmetTutari = 6250.00 },
            new() { MalzemeKodu = "MLZ002", MalzemeAdi = "Priz Kasasi", Miktar = 100, BirimKodu = "AD", Fiyat = 25.00, KdvOrani = "%20", MalHizmetTutari = 2500.00 },
            new() { MalzemeKodu = "MLZ003", MalzemeAdi = "Sigorta Tablolari", Miktar = 10, BirimKodu = "AD", Fiyat = 625.00, KdvOrani = "%20", MalHizmetTutari = 6250.00 }
        };
    }

    public class GelenFaturaDetayItem
    {
        public int Id { get; set; }
        public bool Secili { get; set; }
        public string FaturaTuru { get; set; } = "";
        public string FaturaTipi { get; set; } = "";
        public DateTime? Tarih { get; set; }
        public string FaturaNo { get; set; } = "";
        public string Tedarikci { get; set; } = "";
        public string VergiDairesi { get; set; } = "";
        public string VergiNo { get; set; } = "";
        public double KdvMatrahi { get; set; }
        public double KdvTutari { get; set; }
        public double ToplamTutar { get; set; }
        public string Durumu { get; set; } = "";
        public string KayitDurumu { get; set; } = "";
        public string FatUrl { get; set; } = "";
        public string ETTN { get; set; } = "";
        public int ReferenceNo { get; set; }
        public int RequestNumber { get; set; }
    }

    public class GelenFaturaSatirItem
    {
        public string MalzemeKodu { get; set; } = "";
        public string MalzemeAdi { get; set; } = "";
        public double Miktar { get; set; }
        public string BirimKodu { get; set; } = "";
        public double Fiyat { get; set; }
        public string KdvOrani { get; set; } = "";
        public double MalHizmetTutari { get; set; }
        public double IndirimTutari { get; set; }
        public double KdvMatrahi { get; set; }
        public double KdvTutari { get; set; }
    }
}
