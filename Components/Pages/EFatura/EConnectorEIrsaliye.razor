        // satirlar = db.FatIrsSatirlarView.AsNoTracking().Where(s => s.IrsaliyeId == irsaliye.Id).Select(...).ToList();
        satirlar = GetPlaceholderSatirlar();
    }

    private void Gonder()
    {
        // TODO: Irsaliyeleri e-irsaliye olarak gonder
        // bgFaturalar.RunWorkerAsync() -> FaturalariHazirla() -> EIrsaliyeGonder()
        // Her irsaliye icin API call yapilir
    }

    private async void Yazdir()
    { await JS.InvokeVoidAsync("window.print");
        // TODO: Yazdir islemi
