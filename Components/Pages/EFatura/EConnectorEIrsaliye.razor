    private bool isGonderiliyor = false;

    private List<EIrsaliyeItem> irsaliyeler = new();
    private List<EIrsaliyeSatirItem> satirlar = new();

    protected override void OnInitialized()
    {
        IrsaliyeListesi();
    }

    private void IrsaliyeListesi()
    {
        // TODO: FirmaContext ile veritabanindan veri cekilecek
        // var trCode = new List<int> { 7, 8, 10 };
        // var faturaTipi = new List<int> { 1 };
        // irsaliyeler = db.IrsaliyelerView.AsNoTracking()
