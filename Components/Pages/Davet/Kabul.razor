@page "/davet/kabul"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Davet Kabul - Pinebi ERP</PageTitle>

<div class="davet-container">
    <div class="davet-box">
        <img src="/images/pinebi_logo.png" alt="Pinebi" style="height:48px; margin-bottom:20px;" />
        <h2 style="color:#235881;">Pinebi ERP - Davet</h2>

        @if (yukleniyor)
        {
            <p>Davet dogrulaniyor...</p>
        }
        else if (hata != null)
        {
            <div class="alert-err">
                <b>Hata:</b> @hata
            </div>
            <p style="margin-top:14px;"><a href="/">Ana sayfaya don</a></p>
        }
        else if (invite == null)
        {
            <div class="alert-err">Gecerli token bulunamadi. Link dogru mu?</div>
        }
        else if (kabulEdildi)
        {
            <div class="alert-ok">
                <b>Davet kabul edildi!</b><br/>
                Artik <a href="@($"https://{invite.Subdomain}.pinebi.com")">@($"{invite.Subdomain}.pinebi.com")</a> ile giris yapabilirsiniz.
            </div>
            <div style="margin-top:14px;">
                <b>Kullanici:</b> @invite.KullaniciAdi
            </div>
        }
        else
        {
            <div class="davet-bilgi">
                <p><b>@invite.TenantName</b> firmasina davet edildiniz.</p>
                <table>
                    <tr><td>Email:</td><td>@invite.Email</td></tr>
                    <tr><td>Kullanici adi:</td><td>@invite.KullaniciAdi</td></tr>
                    <tr><td>Ad soyad:</td><td>@(invite.AdSoyad ?? "-")</td></tr>
                    <tr><td>Rol:</td><td>@invite.Rol</td></tr>
                </table>
            </div>
            <div style="margin-top:16px;">
                <label>Sifre belirle (en az 6 karakter):</label>
                <input type="password" @bind="sifre" @bind:event="oninput" style="width:100%; padding:10px; border:1px solid #cbd5e1; border-radius:4px; font-size:14px; margin-top:6px;" />
            </div>
            <div style="margin-top:8px;">
                <label>Sifre tekrar:</label>
                <input type="password" @bind="sifre2" @bind:event="oninput" style="width:100%; padding:10px; border:1px solid #cbd5e1; border-radius:4px; font-size:14px; margin-top:6px;" />
            </div>
            @if (formHata != "")
            {
                <div class="alert-err" style="margin-top:10px;">@formHata</div>
            }
            <button class="btn-primary" style="margin-top:20px; width:100%;" @onclick="DavetKabulEt" disabled="@kabulEdiliyor">
                @(kabulEdiliyor ? "Isleniyor..." : "Daveti Kabul Et")
            </button>
        }
    </div>
</div>

<style>
    .davet-container { min-height:100vh; background:linear-gradient(135deg,#f1f5f9 0%,#e2e8f0 100%); display:flex; align-items:center; justify-content:center; font-family:'Segoe UI', Arial; }
    .davet-box { background:white; border-radius:12px; box-shadow:0 8px 30px rgba(0,0,0,0.1); padding:36px 40px; max-width:460px; width:90%; }
    .davet-bilgi table { margin-top:10px; font-size:14px; }
    .davet-bilgi td { padding:4px 8px; }
    .davet-bilgi td:first-child { color:#64748b; }
    .alert-err { background:#fee2e2; color:#991b1b; padding:12px 16px; border-radius:6px; }
    .alert-ok { background:#dcfce7; color:#166534; padding:12px 16px; border-radius:6px; font-size:14px; }
    .btn-primary { background:#235881; color:white; border:none; padding:12px; border-radius:6px; cursor:pointer; font-size:15px; font-weight:600; }
    .btn-primary:hover:not(:disabled) { background:#1d486a; }
    .btn-primary:disabled { background:#94a3b8; cursor:wait; }
</style>

@code {
    string? token;
    InviteInfo? invite;
    bool yukleniyor = true;
    string? hata;
    string sifre = "", sifre2 = "";
    string formHata = "";
    bool kabulEdiliyor = false;
    bool kabulEdildi = false;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = QueryHelpers.ParseQuery(uri.Query);
        token = q.TryGetValue("token", out var t) ? t.ToString() : null;

        if (string.IsNullOrEmpty(token))
        {
            hata = "Token eksik";
            yukleniyor = false;
            return;
        }

        try
        {
            var resp = await Http.GetAsync($"api/invites/verify/{token}");
            if (resp.IsSuccessStatusCode)
                invite = await resp.Content.ReadFromJsonAsync<InviteInfo>();
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                hata = body;
            }
        }
        catch (Exception ex) { hata = ex.Message; }
        yukleniyor = false;
    }

    async Task DavetKabulEt()
    {
        formHata = "";
        if (sifre.Length < 6) { formHata = "Sifre en az 6 karakter olmali"; return; }
        if (sifre != sifre2) { formHata = "Sifreler eslesmiyor"; return; }

        kabulEdiliyor = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/invites/accept", new { token, sifre });
            if (resp.IsSuccessStatusCode)
                kabulEdildi = true;
            else
                formHata = await resp.Content.ReadAsStringAsync();
        }
        catch (Exception ex) { formHata = ex.Message; }
        kabulEdiliyor = false;
    }

    class InviteInfo
    {
        public Guid InviteId { get; set; }
        public string Email { get; set; } = "";
        public string KullaniciAdi { get; set; } = "";
        public string? AdSoyad { get; set; }
        public string Rol { get; set; } = "";
        public string TenantName { get; set; } = "";
        public string Subdomain { get; set; } = "";
    }
}
