@page "/pine/cari/kart"
@page "/pine/cari/kart/{Id:int}"
@using MACHINEBISS_Web.Models.PineERP.Cari
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject HttpClient Http
@inject MACHINEBISS_Web.Services.ConfirmService Confirm
@inject IJSRuntime JS

<PageTitle>Cari Kart @(Id > 0 ? "- Duzenle" : "- Yeni")</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-id-card"></i> Cari Kart @(Id > 0 ? "- Duzenle" : "- Yeni")
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="Kaydet" disabled="@saving">
                <i class="fa fa-save"></i> @(saving ? "Kaydediliyor..." : "Kaydet")
            </button>
            <button class="btn btn-primary btn-sm" @onclick="KaydetVeYeni" disabled="@saving">
                <i class="fa fa-plus"></i> Kaydet ve Yeni
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="GeriDon">
                <i class="fa fa-arrow-left"></i> Geri Don
            </button>
            <div style="margin-left:auto;">
                <button class="btn btn-secondary btn-sm" @onclick="Yazdir">
                    <i class="fa fa-print"></i> Yazdir
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div style="padding:6px 12px; margin:6px 0; border-radius:4px; font-size:12px;
                        background:@(mesajTip == "error" ? "#fef2f2" : "#f0fdf4");
                        color:@(mesajTip == "error" ? "#dc2626" : "#16a34a");
                        border:1px solid @(mesajTip == "error" ? "#fecaca" : "#bbf7d0");">
                @mesaj
            </div>
        }

        <!-- Tab Control -->
        <div class="xtab">
            <div class="xtab-header">
                @foreach (var (tabName, tabIndex) in tablar)
                {
                    <div class="xtab-header-item @(activeTab == tabIndex ? "active" : "")"
                         @onclick="() => TabDegistir(tabIndex)">
                        @tabName
                    </div>
                }
            </div>

            <div class="xtab-body" style="padding:10px; max-height:calc(100vh - 270px); overflow-y:auto;">

                @* ═══════ TAB 0: GENEL ═══════ *@
                @if (activeTab == 0)
                {
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Temel Bilgiler</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1; position:relative;">
                                        <label>Cari Kodu</label>
                                        <input type="text" class="form-control"
                                               @bind="model.CarKod" @bind:event="oninput" @bind:after="KodDegisti"
                                               @onblur="OnKodBlur" style="max-width:180px;" autocomplete="off" />
                                        @if (kodArama.Count > 0)
                                        {
                                            <div class="stok-suggest">
                                                @foreach (var s in kodArama)
                                                {
                                                    var sec = s;
                                                    <div class="stok-suggest-item" @onmousedown="@(() => CariSec(sec))">
                                                        <b>@sec.CarKod</b> - @sec.CarUnvan
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1; position:relative;">
                                        <label>Unvan 1</label>
                                        <input type="text" class="form-control"
                                               @bind="model.CarUnvan1" @bind:event="oninput" @bind:after="IsimDegisti"
                                               @onblur="OnIsimBlur" autocomplete="off" />
                                        @if (isimArama.Count > 0)
                                        {
                                            <div class="stok-suggest">
                                                @foreach (var s in isimArama)
                                                {
                                                    var sec = s;
                                                    <div class="stok-suggest-item" @onmousedown="@(() => CariSec(sec))">
                                                        <b>@sec.CarKod</b> - @sec.CarUnvan
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Unvan 2</label>
                                        <input type="text" class="form-control" @bind="model.CarUnvan2" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Kisa Isim</label>
                                        <input type="text" class="form-control" @bind="model.CarKisaIsim" style="max-width:250px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Siniflandirma</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Tipi</label>
                                        <select class="form-control" @bind="model.CarTipi" style="max-width:180px;">
                                            <option value="0">Musteri</option>
                                            <option value="1">Tedarikci</option>
                                            <option value="2">Her Ikisi</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Grup</label>
                                        <select class="form-control" @bind="model.CarGrupKodu" style="max-width:180px;">
                                            <option value="">Secilmedi</option>
                                            @if (gruplar != null)
                                            {
                                                @foreach (var g in gruplar)
                                                {
                                                    <option value="@g.CgrKod">@g.CgrAdi</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Sektor</label>
                                        <input type="text" class="form-control" @bind="model.CarSektorKodu" style="max-width:180px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Bolge</label>
                                        <input type="text" class="form-control" @bind="model.CarBolgeKodu" style="max-width:180px;" />
                                    </div>
                                    <div class="form-inline" style="flex:1;">
                                        <label style="min-width:auto;">Plasiyer</label>
                                        <input type="text" class="form-control" @bind="model.CarPlasiyerKodu" style="max-width:180px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* ═══════ TAB 1: ILETISIM ═══════ *@
                @if (activeTab == 1)
                {
                    <div style="display:flex; gap:14px; align-items:stretch;">
                        <!-- SOL: Adresler -->
                        <div style="flex:1; display:flex; flex-direction:column;">
                            <div class="group-box" style="flex:1; display:flex; flex-direction:column;">
                                <span class="group-box-title">Adresler</span>
                                <div style="display:flex; gap:4px; margin-bottom:6px;">
                                    <button class="btn btn-success btn-sm" @onclick="YeniAdres"><i class="fa fa-plus"></i> Yeni</button>
                                    <button class="btn btn-danger btn-sm" @onclick="AdresSil" disabled="@(seciliAdres == null)"><i class="fa fa-trash"></i> Sil</button>
                                </div>

                                @if (adresDuzenle)
                                {
                                    <div style="background:#f9fafb; border:1px solid var(--pinebi-border); border-radius:4px; padding:8px; margin-bottom:6px;">
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:0 0 auto;"><label>Tip</label>
                                                <select class="form-control" @bind="adresModel.CadAdresTipi" style="width:90px;">
                                                    <option value="1">Merkez</option><option value="2">Sevk</option><option value="3">Fatura</option><option value="4">Diğer</option>
                                                </select>
                                            </div>
                                            <div class="form-inline" style="flex:1;"><label>Adres</label><input type="text" class="form-control" @bind="adresModel.CadAdres1" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>İl</label>
                                                <select class="form-control" @bind="adresModel.CadSehirAdi" @bind:after="EkAdresIlDegisti">
                                                    <option value="">-- Seç --</option>
                                                    @foreach (var il in iller) { <option value="@il.IlAdi">@il.IlAdi</option> }
                                                </select>
                                            </div>
                                            <div class="form-inline" style="flex:1;"><label>İlçe</label>
                                                <select class="form-control" @bind="adresModel.CadIlceAdi">
                                                    <option value="">-- Seç --</option>
                                                    @foreach (var ilce in ekAdresIlceler) { <option value="@ilce.IlcIsim">@ilce.IlcIsim</option> }
                                                </select>
                                            </div>
                                            <div class="form-inline" style="flex:1;"><label>Ülke</label>
                                                <select class="form-control" @bind="ekAdresUlke">
                                                    <option value="">-- Seç --</option>
                                                    <option value="TÜRKİYE">TÜRKİYE</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Telefon</label><input type="text" class="form-control" @bind="adresModel.CadTel" /></div>
                                            <div style="display:flex; gap:4px; align-items:center;">
                                                <button class="btn btn-success btn-sm" @onclick="AdresKaydet"><i class="fa fa-save"></i> Kaydet</button>
                                                <button class="btn btn-outline btn-sm" @onclick="@(() => adresDuzenle = false)"><i class="fa fa-times"></i> İptal</button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (anaAdresDuzenleAcik)
                                {
                                    <div style="background:#eef6ff; border:1px solid #93c5fd; border-radius:4px; padding:8px; margin-bottom:6px;">
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Adres</label><input type="text" class="form-control" @bind="model.CarAdres1" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Semt</label><input type="text" class="form-control" @bind="model.CarAdres2" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>İl</label>
                                                <select class="form-control" @bind="model.CarIl" @bind:after="IlDegisti">
                                                    <option value="">-- Seç --</option>
                                                    @foreach (var il in iller) { <option value="@il.IlAdi">@il.IlAdi</option> }
                                                </select>
                                            </div>
                                            <div class="form-inline" style="flex:1;"><label>İlçe</label>
                                                <select class="form-control" @bind="model.CarIlce">
                                                    <option value="">-- Seç --</option>
                                                    @foreach (var ilce in ilceler) { <option value="@ilce.IlcIsim">@ilce.IlcIsim</option> }
                                                </select>
                                            </div>
                                            <div class="form-inline" style="flex:1;"><label>Ülke</label>
                                                <select class="form-control" @bind="model.CarUlke">
                                                    <option value="">-- Seç --</option>
                                                    <option value="TÜRKİYE">TÜRKİYE</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Telefon</label><input type="text" class="form-control" @bind="model.CarTel1" /></div>
                                            <div class="form-inline" style="flex:1;"><label>Web</label><input type="text" class="form-control" @bind="model.CarWeb" /></div>
                                            <div style="display:flex; gap:4px; align-items:center;">
                                                <button class="btn btn-primary btn-sm" @onclick="@(() => anaAdresDuzenleAcik = false)"><i class="fa fa-check"></i> Tamam</button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="grid-container">
                                    <table class="data-grid">
                                        <thead><tr><th>Tip</th><th>Adres</th><th>İl</th><th>İlçe</th><th>Ülke</th><th>Telefon</th><th style="width:80px; text-align:center;">İşlem</th></tr></thead>
                                        <tbody>
                                            <tr style="background:#f0f7ff; font-weight:600; cursor:pointer;" @ondblclick="AnaAdresDuzenle">
                                                <td>Ana</td>
                                                <td>@model.CarAdres1 @model.CarAdres2</td>
                                                <td>@model.CarIl</td>
                                                <td>@model.CarIlce</td>
                                                <td>@model.CarUlke</td>
                                                <td>@model.CarTel1</td>
                                                <td style="text-align:center;"><button class="btn btn-primary btn-sm" @onclick="AnaAdresDuzenle" title="Düzenle"><i class="fas fa-edit"></i></button></td>
                                            </tr>
                                            @if (adresler != null && adresler.Any())
                                            {
                                                @foreach (var a in adresler)
                                                {
                                                    <tr class="@(seciliAdres?.Id == a.Id ? "selected" : "")" @onclick="() => seciliAdres = a" @ondblclick="() => AdresDuzenleBasla(a)" style="cursor:pointer;">
                                                        <td>@AdresTipAdi(a.CadAdresTipi)</td>
                                                        <td>@a.CadAdres1</td>
                                                        <td>@a.CadSehirAdi</td>
                                                        <td>@a.CadIlceAdi</td>
                                                        <td></td>
                                                        <td>@a.CadTel</td>
                                                        <td>
                                                            <div style="display:flex; gap:3px; justify-content:center;">
                                                                <button class="btn btn-primary btn-sm" @onclick="() => AdresDuzenleBasla(a)" @onclick:stopPropagation="true" title="Düzenle"><i class="fas fa-edit"></i></button>
                                                                <button class="btn btn-danger btn-sm" @onclick="() => TekAdresSil(a)" @onclick:stopPropagation="true" title="Sil"><i class="fas fa-trash-alt"></i></button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- SAG: Iletisim Yetkilisi -->
                        <div style="flex:1; display:flex; flex-direction:column;">
                            <div class="group-box" style="flex:1; display:flex; flex-direction:column;">
                                <span class="group-box-title">İletişim Yetkilisi</span>
                                <div style="display:flex; gap:4px; margin-bottom:6px;">
                                    <button class="btn btn-success btn-sm" @onclick="YeniYetkili"><i class="fa fa-plus"></i> Yeni</button>
                                    <button class="btn btn-danger btn-sm" @onclick="YetkiliSilSec" disabled="@(seciliYetkili == null)"><i class="fa fa-trash"></i> Sil</button>
                                </div>
                                @if (yetkiliDuzenle)
                                {
                                    <div style="background:#f9fafb; border:1px solid var(--pinebi-border); border-radius:4px; padding:8px; margin-bottom:6px;">
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Adı</label><input type="text" class="form-control" @bind="yetkiliModel.CayAd" /></div>
                                            <div class="form-inline" style="flex:1;"><label>Soyadı</label><input type="text" class="form-control" @bind="yetkiliModel.CaySoyad" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Cep Telefonu</label><input type="text" class="form-control" @bind="yetkiliModel.CayGsm" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>E-Posta</label><input type="email" class="form-control" @bind="yetkiliModel.CayEmail" /></div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-inline" style="flex:1;"><label>Ünvanı</label><input type="text" class="form-control" @bind="yetkiliModel.CayUnvan" /></div>
                                        </div>
                                        <div class="form-row" style="margin-top:6px;">
                                            <div style="margin-left:auto; display:flex; gap:4px;">
                                                <button class="btn btn-success btn-sm" @onclick="YetkiliKaydet"><i class="fa fa-save"></i> Kaydet</button>
                                                <button class="btn btn-outline btn-sm" @onclick="@(() => yetkiliDuzenle = false)">Vazgec</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                <div class="grid-container" style="flex:1; min-height:0;">
                                    <table class="data-grid">
                                        <thead><tr><th>Adı</th><th>Soyadı</th><th>Cep Tel</th><th>E-Posta</th><th>Ünvanı</th></tr></thead>
                                        <tbody>
                                            @if (yetkililer != null && yetkililer.Any())
                                            {
                                                @foreach (var y in yetkililer)
                                                {
                                                    <tr class="@(seciliYetkili?.Id == y.Id ? "selected" : "")" @onclick="() => seciliYetkili = y" @ondblclick="() => YetkiliDuzenleBasla(y)">
                                                        <td>@y.CayAd</td><td>@y.CaySoyad</td><td>@y.CayGsm</td><td>@y.CayEmail</td><td>@y.CayUnvan</td>
                                                    </tr>
                                                }
                                            }
                                            else { <tr><td colspan="5" style="text-align:center; color:var(--pinebi-text-light); padding:12px;">Yetkili yok</td></tr> }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* ═══════ TAB 2: MALI BILGILER ═══════ *@
                @if (activeTab == 2)
                {
                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Vergi Bilgileri</span>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Vergi Dairesi</label>
                                        <input type="text" class="form-control" @bind="model.CarVergiDairesi" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>Vergi No</label>
                                        <input type="text" class="form-control" @bind="model.CarVergiNo" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>TC Kimlik</label>
                                        <input type="text" class="form-control" @bind="model.CarTcKimlik" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>MERSIS No</label>
                                        <input type="text" class="form-control" @bind="model.CarMersisNo" style="max-width:200px;" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>KEP Adresi</label>
                                        <input type="text" class="form-control" @bind="model.CarKepAdresi" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-inline" style="flex:1;">
                                        <label>NACE Kodu</label>
                                        <input type="text" class="form-control" @bind="model.CarNaceKodu" style="max-width:180px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div style="flex:1; min-width:450px;">
                            <div class="group-box">
                                <span class="group-box-title">Finansal Bilgiler</span>
                                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 16px;">
                                    <div class="form-inline">
                                        <label>Risk Limiti</label>
                                        <input type="number" class="form-control" @bind="model.CarRiskLimiti" step="0.01" />
                                    </div>
                                    <div class="form-inline">
                                        <label>Vade Suresi (Gun)</label>
                                        <input type="number" class="form-control" @bind="model.CarVadeSuresi" />
                                    </div>
                                    <div class="form-inline">
                                        <label>Fiyat Grubu</label>
                                        <input type="number" class="form-control" @bind="model.CarFiyatGrubu" />
                                    </div>
                                    <div class="form-inline">
                                        <label>Iskonto Orani (%)</label>
                                        <input type="number" class="form-control" @bind="model.CarIskontoOrani" step="0.01" />
                                    </div>
                                    <div class="form-inline">
                                        <label>Para Birimi</label>
                                        <input type="text" class="form-control" @bind="model.CarParaBirimi" />
                                    </div>
                                    <div class="form-inline">
                                        <label>Odeme Sekli</label>
                                        <input type="text" class="form-control" @bind="model.CarOdemeSekli" />
                                    </div>
                                </div>
                            </div>
                            <div class="group-box" style="margin-top:8px;">
                                <span class="group-box-title">Ozellikler</span>
                                <div class="form-row">
                                    <div class="form-check">
                                        <input type="checkbox" @bind="model.CarSahisSirketi" />
                                        <label>Sahis Sirketi</label>
                                    </div>
                                    <div class="form-check" style="margin-left:16px;">
                                        <input type="checkbox" @bind="model.CarYurtDisi" />
                                        <label>Yurt Disi</label>
                                    </div>
                                    <div class="form-check" style="margin-left:16px;">
                                        <input type="checkbox" @bind="model.CarPasifFl" />
                                        <label>Pasif</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* ═══════ TAB 3: BANKA BILGILERI ═══════ *@
                @if (activeTab == 3)
                {
                    <div class="grid-container">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="width:40px;">#</th>
                                    <th>Banka Adi</th>
                                    <th>Sube</th>
                                    <th>Hesap No</th>
                                    <th>IBAN</th>
                                    <th>SWIFT</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka1Adi" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka1Sube" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka1Hesap" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka1Iban" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka1Swift" style="width:100%;" /></td>
                                </tr>
                                <tr>
                                    <td>2</td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka2Adi" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka2Sube" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka2Hesap" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka2Iban" style="width:100%;" /></td>
                                    <td><input type="text" class="form-control" @bind="model.CarBanka2Swift" style="width:100%;" /></td>
