                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    // Main model
    private PineCariHesaplar model = new();
    private List<PineCariGruplari>? gruplar;

    // Sub-data
    private List<PineCariAdresler>? adresler;
    private List<PineCariYetkililer>? yetkililer;
    private List<PineCariGorusmeler>? gorusmeler;

    // Sub-models for inline editing
    private PineCariAdresler adresModel = new();
    private PineCariYetkililer yetkiliModel = new();
    private PineCariGorusmeler gorusmeModel = new();

    // Selection
    private PineCariAdresler? seciliAdres;
    private PineCariYetkililer? seciliYetkili;

    // Il/Ilce listeleri
    private List<IlDto> iller = new();
    private List<IlceDto> ilceler = new();
    private List<IlceDto> ekAdresIlceler = new();
    private string ekAdresUlke = "TÜRKİYE";
    private bool anaAdresDuzenleAcik = false;

    // UI state
    private int activeTab = 0;
    private bool saving = false;
    private string mesaj = "";
    private string mesajTip = "";
    private bool adresDuzenle = false;
    private bool yetkiliDuzenle = false;
    private bool gorusmeDuzenle = false;
    private int adresDuzenleId = 0;

    private (string, int)[] tablar = new[]
    {
        ("Genel", 0),
        ("Adres / Yetkili", 1),
        ("Malî Bilgiler", 2),
        ("Banka Bilgileri", 3),
        ("Görüşmeler", 6),
        ("E-Fatura", 7),
        ("Özel Kodlar + Notlar", 8)
    };

    // Autocomplete arama
    private List<CariAramaItem> kodArama = new();
    private List<CariAramaItem> isimArama = new();
    private System.Threading.CancellationTokenSource? kodAramaCts;
    private System.Threading.CancellationTokenSource? isimAramaCts;
    private int _lastLoadedId = -1;

    public class CariAramaItem
    {
        public int Id { get; set; }
        public string CarKod { get; set; } = "";
        public string CarUnvan { get; set; } = "";
        public string? CarVergiNo { get; set; }
    }

    private Task KodDegisti() => AramaYap(model.CarKod ?? "", "kod");
    private Task IsimDegisti() => AramaYap(model.CarUnvan1 ?? "", "isim");
    private void OnKodBlur() => CloseSuggestions("kod");
    private void OnIsimBlur() => CloseSuggestions("isim");

    private async Task AramaYap(string q, string alan)
    {
        var cts = new System.Threading.CancellationTokenSource();
        if (alan == "kod") { kodAramaCts?.Cancel(); kodAramaCts = cts; }
        else { isimAramaCts?.Cancel(); isimAramaCts = cts; }

        if (string.IsNullOrWhiteSpace(q) || q.Length < 2)
        {
            if (alan == "kod") kodArama.Clear(); else isimArama.Clear();
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(250, cts.Token);
            var resp = await Http.GetFromJsonAsync<ApiResp<List<CariAramaItem>>>(
                $"api/cari/ara?q={Uri.EscapeDataString(q)}&alan={alan}&limit=15", cts.Token);
            if (cts.Token.IsCancellationRequested) return;
            var list = resp?.Data ?? new();

            if (alan == "kod")
            {
                var tam = list.FirstOrDefault(c => string.Equals(c.CarKod, q, StringComparison.OrdinalIgnoreCase));
                var secilecek = tam ?? (list.Count == 1 ? list[0] : null);
                if (secilecek != null)
                {
                    kodArama.Clear();
                    StateHasChanged();
                    CariSec(secilecek);
                    return;
                }
                kodArama = list;
            }
            else
            {
                isimArama = list;
            }
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
        catch { }
    }

    private void CloseSuggestions(string alan)
    {
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(150);
            if (alan == "kod") kodArama.Clear(); else isimArama.Clear();
            StateHasChanged();
        });
    }

    private void CariSec(CariAramaItem c)
    {
        kodArama.Clear();
        isimArama.Clear();
        Nav.NavigateTo($"/pine/cari/kart/{c.Id}");
    }

    protected override async Task OnInitializedAsync()
    {
        await GruplariYukle();
        await IlleriYukle();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _lastLoadedId)
        {
            _lastLoadedId = Id;
            if (Id > 0)
            {
                await HesapYukle();
                if (!string.IsNullOrEmpty(model.CarIl)) await IlceleriYukle(model.CarIl);
            }
            else
            {
                model = new PineCariHesaplar();
                adresler = null; yetkililer = null; gorusmeler = null;
            }
        }
    }

    private async Task IlleriYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<IlDto>>>("/api/tanimlar/iller");
            if (resp?.Success == true) iller = resp.Data ?? new();
        }
        catch { }
    }

    private async Task IlceleriYukle(string ilAdi)
    {
        try
        {
            var il = iller.FirstOrDefault(i => i.IlAdi == ilAdi);
            if (il != null)
            {
                var resp = await Http.GetFromJsonAsync<ApiResp<List<IlceDto>>>($"/api/tanimlar/iller/{il.IlPlaka}/ilceler");
                if (resp?.Success == true) ilceler = resp.Data ?? new();
                else ilceler = new();
            }
            else ilceler = new();
        }
        catch { ilceler = new(); }
    }

    private async Task IlDegisti()
    {
        model.CarIlce = "";
        await IlceleriYukle(model.CarIl ?? "");
    }

    private async Task EkAdresIlDegisti()
    {
        adresModel.CadIlceAdi = "";
        try
        {
            var il = iller.FirstOrDefault(i => i.IlAdi == adresModel.CadSehirAdi);
            if (il != null)
            {
                var resp = await Http.GetFromJsonAsync<ApiResp<List<IlceDto>>>($"/api/tanimlar/iller/{il.IlPlaka}/ilceler");
                ekAdresIlceler = resp?.Success == true ? resp.Data ?? new() : new();
            }
            else ekAdresIlceler = new();
        }
        catch { ekAdresIlceler = new(); }
    }

    private async Task GruplariYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<PineCariGruplari>>>("/api/cari/gruplar");
            gruplar = resp?.Data ?? new();
        }
        catch { gruplar = new(); }
    }

    private async Task HesapYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<PineCariHesaplar>>($"/api/cari/hesap/{Id}");
            if (resp?.Success == true && resp.Data != null)
            {
                model = resp.Data;
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Veri yukleme hatasi: {ex.Message}", "error");
        }
    }

    private async Task TabDegistir(int tab)
    {
        activeTab = tab;

        // Lazy load sub-data when tab is selected for the first time
        if (Id > 0)
        {
            if (tab == 1 && adresler == null) await AdresleriYukle();
            if (tab == 1 && yetkililer == null) await YetkililerYukle();
            if (tab == 6 && gorusmeler == null) await GorusmeleriYukle();
        }
    }

    // ── SAVE ─────────────────────────────────────────────
    private async Task Kaydet()
    {
        if (string.IsNullOrWhiteSpace(model.CarKod))
        {
            MesajGoster("Cari kodu bos olamaz!", "error");
            return;
        }

        saving = true;
        mesaj = "";

        try
        {
            HttpResponseMessage resp;
            if (Id > 0)
            {
                resp = await Http.PutAsJsonAsync($"/api/cari/hesap/{Id}", model);
            }
            else
            {
                resp = await Http.PostAsJsonAsync("/api/cari/hesap", model);
            }

            var result = await resp.Content.ReadFromJsonAsync<ApiResp<PineCariHesaplar>>();
            if (result?.Success == true)
            {
                MesajGoster(result.Message ?? "Basarili", "success");
                if (Id == 0 && result.Data != null)
                {
                    // Redirect to edit mode with new ID
                    Nav.NavigateTo($"/pine/cari/kart/{result.Data.Id}", replace: true);
                }
            }
            else
            {
                MesajGoster(result?.Message ?? "Kaydetme hatasi", "error");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Kaydetme hatasi: {ex.Message}", "error");
        }
        finally
        {
            saving = false;
        }
    }

    private async Task KaydetVeYeni()
    {
        await Kaydet();
        if (mesajTip != "error")
        {
            model = new PineCariHesaplar();
            Id = 0;
            adresler = null;
            yetkililer = null;
            gorusmeler = null;
            activeTab = 0;
            Nav.NavigateTo("/pine/cari/kart", replace: true);
        }
    }

    // ── ADRESLER ─────────────────────────────────────────
    private async Task AdresleriYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<PineCariAdresler>>>($"/api/cari/adresler/{Id}");
            adresler = resp?.Data ?? new();
        }
        catch { adresler = new(); }
    }

    private void YeniAdres()
    {
        adresModel = new PineCariAdresler { CadCariKod = model.CarKod, CadAdresTipi = 2 };
        adresDuzenleId = 0;
        adresDuzenle = true;
    }

    private void AdresDuzenleBasla(PineCariAdresler a)
    {
        adresModel = new PineCariAdresler
        {
            Id = a.Id,
            CadCariKod = a.CadCariKod,
            CadAdresTipi = a.CadAdresTipi,
            CadAdresBasligi = a.CadAdresBasligi,
            CadAdres1 = a.CadAdres1,
            CadAdres2 = a.CadAdres2,
            CadPostaKodu = a.CadPostaKodu,
            CadUlkeKodu = a.CadUlkeKodu,
            CadSehirKodu = a.CadSehirKodu,
            CadIlceKodu = a.CadIlceKodu,
            CadSehirAdi = a.CadSehirAdi,
            CadIlceAdi = a.CadIlceAdi,
            CadTel = a.CadTel,
            CadFaks = a.CadFaks,
            CadYetkili = a.CadYetkili,
            CadVarsayilanFl = a.CadVarsayilanFl,
            CadAciklama = a.CadAciklama
        };
        adresDuzenleId = a.Id;
        adresDuzenle = true;
    }

    private async Task AdresKaydet()
    {
        try
        {
            HttpResponseMessage resp;
            if (adresDuzenleId > 0)
            {
                resp = await Http.PutAsJsonAsync($"/api/cari/adres/{adresDuzenleId}", adresModel);
            }
            else
            {
                resp = await Http.PostAsJsonAsync("/api/cari/adres", adresModel);
            }

            var result = await resp.Content.ReadFromJsonAsync<ApiResp<PineCariAdresler>>();
            if (result?.Success == true)
            {
                adresDuzenle = false;
                await AdresleriYukle();
            }
            else
            {
                MesajGoster(result?.Message ?? "Adres kaydetme hatasi", "error");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Adres kaydetme hatasi: {ex.Message}", "error");
        }
    }

    private async Task AdresSil()
    {
        if (seciliAdres == null) return;
        await TekAdresSil(seciliAdres);
    }

    private async Task TekAdresSil(PineCariAdresler a)
    {
        if (!await Confirm.AskAsync($"'{a.CadAdres1}' adresini silmek istediginize emin misiniz?", "Adres Sil")) return;
        try
        {
            var resp = await Http.DeleteAsync($"/api/cari/adres/{a.Id}");
            if (resp.IsSuccessStatusCode)
            {
                await AdresleriYukle();
                seciliAdres = null;
            }
        }
        catch { }
    }

    private void AnaAdresDuzenle()
    {
        // Genel tab'a (tab 0) git - ana adres orada duzenlenebilir
        // Veya Iletisim tab'inda inline form ac
        anaAdresDuzenleAcik = !anaAdresDuzenleAcik;
    }

    // ── YETKILILER ───────────────────────────────────────
    private async Task YetkililerYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<PineCariYetkililer>>>($"/api/cari/yetkililer/{Id}");
            yetkililer = resp?.Data ?? new();
        }
        catch { yetkililer = new(); }
    }

    private void YeniYetkili()
    {
        yetkiliModel = new PineCariYetkililer { CayCariKod = model.CarKod };
        yetkiliDuzenle = true;
    }

    private void YetkiliDuzenleBasla(PineCariYetkililer y)
    {
        yetkiliModel = new PineCariYetkililer
        {
            Id = y.Id, CayCariKod = y.CayCariKod, CayAd = y.CayAd, CaySoyad = y.CaySoyad,
            CayUnvan = y.CayUnvan, CayGorev = y.CayGorev, CayDepartman = y.CayDepartman,
            CayTel = y.CayTel, CayDahili = y.CayDahili, CayGsm = y.CayGsm, CayEmail = y.CayEmail,
            CayVarsayilanFl = y.CayVarsayilanFl
        };
        yetkiliDuzenle = true;
    }

    private async Task YetkiliSilSec()
    {
        if (seciliYetkili == null) return;
        if (!await Confirm.AskAsync($"'{seciliYetkili.CayAd} {seciliYetkili.CaySoyad}' yetkiliyi silmek istediginize emin misiniz?", "Yetkili Sil")) return;
        try
        {
            var resp = await Http.DeleteAsync($"/api/cari/yetkili/{seciliYetkili.Id}");
            if (resp.IsSuccessStatusCode)
            {
                seciliYetkili = null;
                await YetkililerYukle();
            }
        }
        catch { }
    }

    private async Task YetkiliKaydet()
    {
        try
        {
            var resp = await Http.PostAsJsonAsync("/api/cari/yetkili", yetkiliModel);
            var result = await resp.Content.ReadFromJsonAsync<ApiResp<PineCariYetkililer>>();
            if (result?.Success == true)
            {
                yetkiliDuzenle = false;
                await YetkililerYukle();
            }
            else
            {
                MesajGoster(result?.Message ?? "Yetkili kaydetme hatasi", "error");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Yetkili kaydetme hatasi: {ex.Message}", "error");
        }
    }

    // ── GORUSMELER ───────────────────────────────────────
    private async Task GorusmeleriYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<PineCariGorusmeler>>>($"/api/cari/gorusmeler/{Id}");
            gorusmeler = resp?.Data ?? new();
        }
        catch { gorusmeler = new(); }
    }

    private void YeniGorusme()
    {
        gorusmeModel = new PineCariGorusmeler
        {
            CagCariKod = model.CarKod,
            CagTarih = DateTime.Now,
            CagGorusmeTipi = 1
        };
        gorusmeDuzenle = true;
    }

    private async Task GorusmeKaydet()
    {
        try
        {
            var resp = await Http.PostAsJsonAsync("/api/cari/gorusme", gorusmeModel);
            var result = await resp.Content.ReadFromJsonAsync<ApiResp<PineCariGorusmeler>>();
            if (result?.Success == true)
            {
                gorusmeDuzenle = false;
                await GorusmeleriYukle();
            }
            else
            {
                MesajGoster(result?.Message ?? "Gorusme kaydetme hatasi", "error");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Gorusme kaydetme hatasi: {ex.Message}", "error");
        }
    }

    // ── NAVIGATION ───────────────────────────────────────
    private void GeriDon() => Nav.NavigateTo("/pine/cari/liste");
    private async Task Yazdir() => await JS.InvokeVoidAsync("window.print");

    // ── HELPERS ──────────────────────────────────────────
    private void MesajGoster(string msg, string tip)
    {
        mesaj = msg;
        mesajTip = tip;
    }

    private string AdresTipAdi(int tip) => tip switch
    {
        1 => "Merkez",
        2 => "Sevk",
        3 => "Fatura",
        4 => "Diger",
        _ => "-"
    };

    private string GorusmeTipAdi(int tip) => tip switch
    {
        1 => "Telefon",
        2 => "E-Mail",
        3 => "Yuz Yuze",
        4 => "Video",
        5 => "Diger",
        _ => "-"
    };

    // ── DTO ──────────────────────────────────────────────
    private class ApiResp<T>
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
        public T? Data { get; set; }
    }

    private class IlDto
    {
        public int IlPlaka { get; set; }
        public string IlAdi { get; set; } = "";
    }

    private class IlceDto
    {
        public int IlcSehirId { get; set; }
        public string IlcIsim { get; set; } = "";
    }
