@page "/pine/sistem/audit"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Aktivite Gecmisi - PineERP</PageTitle>

<div style="padding:16px;">
    <h3 style="color:#235881;">
        <i class="fa fa-history"></i> Aktivite Gecmisi
    </h3>

    <div style="display:flex; gap:10px; margin:14px 0; align-items:center;">
        <label>Filtre:</label>
        <select @bind="filtre" @bind:after="Yukle" style="padding:6px 10px; border:1px solid #cbd5e1; border-radius:4px;">
            <option value="">Tum olaylar</option>
            @foreach (var t in types)
            {
                <option value="@t.EventType">@t.EventType (@t.Count)</option>
            }
        </select>
        <button class="btn-mini" @onclick="Yukle"><i class="fa fa-sync"></i> Yenile</button>
        <span style="margin-left:auto; color:#64748b; font-size:12px;">Toplam @events.Count kayit</span>
    </div>

    <table class="audit-table">
        <thead>
            <tr>
                <th>Zaman</th>
                <th>Olay</th>
                <th>Actor</th>
                <th>Detay</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @if (events.Count == 0)
            {
                <tr><td colspan="5" style="text-align:center; color:#64748b; padding:20px;">Henuz aktivite yok.</td></tr>
            }
            @foreach (var e in events)
            {
                <tr>
                    <td>@e.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td><code>@e.EventType</code></td>
                    <td><span class="actor-@e.ActorType">@e.ActorType</span></td>
                    <td style="max-width:400px;"><code style="font-size:11px; color:#475569;">@(e.Details.Length > 100 ? e.Details.Substring(0,100)+"..." : e.Details)</code></td>
                    <td>@(e.Ip ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .audit-table { width:100%; border-collapse:collapse; font-size:13px; background:white; }
    .audit-table th { background:#235881; color:white; padding:8px 10px; text-align:left; }
    .audit-table td { padding:8px 10px; border-bottom:1px solid #e2e8f0; vertical-align:top; }
    .audit-table tr:hover { background:#f8fafc; }
    .audit-table code { background:#f1f5f9; padding:2px 6px; border-radius:3px; font-size:12px; }
    .actor-system { background:#dbeafe; color:#1e40af; padding:2px 6px; border-radius:3px; font-size:11px; }
    .actor-platform_user { background:#fef3c7; color:#92400e; padding:2px 6px; border-radius:3px; font-size:11px; }
    .actor-tenant_user { background:#dcfce7; color:#166534; padding:2px 6px; border-radius:3px; font-size:11px; }
    .actor-public { background:#f3e8ff; color:#6b21a8; padding:2px 6px; border-radius:3px; font-size:11px; }
    .btn-mini { background:#f1f5f9; color:#235881; border:1px solid #cbd5e1; padding:4px 10px; border-radius:3px; cursor:pointer; font-size:12px; }
</style>

@code {
    List<EventRow> events = new();
    List<TypeRow> types = new();
    string filtre = "";

    protected override async Task OnInitializedAsync()
    {
        await TypesYukle();
        await Yukle();
    }

    async Task TypesYukle()
    {
        try { types = await Http.GetFromJsonAsync<List<TypeRow>>("api/tenant/audit/event-types") ?? new(); }
        catch { }
    }

    async Task Yukle()
    {
        try
        {
            var url = "api/tenant/audit?limit=200";
            if (!string.IsNullOrEmpty(filtre)) url += "&eventType=" + Uri.EscapeDataString(filtre);
            events = await Http.GetFromJsonAsync<List<EventRow>>(url) ?? new();
        }
        catch { }
    }

    record EventRow
    {
        public DateTime OccurredAt { get; init; }
        public string EventType { get; init; } = "";
        public string ActorType { get; init; } = "";
        public Guid? ActorId { get; init; }
        public string Details { get; init; } = "";
        public string? Ip { get; init; }
    }
    record TypeRow { public string EventType { get; init; } = ""; public int Count { get; init; } }
}
