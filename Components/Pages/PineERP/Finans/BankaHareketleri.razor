@page "/pine/finans/banka"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Banka Hareketleri - PineERP</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-university"></i> Banka Hareketleri
    </div>
    <div class="card-body">
        <!-- Toolbar -->
        <div class="toolbar">
            <button class="btn btn-success btn-sm" @onclick="() => HareketModalAc(0)">
                <i class="fa fa-plus-circle"></i> Banka Girisi
            </button>
            <button class="btn btn-danger btn-sm" @onclick="() => HareketModalAc(1)">
                <i class="fa fa-minus-circle"></i> Banka Cikisi
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Duzenle">
                <i class="fa fa-edit"></i> Duzenle
            </button>
            <span style="border-left:1px solid var(--pinebi-border); height:20px;"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir">
                <i class="fa fa-print"></i> [F4] Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="Yenile">
                <i class="fa fa-sync"></i> [F5] Yenile
            </button>
        </div>

        <!-- Filtre -->
        <div class="form-row" style="margin-bottom:6px;">
            <div class="form-inline">
                <label style="min-width:50px;">Hesap</label>
                <select class="form-control" @bind="seciliHesapKod" @bind:after="Yenile" style="max-width:250px;">
                    <option value="">-- Tum Hesaplar --</option>
                    @foreach (var h in hesapListesi)
                    {
                        <option value="@h.BhsKod">@h.BhsKod - @h.BhsBankaAdi</option>
                    }
                </select>
            </div>
            <div class="form-inline">
                <label style="min-width:60px;">Baslangic</label>
                <input type="date" class="form-control" @bind="baslangicTarih" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label style="min-width:30px;">Bitis</label>
                <input type="date" class="form-control" @bind="bitisTarih" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Yenile">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <div class="form-inline" style="margin-left:auto;">
                <input type="text" class="form-control" placeholder="Ara..." @bind="aramaMetni" @bind:event="oninput" style="max-width:200px;" />
            </div>
        </div>

        <!-- Grid Caption -->
        <div style="background:var(--pinebi-primary); color:white; padding:6px 10px; font-weight:600; font-size:12px; border-radius:4px 4px 0 0;">
            @gridCaption
        </div>

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 320px); overflow:auto;">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:90px;">Tarih</th>
                        <th style="width:100px;">Hesap</th>
                        <th style="width:250px;">Aciklama1</th>
                        <th style="width:250px;">Aciklama2</th>
                        <th style="width:100px;">Cari Kod</th>
                        <th style="width:80px;">Belge No</th>
                        <th style="width:110px; text-align:right;">Giren</th>
                        <th style="width:110px; text-align:right;">Cikan</th>
                        <th style="width:50px;">Doviz</th>
                    </tr>
                </thead>
                <tbody>
                    @if (yukleniyorMu)
                    {
                        <tr><td colspan="9" class="text-center text-muted" style="padding:30px;">Yukleniyor...</td></tr>
                    }
                    else
                    {
                        @foreach (var item in filteredList)
                        {
                            <tr class="@(selectedId == item.Id ? "selected" : "")" @onclick="() => selectedId = item.Id" @ondblclick="Duzenle">
                                <td>@item.Tarih.ToString("dd.MM.yyyy")</td>
                                <td>@item.HesapKod</td>
                                <td>@item.Aciklama1</td>
                                <td>@item.Aciklama2</td>
                                <td>@item.CariKod</td>
                                <td>@item.BelgeNo</td>
                                <td style="text-align:right; color:#16a34a;">@(item.Giren > 0 ? item.Giren.ToString("N2") : "")</td>
                                <td style="text-align:right; color:#dc2626;">@(item.Cikan > 0 ? item.Cikan.ToString("N2") : "")</td>
                                <td>@(item.DovizCinsi ?? "TL")</td>
                            </tr>
                        }
                        @if (!filteredList.Any())
                        {
                            <tr><td colspan="9" class="text-center text-muted" style="padding:30px;">Kayit bulunamadi</td></tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr style="background:var(--pinebi-dark); color:white; font-weight:700;">
                        <td colspan="6" style="text-align:right; padding:6px 8px;">Toplam:</td>
                        <td style="text-align:right; padding:6px 8px;">@toplamGiren.ToString("N2")</td>
                        <td style="text-align:right; padding:6px 8px;">@toplamCikan.ToString("N2")</td>
                        <td></td>
                    </tr>
                    <tr style="background:var(--pinebi-primary); color:white; font-weight:700;">
                        <td colspan="6" style="text-align:right; padding:6px 8px;">Bakiye:</td>
                        <td colspan="2" style="text-align:right; padding:6px 8px; font-size:14px;">@bakiye.ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div style="margin-top:8px; font-size:11px; color:#666;">
            Toplam @filteredList.Count() kayit
        </div>
    </div>
</div>

@* ===== BANKA HAREKET MODAL ===== *@
@if (modalAcik)
{
    <div class="modal-backdrop" @onclick="() => modalAcik = false"></div>
    <div class="modal-dialog" style="width:450px;">
        <div class="card">
            <div class="card-header">
                <i class="fa @(modalTip == 0 ? "fa-plus-circle" : "fa-minus-circle")"></i>
                Banka @(modalTip == 0 ? "Girisi" : "Cikisi")
                <button class="btn btn-sm" style="float:right;" @onclick="() => modalAcik = false">X</button>
            </div>
            <div class="card-body" style="padding:16px;">
                <div style="margin-bottom:12px;">
                    <label>Banka Hesabi:</label>
                    <select class="form-control" @bind="mHesapKod">
                        @foreach (var h in hesapListesi)
                        {
                            <option value="@h.BhsKod">@h.BhsKod - @h.BhsBankaAdi</option>
                        }
                    </select>
                </div>
                <div style="margin-bottom:12px;">
                    <label>Islem Turu:</label>
                    <select class="form-control" @bind="mHareketCinsi">
                        <option value="0">Havale</option>
                        <option value="1">EFT</option>
                        <option value="2">Virman</option>
                        <option value="3">Tahsilat</option>
                        <option value="4">Odeme</option>
                    </select>
                </div>
                <div style="margin-bottom:12px;">
                    <label>Tutar:</label>
                    <input type="number" class="form-control" @bind="mTutar" step="0.01" style="font-weight:700; font-size:16px;" />
                </div>
                <div style="margin-bottom:12px;">
                    <label>Cari Kod:</label>
                    <input type="text" class="form-control" @bind="mCariKod" />
                </div>
                <div style="margin-bottom:12px;">
                    <label>Aciklama 1:</label>
                    <input type="text" class="form-control" @bind="mAciklama1" />
                </div>
                <div style="margin-bottom:12px;">
                    <label>Aciklama 2:</label>
                    <input type="text" class="form-control" @bind="mAciklama2" />
                </div>
                @if (!string.IsNullOrEmpty(modalMesaj))
                {
                    <div style="color:@(modalOk ? "#166534" : "red"); margin-bottom:8px; font-size:12px;">@modalMesaj</div>
                }
                <div style="text-align:right;">
                    <button class="btn btn-success btn-sm" @onclick="HareketKaydet">
                        <i class="fa fa-save"></i> Kaydet
                    </button>
                    <button class="btn btn-outline btn-sm" @onclick="() => modalAcik = false">Vazgec</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime baslangicTarih = DateTime.Today.AddDays(-30);
    private DateTime bitisTarih = DateTime.Today;
    private string seciliHesapKod = "";
    private string aramaMetni = "";
    private int selectedId = 0;
    private bool yukleniyorMu = false;
    private string gridCaption => $"{baslangicTarih:dd.MM.yyyy} - {bitisTarih:dd.MM.yyyy} Banka Hareketleri Raporu";

    private List<HesapItem> hesapListesi = new();
    private List<BankaHareketItem> hareketler = new();

    private IEnumerable<BankaHareketItem> filteredList => string.IsNullOrWhiteSpace(aramaMetni)
        ? hareketler
        : hareketler.Where(x =>
            (x.Aciklama1 ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (x.Aciklama2 ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase) ||
            (x.CariKod ?? "").Contains(aramaMetni, StringComparison.OrdinalIgnoreCase));

    private decimal toplamGiren => filteredList.Sum(x => x.Giren);
    private decimal toplamCikan => filteredList.Sum(x => x.Cikan);
    private decimal bakiye => toplamGiren - toplamCikan;

    protected override async Task OnInitializedAsync()
    {
        await HesaplariYukle();
        await Yenile();
    }

    private async Task HesaplariYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiDataResponse<List<HesapItem>>>("api/finans/banka/hesaplar");
            hesapListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
            if (hesapListesi.Any() && string.IsNullOrEmpty(mHesapKod))
                mHesapKod = hesapListesi.First().BhsKod;
        }
        catch { hesapListesi = new(); }
    }

    private async Task Yenile()
    {
        yukleniyorMu = true;
        try
        {
            var url = $"api/finans/banka/hareketler?baslangic={baslangicTarih:yyyy-MM-dd}&bitis={bitisTarih:yyyy-MM-dd}";
            if (!string.IsNullOrEmpty(seciliHesapKod))
                url += $"&hesapKod={seciliHesapKod}";

            var resp = await Http.GetFromJsonAsync<ApiDataResponse<BankaHareketlerResponse>>(url);
            hareketler = resp?.Success == true ? (resp.Data?.Hareketler ?? new()) : new();
        }
        catch { hareketler = new(); }
        yukleniyorMu = false;
    }

    private void Duzenle()
    {
        if (selectedId == 0) return;
    }

    private async void Yazdir() { await JS.InvokeVoidAsync("window.print"); }

    // ===== MODAL =====
    private bool modalAcik = false;
    private int modalTip = 0;
    private string mHesapKod = "";
    private int mHareketCinsi = 0;
    private decimal mTutar = 0;
    private string mCariKod = "";
    private string mAciklama1 = "";
    private string mAciklama2 = "";
    private string modalMesaj = "";
    private bool modalOk = false;

    private void HareketModalAc(int tip)
    {
        modalTip = tip;
        mTutar = 0;
        mCariKod = "";
        mAciklama1 = "";
        mAciklama2 = "";
        mHareketCinsi = 0;
        modalMesaj = "";
        modalOk = false;
        if (hesapListesi.Any() && string.IsNullOrEmpty(mHesapKod))
            mHesapKod = hesapListesi.First().BhsKod;
        modalAcik = true;
    }

    private async Task HareketKaydet()
    {
        if (mTutar <= 0) { modalMesaj = "Tutar giriniz!"; modalOk = false; return; }
        try
        {
            var dto = new
            {
                HesapKod = mHesapKod,
                Tip = modalTip,
                Tutar = mTutar,
                CariKod = mCariKod,
                Aciklama1 = mAciklama1,
                Aciklama2 = mAciklama2,
                HareketCinsi = mHareketCinsi
            };
            var resp = await Http.PostAsJsonAsync("api/finans/banka/hareket", dto);
            var result = await resp.Content.ReadFromJsonAsync<ApiResult>();
            if (result?.Success == true)
            {
                modalMesaj = "Kaydedildi!";
                modalOk = true;
                modalAcik = false;
                await Yenile();
            }
            else
            {
                modalMesaj = result?.Message ?? "Hata";
                modalOk = false;
            }
        }
        catch (Exception ex) { modalMesaj = $"Hata: {ex.Message}"; modalOk = false; }
    }

    // ===== HELPER CLASSES =====
    public class HesapItem { public string BhsKod { get; set; } = ""; public string BhsBankaAdi { get; set; } = ""; }
    public class BankaHareketItem
    {
        public int Id { get; set; }
        public string HesapKod { get; set; } = "";
        public DateTime Tarih { get; set; }
        public string? Aciklama1 { get; set; }
        public string? Aciklama2 { get; set; }
        public string? CariKod { get; set; }
        public string? BelgeNo { get; set; }
        public string? DovizCinsi { get; set; }
        public decimal Giren { get; set; }
        public decimal Cikan { get; set; }
    }
    public class BankaHareketlerResponse { public List<BankaHareketItem>? Hareketler { get; set; } }
    public class ApiResult { public bool Success { get; set; } public string? Message { get; set; } }
    public class ApiDataResponse<T> { public bool Success { get; set; } public string? Message { get; set; } public T? Data { get; set; } }
}
