@page "/pine/finans/tahsilat"
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Tahsilat Alma - PineERP</PageTitle>

<div class="card" @onkeydown="KlavyeKisayol" tabindex="0" style="outline:none;">
    <div class="card-header">
        <i class="fa fa-money-bill-wave"></i> Tahsilat Alma
    </div>
    <div class="card-body">

        <!-- FORM -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 24px; margin-bottom:12px; padding:10px; border:1px solid var(--pinebi-border); border-radius:4px; background:#fafbfc;">
            <!-- LEFT -->
            <div style="display:flex; flex-direction:column; gap:6px;">
                <div class="form-inline">
                    <label style="min-width:90px; font-weight:700;">Fis No</label>
                    <input type="text" class="form-control" @bind="fisNo" readonly style="flex:1; background:#f0f0f0;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">Tarih</label>
                    <input type="date" class="form-control" @bind="tarih" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px; font-weight:700;">C/H Kodu</label>
                    <input type="text" class="form-control" @bind="cariKod" style="flex:1;" />
                    <button class="btn btn-sm btn-outline" @onclick="CariSecAc" style="padding:2px 6px;"><i class="fa fa-search"></i></button>
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">C/H Ismi</label>
                    <input type="text" class="form-control" value="@cariUnvan" readonly style="flex:1; background:#f0f0f0;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:90px;">Doviz</label>
                    <select class="form-control" @bind="doviz" style="max-width:80px;">
                        <option>TL</option><option>USD</option><option>EUR</option>
                    </select>
                    <label style="margin-left:8px;">Kur</label>
                    <input type="number" class="form-control" @bind="kur" step="0.0001" style="max-width:100px; font-weight:700;" />
                </div>
            </div>

            <!-- RIGHT -->
            <div style="display:flex; flex-direction:column; gap:6px;">
                <div class="form-inline">
                    <label style="min-width:100px; font-weight:700;">Tahsilat Tipi</label>
                    <select class="form-control" @bind="tahsilatTipiId" @bind:after="TahsilatTipiDegisti" style="flex:1;">
                        <option value="1">Nakit</option>
                        <option value="2">Havale/EFT</option>
                        <option value="3">Kredi Karti</option>
                        <option value="4">Cek</option>
                        <option value="5">Senet</option>
                    </select>
                </div>
                <div class="form-inline">
                    @if (tahsilatTipiId == 1)
                    {
                        <label style="min-width:100px;">Kasa</label>
                        <select class="form-control" @bind="kasaKod" style="flex:1;">
                            <option value="">-- Kasa Sec --</option>
                            @foreach (var k in kasaListesi)
                            {
                                <option value="@k.KasKod">@k.KasKod - @k.KasIsim</option>
                            }
                        </select>
                    }
                    else if (tahsilatTipiId == 2 || tahsilatTipiId == 3)
                    {
                        <label style="min-width:100px;">Banka</label>
                        <select class="form-control" @bind="bankaKod" style="flex:1;">
                            <option value="">-- Banka Sec --</option>
                            @foreach (var b in bankaListesi)
                            {
                                <option value="@b.BhsKod">@b.BhsKod - @b.BhsBankaAdi</option>
                            }
                        </select>
                    }
                    else
                    {
                        <label style="min-width:100px;">Hesap</label>
                        <input type="text" class="form-control" value="Cek/Senet" readonly style="flex:1; background:#f0f0f0;" />
                    }
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Belge No</label>
                    <input type="text" class="form-control" @bind="belgeNo" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Aciklama 1</label>
                    <input type="text" class="form-control" @bind="aciklama1" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:100px;">Aciklama 2</label>
                    <input type="text" class="form-control" @bind="aciklama2" style="flex:1;" />
                </div>
            </div>
        </div>

        <!-- CEK/SENET FIELDS -->
        @if (tahsilatTipiId == 4 || tahsilatTipiId == 5)
        {
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:12px; padding:10px; border:1px solid #e0a030; border-radius:4px; background:#fffcf0;">
                <div class="form-inline">
                    <label style="min-width:80px; font-weight:600;"><i class="fa fa-calendar"></i> Vade Tarihi</label>
                    <input type="date" class="form-control" @bind="vadeTarihi" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:60px; font-weight:600;">Banka</label>
                    <input type="text" class="form-control" @bind="cekBanka" style="flex:1;" />
                </div>
                <div class="form-inline">
                    <label style="min-width:60px; font-weight:600;">Seri No</label>
                    <input type="text" class="form-control" @bind="cekSeriNo" style="flex:1;" />
                </div>
            </div>
        }

        <!-- ACIK FATURALAR -->
        <div style="background:#235881; color:white; padding:6px 10px; font-weight:600; font-size:12px; border-radius:4px 4px 0 0;">
            <i class="fa fa-file-invoice"></i> Acik Faturalar
            @if (!string.IsNullOrEmpty(cariUnvan))
            {
                <span style="font-weight:400; font-size:11px; margin-left:8px;">(@cariUnvan)</span>
            }
        </div>
        <div class="grid-container" style="max-height:280px; overflow:auto;">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:40px; text-align:center;">Sec</th>
                        <th style="width:130px;">Fatura No</th>
                        <th style="width:100px;">Tarih</th>
                        <th style="width:110px; text-align:right;">Tutar</th>
                        <th style="width:110px; text-align:right;">Tahsil Edilen</th>
                        <th style="width:110px; text-align:right;">Kalan</th>
                    </tr>
                </thead>
                <tbody>
                    @if (acikFaturalar.Any())
                    {
                        @foreach (var f in acikFaturalar)
                        {
                            <tr>
                                <td style="text-align:center;">
                                    <input type="checkbox" @bind="f.Secili" @bind:after="FaturaSecimDegisti" />
                                </td>
                                <td>@f.FisNo</td>
                                <td>@f.Tarih.ToString("dd.MM.yyyy")</td>
                                <td style="text-align:right;">@f.Tutar.ToString("N2")</td>
                                <td style="text-align:right;">@f.Tahsilat.ToString("N2")</td>
                                <td style="text-align:right; font-weight:700;">@f.Kalan.ToString("N2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted" style="padding:20px;">
                            @(string.IsNullOrEmpty(cariKod) ? "Cari hesap secin" : "Acik fatura bulunamadi")
                        </td></tr>
                    }
                </tbody>
                @if (acikFaturalar.Any(f => f.Secili))
                {
                    <tfoot>
                        <tr style="background:#235881; color:white; font-weight:700;">
                            <td colspan="5" style="text-align:right; padding:6px 8px;">Secilen Toplam:</td>
                            <td style="text-align:right; padding:6px 8px;">@acikFaturalar.Where(f => f.Secili).Sum(f => f.Kalan).ToString("N2")</td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>

        <!-- TUTAR & BUTTONS -->
        <div style="border:1px solid var(--pinebi-border); border-radius:4px; padding:12px; background:#fafbfc; margin-top:10px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                <label style="font-weight:700; font-size:14px; min-width:60px;">Tutar</label>
                <input type="number" class="form-control" @bind="tutar" step="0.01"
                       style="max-width:200px; font-size:16px; font-weight:700; text-align:right; border:2px solid #235881;" />
                <span style="font-size:13px; color:#666;">@doviz</span>
            </div>
            <div style="border-top:1px solid var(--pinebi-border); padding-top:10px; display:flex; gap:8px; align-items:center;">
                <button class="btn btn-success" @onclick="Kaydet" style="min-width:140px;">
                    <i class="fa fa-save"></i> [F2] Kaydet
                </button>
                <button class="btn btn-outline" @onclick="Kapat" style="min-width:100px;">
                    <i class="fa fa-times"></i> [Esc] Kapat
                </button>
                <button class="btn btn-outline" @onclick="Temizle" style="margin-left:auto;">
                    <i class="fa fa-eraser"></i> Temizle
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div style="margin-top:10px; padding:8px 12px; border-radius:4px; font-size:12px;
                        background:@(mesajOk ? "#dcfce7" : "#fee2e2");
                        color:@(mesajOk ? "#166534" : "#991b1b");
                        border:1px solid @(mesajOk ? "#86efac" : "#fca5a5");">
                <i class="fa @(mesajOk ? "fa-check-circle" : "fa-exclamation-triangle")"></i> @mesaj
            </div>
        }
    </div>
</div>

@* ===== CARI SEC MODAL ===== *@
@if (cariModalAcik)
{
    <div class="modal-overlay" @onclick="() => cariModalAcik = false">
        <div class="modal-box" style="width:800px; max-height:80vh;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><i class="fa fa-address-book"></i> Cari Sec</span>
                <button class="modal-close" @onclick="() => cariModalAcik = false">X</button>
            </div>
            <div class="modal-body">
                <div class="form-inline mb-2">
                    <label>Ara:</label>
                    <input type="text" class="form-control" @bind="cariArama" @bind:event="oninput" @bind:after="CariAra" placeholder="Cari kodu veya unvan..." style="flex:1;" />
                </div>
                <div class="grid-container" style="max-height:400px;">
                    <table class="data-grid">
                        <thead><tr><th style="width:100px;">Cari Kodu</th><th>Unvani</th></tr></thead>
                        <tbody>
                            @foreach (var c in cariListesi)
                            {
                                <tr style="cursor:pointer;" @onclick="() => CariSecildi(c)">
                                    <td>@c.CarKod</td>
                                    <td><strong>@c.CarUnvan</strong></td>
                                </tr>
                            }
                            @if (!cariListesi.Any())
                            {
                                <tr><td colspan="2" class="text-center text-muted">Sonuc yok</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ===== FORM FIELDS =====
    private string fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");
    private DateTime tarih = DateTime.Today;
    private string cariKod = "";
    private string cariUnvan = "";
    private string doviz = "TL";
    private decimal kur = 1;
    private int tahsilatTipiId = 1;
    private string kasaKod = "";
    private string bankaKod = "";
    private string belgeNo = "";
    private string aciklama1 = "";
    private string aciklama2 = "";
    private decimal tutar = 0;
    private DateTime vadeTarihi = DateTime.Today.AddDays(30);
    private string cekBanka = "";
    private string cekSeriNo = "";

    private string mesaj = "";
    private bool mesajOk = false;

    // ===== LISTS =====
    private List<KasaItem> kasaListesi = new();
    private List<BankaItem> bankaListesi = new();
    private List<AcikFaturaItem> acikFaturalar = new();

    // ===== CARI MODAL =====
    private bool cariModalAcik = false;
    private string cariArama = "";
    private List<CariDto> cariListesi = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(KasalariYukle(), BankalariYukle());
    }

    private async Task KasalariYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<KasaItem>>>("api/finans/kasalar");
            kasaListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
        }
        catch { }
    }

    private async Task BankalariYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<BankaItem>>>("api/finans/banka/hesaplar");
            bankaListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
        }
        catch { }
    }

    private void TahsilatTipiDegisti() { kasaKod = ""; bankaKod = ""; }

    private void FaturaSecimDegisti()
    {
        tutar = acikFaturalar.Where(f => f.Secili).Sum(f => f.Kalan);
    }

    // ===== CARI =====
    private async Task CariSecAc()
    {
        cariArama = cariKod;
        cariModalAcik = true;
        await CariAra();
    }

    private async Task CariAra()
    {
        try
        {
            var q = Uri.EscapeDataString(cariArama ?? "");
            var resp = await Http.GetFromJsonAsync<ApiResp<List<CariDto>>>($"api/cari/ara?q={q}&limit=50");
            cariListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
        }
        catch { cariListesi = new(); }
    }

    private async Task CariSecildi(CariDto c)
    {
        cariKod = c.CarKod;
        cariUnvan = c.CarUnvan;
        cariModalAcik = false;
        await AcikFaturalariYukle();
    }

    private async Task AcikFaturalariYukle()
    {
        acikFaturalar = new();
        if (string.IsNullOrEmpty(cariKod)) return;

        try
        {
            // Satis faturalari (tip=1) listele, acik olanlari filtrele
            var url = $"api/fatura/liste?tip=1&sayfa=1&boyut=200&arama={Uri.EscapeDataString(cariKod)}";
            var resp = await Http.GetFromJsonAsync<PagedResp<FaturaDto>>(url);
            if (resp?.Success == true && resp.Data != null)
            {
                foreach (var f in resp.Data.Where(x => !x.RecIptal && !x.FatKapandiFl))
                {
                    // Tahsilat bilgisini al
                    decimal tahsil = 0;
                    try
                    {
                        var tResp = await Http.GetFromJsonAsync<ApiResp<TahsilatOzet>>($"api/fatura/tahsilat/{f.Id}");
                        if (tResp?.Success == true)
                            tahsil = tResp.Data?.ToplamTahsilat ?? 0;
                    }
                    catch { }

                    var kalan = f.FatOdenecekTutar - tahsil;
                    if (kalan > 0.01m)
                    {
                        acikFaturalar.Add(new AcikFaturaItem
                        {
                            FaturaId = f.Id,
                            FisNo = f.FisNo,
                            Tarih = f.FatTarih,
                            Tutar = f.FatOdenecekTutar,
                            Tahsilat = tahsil,
                            Kalan = kalan
                        });
                    }
                }
            }
        }
        catch { }
    }

    // ===== KAYDET =====
    private async Task Kaydet()
    {
        mesaj = "";
        if (string.IsNullOrEmpty(cariKod)) { mesaj = "Cari hesap seciniz!"; mesajOk = false; return; }
        if (tutar <= 0) { mesaj = "Tutar giriniz!"; mesajOk = false; return; }
        if (tahsilatTipiId == 1 && string.IsNullOrEmpty(kasaKod)) { mesaj = "Kasa seciniz!"; mesajOk = false; return; }
        if ((tahsilatTipiId == 2 || tahsilatTipiId == 3) && string.IsNullOrEmpty(bankaKod)) { mesaj = "Banka seciniz!"; mesajOk = false; return; }

        try
        {
            // 1. Secilen faturalara tahsilat yaz
            var secilenler = acikFaturalar.Where(f => f.Secili).ToList();
            foreach (var fat in secilenler)
            {
                var dto = new
                {
                    FaturaId = fat.FaturaId,
                    Tip = 0, // Tahsilat
                    OdemeSekli = tahsilatTipiId,
                    Tutar = Math.Min(tutar, fat.Kalan),
                    DovizCinsi = doviz,
                    DovizKuru = kur,
                    KasaKodu = kasaKod,
                    BankaKodu = bankaKod,
                    BelgeNo = belgeNo,
                    Aciklama = aciklama1
                };
                await Http.PostAsJsonAsync("api/fatura/tahsilat", dto);
            }

            // 2. Kasa veya Banka hareketi
            if (tahsilatTipiId == 1)
            {
                await Http.PostAsJsonAsync("api/finans/kasa/hareket", new
                {
                    KasaKod = kasaKod,
                    Tip = 0, // Giris
                    Tutar = tutar,
                    DovizCinsi = doviz,
                    DovizKuru = kur,
                    CariKod = cariKod,
                    HareketCinsi = 2, // Tahsilat
                    BelgeNo = belgeNo,
                    Aciklama1 = $"Tahsilat - {cariUnvan}",
                    Aciklama2 = aciklama1
                });
            }
            else if (tahsilatTipiId == 2 || tahsilatTipiId == 3)
            {
                await Http.PostAsJsonAsync("api/finans/banka/hareket", new
                {
                    HesapKod = bankaKod,
                    Tip = 0, // Giris
                    Tutar = tutar,
                    DovizCinsi = doviz,
                    DovizKuru = kur,
                    CariKod = cariKod,
                    HareketCinsi = 3, // Tahsilat
                    BelgeNo = belgeNo,
                    Aciklama1 = $"Tahsilat - {cariUnvan}",
                    Aciklama2 = aciklama1
                });
            }
            else if (tahsilatTipiId == 4 || tahsilatTipiId == 5)
            {
                await Http.PostAsJsonAsync("api/finans/ceksenet", new
                {
                    CshTip = 'A',
                    CshCins = tahsilatTipiId == 4 ? 'C' : 'S',
                    CshTarih = tarih,
                    CshVadeTarihi = vadeTarihi,
                    CshCariKod = cariKod,
                    CshBanka = cekBanka,
                    CshSeriNo = cekSeriNo,
                    CshTutar = tutar,
                    CshDovizCinsi = doviz,
                    CshDovizKuru = kur,
                    CshDurumu = "Portfoyde",
                    CshAciklama1 = $"Tahsilat - {cariUnvan}",
                    CshAciklama2 = aciklama1
                });
            }

            mesaj = $"Tahsilat kaydedildi! Fis No: {fisNo}";
            mesajOk = true;
            Temizle();
        }
        catch (Exception ex) { mesaj = $"Kayit hatasi: {ex.Message}"; mesajOk = false; }
    }

    private void Temizle()
    {
        fisNo = "THS" + DateTime.Now.ToString("yyyyMMddHHmmss");
        cariKod = ""; cariUnvan = ""; tutar = 0; belgeNo = ""; aciklama1 = ""; aciklama2 = "";
        doviz = "TL"; kur = 1; kasaKod = ""; bankaKod = "";
        cekBanka = ""; cekSeriNo = ""; vadeTarihi = DateTime.Today.AddDays(30);
        acikFaturalar = new();
    }

    private void Kapat() => Nav.NavigateTo("/");

    private async Task KlavyeKisayol(KeyboardEventArgs e)
    {
        if (e.Key == "F2") await Kaydet();
        else if (e.Key == "Escape") Kapat();
    }

    // ===== HELPER CLASSES =====
    public class KasaItem { public string KasKod { get; set; } = ""; public string KasIsim { get; set; } = ""; }
    public class BankaItem { public string BhsKod { get; set; } = ""; public string BhsBankaAdi { get; set; } = ""; }
    public class CariDto { public string CarKod { get; set; } = ""; public string CarUnvan { get; set; } = ""; }
    public class FaturaDto
    {
        public int Id { get; set; }
        public string FisNo { get; set; } = "";
        public DateTime FatTarih { get; set; }
        public decimal FatOdenecekTutar { get; set; }
        public bool FatKapandiFl { get; set; }
        public bool RecIptal { get; set; }
    }
    public class TahsilatOzet { public decimal ToplamTahsilat { get; set; } }
    public class AcikFaturaItem
    {
        public int FaturaId { get; set; }
        public string FisNo { get; set; } = "";
        public DateTime Tarih { get; set; }
        public decimal Tutar { get; set; }
        public decimal Tahsilat { get; set; }
        public decimal Kalan { get; set; }
        public bool Secili { get; set; }
    }
    public class ApiResp<T> { public bool Success { get; set; } public string? Message { get; set; } public T? Data { get; set; } }
    public class PagedResp<T> { public bool Success { get; set; } public List<T>? Data { get; set; } }
}
