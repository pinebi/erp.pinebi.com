@page "/pine/stok/kartlar"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@inject MACHINEBISS_Web.Services.TabService TabSvc
@using System.Net.Http.Json
@using MACHINEBISS_Web.Controllers.Api

<PageTitle>Stok Kartlari - PineERP</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-cubes"></i> Stok / Malzeme Kartlari
    </div>
    <div class="card-body stok-list-page" style="padding:8px 14px;">
        <style>
            .stok-list-page .toolbar { align-items: center; gap: 6px; }
            .stok-list-page .toolbar .btn { height: 32px; padding: 0 12px; display: inline-flex; align-items: center; gap: 6px; line-height: 1; font-size: 12px; }
            .stok-list-page .toolbar .btn i { font-size: 12px; }
            .stok-list-page .toolbar .form-control { height: 32px; padding: 0 10px; font-size: 12px; line-height: 32px; }
            .stok-list-page .toolbar .toolbar-search { display: inline-flex; align-items: center; gap: 6px; height: 32px; }
            .stok-list-page .toolbar .toolbar-search i { color: var(--pinebi-text-light); }
            .stok-list-page .toolbar .toolbar-sep { display: inline-block; width: 1px; height: 22px; background: var(--pinebi-border); margin: 0 4px; }
            .stok-list-page .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; padding: 8px 10px; background: #f9fafb; border: 1px solid var(--pinebi-border); border-radius: 4px; }
            .stok-list-page .filter-bar .filter-item { display: inline-flex; align-items: center; gap: 6px; }
            .stok-list-page .filter-bar .filter-item label { font-size: 12px; font-weight: 600; color: var(--pinebi-text); white-space: nowrap; margin: 0; }
            .stok-list-page .filter-bar .form-control { height: 32px; padding: 0 10px; font-size: 12px; line-height: 32px; min-width: 200px; }
            .stok-list-page .filter-bar .btn { height: 32px; padding: 0 12px; display: inline-flex; align-items: center; gap: 6px; line-height: 1; font-size: 12px; }
        </style>
        <!-- Toolbar -->
        <div class="toolbar" style="margin-bottom:6px;">
            <button class="btn btn-success btn-sm" @onclick="YeniKart" title="Yeni Stok Karti [F3]">
                <i class="fa fa-plus"></i> Yeni</button>
            <button class="btn btn-primary btn-sm" @onclick="DuzenleKart" disabled="@(seciliId == 0)" title="Stok Kartini Duzenle [Enter]">
                <i class="fa fa-pencil"></i> Duzenle
            </button>
            <button class="btn btn-danger btn-sm" @onclick="SilKart" disabled="@(seciliId == 0)" title="Stok Kartini Sil [Del]">
                <i class="fa fa-trash"></i> Sil
            </button>
            <span class="toolbar-sep"></span>
            <button class="btn btn-outline btn-sm" @onclick="ToggleFiltre" title="Filtre Paneli">
                <i class="fa fa-filter"></i> Filtrele
            </button>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir" title="Yazdir">
                <i class="fa fa-print"></i> Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="ExcelExport" title="Excel'e Aktar">
                <i class="fa fa-file-excel-o"></i> Excel
            </button>
            <span class="toolbar-sep"></span>
            <button class="btn btn-outline btn-sm" @onclick="Yenile" title="Listeyi Yenile">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <div class="toolbar-search" style="margin-left:auto;">
                <i class="fa fa-search"></i>
                <input type="text" class="form-control" placeholder="Stok Kodu, Isim, Barkod ile ara..."
                       @bind="aramaText" @bind:event="oninput" @bind:after="AramaYap"
                       style="width:280px;" />
                @if (!string.IsNullOrEmpty(aramaText))
                {
                    <button class="btn btn-sm btn-outline" @onclick="AramaTemizle" title="Aramayi Temizle" style="padding:0 8px; color:#dc2626;">
                        <i class="fa fa-times"></i>
                    </button>
                }
            </div>
        </div>

        <!-- Filtre Paneli -->
        @if (filtreGoster)
        {
            <div class="filter-bar">
                <div class="filter-item">
                    <label>Grup</label>
                    <select class="form-control" @bind="filtreGrup" @bind:after="FiltreleVeYukle">
                        <option value="">-- Tumu --</option>
                        @foreach (var g in gruplar)
                        {
                            <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                        }
                    </select>
                </div>
                <button class="btn btn-outline btn-sm" @onclick="FiltreTemizle" title="Filtreyi Temizle">
                    <i class="fa fa-times"></i> Temizle
                </button>
            </div>
        }

        <!-- Mesaj -->
        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div class="alert @mesajTip" style="margin-bottom:6px;">
                @mesaj
                <button style="float:right; background:none; border:none; cursor:pointer; font-weight:bold;" @onclick="() => mesaj = null">&times;</button>
            </div>
        }

        <!-- Data Grid -->
        <div class="grid-container">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:35px;">#</th>
                        <th @onclick='() => SiralamaYap("StoKod")' style="cursor:pointer; min-width:110px;">
                            Stok Kodu @SiralamaIkon("StoKod")
                        </th>
                        <th @onclick='() => SiralamaYap("StoIsim")' style="cursor:pointer; min-width:200px;">
                            Stok Ismi @SiralamaIkon("StoIsim")
                        </th>
                        <th @onclick='() => SiralamaYap("StoBirim1Ad")' style="cursor:pointer; min-width:70px;">
                            Birim @SiralamaIkon("StoBirim1Ad")
                        </th>
                        <th @onclick='() => SiralamaYap("StoAnagrupKod")' style="cursor:pointer; min-width:100px;">
                            Grup @SiralamaIkon("StoAnagrupKod")
                        </th>
                        <th @onclick='() => SiralamaYap("StoPerakendeVergi")' style="cursor:pointer; text-align:right; min-width:60px;">
                            KDV % @SiralamaIkon("StoPerakendeVergi")
                        </th>
                        <th @onclick='() => SiralamaYap("Fiyat")' style="cursor:pointer; text-align:right; min-width:90px;">
                            Fiyat @SiralamaIkon("Fiyat")
                        </th>
                        <th @onclick='() => SiralamaYap("StoMinStok")' style="cursor:pointer; text-align:right; min-width:70px;">
                            Min Stok @SiralamaIkon("StoMinStok")
                        </th>
                        <th @onclick='() => SiralamaYap("StoMaxStok")' style="cursor:pointer; text-align:right; min-width:70px;">
                            Max Stok @SiralamaIkon("StoMaxStok")
                        </th>
                        <th @onclick='() => SiralamaYap("StoBarkod1")' style="cursor:pointer; min-width:120px;">
                            Barkod @SiralamaIkon("StoBarkod1")
                        </th>
                        <th @onclick='() => SiralamaYap("StoPasifFl")' style="cursor:pointer; min-width:70px;">
                            Durum @SiralamaIkon("StoPasifFl")
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @if (yukleniyor)
                    {
                        <tr><td colspan="11" style="text-align:center; padding:40px; color:var(--pinebi-text-light);">
                            <i class="fa fa-spinner fa-spin"></i> Yukleniyor...
                        </td></tr>
                    }
                    else if (stoklar == null || !stoklar.Any())
                    {
                        <tr><td colspan="11" style="text-align:center; padding:40px; color:var(--pinebi-text-light);">
                            <i class="fa fa-inbox"></i> Kayit bulunamadi
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var (item, idx) in stoklar.Select((s, i) => (s, i)))
                        {
                            <tr class="@(seciliId == item.Id ? "selected" : "")"
                                @onclick="() => SecKayit(item)"
                                @ondblclick="() => CiftTikla(item)"
                                style="cursor:pointer;">
                                <td style="text-align:center; color:var(--pinebi-text-light);">@((sayfa - 1) * sayfaBoyutu + idx + 1)</td>
                                <td><strong>@item.StoKod</strong></td>
                                <td>@item.StoIsim</td>
                                <td>@item.StoBirim1Ad</td>
                                <td>@item.StoAnagrupKod</td>
                                <td style="text-align:right;">%@item.StoPerakendeVergi</td>
                                <td style="text-align:right; font-weight:600;">@(item.Fiyat > 0 ? item.Fiyat.ToString("N2") : "-")</td>
                                <td style="text-align:right;">@item.StoMinStok.ToString("N0")</td>
                                <td style="text-align:right;">@item.StoMaxStok.ToString("N0")</td>
                                <td>@item.StoBarkod1</td>
                                <td>
                                    @if (item.StoPasifFl)
                                    {
                                        <span style="color:#dc2626; font-weight:600;"><i class="fa fa-ban"></i> Pasif</span>
                                    }
                                    else
                                    {
                                        <span style="color:#16a34a;"><i class="fa fa-check-circle"></i> Aktif</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer: Record Count + Pagination -->
        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-top:1px solid var(--pinebi-border); margin-top:4px;">
            <span style="font-size:11px; color:var(--pinebi-text-light);">
                <i class="fa fa-database"></i> Toplam: <strong>@toplamKayit</strong> kayit
                @if (seciliId > 0)
                {
                    <span> | Secili: <strong>@seciliKod</strong></span>
                }
            </span>

            <!-- Pagination -->
            <div style="display:flex; align-items:center; gap:4px;">
                <button class="btn btn-sm btn-outline" disabled="@(sayfa <= 1)" @onclick="() => SayfaDegistir(1)" title="Ilk Sayfa">
                    <i class="fa fa-angle-double-left"></i>
                </button>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa <= 1)" @onclick="() => SayfaDegistir(sayfa - 1)" title="Onceki Sayfa">
                    <i class="fa fa-angle-left"></i>
                </button>
                <span style="font-size:11px; padding:0 8px;">
                    Sayfa <strong>@sayfa</strong> / <strong>@toplamSayfa</strong>
                </span>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa >= toplamSayfa)" @onclick="() => SayfaDegistir(sayfa + 1)" title="Sonraki Sayfa">
                    <i class="fa fa-angle-right"></i>
                </button>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa >= toplamSayfa)" @onclick="() => SayfaDegistir(toplamSayfa)" title="Son Sayfa">
                    <i class="fa fa-angle-double-right"></i>
                </button>
                <select class="form-control" style="width:65px; margin-left:6px;" @bind="sayfaBoyutu" @bind:after="FiltreleVeYukle">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="250">250</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Dialog -->
@if (silOnayGoster)
{
    <div class="modal-overlay">
        <div class="modal-box" style="min-width:380px;">
            <div class="modal-header">
                <span><i class="fa fa-exclamation-triangle"></i> Silme Onayi</span>
                <button class="modal-close" @onclick="() => silOnayGoster = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size:13px;"><strong>@seciliKod</strong> kodlu stok kartini silmek istediginize emin misiniz?</p>
                <p style="font-size:11px; color:var(--pinebi-text-light);">Bu islem geri alinamaz (soft delete yapilir).</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-danger btn-sm" @onclick="SilOnayla"><i class="fa fa-trash"></i> Evet, Sil</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => silOnayGoster = false">Iptal</button>
            </div>
        </div>
    </div>
}

@code {
    // Data
    private List<StokKartDto> stoklar = new();
    private List<GrupDto> gruplar = new();

    // State
    private int seciliId = 0;
    private string seciliKod = "";
    private bool yukleniyor = false;
    private string? mesaj;
    private string mesajTip = "alert-info";
    private bool filtreGoster = false;
    private bool silOnayGoster = false;

    // Search & Filter
    private string aramaText = "";
    private string filtreGrup = "";
    private System.Timers.Timer? aramaTimer;

    // Pagination
    private int sayfa = 1;
    private int sayfaBoyutu = 50;
    private int toplamKayit = 0;
    private int toplamSayfa = 1;

    // Sorting
    private string siralamaKolon = "StoKod";
    private bool siralamaAsc = true;

    protected override async Task OnInitializedAsync()
    {
        await GruplariYukle();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Session'dan filtre state'ini geri yukle, sonra veri cek
            try
            {
                var savedArama = await JS.InvokeAsync<string?>("sessionStorage.getItem", "stok_arama");
                var savedGrup = await JS.InvokeAsync<string?>("sessionStorage.getItem", "stok_filtre_grup");
                var savedSayfa = await JS.InvokeAsync<string?>("sessionStorage.getItem", "stok_sayfa");
                aramaText = savedArama ?? "";
                filtreGrup = savedGrup ?? "";
                if (!string.IsNullOrEmpty(savedSayfa) && int.TryParse(savedSayfa, out var sp)) sayfa = sp;
                if (!string.IsNullOrEmpty(filtreGrup)) filtreGoster = true;
            }
            catch { }

            await VerileriYukle();
        }
    }

    private async Task FiltreKaydet()
    {
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", "stok_arama", aramaText ?? "");
            await JS.InvokeVoidAsync("sessionStorage.setItem", "stok_filtre_grup", filtreGrup ?? "");
            await JS.InvokeVoidAsync("sessionStorage.setItem", "stok_sayfa", sayfa.ToString());
        }
        catch { }
    }

    private async Task VerileriYukle()
    {
        try
        {
            yukleniyor = true;
            StateHasChanged();

            var url = $"api/stok/kartlar?sayfa={sayfa}&boyut={sayfaBoyutu}";
            if (!string.IsNullOrEmpty(aramaText))
                url += $"&arama={Uri.EscapeDataString(aramaText.Replace("*", "").Trim())}";
            if (!string.IsNullOrEmpty(filtreGrup))
                url += $"&grup={Uri.EscapeDataString(filtreGrup)}";

            var response = await Http.GetFromJsonAsync<PagedApiResponse<StokKartDto>>(url);
            if (response != null && response.Success)
            {
                stoklar = response.Data ?? new();
                toplamKayit = response.Toplam;
                toplamSayfa = response.ToplamSayfa > 0 ? response.ToplamSayfa : 1;

                // Client-side sort
                SiralamaUygula();
            }
            else
            {
                stoklar = new();
                MesajGoster(response?.Message ?? "Veri yuklenemedi", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            stoklar = new();
            MesajGoster($"Veri yuklenirken hata: {ex.Message}", "alert-danger");
        }
        finally
        {
            yukleniyor = false;
            await FiltreKaydet();
            StateHasChanged();
        }
    }

    private async Task GruplariYukle()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<GrupDto>>>("api/stok/gruplar?tip=1");
            if (response?.Success == true)
                gruplar = response.Data ?? new();
        }
        catch { }
    }

    // --- Events ---

    private void SecKayit(StokKartDto item)
    {
        seciliId = item.Id;
        seciliKod = item.StoKod;
    }

    private void CiftTikla(StokKartDto item)
    {
        TabSvc.OpenTab($"stok-kart-{item.Id}", $"{item.StoKod} - {item.StoIsim}", $"/pine/stok/kart/{item.Id}", "fa-cube");
        Nav.NavigateTo($"/pine/stok/kart/{item.Id}");
    }

    private void YeniKart()
    {
        TabSvc.OpenTab("stok-kart-yeni", "Yeni Stok", "/pine/stok/kart", "fa-plus-circle");
        Nav.NavigateTo("/pine/stok/kart");
    }

    private void DuzenleKart()
    {
        if (seciliId > 0)
        {
            TabSvc.OpenTab($"stok-kart-{seciliId}", $"{seciliKod}", $"/pine/stok/kart/{seciliId}", "fa-cube");
            Nav.NavigateTo($"/pine/stok/kart/{seciliId}");
        }
    }

    private void SilKart()
    {
        if (seciliId > 0) silOnayGoster = true;
    }

    private async Task SilOnayla()
    {
        try
        {
            silOnayGoster = false;
            var response = await Http.DeleteAsync($"api/stok/kart/{seciliId}");
            var result = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();

            if (result?.Success == true)
            {
                MesajGoster($"'{seciliKod}' basariyla silindi", "alert-success");
                seciliId = 0;
                seciliKod = "";
                await VerileriYukle();
            }
            else
            {
                MesajGoster(result?.Message ?? "Silme basarisiz", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Silme hatasi: {ex.Message}", "alert-danger");
        }
    }

    private void ToggleFiltre() => filtreGoster = !filtreGoster;

    private async Task FiltreTemizle()
    {
        filtreGrup = "";
        aramaText = "";
        sayfa = 1;
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "stok_arama");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "stok_filtre_grup");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "stok_sayfa");
        }
        catch { }
        await VerileriYukle();
    }

    private async Task AramaTemizle()
    {
        aramaText = "";
        sayfa = 1;
        await VerileriYukle();
    }

    private async Task FiltreleVeYukle()
    {
        sayfa = 1;
        await VerileriYukle();
    }

    private async Task AramaYap()
    {
        // Debounce: reset timer on each keystroke
        aramaTimer?.Stop();
        aramaTimer?.Dispose();
        aramaTimer = new System.Timers.Timer(400);
        aramaTimer.Elapsed += async (s, e) =>
        {
            aramaTimer?.Stop();
            await InvokeAsync(async () =>
            {
                sayfa = 1;
                await VerileriYukle();
            });
        };
        aramaTimer.AutoReset = false;
        aramaTimer.Start();
    }

    private async Task Yenile()
    {
        mesaj = null;
        await VerileriYukle();
    }

    private async Task SayfaDegistir(int yeniSayfa)
    {
        sayfa = yeniSayfa;
        await VerileriYukle();
    }

    // --- Sorting ---
    private void SiralamaYap(string kolon)
    {
        if (siralamaKolon == kolon)
            siralamaAsc = !siralamaAsc;
        else
        {
            siralamaKolon = kolon;
            siralamaAsc = true;
        }
        SiralamaUygula();
    }

    private void SiralamaUygula()
    {
        if (stoklar == null || !stoklar.Any()) return;
        stoklar = siralamaKolon switch
        {
            "StoKod" => siralamaAsc ? stoklar.OrderBy(s => s.StoKod).ToList() : stoklar.OrderByDescending(s => s.StoKod).ToList(),
            "StoIsim" => siralamaAsc ? stoklar.OrderBy(s => s.StoIsim).ToList() : stoklar.OrderByDescending(s => s.StoIsim).ToList(),
            "StoBirim1Ad" => siralamaAsc ? stoklar.OrderBy(s => s.StoBirim1Ad).ToList() : stoklar.OrderByDescending(s => s.StoBirim1Ad).ToList(),
            "StoAnagrupKod" => siralamaAsc ? stoklar.OrderBy(s => s.StoAnagrupKod).ToList() : stoklar.OrderByDescending(s => s.StoAnagrupKod).ToList(),
            "StoPerakendeVergi" => siralamaAsc ? stoklar.OrderBy(s => s.StoPerakendeVergi).ToList() : stoklar.OrderByDescending(s => s.StoPerakendeVergi).ToList(),
            "Fiyat" => siralamaAsc ? stoklar.OrderBy(s => s.Fiyat).ToList() : stoklar.OrderByDescending(s => s.Fiyat).ToList(),
            "StoMinStok" => siralamaAsc ? stoklar.OrderBy(s => s.StoMinStok).ToList() : stoklar.OrderByDescending(s => s.StoMinStok).ToList(),
            "StoMaxStok" => siralamaAsc ? stoklar.OrderBy(s => s.StoMaxStok).ToList() : stoklar.OrderByDescending(s => s.StoMaxStok).ToList(),
            "StoBarkod1" => siralamaAsc ? stoklar.OrderBy(s => s.StoBarkod1).ToList() : stoklar.OrderByDescending(s => s.StoBarkod1).ToList(),
            "StoPasifFl" => siralamaAsc ? stoklar.OrderBy(s => s.StoPasifFl).ToList() : stoklar.OrderByDescending(s => s.StoPasifFl).ToList(),
            _ => stoklar
        };
    }

    private string SiralamaIkon(string kolon)
    {
        if (siralamaKolon != kolon) return "";
        return siralamaAsc ? " \u25B2" : " \u25BC";
    }

    // --- Actions ---
    private async Task Yazdir()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ExcelExport()
    {
        MesajGoster("Excel export hazirlaniyour...", "alert-info");
        // TODO: Excel export via API
    }

    // --- Helpers ---
    private void MesajGoster(string text, string tip = "alert-info")
    {
        mesaj = text;
        mesajTip = tip;
    }

    // --- DTOs ---
    public class StokKartDto
    {
        public int Id { get; set; }
        public string StoKod { get; set; } = "";
        public string StoIsim { get; set; } = "";
        public string StoBirim1Ad { get; set; } = "";
        public string? StoAnagrupKod { get; set; }
        public decimal StoPerakendeVergi { get; set; }
        public decimal StoMinStok { get; set; }
        public decimal StoMaxStok { get; set; }
        public string? StoBarkod1 { get; set; }
        public bool StoPasifFl { get; set; }
        public bool RecKilitli { get; set; }
        public decimal Fiyat { get; set; }
    }

    public class GrupDto
    {
        public int Id { get; set; }
        public int SgrTip { get; set; }
        public string SgrKod { get; set; } = "";
        public string SgrIsim { get; set; } = "";
    }
}
