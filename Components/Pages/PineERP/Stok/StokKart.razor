                                        <tr>
                                            <td style="text-align:center; color:#9ca3af;">@(idx + 1)</td>
                                            <td>
                                                <select class="form-control" @bind="f.SfyFiyatGrubu">
                                                    @for (int g = 1; g <= 5; g++)
                                                    {
                                                        var gv = g;
                                                        <option value="@gv">@gv</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-control" @bind="f.SfyDepoKod">
                                                    <option value="">Genel</option>
                                                    @foreach (var dp in depolar)
                                                    {
                                                        <option value="@dp.DepKod">@dp.DepIsim</option>
                                                    }
                                                </select>
