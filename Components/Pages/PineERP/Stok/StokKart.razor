@code {
    [Parameter] public int Id { get; set; }

    // Model
    private StokKartModel model = new();
    private List<FiyatModel> fiyatlar = new();

    // Autocomplete arama
    private List<StokAramaItem> kodArama = new();
    private List<StokAramaItem> isimArama = new();
    private System.Threading.CancellationTokenSource? kodAramaCts;
    private System.Threading.CancellationTokenSource? isimAramaCts;

    public class StokAramaItem
    {
        public int Id { get; set; }
        public string StoKod { get; set; } = "";
        public string StoIsim { get; set; } = "";
    }

    private Task KodDegisti() => AramaYap(model.StoKod ?? "", "kod");
    private Task IsimDegisti() => AramaYap(model.StoIsim ?? "", "isim");

    private void OnKodBlur() { CloseSuggestions("kod"); }
    private void OnIsimBlur() { CloseSuggestions("isim"); }

    private async Task AramaYap(string q, string alan)
    {
        var cts = new System.Threading.CancellationTokenSource();
        if (alan == "kod") { kodAramaCts?.Cancel(); kodAramaCts = cts; }
        else { isimAramaCts?.Cancel(); isimAramaCts = cts; }

        if (string.IsNullOrWhiteSpace(q) || q.Length < 2)
        {
            if (alan == "kod") kodArama.Clear(); else isimArama.Clear();
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(250, cts.Token);
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<StokAramaItem>>>(
                $"api/stok/ara?q={Uri.EscapeDataString(q)}&alan={alan}&limit=15", cts.Token);
            if (cts.Token.IsCancellationRequested) return;
            var list = resp?.Data ?? new();

            // Kod alaninda tam eslesme veya tek sonuc varsa otomatik sec
            if (alan == "kod")
            {
                var tam = list.FirstOrDefault(s => string.Equals(s.StoKod, q, StringComparison.OrdinalIgnoreCase));
                // Tam kod eslesmesi VEYA tek sonuc (barkod okutuldugunda tek sonuc gelir)
                var secilecek = tam ?? (list.Count == 1 ? list[0] : null);
                if (secilecek != null)
                {
                    kodArama.Clear();
                    StateHasChanged();
                    StokSec(secilecek);
                    return;
                }
                kodArama = list;
            }
            else
            {
                isimArama = list;
            }
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
        catch (Exception ex) { Console.WriteLine($"StokArama hata: {ex.Message}"); }
    }

    private void CloseSuggestions(string alan)
    {
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(150);
            if (alan == "kod") kodArama.Clear(); else isimArama.Clear();
            StateHasChanged();
        });
    }

    private void StokSec(StokAramaItem s)
    {
        kodArama.Clear();
        isimArama.Clear();
        Nav.NavigateTo($"/pine/stok/kart/{s.Id}", forceLoad: false);
    }

    // Depolar
    private List<DepoItem> depolar = new();

    // Barkodlar
    private List<BarkodModel> barkodlar = new();
    private BarkodModel barkodForm = new();

    // Grup lookup cache (tip -> liste)
    private Dictionary<int, List<GrupDto>> lookups = new();
    private List<GrupDto> L(int tip) => lookups.TryGetValue(tip, out var l) ? l : new List<GrupDto>();

    private string GrupDisplayValue(int tip, string? kod)
    {
        if (string.IsNullOrEmpty(kod)) return "";
        var g = L(tip).FirstOrDefault(x => x.SgrKod == kod);
        return g != null ? $"{g.SgrKod} - {g.SgrIsim}" : kod;
    }

    private void GrupInputChanged(int tip, string? inputVal, Action<string> setter)
    {
        if (string.IsNullOrWhiteSpace(inputVal)) { setter(""); return; }
        // "KOD - ISIM" formatindan KOD'u cikar
        var kod = inputVal.Contains(" - ") ? inputVal.Split(" - ")[0].Trim() : inputVal.Trim();
        var match = L(tip).FirstOrDefault(x => x.SgrKod == kod);
        setter(match != null ? match.SgrKod : kod);
    }

    private RenderFragment GrupDropdown(string label, int tip, string? currentValue, Action<string> setter) => __builder =>
    {
        <div class="form-row">
            <div class="form-inline">
                <label>@label</label>
                <select class="form-control" value="@currentValue"
                        @onchange="@(e => setter(e.Value?.ToString() ?? ""))">
                    <option value="">-- Sec --</option>
                    @foreach (var g in L(tip))
                    {
                        <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                    }
                </select>
                <button type="button" class="btn btn-sm btn-outline" title="Yonet" @onclick="@(() => Nav.NavigateTo($"/pine/tanimlar/stokgruplari?tip={tip}"))"><i class="fa fa-cog"></i></button>
            </div>
        </div>
    };
    private List<BirimDto> birimler = new();
    private List<GrupDto> gruplar = new();

    // Grup listeleri (filtrelenmis)
    private List<GrupDto> anaGruplar = new();
    private List<GrupDto> altGruplar = new();
    private List<GrupDto> kategoriler = new();
    private List<GrupDto> markalar = new();
    private List<GrupDto> sektorler = new();

    // Grup ekleme modal
    private bool grupEkleAcik = false;
    private int grupEkleTip = 1;
    private string grupTipAdi => grupEkleTip switch { 1 => "Ana Grup", 2 => "Alt Grup", 3 => "Kategori", 4 => "Marka", 5 => "Sektor", _ => "Grup" };
    private string yeniGrupKod = "";
    private string yeniGrupIsim = "";

    // Birim listesi (dropdown icin)
    private List<string> birimListesi = new();

    // KDV oranlari (DB'den)
    private List<decimal> kdvOranlari = new() { 0m, 1m, 10m, 20m };
    private bool birimEkleAcik = false;
    private string yeniBirimKod = "";
    private string yeniBirimIsim = "";

    // State
    private int aktifTab = 0;
    private bool yukleniyor = false;
    private bool kaydediliyor = false;
    private string? mesaj;
    private string mesajTip = "alert-info";

    private int _lastLoadedId = -1;

    protected override async Task OnInitializedAsync()
    {
        await YardimciVerileriYukle();
        await KdvOranlariYukle();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _lastLoadedId)
        {
            _lastLoadedId = Id;
            if (Id > 0)
            {
                await KartYukle();
            }
            else
            {
                model = new StokKartModel();
                fiyatlar = new();
                barkodlar = new();
            }
        }
    }

    private async Task KdvOranlariYukle()
    {
        try
        {
            using var ndb = await NetworkFactory.CreateDbContextAsync();
            var list = await ndb.KdvOranlari.OrderBy(k => k.KdvOrani).ToListAsync();
            if (list.Any())
                kdvOranlari = list.Where(k => k.KdvOrani.HasValue).Select(k => (decimal)k.KdvOrani!.Value).ToList();
        }
        catch { }
    }

    private async Task YardimciVerileriYukle()
    {
        try
        {
            // Birimler
            var brResp = await Http.GetFromJsonAsync<ApiResponse<List<BirimDto>>>("api/tanimlar/birimler");
            if (brResp?.Success == true)
            {
                birimler = brResp.Data ?? new();
                birimListesi = birimler.Select(b => b.BirKod).ToList();
            }

            // Depolar
            try
            {
                var dpResp = await Http.GetFromJsonAsync<ApiResponse<List<DepoItem>>>("api/stok/depolar");
                if (dpResp?.Success == true) depolar = dpResp.Data ?? new();
            }
            catch { }

            // Gruplar - tum tipler
            var grResp = await Http.GetFromJsonAsync<ApiResponse<List<GrupDto>>>("api/stok/gruplar");
            if (grResp?.Success == true)
            {
                gruplar = grResp.Data ?? new();
                GruplariFiltreUygula();

                // Tip bazinda lookup cache
                lookups = gruplar.GroupBy(g => g.SgrTip).ToDictionary(g => g.Key, g => g.OrderBy(x => x.SgrKod).ToList());
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Yardimci veriler yuklenemedi: {ex.Message}");
        }
    }

    private void GruplariFiltreUygula()
    {
        anaGruplar = gruplar.Where(g => g.SgrTip == 1).ToList();
        altGruplar = gruplar.Where(g => g.SgrTip == 2).ToList();
        kategoriler = gruplar.Where(g => g.SgrTip == 3).ToList();
        markalar = gruplar.Where(g => g.SgrTip == 4).ToList();
        sektorler = gruplar.Where(g => g.SgrTip == 5).ToList();
    }

    // Grup ekleme
    private void GrupEkleAc(int tip) { grupEkleTip = tip; yeniGrupKod = ""; yeniGrupIsim = ""; grupEkleAcik = true; }

    private async Task GrupKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniGrupKod) || string.IsNullOrWhiteSpace(yeniGrupIsim)) return;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/stok/grup", new { SgrTip = grupEkleTip, SgrKod = yeniGrupKod, SgrIsim = yeniGrupIsim, SgrAktif = true });
            if (resp.IsSuccessStatusCode)
            {
                // Listeyi yeniden yukle
                var grResp = await Http.GetFromJsonAsync<ApiResponse<List<GrupDto>>>("api/stok/gruplar");
                if (grResp?.Success == true)
                {
                    gruplar = grResp.Data ?? new();
                    GruplariFiltreUygula();
                }
                grupEkleAcik = false;
            }
        }
        catch { }
    }

    // Birim ekleme
    private void BirimEkleAc() { yeniBirimKod = ""; yeniBirimIsim = ""; birimEkleAcik = true; }

    private async Task BirimKaydet()
    {
        if (string.IsNullOrWhiteSpace(yeniBirimKod)) return;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/tanimlar/birimler", new { BirKod = yeniBirimKod, BirIsim = string.IsNullOrWhiteSpace(yeniBirimIsim) ? yeniBirimKod : yeniBirimIsim, BirAktif = true });
            if (resp.IsSuccessStatusCode)
            {
                var brResp = await Http.GetFromJsonAsync<ApiResponse<List<BirimDto>>>("api/tanimlar/birimler");
                if (brResp?.Success == true)
                {
                    birimler = brResp.Data ?? new();
                    birimListesi = birimler.Select(b => b.BirKod).ToList();
                }
                birimEkleAcik = false;
            }
        }
        catch { }
    }

    private async Task KartYukle()
    {
        try
        {
            yukleniyor = true;
            StateHasChanged();

            var response = await Http.GetFromJsonAsync<ApiResponse<StokKartModel>>($"api/stok/kart/{Id}");
            if (response?.Success == true && response.Data != null)
            {
                model = response.Data;
            }
            else
            {
                MesajGoster(response?.Message ?? "Stok karti bulunamadi", "alert-danger");
            }

            // Fiyatlari yukle
            try
            {
                var fResp = await Http.GetFromJsonAsync<ApiResponse<List<FiyatModel>>>($"api/stok/fiyatlar/{Id}");
                if (fResp?.Success == true)
                    fiyatlar = fResp.Data ?? new();
            }
            catch { }

            // Barkodlari yukle
            await BarkodlariYukle();
        }
        catch (Exception ex)
        {
            MesajGoster($"Yukleme hatasi: {ex.Message}", "alert-danger");
        }
        finally
        {
            yukleniyor = false;
            StateHasChanged();
        }
    }

    // ===== BARKODLAR =====
    private async Task BarkodlariYukle()
    {
        if (Id <= 0) { barkodlar = new(); return; }
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<BarkodModel>>>($"api/stok/barkodlar/{Id}");
            if (resp?.Success == true) barkodlar = resp.Data ?? new();
        }
        catch { barkodlar = new(); }
    }

    private void BarkodFormTemizle()
    {
        barkodForm = new BarkodModel { SbkStokId = Id, SbkStokKod = model.StoKod };
    }

    private void BarkodSec(BarkodModel b)
    {
        barkodForm = new BarkodModel
        {
            Id = b.Id, SbkStokId = b.SbkStokId, SbkStokKod = b.SbkStokKod,
            SbkBaglantiTipi = b.SbkBaglantiTipi, SbkPartiKodu = b.SbkPartiKodu, SbkLotNo = b.SbkLotNo,
            SbkSeriNo = b.SbkSeriNo, SbkAsortiKodu = b.SbkAsortiKodu,
            SbkBarkodTipi = b.SbkBarkodTipi, SbkIcerik = b.SbkIcerik, SbkKodu = b.SbkKodu,
            SbkBirimi = b.SbkBirimi, SbkBedeni = b.SbkBedeni, SbkRengi = b.SbkRengi, SbkMaster = b.SbkMaster
        };
    }

    private async Task BarkodEkle()
    {
        if (Id <= 0)
        {
            MesajGoster("Once stok kartini kaydedin", "alert-warning");
            return;
        }
        if (string.IsNullOrWhiteSpace(barkodForm.SbkKodu))
        {
            MesajGoster("Barkod kodu bos olamaz", "alert-warning");
            return;
        }
        try
        {
            barkodForm.SbkStokId = Id;
            barkodForm.SbkStokKod = model.StoKod;
            var resp = await Http.PostAsJsonAsync("api/stok/barkod", barkodForm);
            if (resp.IsSuccessStatusCode)
            {
                BarkodFormTemizle();
                await BarkodlariYukle();
                MesajGoster("Barkod eklendi", "alert-success");
            }
        }
        catch (Exception ex) { MesajGoster($"Barkod eklenemedi: {ex.Message}", "alert-danger"); }
    }

    private async Task BarkodGuncelle()
    {
        if (barkodForm.Id <= 0) return;
        try
        {
            var resp = await Http.PutAsJsonAsync($"api/stok/barkod/{barkodForm.Id}", barkodForm);
            if (resp.IsSuccessStatusCode)
            {
                BarkodFormTemizle();
                await BarkodlariYukle();
                MesajGoster("Barkod guncellendi", "alert-success");
            }
        }
        catch (Exception ex) { MesajGoster($"Barkod guncellenemedi: {ex.Message}", "alert-danger"); }
    }

    private async Task BarkodSil(int id)
    {
        var bk = barkodlar.FirstOrDefault(b => b.Id == id);
        var kod = bk?.SbkKodu ?? "bu barkod";
        if (!await Confirm.AskAsync($"{kod} barkodunu silmek istediginize emin misiniz?", "Barkod Sil")) return;
        try
        {
            var resp = await Http.DeleteAsync($"api/stok/barkod/{id}");
            if (resp.IsSuccessStatusCode)
            {
                if (barkodForm.Id == id) BarkodFormTemizle();
                await BarkodlariYukle();
                MesajGoster("Barkod silindi", "alert-success");
            }
        }
        catch (Exception ex) { MesajGoster($"Barkod silinemedi: {ex.Message}", "alert-danger"); }
    }

    private async Task Kaydet()
    {
        try
        {
            // Validasyon
            if (string.IsNullOrWhiteSpace(model.StoKod))
            {
                MesajGoster("Stok kodu bos olamaz!", "alert-danger");
                aktifTab = 0;
                return;
            }
            if (string.IsNullOrWhiteSpace(model.StoIsim))
            {
                MesajGoster("Stok ismi bos olamaz!", "alert-danger");
                aktifTab = 0;
                return;
            }

            kaydediliyor = true;
            StateHasChanged();

            HttpResponseMessage response;

            if (Id > 0)
            {
                // Guncelle
                response = await Http.PutAsJsonAsync($"api/stok/kart/{Id}", model);
            }
            else
            {
                // Yeni
                response = await Http.PostAsJsonAsync("api/stok/kart", model);
            }

            var result = await response.Content.ReadFromJsonAsync<ApiResponse<StokKartModel>>();

            if (result?.Success == true)
            {
                // Fiyatlari kaydet
                foreach (var f in fiyatlar)
                {
                    f.SfyStokKod = model.StoKod;
                    try
                    {
                        await Http.PostAsJsonAsync("api/stok/fiyat", f);
                    }
                    catch { }
                }

                MesajGoster("Kayit basariyla tamamlandi!", "alert-success");

                // Yeni kayitsa ID'yi guncelle
                if (Id == 0 && result.Data != null)
                {
                    Nav.NavigateTo($"/pine/stok/kart/{result.Data.Id}", replace: true);
                }
            }
            else
            {
                MesajGoster(result?.Message ?? "Kayit basarisiz", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            MesajGoster($"Kayit hatasi: {ex.Message}", "alert-danger");
        }
        finally
        {
            kaydediliyor = false;
            StateHasChanged();
        }
    }

    private void YeniKayit()
    {
        Nav.NavigateTo("/pine/stok/kart", forceLoad: true);
    }

    private void BenzerKayitOlustur()
    {
        // Clone: tum degerleri koru, ID sifirla, stok kodu ve barkodlari temizle
        model.Id = 0;
        model.StoKod = "";
        model.StoBarkod1 = "";
        model.StoBarkod2 = "";
        model.StoBarkod3 = "";

        // Fiyatlari da klonla (ID sifirla)
        foreach (var f in fiyatlar) { f.Id = 0; }

        // Barkodlari temizle (klonlanmaz, yeni girilmeli)
        barkodlar = new();
        barkodForm = new();

        // Yeni kayit moduna gec
        Id = 0;
        aktifTab = 0; // Genel Bilgiler'e don (stok kodu girilmeli)
        MesajGoster("Benzer kayit olusturuldu. Stok kodu ve barkod bilgilerini girmeniz zorunludur.", "alert-warning");
        StateHasChanged();
    }

    private void Kapat()
    {
        Nav.NavigateTo("/pine/stok/kartlar");
    }

    // Fiyat islemleri
    private void FiyatEkle()
    {
        var nextGrup = fiyatlar.Any() ? fiyatlar.Max(f => f.SfyFiyatGrubu) + 1 : 1;
        fiyatlar.Add(new FiyatModel
        {
            SfyFiyatGrubu = nextGrup,
            SfyDovizKodu = "TL",
            SfyKdvOrani = model.StoPerakendeVergi,
            SfyAktif = true
        });
    }

    private void FiyatSil(int idx)
    {
        if (idx >= 0 && idx < fiyatlar.Count) fiyatlar.RemoveAt(idx);
    }

    private void MesajGoster(string text, string tip = "alert-info")
    {
        mesaj = text;
        mesajTip = tip;
    }

