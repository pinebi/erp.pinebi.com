                                            <td><input type="number" class="form-control text-right" @bind="f.SfyIskontoOrani1" step="0.01" /></td>
                                            <td><input type="date" class="form-control" @bind="f.SfyGecerlilikBaslangic" /></td>
                                            <td><input type="date" class="form-control" @bind="f.SfyGecerlilikBitis" /></td>
                                            <td style="text-align:center;"><input type="checkbox" @bind="f.SfyAktif" /></td>
                                            <td><button class="btn btn-danger btn-sm" @onclick="() => FiyatSil(idx)" title="Sil">×</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
