@page "/pine/stok/kart"
@page "/pine/stok/kart/{Id:int}"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@inject MACHINEBISS_Web.Services.ConfirmService Confirm
@inject IDbContextFactory<MACHINEBISS_Web.Db.NetworkContext> NetworkFactory
@using System.Net.Http.Json
@using Microsoft.EntityFrameworkCore
@using MACHINEBISS_Web.Controllers.Api

<PageTitle>Stok Kart @(Id > 0 ? "- Duzenle" : "- Yeni") - PineERP</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-cube"></i> Stok Kart @(Id > 0 ? $"- Duzenle [{model.StoKod}]" : "- Yeni Kayit")
    </div>
    <div class="card-body pine-stok-form" style="padding:8px 14px;">
        <style>
            .pine-stok-form .form-row { align-items: center; margin-bottom: 10px; }
            .pine-stok-form .form-inline { flex: 1; min-width: 0; }
            .pine-stok-form .form-inline label { min-width: 130px; max-width: 130px; font-size: 12px; font-weight: 600; }
            .pine-stok-form .form-inline .form-control { flex: 1; max-width: none; width: 100%; }
            .pine-stok-form .group-box { padding: 16px 14px 12px; }
            .pine-stok-form .picker-btn { flex: 0 0 32px; }
            .pine-stok-form .katsayi-input { flex: 0 0 80px; max-width: 80px; text-align: center; }
            .pine-stok-form .katsayi-label { flex: 0 0 auto; min-width: auto !important; max-width: none !important; font-size: 11px; color: #94a3b8; }
            .pine-stok-form .add-btn { flex: 0 0 32px; background: #235881; color: white; border: 1px solid #235881; border-radius: 4px; padding: 6px 8px; cursor: pointer; }
            .pine-stok-form .add-btn:hover { background: #1d486a; }
            .stok-suggest { position: absolute; top: 100%; left: 130px; right: 0; z-index: 1000; background: #fff; border: 1px solid #cbd5e1; border-top: none; max-height: 260px; overflow-y: auto; box-shadow: 0 4px 10px rgba(0,0,0,.08); }
            .stok-suggest-item { padding: 6px 10px; cursor: pointer; font-size: 12px; border-bottom: 1px solid #f1f5f9; }
            .stok-suggest-item:hover { background: #e8f2fb; }
            .stok-suggest-item b { color: #235881; }
        </style>

        <!-- Mesaj -->
        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div class="alert @mesajTip" style="margin-bottom:8px;">
                @mesaj
                <button style="float:right; background:none; border:none; cursor:pointer; font-weight:bold;" @onclick="() => mesaj = null">&times;</button>
            </div>
        }

        @if (yukleniyor)
        {
            <div style="text-align:center; padding:60px; color:var(--pinebi-text-light);">
                <i class="fa fa-spinner fa-spin" style="font-size:24px;"></i>
                <p style="margin-top:8px;">Yukleniyor...</p>
            </div>
        }
        else
        {
            <!-- TABS -->
            <div class="xtab">
                <div class="xtab-header">
                    <div class="xtab-header-item @(aktifTab == 0 ? "active" : "")" @onclick="() => aktifTab = 0">
                        <i class="fa fa-info-circle"></i> Genel Bilgiler
                    </div>
                    <div class="xtab-header-item @(aktifTab == 1 ? "active" : "")" @onclick="() => aktifTab = 1">
                        <i class="fa fa-arrows-alt"></i> Olcu / Seviye
                    </div>
                    <div class="xtab-header-item @(aktifTab == 2 ? "active" : "")" @onclick="() => aktifTab = 2">
                        <i class="fa fa-barcode"></i> Barkod
                    </div>
                    <div class="xtab-header-item @(aktifTab == 3 ? "active" : "")" @onclick="() => aktifTab = 3">
                        <i class="fa fa-tag"></i> Fiyatlar
                    </div>
                    <div class="xtab-header-item @(aktifTab == 6 ? "active" : "")" @onclick="() => aktifTab = 6">
                        <i class="fa fa-clipboard-check"></i> Takip Detaylari
                    </div>
                    <div class="xtab-header-item @(aktifTab == 7 ? "active" : "")" @onclick="() => aktifTab = 7">
                        <i class="fa fa-calculator"></i> Entegrasyon Kodlari
                    </div>
                    <div class="xtab-header-item @(aktifTab == 8 ? "active" : "")" @onclick="() => aktifTab = 8">
                        <i class="fa fa-layer-group"></i> Grup Tanitim
                    </div>
                    <div class="xtab-header-item @(aktifTab == 9 ? "active" : "")" @onclick="() => aktifTab = 9">
                        <i class="fa fa-flag"></i> Pozisyon Bayraklari
                    </div>
                    <div class="xtab-header-item @(aktifTab == 5 ? "active" : "")" @onclick="() => aktifTab = 5">
                        <i class="fa fa-sticky-note"></i> Aciklamalar
                    </div>
                </div>
                <div class="xtab-body">

                    @* ===== TAB 0: GENEL BILGILER ===== *@
                    @if (aktifTab == 0)
                    {
                        <div style="display:flex; gap:20px; flex-wrap:wrap;">
                            <!-- Sol Kolon -->
                            <div style="flex:1; min-width:420px;">
                                <div class="group-box">
                                    <span class="group-box-title">Temel Bilgiler</span>
                                    <div class="form-row">
                                        <div class="form-inline" style="position:relative;">
                                            <label>Stok Kodu</label>
                                            <input type="text" class="form-control"
                                                   @bind="model.StoKod"
                                                   @bind:event="oninput"
                                                   @bind:after="KodDegisti"
                                                   @onblur="OnKodBlur"
                                                   maxlength="25"
                                                   autocomplete="off" />
                                            @if (kodArama.Count > 0)
                                            {
                                                <div class="stok-suggest">
                                                    @foreach (var s in kodArama)
                                                    {
                                                        var sec = s;
                                                        <div class="stok-suggest-item" @onmousedown="@(() => StokSec(sec))">
                                                            <b>@sec.StoKod</b> - @sec.StoIsim
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <div class="form-check" style="margin-left:10px;">
                                            <input type="checkbox" @bind="model.StoPasifFl" />
                                            <label>Pasif</label>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline" style="position:relative;">
                                            <label>Stok Ismi</label>
                                            <input type="text" class="form-control"
                                                   @bind="model.StoIsim"
                                                   @bind:event="oninput"
                                                   @bind:after="IsimDegisti"
                                                   @onblur="OnIsimBlur"
                                                   maxlength="200"
                                                   autocomplete="off" />
                                            @if (isimArama.Count > 0)
                                            {
                                                <div class="stok-suggest">
                                                    @foreach (var s in isimArama)
                                                    {
                                                        var sec = s;
                                                        <div class="stok-suggest-item" @onmousedown="@(() => StokSec(sec))">
                                                            <b>@sec.StoKod</b> - @sec.StoIsim
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Kisa Isim</label>
                                            <input type="text" class="form-control" @bind="model.StoKisaIsim" maxlength="50" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Yabanci Isim</label>
                                            <input type="text" class="form-control" @bind="model.StoYabanciIsim" maxlength="200" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Stok Cinsi</label>
                                            <select class="form-control" @bind="model.StoCins">
                                                <option value="0">Mamul</option>
                                                <option value="1">Ticari Mal</option>
                                                <option value="2">Hammadde</option>
                                                <option value="3">Yari Mamul</option>
                                                <option value="4">Hizmet</option>
                                                <option value="5">Diger</option>
                                                <option value="6">Ambalaj</option>
                                                <option value="7">Demirbas</option>
                                                <option value="8">Masraf</option>
                                                <option value="9">Sarf Malzeme</option>
                                                <option value="10">Proje</option>
                                                <option value="11">Sanal</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="group-box">
                                    <span class="group-box-title">Birim Bilgileri</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Birim 1</label>
                                            <select class="form-control" @bind="model.StoBirim1Ad">
                                                <option value="">-- Sec --</option>
                                                @foreach (var b in birimListesi)
                                                {
                                                    <option value="@b">@b</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="BirimEkleAc" title="Yeni Birim Ekle"><i class="fa fa-plus"></i></button>
                                            <span class="katsayi-label">Katsayi</span>
                                            <input type="number" class="form-control katsayi-input" value="1" readonly style="background:#f1f5f9;" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Birim 2</label>
                                            <select class="form-control" @bind="model.StoBirim2Ad">
                                                <option value="">-- Sec --</option>
                                                @foreach (var b in birimListesi)
                                                {
                                                    <option value="@b">@b</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="BirimEkleAc" title="Yeni Birim Ekle"><i class="fa fa-plus"></i></button>
                                            <span class="katsayi-label">Katsayi</span>
                                            <input type="number" class="form-control katsayi-input" @bind="model.StoBirim2Katsayi" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Birim 3</label>
                                            <select class="form-control" @bind="model.StoBirim3Ad">
                                                <option value="">-- Sec --</option>
                                                @foreach (var b in birimListesi)
                                                {
                                                    <option value="@b">@b</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="BirimEkleAc" title="Yeni Birim Ekle"><i class="fa fa-plus"></i></button>
                                            <span class="katsayi-label">Katsayi</span>
                                            <input type="number" class="form-control katsayi-input" @bind="model.StoBirim3Katsayi" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Birim 4</label>
                                            <select class="form-control" @bind="model.StoBirim4Ad">
                                                <option value="">-- Sec --</option>
                                                @foreach (var b in birimListesi)
                                                {
                                                    <option value="@b">@b</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="BirimEkleAc" title="Yeni Birim Ekle"><i class="fa fa-plus"></i></button>
                                            <span class="katsayi-label">Katsayi</span>
                                            <input type="number" class="form-control katsayi-input" @bind="model.StoBirim4Katsayi" step="0.01" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Sag Kolon -->
                            <div style="flex:1; min-width:420px;">
                                <div class="group-box">
                                    <span class="group-box-title">Siniflandirma</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Ana Grup</label>
                                            <select class="form-control" @bind="model.StoAnagrupKod">
                                                <option value="">-- Sec --</option>
                                                @foreach (var g in anaGruplar)
                                                {
                                                    <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="() => GrupEkleAc(1)" title="Yeni Ana Grup Ekle"><i class="fa fa-plus"></i></button>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Alt Grup</label>
                                            <select class="form-control" @bind="model.StoAltgrupKod">
                                                <option value="">-- Sec --</option>
                                                @foreach (var g in altGruplar)
                                                {
                                                    <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="() => GrupEkleAc(2)" title="Yeni Alt Grup Ekle"><i class="fa fa-plus"></i></button>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Kategori</label>
                                            <select class="form-control" @bind="model.StoKategoriKodu">
                                                <option value="">-- Sec --</option>
                                                @foreach (var g in kategoriler)
                                                {
                                                    <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="() => GrupEkleAc(3)" title="Yeni Kategori Ekle"><i class="fa fa-plus"></i></button>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Marka</label>
                                            <select class="form-control" @bind="model.StoMarkaKodu">
                                                <option value="">-- Sec --</option>
                                                @foreach (var g in markalar)
                                                {
                                                    <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="() => GrupEkleAc(4)" title="Yeni Marka Ekle"><i class="fa fa-plus"></i></button>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Sektor</label>
                                            <select class="form-control" @bind="model.StoSektorKodu">
                                                <option value="">-- Sec --</option>
                                                @foreach (var g in sektorler)
                                                {
                                                    <option value="@g.SgrKod">@g.SgrKod - @g.SgrIsim</option>
                                                }
                                            </select>
                                            <button type="button" class="add-btn" @onclick="() => GrupEkleAc(5)" title="Yeni Sektor Ekle"><i class="fa fa-plus"></i></button>
                                        </div>
                                    </div>
                                </div>

                                <div class="group-box">
                                    <span class="group-box-title">Vergi Bilgileri</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Perakende KDV %</label>
                                            <select class="form-control" value="@((int)model.StoPerakendeVergi)" @onchange="@(e => model.StoPerakendeVergi = int.Parse(e.Value?.ToString() ?? "20"))">
                                                @foreach (var k in kdvOranlari)
                                                {
                                                    <option value="@((int)k)">%@((int)k)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-inline">
                                            <label>Toptan KDV %</label>
                                            <select class="form-control" value="@((int)model.StoToptanVergi)" @onchange="@(e => model.StoToptanVergi = int.Parse(e.Value?.ToString() ?? "20"))">
                                                @foreach (var k in kdvOranlari)
                                                {
                                                    <option value="@((int)k)">%@((int)k)</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>OTV Uygulama</label>
                                            <select class="form-control" @bind="model.StoOtvUygulama">
                                                <option value="0">Yok</option>
                                                <option value="1">Yuzde</option>
                                                <option value="2">Tutar</option>
                                            </select>
                                        </div>
                                        <div class="form-inline">
                                            <label>OTV Tutari</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoOtvTutari" step="0.01" />
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    }

                    @* ===== TAB 1: OLCU / BOYUT + STOK SEVIYE (birlesik) ===== *@
                    @if (aktifTab == 1)
                    {
                        <div style="display:flex; gap:20px; flex-wrap:wrap;">
                            <div style="flex:1; min-width:420px;">
                                <div class="group-box">
                                    <span class="group-box-title">Olcu ve Agirlik Bilgileri</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Agirlik (kg)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoBirimAgirlik" step="0.001" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>En (cm)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoBirimEn" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Boy (cm)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoBirimBoy" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Yukseklik (cm)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoBirimYukseklik" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Hacim (m³)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoBirimHacim" step="0.0001" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="flex:1; min-width:420px;">
                                <div class="group-box">
                                    <span class="group-box-title">Stok Seviye Tanimlari</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Minimum Stok</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoMinStok" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Maksimum Stok</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoMaxStok" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Siparis Noktasi</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoSiparisStok" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Hedef Stok</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoHedefStok" step="0.01" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Siparis Suresi (gun)</label>
                                            <input type="number" class="form-control text-right" @bind="model.StoSiparisSure" step="1" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* ===== TAB 2: BARKOD TANITIM KARTI (Mikro) ===== *@
                    @if (aktifTab == 2)
                    {
                        <div style="display:flex; gap:20px; flex-wrap:wrap;">
                            <!-- Sol: Form -->
                            <div style="flex:1; min-width:480px;">
                                <div class="group-box">
                                    <span class="group-box-title">Barkod Tanitim Karti</span>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Baglanti Tipi</label>
                                            <select class="form-control" @bind="barkodForm.SbkBaglantiTipi">
                                                <option value="Stok barkodu">Stok barkodu</option>
                                                <option value="Cari barkodu">Cari barkodu</option>
                                                <option value="Hizmet barkodu">Hizmet barkodu</option>
                                                <option value="Sabit kiymet barkodu">Sabit kiymet barkodu</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Baglantili Kodu</label>
                                            <input type="text" class="form-control" value="@model.StoKod" disabled />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Baglantili Adi</label>
                                            <input type="text" class="form-control" value="@model.StoIsim" disabled />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Parti Kodu</label>
                                            <input type="text" class="form-control" @bind="barkodForm.SbkPartiKodu" maxlength="50" />
                                        </div>
                                        <div class="form-inline">
                                            <label>Lot No</label>
                                            <input type="text" class="form-control" @bind="barkodForm.SbkLotNo" maxlength="50" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Seri No / Bag Kodu</label>
                                            <input type="text" class="form-control" @bind="barkodForm.SbkSeriNo" maxlength="50" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Asorti Tanim Kodu</label>
                                            <input type="text" class="form-control" @bind="barkodForm.SbkAsortiKodu" maxlength="50" />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Barkod Tipi</label>
                                            <select class="form-control" @bind="barkodForm.SbkBarkodTipi">
                                                <option value="EAN-13">EAN-13</option>
                                                <option value="EAN-8">EAN-8</option>
                                                <option value="UPC-A">UPC-A</option>
                                                <option value="UPC-E">UPC-E</option>
                                                <option value="Code-128">Code-128</option>
                                                <option value="Code-39">Code-39</option>
                                                <option value="ITF-14">ITF-14</option>
                                                <option value="QR">QR</option>
                                                <option value="Diger">Diger</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Icerik</label>
                                            <select class="form-control" @bind="barkodForm.SbkIcerik">
                                                <option value="Kod">Kod</option>
                                                <option value="Kod + miktar">Kod + miktar</option>
                                                <option value="Kod + birim fiyat">Kod + birim fiyat</option>
                                                <option value="Kod + tutar">Kod + tutar</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Kodu</label>
                                            <input type="text" class="form-control" @bind="barkodForm.SbkKodu" maxlength="50" placeholder="Barkod kodunu girin..." />
                                        </div>
                                    </div>
                                    <div class="form-row">
                                        <div class="form-inline">
                                            <label>Birimi</label>
                                            <select class="form-control" @bind="barkodForm.SbkBirimi">
