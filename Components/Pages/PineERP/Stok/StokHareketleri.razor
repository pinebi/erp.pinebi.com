@page "/pine/stok/hareketler"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Json
@using MACHINEBISS_Web.Controllers.Api

<PageTitle>Stok Hareketleri - PineERP</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-exchange"></i> Stok Hareketleri
    </div>
    <div class="card-body" style="padding:8px 14px;">
        <!-- Toolbar -->
        <div class="toolbar" style="margin-bottom:6px;">
            <button class="btn btn-outline btn-sm" @onclick="Yenile" title="Yenile">
                <i class="fa fa-refresh"></i> Yenile
            </button>
            <button class="btn btn-outline btn-sm" @onclick="Yazdir" title="Yazdir">
                <i class="fa fa-print"></i> Yazdir
            </button>
            <button class="btn btn-outline btn-sm" @onclick="ExcelExport" title="Excel">
                <i class="fa fa-file-excel-o"></i> Excel
            </button>
        </div>

        <!-- Filtre -->
        <div class="group-box" style="margin-bottom:8px; background:#f9fafb;">
            <span class="group-box-title">Filtre</span>
            <div class="form-row">
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:70px;">Stok Kodu:</label>
                    <input type="text" class="form-control" @bind="filtreStokKod" placeholder="STK-001" style="width:160px;" />
                </div>
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:auto;">Baslangic:</label>
                    <input type="date" class="form-control" @bind="filtreBaslangic" style="width:140px;" />
                </div>
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:auto;">Bitis:</label>
                    <input type="date" class="form-control" @bind="filtreBitis" style="width:140px;" />
                </div>
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:auto;">Tip:</label>
                    <select class="form-control" @bind="filtreTip" style="width:110px;">
                        <option value="">Tumu</option>
                        <option value="1">Giris</option>
                        <option value="2">Cikis</option>
                    </select>
                </div>
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:auto;">Depo:</label>
                    <select class="form-control" @bind="filtreDepo" style="width:130px;">
                        <option value="">Tumu</option>
                        @foreach (var d in depolar)
                        {
                            <option value="@d.Id">@d.DepKod - @d.DepIsim</option>
                        }
                    </select>
                </div>
                <div class="form-inline" style="flex:0 0 auto;">
                    <label style="min-width:auto;">Belge No:</label>
                    <input type="text" class="form-control" @bind="filtreBelgeNo" style="width:130px;" />
                </div>
                <button class="btn btn-primary btn-sm" @onclick="FiltreleVeYukle">
                    <i class="fa fa-search"></i> Ara
                </button>
                <button class="btn btn-outline btn-sm" @onclick="FiltreTemizle">
                    <i class="fa fa-times"></i> Temizle
                </button>
            </div>
        </div>

        <!-- Mesaj -->
        @if (!string.IsNullOrEmpty(mesaj))
        {
            <div class="alert @mesajTip" style="margin-bottom:6px;">
                @mesaj
                <button style="float:right; background:none; border:none; cursor:pointer; font-weight:bold;" @onclick="() => mesaj = null">&times;</button>
            </div>
        }

        <!-- Data Grid -->
        <div class="grid-container" style="max-height:calc(100vh - 340px);">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th style="width:30px;">#</th>
                        <th style="min-width:90px;">Tarih</th>
                        <th style="min-width:100px;">Stok Kodu</th>
                        <th style="min-width:180px;">Stok Ismi</th>
                        <th style="min-width:70px;">Tip</th>
                        <th style="min-width:70px;">Cins</th>
                        <th style="text-align:right; min-width:80px;">Miktar</th>
                        <th style="min-width:50px;">Birim</th>
                        <th style="text-align:right; min-width:90px;">Tutar</th>
                        <th style="min-width:90px;">Belge No</th>
                        <th style="min-width:60px;">Depo</th>
                        <th style="min-width:100px;">Cari Kod</th>
                        <th style="min-width:140px;">Aciklama</th>
                    </tr>
                </thead>
                <tbody>
                    @if (yukleniyor)
                    {
                        <tr><td colspan="13" style="text-align:center; padding:40px; color:var(--pinebi-text-light);">
                            <i class="fa fa-spinner fa-spin"></i> Yukleniyor...
                        </td></tr>
                    }
                    else if (hareketler == null || !hareketler.Any())
                    {
                        <tr><td colspan="13" style="text-align:center; padding:40px; color:var(--pinebi-text-light);">
                            <i class="fa fa-inbox"></i> Kayit bulunamadi. Filtreleri doldurup "Ara" butonuna basin.
                        </td></tr>
                    }
                    else
                    {
                        @foreach (var (h, idx) in hareketler.Select((x, i) => (x, i)))
                        {
                            <tr class="@(seciliId == h.Id ? "selected" : "")" @onclick="() => seciliId = h.Id" style="cursor:pointer;">
                                <td style="text-align:center; color:var(--pinebi-text-light);">@((sayfa - 1) * sayfaBoyutu + idx + 1)</td>
                                <td>@h.SthTarih.ToString("dd.MM.yyyy")</td>
                                <td><strong>@h.SthStokKod</strong></td>
                                <td>@stokIsimleri.GetValueOrDefault(h.SthStokKod, "-")</td>
                                <td>
                                    @if (h.SthTip == 1)
                                    {
                                        <span style="color:#16a34a; font-weight:600;"><i class="fa fa-arrow-down"></i> Giris</span>
                                    }
                                    else
                                    {
                                        <span style="color:#dc2626; font-weight:600;"><i class="fa fa-arrow-up"></i> Cikis</span>
                                    }
                                </td>
                                <td>@HareketCinsiAdi(h.SthCins)</td>
                                <td style="text-align:right; font-weight:600;">@h.SthMiktar.ToString("N2")</td>
                                <td>@h.SthBirim</td>
                                <td style="text-align:right;">@h.SthTutar.ToString("N2")</td>
                                <td>@h.SthBelgeNo</td>
                                <td>@h.SthDepoNo</td>
                                <td>@h.SthCariKod</td>
                                <td>@h.SthAciklama1</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer: Toplamlar + Sayfalama -->
        <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-top:1px solid var(--pinebi-border); margin-top:4px;">
            <div style="display:flex; gap:16px; font-size:11px;">
                <span><i class="fa fa-database"></i> Toplam: <strong>@toplamKayit</strong> kayit</span>
                @if (hareketler.Any())
                {
                    <span style="color:#16a34a;">Giris: <strong>@hareketler.Where(h => h.SthTip == 1).Sum(h => h.SthMiktar).ToString("N2")</strong></span>
                    <span style="color:#dc2626;">Cikis: <strong>@hareketler.Where(h => h.SthTip == 2).Sum(h => h.SthMiktar).ToString("N2")</strong></span>
                    <span>Tutar: <strong>@hareketler.Sum(h => h.SthTutar).ToString("N2")</strong></span>
                }
            </div>

            <div style="display:flex; align-items:center; gap:4px;">
                <button class="btn btn-sm btn-outline" disabled="@(sayfa <= 1)" @onclick="() => SayfaDegistir(1)">
                    <i class="fa fa-angle-double-left"></i>
                </button>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa <= 1)" @onclick="() => SayfaDegistir(sayfa - 1)">
                    <i class="fa fa-angle-left"></i>
                </button>
                <span style="font-size:11px; padding:0 8px;">
                    Sayfa <strong>@sayfa</strong> / <strong>@toplamSayfa</strong>
                </span>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa >= toplamSayfa)" @onclick="() => SayfaDegistir(sayfa + 1)">
                    <i class="fa fa-angle-right"></i>
                </button>
                <button class="btn btn-sm btn-outline" disabled="@(sayfa >= toplamSayfa)" @onclick="() => SayfaDegistir(toplamSayfa)">
                    <i class="fa fa-angle-double-right"></i>
                </button>
                <select class="form-control" style="width:65px; margin-left:6px;" @bind="sayfaBoyutu" @bind:after="FiltreleVeYukle">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="250">250</option>
                </select>
            </div>
        </div>
    </div>
</div>

@code {
    // Data
    private List<HareketDto> hareketler = new();
    private List<DepoDto> depolar = new();
    private Dictionary<string, string> stokIsimleri = new();

    // State
    private int seciliId = 0;
    private bool yukleniyor = false;
    private string? mesaj;
    private string mesajTip = "alert-info";

    // Filtre
    private string filtreStokKod = "";
    private DateTime? filtreBaslangic;
    private DateTime? filtreBitis;
    private string filtreTip = "";
    private string filtreDepo = "";
    private string filtreBelgeNo = "";

    // Pagination
    private int sayfa = 1;
    private int sayfaBoyutu = 50;
    private int toplamKayit = 0;
    private int toplamSayfa = 1;

    protected override async Task OnInitializedAsync()
    {
        // Varsayilan tarih araligi: bu ay
        filtreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        filtreBitis = DateTime.Now.Date;

        await DepolariYukle();
        await VerileriYukle();
    }

    private async Task DepolariYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<DepoDto>>>("api/stok/depolar");
            if (resp?.Success == true) depolar = resp.Data ?? new();
        }
        catch { }
    }

    private async Task VerileriYukle()
    {
        try
        {
            yukleniyor = true;
            StateHasChanged();

            var url = $"api/stok/hareketler?sayfa={sayfa}&boyut={sayfaBoyutu}";

            if (!string.IsNullOrEmpty(filtreStokKod))
                url += $"&stokKod={Uri.EscapeDataString(filtreStokKod)}";

            if (filtreBaslangic.HasValue)
                url += $"&baslangic={filtreBaslangic.Value:yyyy-MM-dd}";

            if (filtreBitis.HasValue)
                url += $"&bitis={filtreBitis.Value:yyyy-MM-dd}";

            if (!string.IsNullOrEmpty(filtreTip))
                url += $"&tip={filtreTip}";

            if (!string.IsNullOrEmpty(filtreDepo))
                url += $"&depoNo={filtreDepo}";

            if (!string.IsNullOrEmpty(filtreBelgeNo))
                url += $"&belgeNo={Uri.EscapeDataString(filtreBelgeNo)}";

            var response = await Http.GetFromJsonAsync<PagedApiResponse<HareketDto>>(url);
            if (response?.Success == true)
            {
                hareketler = response.Data ?? new();
                toplamKayit = response.Toplam;
                toplamSayfa = response.ToplamSayfa > 0 ? response.ToplamSayfa : 1;

                // Stok isimlerini yukle (benzersiz kodlar icin)
                await StokIsimleriniYukle();
            }
            else
            {
                hareketler = new();
                MesajGoster(response?.Message ?? "Veri yuklenemedi", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            hareketler = new();
            MesajGoster($"Yukleme hatasi: {ex.Message}", "alert-danger");
        }
        finally
        {
            yukleniyor = false;
            StateHasChanged();
        }
    }

    private async Task StokIsimleriniYukle()
    {
        // Her benzersiz stok kodu icin isim bul
        var kodlar = hareketler.Select(h => h.SthStokKod).Distinct().ToList();
        stokIsimleri = new Dictionary<string, string>();

        foreach (var kod in kodlar)
        {
            if (stokIsimleri.ContainsKey(kod)) continue;
            try
            {
                var resp = await Http.GetFromJsonAsync<ApiResponse<StokIsimDto>>($"api/stok/kart/kod/{Uri.EscapeDataString(kod)}");
                if (resp?.Success == true && resp.Data != null)
                    stokIsimleri[kod] = resp.Data.StoIsim;
                else
                    stokIsimleri[kod] = "-";
            }
            catch
            {
                stokIsimleri[kod] = "-";
            }
        }
    }

    private async Task FiltreleVeYukle()
    {
        sayfa = 1;
        await VerileriYukle();
    }

    private async Task FiltreTemizle()
    {
        filtreStokKod = "";
        filtreBaslangic = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        filtreBitis = DateTime.Now.Date;
        filtreTip = "";
        filtreDepo = "";
        filtreBelgeNo = "";
        sayfa = 1;
        await VerileriYukle();
    }

    private async Task Yenile()
    {
        mesaj = null;
        await VerileriYukle();
    }

    private async Task SayfaDegistir(int yeniSayfa)
    {
        sayfa = yeniSayfa;
        await VerileriYukle();
    }

    private async Task Yazdir() => await JS.InvokeVoidAsync("window.print");

    private void ExcelExport()
    {
        MesajGoster("Excel export hazirlaniyour...", "alert-info");
    }

    private string HareketCinsiAdi(int cins) => cins switch
    {
        1 => "Fatura",
        2 => "Irsaliye",
        3 => "Siparis",
        4 => "Depo Transfer",
        5 => "Sayim",
        6 => "Fire",
        _ => "Diger"
    };

    private void MesajGoster(string text, string tip = "alert-info")
    {
        mesaj = text;
        mesajTip = tip;
    }

    // --- DTOs ---
    public class HareketDto
    {
        public int Id { get; set; }
        public string SthStokKod { get; set; } = "";
        public DateTime SthTarih { get; set; }
        public int SthTip { get; set; }
        public int SthCins { get; set; }
        public decimal SthMiktar { get; set; }
        public string? SthBirim { get; set; }
        public decimal SthTutar { get; set; }
        public string? SthBelgeNo { get; set; }
        public int SthDepoNo { get; set; }
        public string? SthCariKod { get; set; }
        public string? SthAciklama1 { get; set; }
    }

    public class DepoDto
    {
        public int Id { get; set; }
        public string DepKod { get; set; } = "";
        public string DepIsim { get; set; } = "";
    }

    public class StokIsimDto
    {
        public string StoIsim { get; set; } = "";
    }
}
