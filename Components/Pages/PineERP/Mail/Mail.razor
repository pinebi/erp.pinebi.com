    .m-ai-item:last-child { border-bottom:none; }
    .m-ai-item:hover { background:#f1f5f9; }
</style>

@code {
    HttpClient Http => _http ??= new HttpClient { BaseAddress = new Uri(Nav.BaseUri), Timeout = TimeSpan.FromMinutes(2) };
    HttpClient? _http;

    List<HesapItem>? hesaplar;
    HesapItem? secHesap;
    List<KlasorItem>? klasorler;
    string secKlasor = "INBOX";
    List<MesajItem>? mesajlar;
    uint? secUid;
    MesajDetay? detay;
    string arama = "";

    bool composeAcik = false;
    string composeBaslik = "Yeni Mail";
    string composeAlici = "", composeCc = "", composeKonu = "", composeGovde = "";
    string composeHata = "";
    bool gonderiliyor = false;
    bool aiCalisiyor = false;
    bool aiMenuAcik = false;

    // Hesap ekleme
    bool hesapAcik = false;
    string hAd = "", hEmail = "", hImapHost = "imap.yandex.com", hImapUser = "", hImapPass = "", hSmtpHost = "smtp.yandex.com", hSmtpUser = "", hSmtpPass = "";
    int hImapPort = 993, hSmtpPort = 587;
    string hesapHata = "", hesapOk = "";

    public class HesapItem { public Guid AccountId { get; set; } public string Ad { get; set; } = ""; public string Email { get; set; } = ""; }
    public class KlasorItem { public string name { get; set; } = ""; public string fullName { get; set; } = ""; public int unread { get; set; } public int total { get; set; } }
    public class MesajItem { public uint uid { get; set; } public string? konu { get; set; } public string? gonderen { get; set; } public DateTime tarih { get; set; } public bool okundu { get; set; } public bool ekVar { get; set; } }
    public class MesajDetay
    {
        public uint uid { get; set; } public string? konu { get; set; } public DateTime tarih { get; set; }
        public List<Adres> gonderen { get; set; } = new(); public List<Adres> alici { get; set; } = new();
        public List<Adres>? cc { get; set; } public string? html { get; set; } public List<Ek>? ekler { get; set; }
    }
    public class Adres { public string? Name { get; set; } public string? Address { get; set; } }
    public class Ek { public string? ad { get; set; } public string? mime { get; set; } }

    protected override async Task OnInitializedAsync() => await HesaplariYukle();

    async Task HesaplariYukle()
    {
        try { hesaplar = await Http.GetFromJsonAsync<List<HesapItem>>("/api/mail/hesaplar") ?? new(); }
        catch { hesaplar = new(); }
        if (hesaplar.Count > 0 && secHesap == null) await HesapSec(hesaplar[0]);
    }

    async Task HesapSec(HesapItem h)
    {
        secHesap = h; klasorler = null; mesajlar = null; detay = null; secUid = null;
        try
        {
            klasorler = await Http.GetFromJsonAsync<List<KlasorItem>>($"/api/mail/klasorler/{h.AccountId}") ?? new();
            secKlasor = "INBOX";
            await MesajlariYukle();
        }
        catch (Exception ex) { hesapHata = ex.Message; }
    }

    async Task KlasorSec(string f) { secKlasor = f; detay = null; secUid = null; await MesajlariYukle(); }

    async Task MesajlariYukle()
    {
        if (secHesap == null) return;
        mesajlar = null;
        try
        {
            var url = $"/api/mail/mesajlar/{secHesap.AccountId}?folder={Uri.EscapeDataString(secKlasor)}&take=50";
            if (!string.IsNullOrWhiteSpace(arama)) url += "&arama=" + Uri.EscapeDataString(arama);
            var r = await Http.GetFromJsonAsync<MesajListesi>(url);
            mesajlar = r?.items ?? new();
        }
        catch (Exception ex) { mesajlar = new(); composeHata = ex.Message; }
    }

    public class MesajListesi { public int total { get; set; } public List<MesajItem> items { get; set; } = new(); }

    async Task MesajAc(uint uid)
    {
        if (secHesap == null) return;
        secUid = uid;
        detay = null;
        try
        {
            detay = await Http.GetFromJsonAsync<MesajDetay>($"/api/mail/mesaj/{secHesap.AccountId}/{Uri.EscapeDataString(secKlasor)}/{uid}");
            // listede okundu isaretle
            var m = mesajlar?.FirstOrDefault(x => x.uid == uid); if (m != null) m.okundu = true;
        }
        catch (Exception ex) { composeHata = ex.Message; }
    }

    async Task Yenile() => await MesajlariYukle();
    async Task AramaKey(KeyboardEventArgs e) { if (e.Key == "Enter") await MesajlariYukle(); }

    void YeniMesaj() { composeBaslik = "Yeni Mail"; composeAlici = composeCc = composeKonu = composeGovde = composeHata = ""; composeAcik = true; }
    void Yanitla() { if (detay == null) return; var from = detay.gonderen.FirstOrDefault()?.Address ?? ""; composeBaslik = "Yanitla"; composeAlici = from; composeCc = ""; composeKonu = "Re: " + detay.konu; composeGovde = ""; composeAcik = true; }
    void Ilet() { if (detay == null) return; composeBaslik = "Ilet"; composeAlici = composeCc = ""; composeKonu = "Fwd: " + detay.konu; composeGovde = "<br/><br/>---Iletilen---<br/>" + detay.html; composeAcik = true; }

    async Task AIUygula(string aksiyon)
    {
        aiMenuAcik = false;
        if (string.IsNullOrWhiteSpace(composeGovde) && aksiyon != "genislet") { composeHata = "Mesaj bos"; return; }
        aiCalisiyor = true; composeHata = "";
        try
        {
            // Tarayici uzerinden fetch - cookie otomatik gider, auth engeli yok
            var result = await JS.InvokeAsync<AIResult>("pinebiMailAI", composeGovde ?? "", composeKonu ?? "", aksiyon);
            if (result.ok && !string.IsNullOrEmpty(result.metin)) composeGovde = result.metin;
            else composeHata = result.hata ?? "AI hata";
        }
        catch (Exception ex) { composeHata = ex.Message; }
        aiCalisiyor = false;
        StateHasChanged();
    }
    public class AIResult { public bool ok { get; set; } public string? metin { get; set; } public string? hata { get; set; } }

    async Task Gonder()
    {
        if (secHesap == null) return;
        gonderiliyor = true; composeHata = "";
        try
        {
            var dto = new { AccountId = secHesap.AccountId, Alici = composeAlici, Cc = composeCc, Konu = composeKonu, GovdeHtml = composeGovde.Replace("\n", "<br/>") };
            var resp = await Http.PostAsJsonAsync("/api/mail/gonder", dto);
            if (!resp.IsSuccessStatusCode) { composeHata = await resp.Content.ReadAsStringAsync(); }
            else { composeAcik = false; }
        }
        catch (Exception ex) { composeHata = ex.Message; }
        gonderiliyor = false;
    }

    async Task Sil()
    {
        if (secHesap == null || secUid == null) return;
        try
        {
            await Http.DeleteAsync($"/api/mail/mesaj/{secHesap.AccountId}/{Uri.EscapeDataString(secKlasor)}/{secUid}");
            detay = null; secUid = null; await MesajlariYukle();
        }
        catch (Exception ex) { composeHata = ex.Message; }
    }

