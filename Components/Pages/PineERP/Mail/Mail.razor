    .mail-pane { background:white; overflow-y:auto; }
    .mail-left { width:260px; flex-shrink:0; border-right:1px solid #e2e8f0; padding:12px; }
    .mail-mid { width:380px; flex-shrink:0; border-right:1px solid #e2e8f0; }
    .mail-right { flex:1; padding:20px; }

    .m-header { padding-bottom:12px; border-bottom:1px solid #f1f5f9; margin-bottom:12px; }
    .m-new-btn { width:100%; background:#235881; color:white; border:none; padding:10px; border-radius:10px; font-weight:600; cursor:pointer; font-size:14px; }
    .m-new-btn:hover { background:#1d486a; }

    .m-loading, .m-empty-wrap { padding:20px; text-align:center; color:#94a3b8; font-size:13px; }
    .m-empty-wrap p { margin:8px 0; }

    .m-acc { padding:10px 12px; border-radius:8px; cursor:pointer; margin-bottom:4px; }
    .m-acc:hover { background:#f1f5f9; }
    .m-acc.active { background:#eff6ff; border-left:3px solid #235881; padding-left:9px; }
    .m-acc-head { font-weight:600; font-size:13px; color:#235881; }
    .m-acc-email { font-size:11px; color:#94a3b8; }

    .m-folders { margin-top:12px; padding-top:12px; border-top:1px solid #f1f5f9; }
    .m-folder { display:flex; align-items:center; gap:8px; padding:8px 10px; border-radius:6px; cursor:pointer; font-size:13px; color:#475569; }
    .m-folder:hover { background:#f1f5f9; }
    .m-folder.active { background:#dbeafe; color:#1e40af; font-weight:600; }
    .m-folder-ikon { width:16px; text-align:center; }
    .m-folder-ad { flex:1; }
    .m-unread { background:#235881; color:white; font-size:10px; padding:1px 6px; border-radius:10px; font-weight:600; }

    .m-btn-link { background:none; border:none; color:#235881; cursor:pointer; margin-top:8px; font-size:12px; padding:4px 10px; }

    .m-listbar { display:flex; gap:6px; padding:12px; border-bottom:1px solid #f1f5f9; }
    .m-listbar input { flex:1; padding:7px 10px; border:1px solid #e2e8f0; border-radius:8px; font-size:13px; background:#f8fafc; }
