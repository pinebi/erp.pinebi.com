    async Task HesapKaydet()
    {
        hesapHata = hesapOk = "";
        try
        {
            var dto = new { Ad = hAd, Email = hEmail, ImapHost = hImapHost, ImapPort = hImapPort, ImapSsl = true, ImapUser = hImapUser, ImapPass = hImapPass, SmtpHost = hSmtpHost, SmtpPort = hSmtpPort, SmtpSsl = true, SmtpUser = hSmtpUser, SmtpPass = hSmtpPass };
