    string FolderIcon(string ad) => ad.ToLower() switch
    {
        "inbox" or "gelen" or "gelen kutusu" => "📥",
        "sent" or "giden" or "gonderilenler" => "📤",
        "drafts" or "taslak" or "taslaklar" => "📝",
        "trash" or "cop" or "silinmis" => "🗑",
        "spam" or "junk" => "⚠",
        _ => "📁"
    };
    string FolderAd(string ad) => ad.ToLower() switch
    {
        "inbox" => "Gelen Kutusu", "sent" => "Gonderilenler",
        "drafts" => "Taslaklar", "trash" => "Cop", "junk" => "Spam",
        _ => ad
    };
    string FormatTarih(DateTime d)
    {
        var local = d.ToLocalTime();
        if (local.Date == DateTime.Today) return local.ToString("HH:mm");
        if (local.Year == DateTime.Now.Year) return local.ToString("dd MMM");
        return local.ToString("dd.MM.yyyy");
    }
    string TemizEmail(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        var i = s.IndexOf('<'); return i > 0 ? s.Substring(0, i).Trim().Trim('"') : s;
    }

