@page "/pine/mail"
@layout MACHINEBISS_Web.Components.Layout.PineLayout
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Mail - Pinebi</PageTitle>

<div class="mail-wrap">
    <!-- SOL PANEL: Hesaplar + Klasorler -->
    <div class="mail-pane mail-left">
        <div class="m-header">
            <button class="m-new-btn" @onclick="() => YeniMesaj()"><i class="fa fa-pen"></i> Yeni Mail</button>
        </div>

        @if (hesaplar == null) { <div class="m-loading">Yukleniyor...</div> }
        else if (hesaplar.Count == 0)
        {
            <div class="m-empty-wrap">
                <i class="fa fa-envelope" style="font-size:32px; color:#cbd5e1;"></i>
                <p>Henuz mail hesabi yok</p>
                <button class="m-btn-primary" @onclick="HesapEkleAc">+ Hesap Ekle</button>
            </div>
        }
        else
        {
            @foreach (var h in hesaplar)
            {
                <div class="m-acc @(secHesap?.AccountId == h.AccountId ? "active" : "")" @onclick="() => HesapSec(h)">
                    <div class="m-acc-head">
                        <i class="fa fa-envelope"></i> @h.Ad
                    </div>
                    <div class="m-acc-email">@h.Email</div>
                </div>
            }
            @if (secHesap != null && klasorler != null)
            {
                <div class="m-folders">
                    @foreach (var k in klasorler)
                    {
                        <div class="m-folder @(secKlasor == k.fullName ? "active" : "")" @onclick="() => KlasorSec(k.fullName)">
                            <span class="m-folder-ikon">@FolderIcon(k.name)</span>
                            <span class="m-folder-ad">@FolderAd(k.name)</span>
                            @if (k.unread > 0) { <span class="m-unread">@k.unread</span> }
                        </div>
                    }
                </div>
            }
            <button class="m-btn-link" @onclick="HesapEkleAc">+ Hesap Ekle</button>
        }
    </div>

    <!-- ORTA PANEL: Mesaj listesi -->
    <div class="mail-pane mail-mid">
        <div class="m-listbar">
            <input type="search" placeholder="Mail ara..." @bind="arama" @bind:event="oninput" @onkeydown="AramaKey" />
            <button class="m-refresh" @onclick="Yenile" title="Yenile"><i class="fa fa-redo"></i></button>
        </div>
        @if (mesajlar == null && secHesap != null) { <div class="m-loading">Mesajlar aliniyor...</div> }
        else if (mesajlar != null && mesajlar.Count == 0) { <div class="m-empty-wrap"><p>Mesaj yok</p></div> }
        else if (mesajlar != null)
        {
            @foreach (var m in mesajlar)
            {
                <div class="m-msg @(secUid == m.uid ? "active" : "") @(m.okundu ? "okundu" : "yeni")"
                     @onclick="() => MesajAc(m.uid)">
                    <div class="m-msg-from">
                        @(m.okundu ? "" : "●") @TemizEmail(m.gonderen)
                    </div>
                    <div class="m-msg-subj">@m.konu</div>
                    <div class="m-msg-tarih">@FormatTarih(m.tarih)</div>
                    @if (m.ekVar) { <i class="fa fa-paperclip m-msg-ek"></i> }
                </div>
            }
        }
    </div>

    <!-- SAG PANEL: Onizleme -->
    <div class="mail-pane mail-right">
        @if (detay != null)
        {
            <div class="m-detay">
                <div class="m-detay-baslik">
                    <h3>@detay.konu</h3>
                    <div class="m-detay-aksiyonlar">
                        <button class="m-icon-btn" @onclick="Yanitla" title="Yanitla"><i class="fa fa-reply"></i></button>
                        <button class="m-icon-btn" @onclick="Ilet" title="Ilet"><i class="fa fa-share"></i></button>
                        <button class="m-icon-btn m-sil" @onclick="Sil" title="Sil"><i class="fa fa-trash"></i></button>
                    </div>
                </div>
                <div class="m-detay-meta">
                    <div><b>Kimden:</b> @string.Join(", ", detay.gonderen.Select(g => g.Name + " <" + g.Address + ">"))</div>
                    <div><b>Kime:</b> @string.Join(", ", detay.alici.Select(g => g.Name + " <" + g.Address + ">"))</div>
                    @if (detay.cc?.Count > 0)
                    {
                        <div><b>Cc:</b> @string.Join(", ", detay.cc.Select(g => g.Name + " <" + g.Address + ">"))</div>
                    }
                    <div><b>Tarih:</b> @detay.tarih.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                </div>
                @if (detay.ekler?.Count > 0)
                {
                    <div class="m-ekler">
                        @foreach (var e in detay.ekler) { <span class="m-ek"><i class="fa fa-paperclip"></i> @e.ad</span> }
                    </div>
                }
                <iframe srcdoc="@detay.html" class="m-body-frame" sandbox="allow-same-origin"></iframe>
            </div>
        }
        else
        {
            <div class="m-onizleme-bos">
                <i class="fa fa-envelope-open" style="font-size:48px; color:#cbd5e1;"></i>
                <p>Bir mail secin</p>
            </div>
        }
    </div>
</div>

<!-- Compose modal -->
@if (composeAcik)
{
    <div class="m-compose-overlay" @onclick="() => composeAcik = false">
        <div class="m-compose" @onclick:stopPropagation="true">
            <div class="m-compose-bar">
                <h3>@composeBaslik</h3>
                <button class="m-icon-btn" @onclick="() => composeAcik = false"><i class="fa fa-times"></i></button>
            </div>
            <div class="m-field"><label>Kime</label><input @bind="composeAlici" placeholder="ahmet@x.com, mehmet@y.com" /></div>
            <div class="m-field"><label>Cc</label><input @bind="composeCc" placeholder="(opsiyonel)" /></div>
            <div class="m-field"><label>Konu</label><input @bind="composeKonu" /></div>
            <div class="m-field">
                <div style="display:flex; align-items:center; justify-content:space-between;">
                    <label>Mesaj</label>
                    <div class="m-ai-wrap">
                        <button type="button" class="m-ai-btn" @onclick="() => aiMenuAcik = !aiMenuAcik" disabled="@aiCalisiyor">
                            ✨ @(aiCalisiyor ? "AI duzenliyor..." : "AI Yardim")
                        </button>
                        @if (aiMenuAcik)
                        {
                            <div class="m-ai-menu">
                                <div class="m-ai-item" @onclick='() => AIUygula("duzelt")'>✏️ Yazim/gramer duzelt</div>
                                <div class="m-ai-item" @onclick='() => AIUygula("profesyonel")'>👔 Profesyonellestir</div>
                                <div class="m-ai-item" @onclick='() => AIUygula("ozetle")'>📝 Ozetle</div>
                                <div class="m-ai-item" @onclick='() => AIUygula("genislet")'>📖 Genislet</div>
                            </div>
                        }
                    </div>
                </div>
                <textarea @bind="composeGovde" rows="12"></textarea>
            </div>
            @if (!string.IsNullOrEmpty(composeHata)) { <div class="m-err">@composeHata</div> }
            <div class="m-compose-actions">
                <button class="m-btn-primary" @onclick="Gonder" disabled="@gonderiliyor">
                    <i class="fa fa-paper-plane"></i> @(gonderiliyor ? "Gonderiliyor..." : "Gonder")
                </button>
                <button class="m-btn-secondary" @onclick="() => composeAcik = false">Iptal</button>
            </div>
        </div>
    </div>
}

<!-- Account modal -->
@if (hesapAcik)
{
    <div class="m-compose-overlay" @onclick="() => hesapAcik = false">
        <div class="m-compose" style="max-width:560px;" @onclick:stopPropagation="true">
            <div class="m-compose-bar"><h3>Mail Hesabi Ekle</h3></div>
            <div class="m-row">
                <div class="m-field"><label>Gorunen Ad</label><input @bind="hAd" /></div>
                <div class="m-field"><label>Email</label><input @bind="hEmail" /></div>
            </div>
            <h4 class="m-sec">IMAP (Gelen)</h4>
            <div class="m-row">
                <div class="m-field"><label>Sunucu</label><input @bind="hImapHost" placeholder="imap.yandex.com" /></div>
                <div class="m-field"><label>Port</label><input type="number" @bind="hImapPort" /></div>
            </div>
            <div class="m-field"><label>Kullanici Adi</label><input @bind="hImapUser" /></div>
            <div class="m-field"><label>Sifre</label><input type="password" @bind="hImapPass" /></div>
            <h4 class="m-sec">SMTP (Giden)</h4>
            <div class="m-row">
                <div class="m-field"><label>Sunucu</label><input @bind="hSmtpHost" placeholder="smtp.yandex.com" /></div>
                <div class="m-field"><label>Port</label><input type="number" @bind="hSmtpPort" /></div>
            </div>
            <div class="m-field"><label>Kullanici Adi</label><input @bind="hSmtpUser" /></div>
            <div class="m-field"><label>Sifre</label><input type="password" @bind="hSmtpPass" /></div>
            @if (!string.IsNullOrEmpty(hesapHata)) { <div class="m-err">@hesapHata</div> }
            @if (!string.IsNullOrEmpty(hesapOk)) { <div class="m-ok">@hesapOk</div> }
            <div class="m-compose-actions">
                <button class="m-btn-secondary" @onclick="HesapTest">Baglantiyi Test Et</button>
                <button class="m-btn-primary" @onclick="HesapKaydet">Kaydet</button>
                <button class="m-btn-secondary" @onclick="() => hesapAcik = false">Iptal</button>
            </div>
        </div>
    </div>
}

<style>
