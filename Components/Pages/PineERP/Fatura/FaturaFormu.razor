@code {
    [Parameter] public int Id { get; set; }
    [SupplyParameterFromQuery] public int Tip { get; set; } = 1;

    private int activeTab = 0;
    private int seciliSatirIdx = -1;

    // ===== HEADER FIELDS =====
    private string evrakNo = "(Otomatik)";
    private DateTime tarih = DateTime.Today;
    private DateTime vadeTarihi = DateTime.Today.AddDays(30);
    private string cariKod = "";
    private string cariUnvan = "";
    private string belgeNo = "";
    private string dovizCinsi = "TL";
    private decimal dovizKuru = 1;
    private int depoNo = 1;
    private string plasiyerKodu = "";
    private string odemeSekli = "";
    private string projeKodu = "";
    private string sorumlulukMerkezi = "";
    private string ozelKod1 = "";
    private string ozelKod2 = "";
    private string ozelKod3 = "";
    private string aciklama1 = "";
    private string aciklama2 = "";
    private string aciklama3 = "";

    // ===== STOK ARAMA MODAL =====
    private bool stokAramaModalAcik = false;
    private string stokAramaText = "";
    private bool stokAramaYukleniyor = false;
    private List<StokDto> stokAramaListesi = new();
    private int stokAramaSatirIdx = -1;

    // ===== SATIRLAR =====
    private List<FaturaSatirItem> satirlar = new();

    // ===== KDV ORANLARI (DB) =====
    private List<int> kdvOranlari = new() { 0, 1, 10, 20 };

    // ===== TOPLAMLAR =====
    private decimal araToplam => satirlar.Sum(s => s.Tutar);
    private decimal toplamIskonto => satirlar.Sum(s => s.IskontoTutari);
    private decimal kdvMatrahi => satirlar.Sum(s => s.NetTutar);
    private decimal kdvTutari => satirlar.Sum(s => s.KdvTutari);
    private decimal genelToplam => satirlar.Sum(s => s.SatirToplami);

    // ===== UI STATE =====
    private string mesaj = "";
    private bool mesajOk = false;
    private bool uyariModalAcik = false;
    private string uyariMesaj = "";

    // ===== CARI MODAL =====
    private bool cariModalAcik = false;
    private string cariArama = "";
    private bool cariYukleniyor = false;
    private List<CariDto> cariListesi = new();

    // ===== STOK AUTOCOMPLETE =====
    private bool stokOneriAcik = false;
    private List<StokDto> stokOnerileri = new();
    private int stokOneriSatirIdx = -1;
    private int stokOneriTop = 200;
    private int stokOneriLeft = 200;

    protected override async Task OnInitializedAsync()
    {
        if (Tip == 0) Tip = 1;

        try
        {
            using var ndb = await NetworkFactory.CreateDbContextAsync();
            var list = await ndb.KdvOranlari.OrderBy(k => k.KdvOrani).ToListAsync();
            if (list.Any())
                kdvOranlari = list.Where(k => k.KdvOrani.HasValue).Select(k => (int)k.KdvOrani!.Value).ToList();
        }
        catch { }

        if (Id > 0)
        {
            await FaturaYukle();
        }
    }

    private async Task FaturaYukle()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<FaturaDetayResponse>($"api/fatura/{Id}");
            if (resp?.Success == true && resp.Data != null)
            {
                var f = resp.Data.Fatura;
                Tip = f.FatTip;
                evrakNo = (f.FatEvrakSeri ?? "") + f.FatEvrakSira.ToString("D6");
                tarih = f.FatTarih;
                vadeTarihi = f.FatVadeTarihi ?? DateTime.Today.AddDays(30);
                cariKod = f.FatCariKod;
                cariUnvan = f.FatCariUnvan ?? "";
                belgeNo = f.FatBelgeNo ?? "";
                dovizCinsi = f.FatDovizCinsi ?? "TL";
                dovizKuru = f.FatDovizKuru;
                depoNo = f.FatDepoNo;
                plasiyerKodu = f.FatPlasiyerKodu ?? "";
                odemeSekli = f.FatOdemeSekli ?? "";
                projeKodu = f.FatProjeKodu ?? "";
                aciklama1 = f.FatAciklama1 ?? "";
                aciklama2 = f.FatAciklama2 ?? "";
                aciklama3 = f.FatAciklama3 ?? "";
                ozelKod1 = f.FatOzelkod1 ?? "";
                ozelKod2 = f.FatOzelkod2 ?? "";
                ozelKod3 = f.FatOzelkod3 ?? "";

                satirlar = (resp.Data.Satirlar ?? new()).Select(s => new FaturaSatirItem
                {
                    StokKod = s.FtsStokKod,
                    StokAdi = s.FtsStokAdi ?? "",
                    Miktar = s.FtsMiktar,
                    Birim = s.FtsBirim ?? "",
                    BirimFiyat = s.FtsBirimFiyat,
                    IskontoOrani = s.FtsIskontoOrani1,
                    KdvOrani = s.FtsKdvOrani,
                    Tutar = s.FtsTutar,
                    IskontoTutari = s.FtsIskontoTutari,
                    NetTutar = s.FtsNetTutar,
                    KdvTutari = s.FtsKdvTutari,
                    SatirToplami = s.FtsSatirToplami
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            mesaj = $"Fatura yukleme hatasi: {ex.Message}";
            mesajOk = false;
        }
    }

    // ===== SATIR ISLEMLERI =====

    private void SatirEkle()
    {
        satirlar.Add(new FaturaSatirItem { Birim = "AD", KdvOrani = 20 });
        seciliSatirIdx = satirlar.Count - 1;
    }

    private void SatirSil(int idx)
    {
        if (idx >= 0 && idx < satirlar.Count)
        {
            satirlar.RemoveAt(idx);
            seciliSatirIdx = -1;
        }
    }

    private void SatirHesapla(int idx)
    {
        if (idx < 0 || idx >= satirlar.Count) return;
        var s = satirlar[idx];
        s.Tutar = s.Miktar * s.BirimFiyat;
        s.IskontoTutari = s.Tutar * s.IskontoOrani / 100m;
        s.NetTutar = s.Tutar - s.IskontoTutari;
        s.KdvTutari = s.NetTutar * s.KdvOrani / 100m;
        s.SatirToplami = s.NetTutar + s.KdvTutari;
    }

    // ===== STOK AUTOCOMPLETE =====

    private System.Timers.Timer? _debounce;

    private async Task StokKodDegisti(int idx, string val)
    {
        if (idx < 0 || idx >= satirlar.Count) return;
        satirlar[idx].StokKod = val;
        stokOneriSatirIdx = idx;

        if (string.IsNullOrWhiteSpace(val) || val.Length < 2)
        {
            stokOneriAcik = false;
            return;
        }

        try
        {
            var q = Uri.EscapeDataString(val.Replace("*", ""));
            var resp = await Http.GetFromJsonAsync<StokAramaResponse>($"api/stok/ara?q={q}&limit=10");
            if (resp?.Success == true && resp.Data != null)
            {
                stokOnerileri = resp.Data;
                stokOneriAcik = stokOnerileri.Any();
            }
            else
            {
                stokOneriAcik = false;
            }
        }
        catch
        {
            stokOneriAcik = false;
        }
    }

    private async Task StokInputKeyDown(KeyboardEventArgs e, int idx, int alan)
    {
        // * veya F10 => Stok arama modali ac
        if (e.Key == "*" || e.Key == "F10")
        {
            if (idx >= 0 && idx < satirlar.Count)
            {
                var s = satirlar[idx];
                stokAramaSatirIdx = idx;
                stokAramaText = (alan == 0 ? s.StokKod : s.StokAdi).Replace("*", "").Trim();
                stokAramaModalAcik = true;
                stokAramaYukleniyor = true;
                await StokAramaYap();
            }
        }
    }

    private void StokSecildi(StokDto stok)
    {
        if (stokOneriSatirIdx >= 0 && stokOneriSatirIdx < satirlar.Count)
        {
            var s = satirlar[stokOneriSatirIdx];
            s.StokKod = stok.StoKod;
            s.StokAdi = stok.StoIsim;
            s.Birim = stok.StoBirim;
            if (stok.StoSatisFiyat > 0) s.BirimFiyat = stok.StoSatisFiyat;
            if (stok.StoKdvOrani > 0) s.KdvOrani = stok.StoKdvOrani;
            SatirHesapla(stokOneriSatirIdx);
        }
        stokOneriAcik = false;
    }

    // ===== STOK ARAMA MODAL =====

    private async Task StokAramaAc(int idx)
    {
        stokAramaSatirIdx = idx;
        stokAramaText = idx >= 0 && idx < satirlar.Count ? satirlar[idx].StokKod : "";
        stokAramaModalAcik = true;
        stokAramaYukleniyor = true;
        await StokAramaYap();
    }

    private async Task StokAramaYap()
    {
        stokAramaYukleniyor = true;
        try
        {
            var q = Uri.EscapeDataString((stokAramaText ?? "").Replace("*", "").Trim());
            var resp = await Http.GetFromJsonAsync<StokAramaResponse>($"api/stok/ara?q={q}&limit=50");
            stokAramaListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
        }
        catch { stokAramaListesi = new(); }
        stokAramaYukleniyor = false;
    }

    private void StokAramaSecildi(StokDto stok)
    {
        if (stokAramaSatirIdx >= 0 && stokAramaSatirIdx < satirlar.Count)
        {
            var s = satirlar[stokAramaSatirIdx];
            s.StokKod = stok.StoKod;
            s.StokAdi = stok.StoIsim;
            s.Birim = stok.StoBirim;
            if (stok.StoSatisFiyat > 0) s.BirimFiyat = stok.StoSatisFiyat;
            if (stok.StoKdvOrani > 0) s.KdvOrani = stok.StoKdvOrani;
            SatirHesapla(stokAramaSatirIdx);
        }
        stokAramaModalAcik = false;
    }

    // ===== CARI MODAL =====

    private async Task CariSecAc()
    {
        cariArama = cariKod;
        cariModalAcik = true;
        cariYukleniyor = true;
        await CariAra();
    }

    private async Task CariAra()
    {
        cariYukleniyor = true;
        try
        {
            var q = Uri.EscapeDataString(cariArama ?? "");
            var resp = await Http.GetFromJsonAsync<CariAramaResponse>($"api/cari/ara?q={q}&limit=50");
            cariListesi = resp?.Success == true ? (resp.Data ?? new()) : new();
        }
        catch { cariListesi = new(); }
        cariYukleniyor = false;
    }

    private void CariSecildi(CariDto c)
    {
        cariKod = c.CarKod;
        cariUnvan = c.CarUnvan;
        cariModalAcik = false;
    }

    // ===== KAYDET =====

    private async Task Kaydet()
    {
        mesaj = "";
        if (string.IsNullOrWhiteSpace(cariKod))
        {
            uyariMesaj = "Lutfen cari hesap seciniz!";
            uyariModalAcik = true;
            return;
        }
        if (!satirlar.Any() || !satirlar.Any(s => !string.IsNullOrWhiteSpace(s.StokKod) && s.Miktar > 0))
        {
            uyariMesaj = "Faturada en az bir gecerli urun (stok kodu ve miktar girilmis) olmalidir!";
            uyariModalAcik = true;
            return;
        }

        try
        {
            var fatura = new
            {
                FatTip = Tip,
                FatFaturaTipi = 0,
                FatTarih = tarih,
                FatVadeTarihi = vadeTarihi,
                FatBelgeNo = belgeNo,
                FatCariKod = cariKod,
                FatCariUnvan = cariUnvan,
                FatOdemeSekli = odemeSekli,
                FatDovizCinsi = dovizCinsi,
                FatDovizKuru = dovizKuru,
                FatDepoNo = depoNo,
                FatPlasiyerKodu = plasiyerKodu,
                FatProjeKodu = projeKodu,
                FatSorumlulukMerkezi = sorumlulukMerkezi,
                FatTutar = araToplam,
                FatToplamIskonto = toplamIskonto,
                FatKdvMatrahi = kdvMatrahi,
                FatKdvTutari = kdvTutari,
                FatToplamTutar = genelToplam,
                FatOdenecekTutar = genelToplam,
                FatTlTutar = araToplam * dovizKuru,
                FatTlKdvMatrahi = kdvMatrahi * dovizKuru,
                FatTlKdvTutari = kdvTutari * dovizKuru,
                FatTlToplamTutar = genelToplam * dovizKuru,
                FatTlOdenecekTutar = genelToplam * dovizKuru,
                FatAciklama1 = aciklama1,
                FatAciklama2 = aciklama2,
                FatAciklama3 = aciklama3,
                FatOzelkod1 = ozelKod1,
                FatOzelkod2 = ozelKod2,
                FatOzelkod3 = ozelKod3,
                FatDurumu = "Acik"
            };

            var satirlarDto = satirlar.Select((s, i) => new
            {
                FtsSatirNo = i + 1,
                FtsStokKod = s.StokKod,
                FtsStokAdi = s.StokAdi,
                FtsMiktar = s.Miktar,
                FtsBirim = s.Birim,
                FtsBirimFiyat = s.BirimFiyat,
                FtsTutar = s.Tutar,
                FtsIskontoOrani1 = s.IskontoOrani,
                FtsIskontoTutari = s.IskontoTutari,
                FtsNetTutar = s.NetTutar,
                FtsKdvOrani = s.KdvOrani,
                FtsKdvTutari = s.KdvTutari,
                FtsSatirToplami = s.SatirToplami,
                FtsDovizCinsi = dovizCinsi,
                FtsDovizKuru = dovizKuru,
                FtsTlTutar = s.Tutar * dovizKuru,
                FtsTlNetTutar = s.NetTutar * dovizKuru,
                FtsTlKdvTutari = s.KdvTutari * dovizKuru,
                FtsTlSatirToplami = s.SatirToplami * dovizKuru,
                FtsDepoNo = depoNo
            }).ToList();

            var payload = new { Fatura = fatura, Satirlar = satirlarDto };

            HttpResponseMessage resp;
            if (Id > 0)
            {
                resp = await Http.PutAsJsonAsync($"api/fatura/{Id}", payload);
            }
            else
            {
                resp = await Http.PostAsJsonAsync("api/fatura", payload);
            }

            var result = await resp.Content.ReadFromJsonAsync<ApiResult>();
            if (result?.Success == true)
            {
                mesaj = Id > 0 ? "Fatura guncellendi!" : "Fatura kaydedildi!";
                mesajOk = true;
            }
            else
            {
                mesaj = result?.Message ?? "Kayit hatasi";
                mesajOk = false;
            }
        }
        catch (Exception ex)
        {
            mesaj = $"Hata: {ex.Message}";
            mesajOk = false;
        }
    }

    private void Kapat()
    {
        if (Tip == 1 || Tip == 2)
            Nav.NavigateTo("/pine/satis/faturalar");
        else
            Nav.NavigateTo("/");
    }

    private async Task KlavyeKisayol(KeyboardEventArgs e)
    {
        if (e.Key == "F2") await Kaydet();
        else if (e.Key == "Escape") Kapat();
    }

    // ===== HELPER CLASSES =====

    public class FaturaSatirItem
    {
        public string StokKod { get; set; } = "";
        public string StokAdi { get; set; } = "";
        public decimal Miktar { get; set; } = 1;
        public string Birim { get; set; } = "AD";
        public decimal BirimFiyat { get; set; }
        public decimal IskontoOrani { get; set; }
        public decimal KdvOrani { get; set; } = 20;
        public decimal Tutar { get; set; }
        public decimal IskontoTutari { get; set; }
        public decimal NetTutar { get; set; }
        public decimal KdvTutari { get; set; }
        public decimal SatirToplami { get; set; }
    }

    public class CariDto
    {
        public string CarKod { get; set; } = "";
        public string CarUnvan { get; set; } = "";
        public string? CarVergiNo { get; set; }
    }

    public class StokDto
    {
        public string StoKod { get; set; } = "";
        public string StoIsim { get; set; } = "";
        public string StoBirim { get; set; } = "AD";
        public decimal StoSatisFiyat { get; set; }
        public decimal StoKdvOrani { get; set; }
    }

    public class ApiResult { public bool Success { get; set; } public string? Message { get; set; } }
    public class CariAramaResponse { public bool Success { get; set; } public List<CariDto>? Data { get; set; } }
    public class StokAramaResponse { public bool Success { get; set; } public List<StokDto>? Data { get; set; } }

    public class FaturaDetayData
    {
        public FaturaHeader Fatura { get; set; } = new();
        public List<SatirData>? Satirlar { get; set; }
    }

    public class FaturaDetayResponse { public bool Success { get; set; } public FaturaDetayData? Data { get; set; } }

    public class FaturaHeader
    {
        public int FatTip { get; set; }
        public DateTime FatTarih { get; set; }
        public DateTime? FatVadeTarihi { get; set; }
        public string? FatEvrakSeri { get; set; }
        public int FatEvrakSira { get; set; }
        public string? FatBelgeNo { get; set; }
        public string FatCariKod { get; set; } = "";
        public string? FatCariUnvan { get; set; }
        public string? FatOdemeSekli { get; set; }
        public string? FatDovizCinsi { get; set; }
        public decimal FatDovizKuru { get; set; }
        public int FatDepoNo { get; set; }
        public string? FatPlasiyerKodu { get; set; }
        public string? FatProjeKodu { get; set; }
        public string? FatAciklama1 { get; set; }
