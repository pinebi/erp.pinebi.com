    {
        public MACHINEBISS_Web.Models.PineERP.Takvim.PineEvent Ev { get; set; } = null!;
        public List<MACHINEBISS_Web.Models.PineERP.Takvim.PineEventParticipant>? Katilimcilar { get; set; }
    }

    public void Dispose() => _ref?.Dispose();
