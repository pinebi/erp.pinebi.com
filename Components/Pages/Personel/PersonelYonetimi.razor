                                    <th style="width:90px;">Tarih</th>
                                    <th style="width:120px;">Konu</th>
                                    <th style="min-width:300px;">Aciklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (gorusListesi != null)
                                {
                                    foreach (var g in gorusListesi)
                                    {
                                        <tr class="@(seciliGorusId == g.Id ? "selected" : "")" @onclick="() => seciliGorusId = g.Id">
                                            <td>@g.Personel</td>
                                            <td>@g.Tarih?.ToString("dd.MM.yyyy")</td>
                                            <td>@g.Konu</td>
                                            <td>@g.Aciklama</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

