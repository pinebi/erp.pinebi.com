@page "/personel"
@inject NavigationManager Nav
@inject IDbContextFactory<MACHINEBISS_Web.Db.FirmaContext> FirmaFactory
@using Microsoft.EntityFrameworkCore
@using MACHINEBISS_Web.Models.MachineBiss

<PageTitle>Personel Yonetimi</PageTitle>

<div class="card">
    <div class="card-header">
        <i class="fa fa-users"></i> Personel Yonetimi
    </div>
    <div class="card-body">
        <!-- Sidebar + Content Layout -->
        <div style="display:flex; gap:12px;">
            <!-- Left Accordion Nav -->
            <div style="min-width:200px; max-width:200px; border:1px solid var(--pinebi-border); border-radius:4px; background:var(--pinebi-white);">
                <div class="accordion-item @(activeSection == "liste" ? "active" : "")" @onclick='() => SectionChanged("liste")'>
                    <i class="fa fa-list"></i> Personel Listesi
                </div>
                <div class="accordion-item @(activeSection == "izin" ? "active" : "")" @onclick='() => SectionChanged("izin")'>
                    <i class="fa fa-calendar"></i> Izin Listesi
                </div>
                <div class="accordion-item @(activeSection == "saglik" ? "active" : "")" @onclick='() => SectionChanged("saglik")'>
                    <i class="fa fa-medkit"></i> Saglik Raporlari
                </div>
                <div class="accordion-item @(activeSection == "tutanak" ? "active" : "")" @onclick='() => SectionChanged("tutanak")'>
                    <i class="fa fa-file-text-o"></i> Disiplin Tutanaklari
                </div>
                <div class="accordion-item @(activeSection == "geneltutanak" ? "active" : "")" @onclick='() => SectionChanged("geneltutanak")'>
                    <i class="fa fa-file-o"></i> Genel Tutanaklar
                </div>
                <div class="accordion-item @(activeSection == "zimmet" ? "active" : "")" @onclick='() => SectionChanged("zimmet")'>
                    <i class="fa fa-briefcase"></i> Zimmet Islemleri
                </div>
                <div class="accordion-item @(activeSection == "maas" ? "active" : "")" @onclick='() => SectionChanged("maas")'>
                    <i class="fa fa-money"></i> Maas Bordrosu
                </div>
                <div class="accordion-item @(activeSection == "puantaj" ? "active" : "")" @onclick='() => SectionChanged("puantaj")'>
                    <i class="fa fa-clock-o"></i> Puantaj
                </div>
                <div class="accordion-item @(activeSection == "talep" ? "active" : "")" @onclick='() => SectionChanged("talep")'>
                    <i class="fa fa-inbox"></i> Talepler
                </div>
                <div class="accordion-item @(activeSection == "gecmis" ? "active" : "")" @onclick='() => SectionChanged("gecmis")'>
                    <i class="fa fa-history"></i> Isten Ayrilanlar
                </div>
                <div class="accordion-item @(activeSection == "oneri" ? "active" : "")" @onclick='() => SectionChanged("oneri")'>
                    <i class="fa fa-comment"></i> Gorus ve Oneriler
                </div>
            </div>

            <!-- Right Content Area -->
            <div style="flex:1; min-width:0;">
                @* ===== PERSONEL LISTESI ===== *@
                @if (activeSection == "liste")
                {
                    <div class="toolbar">
                        <button class="btn btn-success btn-sm" @onclick="PersonelEkle">
                            <i class="fa fa-plus"></i> Ekle
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="PersonelDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="PersonelIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="IzinFormuAc">
                            <i class="fa fa-calendar-plus-o"></i> Izin Formu
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="form-row" style="margin-bottom:10px;">
                        <div class="form-inline" style="margin-left:auto;">
                            <label style="min-width:30px;">Ara</label>
                            <input type="text" class="form-control" placeholder="Ad, soyad, departman..." @bind="aramaMetniPersonel" @bind:event="oninput" style="max-width:250px;" />
                        </div>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="width:50px;">Foto</th>
                                    <th style="width:80px;">Sicil No</th>
                                    <th style="min-width:120px;">Ad</th>
                                    <th style="min-width:120px;">Soyad</th>
                                    <th style="width:100px;">TC Kimlik No</th>
                                    <th style="width:90px;">Dogum Tarihi</th>
                                    <th style="min-width:120px;">Departman</th>
                                    <th style="min-width:120px;">Gorevi</th>
                                    <th style="width:90px;">Ise Giris Tarihi</th>
                                    <th style="width:100px;">Telefon</th>
                                    <th style="min-width:150px;">E-Posta</th>
                                    <th style="width:80px;">Kan Grubu</th>
                                    <th style="width:100px;">Egitim Durumu</th>
                                    <th style="width:60px;">Cinsiyet</th>
                                    <th style="width:80px;">Askerlik</th>
                                    <th style="min-width:100px;">Sehir</th>
                                    <th style="min-width:100px;">Ilce</th>
                                    <th style="min-width:150px;">Adres</th>
                                    <th style="width:80px;">SGK No</th>
                                    <th style="min-width:120px;">Isyeri</th>
                                    <th style="width:100px;">Kasa Kodu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (personelListesi != null)
                                {
                                    foreach (var p in filtrelenmisPersoneller)
                                    {
                                        <tr class="@(seciliPersonelId == p.Id ? "selected" : "")" @onclick="() => seciliPersonelId = p.Id">
                                            <td><i class="fa fa-user" style="color:var(--pinebi-primary);"></i></td>
                                            <td>@p.SicilNo</td>
                                            <td>@p.Ad</td>
                                            <td>@p.Soyad</td>
                                            <td>@p.TcKimlikNo</td>
                                            <td>@p.DogumTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@p.Departman</td>
                                            <td>@p.Gorevi</td>
                                            <td>@p.IseGirisTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@p.Telefon</td>
                                            <td>@p.EPosta</td>
                                            <td>@p.KanGrubu</td>
                                            <td>@p.EgitimDurumu</td>
                                            <td>@p.Cinsiyet</td>
                                            <td>@p.Askerlik</td>
                                            <td>@p.Sehir</td>
                                            <td>@p.Ilce</td>
                                            <td>@p.Adres</td>
                                            <td>@p.SgkNo</td>
                                            <td>@p.Isyeri</td>
                                            <td>@p.KasaKodu</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== IZIN LISTESI ===== *@
                @if (activeSection == "izin")
                {
                    <div class="toolbar">
                        <button class="btn btn-primary btn-sm" @onclick="IzinDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="IzinIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="min-width:120px;">Personel</th>
                                    <th style="width:100px;">Izin Turu</th>
                                    <th style="width:90px;">Baslangic</th>
                                    <th style="width:90px;">Bitis</th>
                                    <th style="width:60px;">Gun Sayisi</th>
                                    <th style="min-width:150px;">Aciklama</th>
                                    <th style="width:100px;">Onay Durumu</th>
                                    <th style="min-width:150px;">Onay Aciklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (izinListesi != null)
                                {
                                    foreach (var iz in izinListesi)
                                    {
                                        <tr class="@(seciliIzinId == iz.Id ? "selected" : "")" @onclick="() => seciliIzinId = iz.Id">
                                            <td>@iz.Personel</td>
                                            <td>@iz.IzinTuru</td>
                                            <td>@iz.BaslangicTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@iz.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@iz.GunSayisi</td>
                                            <td>@iz.Aciklama</td>
                                            <td>@iz.OnayDurumu</td>
                                            <td>@iz.OnayAciklama</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== SAGLIK RAPORLARI ===== *@
                @if (activeSection == "saglik")
                {
                    <div class="toolbar">
                        <button class="btn btn-primary btn-sm" @onclick="SaglikDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="SaglikIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="min-width:120px;">Personel</th>
                                    <th style="width:100px;">Rapor Turu</th>
                                    <th style="width:90px;">Baslangic</th>
                                    <th style="width:90px;">Bitis</th>
                                    <th style="width:60px;">Gun Sayisi</th>
                                    <th style="min-width:150px;">Hastane</th>
                                    <th style="min-width:150px;">Aciklama</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (saglikListesi != null)
                                {
                                    foreach (var s in saglikListesi)
                                    {
                                        <tr class="@(seciliSaglikId == s.Id ? "selected" : "")" @onclick="() => seciliSaglikId = s.Id">
                                            <td>@s.Personel</td>
                                            <td>@s.RaporTuru</td>
                                            <td>@s.BaslangicTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@s.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@s.GunSayisi</td>
                                            <td>@s.Hastane</td>
                                            <td>@s.Aciklama</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== DISIPLIN TUTANAKLARI ===== *@
                @if (activeSection == "tutanak")
                {
                    <div class="toolbar">
                        <button class="btn btn-success btn-sm" @onclick="TutanakEkle">
                            <i class="fa fa-plus"></i> Ekle
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="TutanakDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="TutanakIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="min-width:120px;">Personel</th>
                                    <th style="width:90px;">Tarih</th>
                                    <th style="width:120px;">Tutanak Turu</th>
                                    <th style="min-width:200px;">Aciklama</th>
                                    <th style="width:100px;">Ceza Turu</th>
                                    <th style="width:80px;">Dosya Eki</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (tutanakListesi != null)
                                {
                                    foreach (var t in tutanakListesi)
                                    {
                                        <tr class="@(seciliTutanakId == t.Id ? "selected" : "")" @onclick="() => seciliTutanakId = t.Id">
                                            <td>@t.Personel</td>
                                            <td>@t.Tarih?.ToString("dd.MM.yyyy")</td>
                                            <td>@t.TutanakTuru</td>
                                            <td>@t.Aciklama</td>
                                            <td>@t.CezaTuru</td>
                                            <td>@t.DosyaEki</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== GENEL TUTANAKLAR ===== *@
                @if (activeSection == "geneltutanak")
                {
                    <div class="toolbar">
                        <button class="btn btn-success btn-sm" @onclick="GenelTutanakEkle">
                            <i class="fa fa-plus"></i> Ekle
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="GenelTutanakDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="GenelTutanakIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="width:90px;">Tarih</th>
                                    <th style="width:120px;">Tutanak Turu</th>
                                    <th style="min-width:250px;">Aciklama</th>
                                    <th style="width:80px;">Dosya Eki</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (genelTutanakListesi != null)
                                {
                                    foreach (var t in genelTutanakListesi)
                                    {
                                        <tr class="@(seciliGenelTutanakId == t.Id ? "selected" : "")" @onclick="() => seciliGenelTutanakId = t.Id">
                                            <td>@t.Tarih?.ToString("dd.MM.yyyy")</td>
                                            <td>@t.TutanakTuru</td>
                                            <td>@t.Aciklama</td>
                                            <td>@t.DosyaEki</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== ZIMMET ISLEMLERI ===== *@
                @if (activeSection == "zimmet")
                {
                    <div class="toolbar">
                        <button class="btn btn-success btn-sm" @onclick="ZimmetEkle">
                            <i class="fa fa-plus"></i> Ekle
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="ZimmetDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="ZimmetIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="min-width:120px;">Personel</th>
                                    <th style="width:90px;">Tarih</th>
                                    <th style="width:120px;">Zimmet Turu</th>
                                    <th style="min-width:200px;">Aciklama</th>
                                    <th style="width:80px;">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (zimmetListesi != null)
                                {
                                    foreach (var z in zimmetListesi)
                                    {
                                        <tr class="@(seciliZimmetId == z.Id ? "selected" : "")" @onclick="() => seciliZimmetId = z.Id">
                                            <td>@z.Personel</td>
                                            <td>@z.Tarih?.ToString("dd.MM.yyyy")</td>
                                            <td>@z.ZimmetTuru</td>
                                            <td>@z.Aciklama</td>
                                            <td>@z.Durum</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== MAAS BORDROSU ===== *@
                @if (activeSection == "maas")
                {
                    <div style="padding:20px; text-align:center; color:var(--pinebi-text-light);">
                        <i class="fa fa-money" style="font-size:48px; margin-bottom:10px;"></i>
                        <p>Maas Bordrosu modulu hazirlaniyor...</p>
                    </div>
                }

                @* ===== PUANTAJ ===== *@
                @if (activeSection == "puantaj")
                {
                    <div class="toolbar">
                        <div class="form-inline">
                            <label>Yil</label>
                            <select class="form-control" @bind="puantajYil" style="max-width:100px;">
                                @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year; y++)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <span style="border-left:1px solid var(--pinebi-border); height:20px; margin:0 4px;"></span>
                        <button class="btn btn-outline btn-sm" @onclick="PuantajYazdir">
                            <i class="fa fa-print"></i> Yazdir
                        </button>
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <!-- Month Tabs -->
                    <div style="display:flex; gap:2px; margin:8px 0; flex-wrap:wrap;">
                        @{ string[] aylar = { "Ocak", "Subat", "Mart", "Nisan", "Mayis", "Haziran", "Temmuz", "Agustos", "Eylul", "Ekim", "Kasim", "Aralik" }; }
                        @for (int i = 0; i < 12; i++)
                        {
                            var ayIndex = i;
                            <button class="btn btn-sm @(puantajAy == ayIndex ? "btn-primary" : "btn-outline")" @onclick="() => puantajAy = ayIndex">
                                @aylar[ayIndex]
                            </button>
                        }
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 360px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="min-width:100px;">Personel</th>
                                    <th style="width:60px;">Yil</th>
                                    <th style="width:60px;">Ay</th>
                                    @for (int d = 1; d <= 31; d++)
                                    {
                                        <th style="width:35px; text-align:center;">@d</th>
                                    }
                                    <th style="width:60px; text-align:center;">Toplam</th>
                                    <th style="width:60px; text-align:center;">Mesai</th>
                                    <th style="width:60px; text-align:center;">Izin</th>
                                    <th style="width:60px; text-align:center;">Rapor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (puantajListesi != null)
                                {
                                    foreach (var p in puantajListesi)
                                    {
                                        <tr>
                                            <td>@p.Personel</td>
                                            <td>@p.Yil</td>
                                            <td>@p.Ay</td>
                                            @for (int d = 1; d <= 31; d++)
                                            {
                                                <td style="text-align:center;">@p.Gunler[d - 1]</td>
                                            }
                                            <td style="text-align:center;">@p.Toplam</td>
                                            <td style="text-align:center;">@p.Mesai</td>
                                            <td style="text-align:center;">@p.Izin</td>
                                            <td style="text-align:center;">@p.Rapor</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== TALEPLER ===== *@
                @if (activeSection == "talep")
                {
                    <div style="padding:20px; text-align:center; color:var(--pinebi-text-light);">
                        <i class="fa fa-inbox" style="font-size:48px; margin-bottom:10px;"></i>
                        <p>Talep modulu hazirlaniyor...</p>
                    </div>
                }

                @* ===== ISTEN AYRILANLAR ===== *@
                @if (activeSection == "gecmis")
                {
                    <div class="toolbar">
                        <button class="btn btn-outline btn-sm" @onclick="ExcelAktar">
                            <i class="fa fa-file-excel-o"></i> Excel Aktar
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th style="width:80px;">Sicil No</th>
                                    <th style="min-width:120px;">Ad</th>
                                    <th style="min-width:120px;">Soyad</th>
                                    <th style="min-width:120px;">Departman</th>
                                    <th style="min-width:120px;">Gorevi</th>
                                    <th style="width:90px;">Ise Giris</th>
                                    <th style="width:90px;">Isten Ayrilma</th>
                                    <th style="min-width:200px;">Ayrilma Sebebi</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (istenAyrilanlar != null)
                                {
                                    foreach (var p in istenAyrilanlar)
                                    {
                                        <tr>
                                            <td>@p.SicilNo</td>
                                            <td>@p.Ad</td>
                                            <td>@p.Soyad</td>
                                            <td>@p.Departman</td>
                                            <td>@p.Gorevi</td>
                                            <td>@p.IseGirisTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@p.IsiBirakmaTarihi?.ToString("dd.MM.yyyy")</td>
                                            <td>@p.IsiBirakmaSebebi</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== GORUS VE ONERILER ===== *@
                @if (activeSection == "oneri")
                {
                    <div class="toolbar">
                        <button class="btn btn-success btn-sm" @onclick="GorusEkle">
                            <i class="fa fa-plus"></i> Ekle
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="GorusDuzenle">
                            <i class="fa fa-pencil"></i> Duzenle
                        </button>
                        <button class="btn btn-danger btn-sm" @onclick="GorusIptal">
                            <i class="fa fa-ban"></i> Iptal
                        </button>
                    </div>

                    <div class="grid-container" style="max-height:calc(100vh - 300px);">
