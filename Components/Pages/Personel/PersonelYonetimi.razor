                .Where(p => p.Iptal != true && p.IstenAyrildi != true)
                .OrderBy(p => p.AdSoyad)
                .ToListAsync();

            personelListesi = list.Select(p =>
            {
                var adParts = (p.AdSoyad ?? "").Split(' ', 2);
                return new PersonelItem
                {
                    Id = p.Id,
                    SicilNo = p.PersonelOzluk,
                    Ad = adParts.Length > 0 ? adParts[0] : "",
                    Soyad = adParts.Length > 1 ? adParts[1] : "",
                    TcKimlikNo = p.TCKNo,
                    DogumTarihi = p.DogumTarihi,
                    Departman = p.Unvan,
