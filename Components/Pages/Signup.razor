@page "/signup"
@layout MACHINEBISS_Web.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Hesap Olustur - Pinebi ERP</PageTitle>

<div class="signup-wrap">
    <div class="signup-box">
        <img src="/images/pinebi_logo.png" alt="Pinebi" style="height:48px; margin-bottom:18px;" />
        <h1>Pinebi ERP'ye Hosgeldiniz</h1>
        <p class="lead">10 saniyede kendi firmanizi olusturun, hemen baslayin.</p>

        @if (basarili)
        {
            <div class="success">
                <h3>✓ Hesabiniz olusturuldu!</h3>
                <p>Giris bilgileri <b>@email</b> adresine gonderildi.</p>
                <p>URL: <a href="@url">@url</a></p>
                <p><small>Birkac saniye bekleyin, sonra URL'e gidip <b>admin</b> kullaniciyla giris yapin.</small></p>
            </div>
        }
        else
        {
            <form @onsubmit="OlusturForm" @onsubmit:preventDefault>
                <div class="row">
                    <div>
                        <label>Firma Adi</label>
                        <input @bind="companyName" @bind:event="oninput" placeholder="ACME Ltd." />
                    </div>
                    <div>
                        <label>Subdomain (tekilliginiz)</label>
                        <div class="sub-input">
                            <input @bind="subdomain" @bind:event="oninput" @onblur="KontrolEt"
                                   placeholder="acme" maxlength="30" />
                            <span>.pinebi.com</span>
                        </div>
                        @if (subdomainKontrolMsj != "")
                        {
                            <small class="@(subdomainKontrolOk ? "ok" : "err")">@subdomainKontrolMsj</small>
                        }
                    </div>
                </div>

                <label>Ad Soyad</label>
                <input @bind="fullName" @bind:event="oninput" placeholder="Ahmet Yilmaz" />

                <label>Email</label>
                <input @bind="email" @bind:event="oninput" type="email" placeholder="admin@acme.com" />

                <label>Sifre (en az 6 karakter)</label>
                <input @bind="password" @bind:event="oninput" type="password" autocomplete="new-password" />

                <div class="plan-box">
                    <b>Free Plan</b> · 2 kullanici · 1 GB depolama · 100 fatura/ay · Ucretsiz
                </div>

                @if (hata != "")
                {
                    <div class="err-box">@hata</div>
                }

                <button type="submit" class="btn" disabled="@yukleniyor">
                    @(yukleniyor ? "Olusturuluyor..." : "Hesap Olustur")
                </button>

                <p class="footer">
                    Zaten hesabiniz var mi? <a href="/platform/login">Platform admin girisi</a>
                </p>
            </form>
        }
    </div>
</div>

<style>
    .signup-wrap { min-height:100vh; background:linear-gradient(135deg,#235881 0%,#0E3D5C 100%); display:flex; align-items:center; justify-content:center; font-family:'Segoe UI', Arial; padding:20px; }
    .signup-box { background:white; border-radius:14px; box-shadow:0 20px 60px rgba(0,0,0,0.25); padding:42px; max-width:520px; width:100%; }
    .signup-box h1 { color:#235881; margin:0 0 4px; font-size:26px; }
    .signup-box .lead { color:#64748b; margin:0 0 24px; font-size:14px; }
    .signup-box label { display:block; font-size:12px; color:#64748b; margin:12px 0 4px; font-weight:600; text-transform:uppercase; letter-spacing:0.3px; }
    .signup-box input { width:100%; padding:10px 12px; border:1px solid #cbd5e1; border-radius:6px; font-size:14px; box-sizing:border-box; }
    .signup-box input:focus { outline:none; border-color:#235881; box-shadow:0 0 0 3px rgba(35,88,129,0.1); }
    .row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
    .sub-input { display:flex; align-items:center; border:1px solid #cbd5e1; border-radius:6px; overflow:hidden; }
    .sub-input input { border:none; flex:1; padding:10px 12px; }
    .sub-input input:focus { box-shadow:none; }
    .sub-input span { background:#f1f5f9; padding:10px 14px; font-size:13px; color:#64748b; white-space:nowrap; }
    .plan-box { background:#f8fafc; border:1px solid #e2e8f0; border-radius:6px; padding:12px; margin:16px 0; font-size:13px; color:#475569; }
    .btn { width:100%; background:#235881; color:white; border:none; padding:14px; border-radius:6px; cursor:pointer; font-size:16px; font-weight:600; margin-top:12px; }
    .btn:hover:not(:disabled) { background:#1d486a; }
    .btn:disabled { background:#94a3b8; cursor:wait; }
    .err-box { background:#fee2e2; color:#991b1b; padding:10px 12px; border-radius:6px; margin-top:10px; font-size:13px; }
    small.ok { color:#166534; }
    small.err { color:#991b1b; }
    .footer { text-align:center; color:#64748b; font-size:13px; margin-top:20px; margin-bottom:0; }
    .footer a { color:#235881; text-decoration:none; }
    .success { text-align:center; padding:30px 0; }
    .success h3 { color:#166534; }
    .success a { color:#235881; word-break:break-all; }
</style>

@code {
    string companyName = "", subdomain = "", fullName = "", email = "", password = "";
    string hata = "", subdomainKontrolMsj = "";
    bool subdomainKontrolOk = false;
    bool yukleniyor = false;
    bool basarili = false;
    string url = "";

    async Task KontrolEt()
    {
        subdomainKontrolMsj = "";
        if (string.IsNullOrWhiteSpace(subdomain)) return;

        try
        {
            var resp = await Http.GetFromJsonAsync<System.Text.Json.JsonElement>(
                $"api/public/signup/check-subdomain/{Uri.EscapeDataString(subdomain.ToLower())}");
            var avail = resp.GetProperty("available").GetBoolean();
            if (avail)
            {
                subdomainKontrolOk = true;
                subdomainKontrolMsj = $"✓ {subdomain}.pinebi.com kullanilabilir";
            }
            else
            {
                subdomainKontrolOk = false;
                var reason = resp.TryGetProperty("reason", out var r) ? r.GetString() : "";
                subdomainKontrolMsj = reason switch
                {
                    "TAKEN" => "✗ Bu subdomain zaten kullaniliyor",
                    "RESERVED" => "✗ Rezerve edilmis kelime",
                    "INVALID_FORMAT" => "✗ Gecersiz format (a-z, 0-9, tire)",
                    _ => "✗ Kullanilamaz"
                };
            }
        }
        catch (Exception ex) { subdomainKontrolMsj = ex.Message; }
    }

    async Task OlusturForm()
    {
        hata = "";
        yukleniyor = true;
        try
        {
            var payload = new { companyName, subdomain, email, fullName, password };
            var resp = await Http.PostAsJsonAsync("api/public/signup", payload);
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                url = r.GetProperty("loginUrl").GetString() ?? "";
                basarili = true;
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                hata = $"Hata: {resp.StatusCode} · {body}";
            }
        }
        catch (Exception ex) { hata = ex.Message; }
        yukleniyor = false;
    }
}
