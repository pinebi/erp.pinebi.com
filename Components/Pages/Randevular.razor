@page "/randevular"
@inject NavigationManager Nav

<PageTitle>Randevular</PageTitle>

<div class="card">
    <div class="card-header"><i class="fa fa-calendar-alt"></i> Randevular</div>
    <div class="card-body">
        <div class="toolbar">
            <button class="btn btn-success btn-sm"><i class="fa fa-plus"></i> Yeni</button>
            <button class="btn btn-primary btn-sm"><i class="fa fa-edit"></i> Duzenle</button>
            <button class="btn btn-danger btn-sm"><i class="fa fa-trash"></i> Sil</button>
        </div>
        <div class="form-row mb-2">
            <div class="form-inline">
                <label>Baslangic</label>
                <input type="date" class="form-control" style="max-width:150px;" />
            </div>
            <div class="form-inline">
                <label>Bitis</label>
                <input type="date" class="form-control" style="max-width:150px;" />
            </div>
            <button class="btn btn-primary btn-sm"><i class="fa fa-search"></i> Listele</button>
        </div>
        <div class="grid-container" style="max-height:500px;">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Randevu Tarihi</th>
                        <th>Randevu Saati</th>
                        <th>Cari Unvan</th>
                        <th>Yetkili</th>
                        <th>Konu</th>
                        <th>Aciklama</th>
                        <th>Durumu</th>
                        <th>Olusturan</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="9" class="text-center text-muted">Kayit bulunamadi</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
