                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn accent" @onclick='() => OpenTab("yenisatisfaturasi", "Yeni Fatura", "/satis/fatura/yeni")'><i class="fa fa-plus"></i><span>Yeni Fatura</span></button>
                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("proformafaturalar", "Proforma", "/satis/proforma")'><i class="fa fa-file"></i><span>Proforma</span></button>
                    break;

                case "satinalma":
                    <button class="ribbon-btn" @onclick='() => OpenTab("satinalmatalepleri", "Talepler", "/satinalma/talepler")'><i class="fa fa-hand-paper"></i><span>Talepler</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("satinalmasiparisleri", "Siparisler", "/satinalma/siparisler")'><i class="fa fa-clipboard-list"></i><span>Siparisler</span></button>
