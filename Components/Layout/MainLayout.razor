                    <button class="ribbon-btn" @onclick='() => OpenTab("bankahareketleri", "Banka", "/finans/banka")'><i class="fa fa-university"></i><span>Banka</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("ceksenet", "Cek/Senet", "/finans/ceksenet")'><i class="fa fa-money-check"></i><span>Cek/Senet</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("kredikartihareketleri", "Kredi Karti", "/finans/kredikartlari")'><i class="fa fa-credit-card"></i><span>Kredi Karti</span></button>
                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("bankakredibilgileri", "Banka Kredileri", "/finans/bankakredileri")'><i class="fa fa-hand-holding-usd"></i><span>Krediler</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("odemeplanlari", "Odeme Planlari", "/finans/odemeplanlari")'><i class="fa fa-calendar-check"></i><span>Odeme Plani</span></button>
