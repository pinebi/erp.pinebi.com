                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("birimler", "Birimler", "/tanimlar/birimler")'><i class="fa fa-ruler"></i><span>Birimler</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("kdvoranlari", "KDV Oranlari", "/tanimlar/kdvoranlari")'><i class="fa fa-percentage"></i><span>KDV</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("vergidaireleri", "Vergi Daireleri", "/tanimlar/vergidaireleri")'><i class="fa fa-landmark"></i><span>Vergi D.</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("giderturleri", "Gider Turleri", "/tanimlar/giderturleri")'><i class="fa fa-minus-circle"></i><span>Gider T.</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("dovizguncelle", "Doviz Kuru", "/tanimlar/doviz")'><i class="fa fa-dollar-sign"></i><span>Doviz</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("faturanumarator", "Numarator", "/tanimlar/numarator")'><i class="fa fa-sort-numeric-up"></i><span>Numarator</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("faturaalanlari", "Fatura Alanlari", "/ayarlar/fatura-alanlari")'><i class="fa fa-columns"></i><span>Fatura Alanlari</span></button>
                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("sifredegistir", "Sifre", "/ayarlar/sifredegistir")'><i class="fa fa-key"></i><span>Sifre</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("lisansbilgileri", "Lisans", "/ayarlar/lisans")'><i class="fa fa-certificate"></i><span>Lisans</span></button>
                    break;
            }
        </div>

        <!-- Open Page Tabs -->
        <div class="tab-bar">
            @foreach (var tab in TabSvc.OpenTabs)
            {
                <div class="tab-item @(tab.Id == TabSvc.ActiveTabId ? "active" : "")" @onclick="() => TabSvc.SetActiveTab(tab.Id)">
                    <span>@tab.Title</span>
                    <button class="tab-close" @onclick:stopPropagation="true" @onclick="() => CloseTab(tab.Id)">x</button>
                </div>
            }
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @Body
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Bir hata olustu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">X</span>
</div>

@code {
    private string activeRibbon = "sirket";
    private MACHINEBISS_Web.Services.YetkiBilgileri yetkiler = new();

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthStateChanged += OnAuthChanged;
        TabSvc.OnTabsChanged += StateHasChanged;

        if (Auth.IsAuthenticated)
        {
            yetkiler = await Sistem.YetkileriGetir();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !Auth.IsAuthenticated)
        {
            // Refresh sonrasi localStorage'dan oturumu geri yukle
            var restored = await Auth.RestoreFromBrowserAsync(JS);
            if (restored) StateHasChanged();
        }
    }

    private async void OnAuthChanged()
    {
        if (Auth.IsAuthenticated)
        {
            yetkiler = await Sistem.YetkileriGetir();
            TabSvc.OpenTab("dashboard", "Dashboard", "/dashboard", "fa-tachometer-alt");
            await InvokeAsync(() => Nav.NavigateTo("/dashboard"));
        }
        await InvokeAsync(StateHasChanged);
    }

    private void SetRibbon(string ribbon)
    {
        activeRibbon = ribbon;
    }

    private void OpenTab(string id, string title, string url, string icon = "")
    {
        TabSvc.OpenTab(id, title, url, icon);
        Nav.NavigateTo(url);
    }

    private void CloseTab(string id)
    {
        TabSvc.CloseTab(id);
        var activeTab = TabSvc.OpenTabs.FirstOrDefault(t => t.Id == TabSvc.ActiveTabId);
        if (activeTab != null)
            Nav.NavigateTo(activeTab.Url);
        else
            Nav.NavigateTo("/dashboard");
    }

    private async Task Logout()
    {
        await Auth.ClearBrowserAsync(JS);
        Nav.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnAuthChanged;
        TabSvc.OnTabsChanged -= StateHasChanged;
    }
}
