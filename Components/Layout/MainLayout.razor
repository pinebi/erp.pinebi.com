        <!-- Ribbon Top Bar -->
        <div class="ribbon-topbar">
            <div class="ribbon-brand">
                <img src="images/pinebi_logo.png" alt="Pinebi" class="ribbon-logo" />
                <span class="ribbon-title">MachineBiss</span>
            </div>
            <div class="ribbon-tabs">
                <button class="ribbon-tab @(activeRibbon == "sirket" ? "active" : "")" @onclick='() => SetRibbon("sirket")'>
                    <i class="fa fa-building"></i> Sirket
                </button>
                <button class="ribbon-tab @(activeRibbon == "muhasebe" ? "active" : "")" @onclick='() => SetRibbon("muhasebe")'>
                    <i class="fa fa-calculator"></i> Muhasebe
                </button>
                <button class="ribbon-tab @(activeRibbon == "satis" ? "active" : "")" @onclick='() => SetRibbon("satis")'>
                    <i class="fa fa-shopping-cart"></i> Satis
                </button>
                <button class="ribbon-tab @(activeRibbon == "satinalma" ? "active" : "")" @onclick='() => SetRibbon("satinalma")'>
                    <i class="fa fa-cart-plus"></i> Satinalma
                </button>
                <button class="ribbon-tab @(activeRibbon == "stok" ? "active" : "")" @onclick='() => SetRibbon("stok")'>
                    <i class="fa fa-warehouse"></i> Stok
                </button>
                <button class="ribbon-tab @(activeRibbon == "efatura" ? "active" : "")" @onclick='() => SetRibbon("efatura")'>
                    <i class="fa fa-file-invoice"></i> E-Fatura
                </button>
                <button class="ribbon-tab @(activeRibbon == "diger" ? "active" : "")" @onclick='() => SetRibbon("diger")'>
                    <i class="fa fa-th"></i> Diger
                </button>
            </div>
            <div class="ribbon-right">
                <span class="ribbon-user"><i class="fa fa-user"></i> @Auth.ErpKullaniciAdi</span>
