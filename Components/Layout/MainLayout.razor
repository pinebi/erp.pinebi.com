@inherits LayoutComponentBase
@inject MACHINEBISS_Web.Services.AuthService Auth
@inject MACHINEBISS_Web.Services.TabService TabSvc
@inject MACHINEBISS_Web.Services.SistemAyarlariService Sistem
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Pine versiyonuna yonlendir *@
@code {
    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (!uri.AbsolutePath.StartsWith("/pine", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/pine");
            return;
        }
    }
}

@if (!Auth.IsAuthenticated)
{
    <MACHINEBISS_Web.Components.Pages.Auth.Login />
}
else
{
