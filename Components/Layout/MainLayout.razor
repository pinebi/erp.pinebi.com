                    break;

                case "diger":
                    <button class="ribbon-btn" @onclick='() => OpenTab("dashboard", "Dashboard", "/dashboard")'><i class="fa fa-tachometer-alt"></i><span>Dashboard</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("hatirlatmalar", "Hatirlatmalar", "/hatirlatmalar")'><i class="fa fa-bell"></i><span>Hatirlatmalar</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("projeler", "Projeler", "/projeler")'><i class="fa fa-project-diagram"></i><span>Projeler</span></button>
