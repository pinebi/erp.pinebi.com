                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("sirketprofili", "Sirket Profili", "/sirket/profil")'><i class="fa fa-id-card"></i><span>Sirket Profili</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("sirketdokumanlari", "Dokumanlar", "/sirket/dokumanlar")'><i class="fa fa-folder"></i><span>Dokumanlar</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("sirketortaklari", "Ortaklar", "/sirket/ortaklar")'><i class="fa fa-users"></i><span>Ortaklar</span></button>
                    <button class="ribbon-btn" @onclick='() => OpenTab("sirketmail", "Mail", "/sirket/mail")'><i class="fa fa-envelope"></i><span>Mail</span></button>
                    <span class="ribbon-sep"></span>
                    <button class="ribbon-btn" @onclick='() => OpenTab("envanter", "Envanter", "/envanter")'><i class="fa fa-boxes"></i><span>Envanter</span></button>
