    private async void OnAuthChanged()
    {
        if (Auth.IsAuthenticated)
        {
            TabSvc.OpenTab("pine-dashboard", "Dashboard", "/pine", "fa-tachometer-alt");
            var mevcut = new Uri(Nav.Uri).AbsolutePath;
            if (mevcut == "/" || mevcut.StartsWith("/login", StringComparison.OrdinalIgnoreCase))
            {
                await InvokeAsync(() => Nav.NavigateTo("/pine"));
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private void SetRibbon(string key)
    {
        activeRibbon = key;
    }

    private void OpenTab(string id, string title, string url, string icon = "")
    {
        // Determine icon from menu items
        string resolvedIcon = icon;
        if (string.IsNullOrEmpty(resolvedIcon))
        {
            foreach (var g in menuGroups.Values)
            {
                var found = g.Items.FirstOrDefault(i => i.Id == id);
                if (found != null) { resolvedIcon = found.Icon; break; }
            }
        }
        TabSvc.OpenTab(id, title, url, resolvedIcon);
        Nav.NavigateTo(url);
    }

    private void ActivateTab(MACHINEBISS_Web.Services.TabItem tab)
    {
        TabSvc.SetActiveTab(tab.Id);
        Nav.NavigateTo(tab.Url);
    }

    private void CloseTab(string id)
    {
        TabSvc.CloseTab(id);
        var activeTab = TabSvc.OpenTabs.FirstOrDefault(t => t.Id == TabSvc.ActiveTabId);
        if (activeTab != null)
            Nav.NavigateTo(activeTab.Url);
        else
            Nav.NavigateTo("/pine");
    }

    private async Task Logout()
    {
        await Auth.ClearBrowserAsync(JS);
        Nav.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnAuthChanged;
        TabSvc.OnTabsChanged -= StateHasChanged;
    }
}
