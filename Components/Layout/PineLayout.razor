@inherits LayoutComponentBase
@inject MACHINEBISS_Web.Services.AuthService Auth
@inject MACHINEBISS_Web.Services.TabService TabSvc
@inject MACHINEBISS_Web.Services.SistemAyarlariService Sistem
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (!Auth.IsAuthenticated)
{
    <MACHINEBISS_Web.Components.Pages.Auth.Login />
}
else
{
    <div class="pine-app">
        <!-- TOP BAR -->
        <header class="pine-topbar">
            <div class="pine-topbar-left">
                <div class="pine-logo" @onclick='() => OpenTab("pine-dashboard", "Dashboard", "/pine")'>
                    <img src="images/pinebi_logo.png" alt="PineERP" class="pine-logo-img" />
                    <span class="pine-logo-text">PineERP</span>
                </div>
                <!-- RIBBON TAB HEADERS - logodan sonra, yerden tasarruf icin topbar icinde -->
                <nav class="pine-ribbon-tabs inline-ribbon">
                    @foreach (var group in menuGroups)
                    {
                        <button class="pine-rtab @(activeRibbon == group.Key ? "active" : "")"
                                @onclick="() => SetRibbon(group.Key)">
                            <i class="fa @group.Value.Icon"></i>
                            <span>@group.Value.Label</span>
                        </button>
                    }
                </nav>
            </div>
            <div class="pine-topbar-right">
                <div class="pine-firma-info">
                    <i class="fa fa-building"></i>
                    <span>@Auth.SirketKodu</span>
                </div>
                <div class="pine-user-info">
                    <i class="fa fa-user-circle"></i>
                    <span>@Auth.ErpKullaniciAdi</span>
                </div>
                <button class="pine-btn-logout" @onclick="Logout" title="Cikis Yap">
                    <i class="fa fa-sign-out-alt"></i>
                </button>
            </div>
        </header>

        <!-- RIBBON COMMANDS (context-sensitive) -->
        <div class="pine-ribbon-commands">
            @if (menuGroups.TryGetValue(activeRibbon, out var activeGroup))
            {
                @foreach (var item in activeGroup.Items)
                {
                    if (item.IsSeparator)
                    {
                        <span class="pine-cmd-sep"></span>
                    }
                    else
                    {
                        <button class="pine-cmd @(item.Accent ? "accent" : "")"
                                @onclick="() => OpenTab(item.Id, item.Title, item.Url)">
                            <i class="fa @item.Icon"></i>
                            <span>@item.Title</span>
                        </button>
                    }
                }
            }
        </div>

        <!-- OPEN PAGE TABS -->
        <div class="pine-tabbar">
            <div class="pine-tabbar-scroll">
                @foreach (var tab in TabSvc.OpenTabs)
                {
                    <div class="pine-tab @(tab.Id == TabSvc.ActiveTabId ? "active" : "")"
                         @onclick="() => ActivateTab(tab)">
                        @if (!string.IsNullOrEmpty(tab.Icon))
                        {
                            <i class="fa @tab.Icon pine-tab-icon"></i>
                        }
                        <span class="pine-tab-title">@tab.Title</span>
                        <button class="pine-tab-close" @onclick:stopPropagation="true"
                                @onclick="() => CloseTab(tab.Id)">
                            <i class="fa fa-times"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- PAGE CONTENT -->
        <main class="pine-content">
            @Body
        </main>
    </div>

    <!-- Global Confirm Modal -->
    <ConfirmModal />
}

<div id="blazor-error-ui" data-nosnippet>
    Bir hata olustu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">X</span>
</div>

